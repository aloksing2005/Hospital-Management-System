<% var title = 'Home - HMS Enterprise'; %>
<%- include('partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

<style>
    .gradient-text {
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .hero-bg {
        background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.15), transparent),
                    radial-gradient(circle at bottom left, rgba(168, 85, 247, 0.1), transparent);
    }
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .floating {
        animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }
</style>

<div class="min-h-screen bg-white selection:bg-indigo-100 hero-bg">
    <!-- Hero Section -->
    <section class="relative pt-20 pb-32 overflow-hidden">
        <div class="container mx-auto px-6 relative z-10">
            <div class="flex flex-col lg:flex-row items-center gap-16">
                <div class="lg:w-1/2 text-center lg:text-left">
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-50 border border-indigo-100 mb-8 animate__animated animate__fadeInDown">
                        <span class="w-2 h-2 rounded-full bg-indigo-600 animate-pulse"></span>
                        <span class="text-sm font-bold text-indigo-900 uppercase tracking-widest">Next-Gen Healthcare</span>
                    </div>
                    <h1 class="text-6xl lg:text-7xl font-black text-gray-900 leading-[1.1] mb-8 animate__animated animate__fadeInLeft">
                        Smart Care <br/> 
                        <span class="gradient-text">Redefined.</span>
                    </h1>
                    <p class="text-xl text-gray-500 max-w-xl mb-12 animate__animated animate__fadeInLeft animate__delay-1s">
                        Experience the future of hospital management with AI-driven diagnostics, real-time tracking, and a 360-degree patient ecosystem.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start animate__animated animate__fadeInUp animate__delay-1s">
                        <a href="/register" class="px-10 py-5 bg-indigo-600 text-white rounded-[30px] font-black text-lg shadow-2xl shadow-indigo-200 hover:bg-indigo-700 hover:scale-105 transition-all">Get Started Free</a>
                        <a href="/login" class="px-10 py-5 bg-white text-gray-900 rounded-[30px] font-black text-lg border-2 border-gray-100 hover:bg-gray-50 transition-all">Sign In</a>
                    </div>
                </div>
                <div class="lg:w-1/2 relative">
                    <div class="relative floating">
                        <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=800" class="rounded-[60px] shadow-2xl border-[12px] border-white" alt="Doctor">
                        <div class="absolute -bottom-10 -left-10 glass-card p-8 rounded-[40px] shadow-xl animate__animated animate__fadeInUp animate__delay-2s">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center text-white"><i class="fas fa-check"></i></div>
                                <div>
                                    <p class="text-sm font-bold text-gray-400">Available Doctors</p>
                                    <p class="text-2xl font-black text-gray-900">482 Online</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-20 bg-gray-900 text-white">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 text-center">
                <div>
                    <h3 class="text-5xl font-black mb-2">12k+</h3>
                    <p class="text-gray-400 font-bold uppercase tracking-widest text-sm">Patients Served</p>
                </div>
                <div>
                    <h3 class="text-5xl font-black mb-2">500+</h3>
                    <p class="text-gray-400 font-bold uppercase tracking-widest text-sm">Specialists</p>
                </div>
                <div>
                    <h3 class="text-5xl font-black mb-2">99.9%</h3>
                    <p class="text-gray-400 font-bold uppercase tracking-widest text-sm">Uptime</p>
                </div>
                <div>
                    <h3 class="text-5xl font-black mb-2">24/7</h3>
                    <p class="text-gray-400 font-bold uppercase tracking-widest text-sm">Emergency</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Grid -->
    <section class="py-32">
        <div class="container mx-auto px-6">
            <div class="text-center mb-20">
                <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4">Everything You Need</h2>
                <p class="text-gray-500 text-xl">Powerful features designed for modern healthcare.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <div class="p-10 rounded-[50px] bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-2xl transition-all duration-500 group">
                    <div class="w-16 h-16 bg-indigo-50 text-indigo-600 rounded-3xl flex items-center justify-center text-2xl mb-8 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                        <i class="fas fa-ambulance"></i>
                    </div>
                    <h4 class="text-2xl font-bold text-gray-900 mb-4">Smart Ambulance</h4>
                    <p class="text-gray-500 leading-relaxed">Real-time fleet tracking and emergency dispatch with live status updates.</p>
                </div>
                <div class="p-10 rounded-[50px] bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-2xl transition-all duration-500 group">
                    <div class="w-16 h-16 bg-purple-50 text-purple-600 rounded-3xl flex items-center justify-center text-2xl mb-8 group-hover:bg-purple-600 group-hover:text-white transition-all">
                        <i class="fas fa-robot"></i>
                    </div>
                    <h4 class="text-2xl font-bold text-gray-900 mb-4">AI Diagnostics</h4>
                    <p class="text-gray-500 leading-relaxed">Advanced symptom checker and predictive health analytics powered by AI.</p>
                </div>
                <div class="p-10 rounded-[50px] bg-white border border-gray-100 hover:border-indigo-100 hover:shadow-2xl transition-all duration-500 group">
                    <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-3xl flex items-center justify-center text-2xl mb-8 group-hover:bg-blue-600 group-hover:text-white transition-all">
                        <i class="fas fa-video"></i>
                    </div>
                    <h4 class="text-2xl font-bold text-gray-900 mb-4">Tele-Consult</h4>
                    <p class="text-gray-500 leading-relaxed">Secure video consultations with expert doctors from the comfort of home.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="pb-32 px-6">
        <div class="container mx-auto max-w-6xl">
            <div class="bg-indigo-600 rounded-[60px] p-16 text-center text-white relative overflow-hidden">
                <div class="relative z-10">
                    <h2 class="text-5xl font-black mb-8 leading-tight">Ready to transform your <br/> healthcare experience?</h2>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a href="/register" class="px-10 py-5 bg-white text-indigo-600 rounded-[30px] font-black text-lg shadow-xl hover:scale-105 transition-all">Join HMS Today</a>
                        <a href="/login" class="px-10 py-5 bg-indigo-700 text-white rounded-[30px] font-black text-lg hover:bg-indigo-800 transition-all">Sign In</a>
                    </div>
                </div>
                <i class="fas fa-heartbeat absolute -bottom-20 -right-20 text-[300px] text-white/5"></i>
            </div>
        </div>
    </section>
</div>

<%- include('partials/footer') %>

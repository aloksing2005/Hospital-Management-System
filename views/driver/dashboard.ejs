<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Dashboard - HMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
        #map { height: 400px; width: 100%; border-radius: 12px; }
        .request-card { transition: all 0.3s ease; }
        .request-card:hover { transform: translateY(-2px); }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Navbar -->
    <nav class="bg-indigo-700 text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center">
                    <i class="fas fa-ambulance text-2xl mr-3"></i>
                    <span class="text-xl font-bold tracking-tight">Driver Portal</span>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="flex items-center bg-indigo-800 px-3 py-1 rounded-full">
                        <div class="w-2 h-2 rounded-full bg-green-400 mr-2 animate-pulse"></div>
                        <span class="text-sm font-medium">Online</span>
                    </div>
                    <a href="/logout" class="hover:text-indigo-200 transition"><i class="fas fa-sign-out-alt"></i></a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column: Map & Status -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl shadow-sm p-6">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-lg font-semibold text-gray-800">Your Live Location</h2>
                        <span class="text-sm text-gray-500" id="coords">Detecting...</span>
                    </div>
                    <div id="map"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="bg-white p-6 rounded-2xl shadow-sm">
                        <p class="text-sm text-gray-500 mb-1">Total Trips</p>
                        <p class="text-2xl font-bold text-gray-800">24</p>
                    </div>
                    <div class="bg-white p-6 rounded-2xl shadow-sm">
                        <p class="text-sm text-gray-500 mb-1">Vehicle</p>
                        <p class="text-2xl font-bold text-indigo-600"><%= ambulance.vehicle_no %></p>
                    </div>
                    <div class="bg-white p-6 rounded-2xl shadow-sm">
                        <p class="text-sm text-gray-500 mb-1">Rating</p>
                        <p class="text-2xl font-bold text-yellow-500">4.9 <i class="fas fa-star text-xs"></i></p>
                    </div>
                </div>
            </div>

            <!-- Right Column: Requests -->
            <div class="space-y-6">
                <div class="bg-white rounded-2xl shadow-sm p-6 h-full min-h-[500px]">
                    <h2 class="text-lg font-semibold text-gray-800 mb-6 flex items-center">
                        <i class="fas fa-bell text-indigo-500 mr-3"></i>
                        Live Requests
                        <span id="requestCount" class="ml-auto bg-indigo-100 text-indigo-700 text-xs px-2 py-1 rounded-full"><%= pendingRequests.length %></span>
                    </h2>

                    <div id="requestContainer" class="space-y-4">
                        <% if (pendingRequests.length === 0) { %>
                            <div class="text-center py-12" id="noRequests">
                                <i class="fas fa-search-location text-4xl text-gray-200 mb-4 block"></i>
                                <p class="text-gray-400">Waiting for new requests...</p>
                            </div>
                        <% } else { %>
                            <% pendingRequests.forEach(req => { %>
                                <div class="request-card bg-gray-50 border border-gray-100 rounded-xl p-4" id="req-<%= req.id %>">
                                    <div class="flex justify-between items-start mb-3">
                                        <span class="text-xs font-bold uppercase tracking-wider text-red-500 bg-red-50 px-2 py-1 rounded">Emergency</span>
                                        <span class="text-xs text-gray-400">Just now</span>
                                    </div>
                                    <h3 class="font-bold text-gray-800"><%= req.patient_name %></h3>
                                    <p class="text-sm text-gray-600 mt-1"><i class="fas fa-map-marker-alt text-indigo-500 mr-2"></i><%= req.pickup_address %></p>
                                    <div class="mt-4 flex gap-2">
                                        <button onclick="acceptRequest(`<%= req.id %>`)" class="flex-1 bg-indigo-600 text-white py-2 rounded-lg font-medium hover:bg-indigo-700 transition">Accept</button>
                                        <button class="px-4 py-2 text-gray-400 hover:text-gray-600 transition"><i class="fas fa-times"></i></button>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Active Trip Modal -->
    <div id="tripModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-3xl w-full max-w-md p-8 shadow-2xl">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-route text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-800">Trip in Progress</h3>
                <p class="text-gray-500" id="activePatient">Patient: John Doe</p>
            </div>
            
            <div class="space-y-4 mb-8">
                <div class="flex items-center p-4 bg-gray-50 rounded-2xl">
                    <i class="fas fa-phone-alt text-indigo-500 mr-4"></i>
                    <span id="activePhone">+91 9876543210</span>
                </div>
                <div class="flex items-center p-4 bg-gray-50 rounded-2xl">
                    <i class="fas fa-map-marked-alt text-indigo-500 mr-4"></i>
                    <span id="activeAddress">123 Street Name, City</span>
                </div>
            </div>

            <button onclick="completeTrip()" class="w-full bg-green-600 text-white py-4 rounded-2xl font-bold text-lg hover:bg-green-700 shadow-lg shadow-green-200 transition">
                Complete Trip
            </button>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const socket = io();
        const driverId = `<%= user.id %>`;
        let map, marker, activeRequestId = null;

        socket.emit('join', { userId: String(driverId), role: 'driver' });
        socket.emit('driver-online', { driverId });

        // Init Map
        function initMap() {
            map = L.map('map').setView([28.6139, 77.2090], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
            marker = L.marker([28.6139, 77.2090]).addTo(map);
        }

        // Get Location
        if ("geolocation" in navigator) {
            navigator.geolocation.watchPosition(pos => {
                const { latitude, longitude } = pos.coords;
                marker.setLatLng([latitude, longitude]);
                map.setView([latitude, longitude], 15);
                document.getElementById('coords').innerText = `${latitude.toFixed(4)}, ${longitude.toFixed(4)}`;

                // Update server/DB
                fetch('/driver/update-location', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lat: latitude, lng: longitude })
                });
            });
        }

        initMap();

        // Listen for new requests
        socket.on('new-ambulance-request', (data) => {
            const container = document.getElementById('requestContainer');
            const noReq = document.getElementById('noRequests');
            if(noReq) noReq.remove();

            const card = document.createElement('div');
            card.className = 'request-card bg-gray-50 border border-gray-100 rounded-xl p-4 animate-bounce';
            card.id = `req-${data.id}`;
            card.innerHTML = `
                <div class="flex justify-between items-start mb-3">
                    <span class="text-xs font-bold uppercase tracking-wider text-red-500 bg-red-50 px-2 py-1 rounded">Emergency</span>
                    <span class="text-xs text-gray-400">Just now</span>
                </div>
                <h3 class="font-bold text-gray-800">${data.patient_name}</h3>
                <p class="text-sm text-gray-600 mt-1"><i class="fas fa-map-marker-alt text-indigo-500 mr-2"></i>${data.pickup_address}</p>
                <div class="mt-4 flex gap-2">
                    <button onclick="acceptRequest(${data.id})" class="flex-1 bg-indigo-600 text-white py-2 rounded-lg font-medium hover:bg-indigo-700 transition">Accept</button>
                    <button class="px-4 py-2 text-gray-400 hover:text-gray-600 transition"><i class="fas fa-times"></i></button>
                </div>
            `;
            container.prepend(card);
            
            // Update count
            const count = document.getElementById('requestCount');
            count.innerText = parseInt(count.innerText) + 1;

            // Play notification sound
            new Audio('https://actions.google.com/sounds/v1/alarms/beep_short.ogg').play();
        });

        // Accept Request
        function acceptRequest(requestId) {
            fetch('/driver/accept-request', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ requestId })
            }).then(res => res.json()).then(data => {
                if(data.success) {
                    activeRequestId = requestId;
                    document.getElementById('activePatient').innerText = `Patient: ${data.request.patient_name}`;
                    document.getElementById('activePhone').innerText = data.request.patient_phone;
                    document.getElementById('activeAddress').innerText = data.request.pickup_address;
                    document.getElementById('tripModal').classList.remove('hidden');
                    
                    // Remove other cards
                    document.getElementById('requestContainer').innerHTML = '<p class="text-center text-gray-400 py-10">Trip in progress...</p>';
                } else {
                    alert(data.error);
                }
            });
        }

        // Complete Trip
        function completeTrip() {
            fetch('/driver/complete-trip', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ requestId: activeRequestId })
            }).then(res => res.json()).then(data => {
                if(data.success) {
                    window.location.reload();
                }
            });
        }
    </script>
</body>
</html>

<% var title = 'Doctor Dashboard - HMS Premium'; %>
<%- include('../partials/header') %>
<%- include('../partials/incoming-call-modal') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/doctor-sidebar', { active: 'dashboard' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
      <!-- Welcome Header -->
      <div class="mb-8 animate-fade-in flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-black text-white mb-2">Welcome back, Dr. <%= doctor.name %></h1>
          <p class="text-gray-400 font-medium">Here's your clinical schedule and hospital telemetry for today.</p>
        </div>
        <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-xl border border-white/10 shrink-0 self-start md:self-auto">
          <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse"></div>
          <span class="text-sm font-bold text-gray-300">Live Practice Portal</span>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Stat 1: Total Visits -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-indigo-500/40 relative overflow-hidden group animate-scale-in transition-all duration-300">
          <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-indigo-500/10 blur-2xl pointer-events-none group-hover:bg-indigo-500/20 transition-all"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 rounded-xl flex items-center justify-center text-xl shadow-inner shadow-indigo-500/10">
              <i class="fas fa-calendar-check"></i>
            </div>
            <span class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest bg-indigo-500/10 px-2 py-0.5 rounded-full">Month</span>
          </div>
          <div class="text-3xl font-black text-white tracking-tight mb-1"><%= stats.total_appointments || 0 %></div>
          <div class="text-sm font-bold text-gray-400 tracking-wide mb-3">Total Patient Visits</div>
          <div class="text-xs font-semibold text-emerald-400 flex items-center gap-1.5 bg-emerald-500/10 w-fit px-2.5 py-1 rounded-lg">
            <i class="fas fa-arrow-up text-[10px]"></i>
            <span>+15% since last month</span>
          </div>
        </div>

        <!-- Stat 2: Pending -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-amber-500/40 relative overflow-hidden group animate-scale-in animate-delay-100 transition-all duration-300">
          <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-amber-500/10 blur-2xl pointer-events-none group-hover:bg-amber-500/20 transition-all"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-amber-500/20 text-amber-400 rounded-xl flex items-center justify-center text-xl shadow-inner shadow-amber-500/10">
              <i class="fas fa-clock animate-pulse"></i>
            </div>
            <span class="text-[10px] font-bold text-amber-400 uppercase tracking-widest bg-amber-500/10 px-2 py-0.5 rounded-full">Queue</span>
          </div>
          <div class="text-3xl font-black text-white tracking-tight mb-1"><%= stats.pending || 0 %></div>
          <div class="text-sm font-bold text-gray-400 tracking-wide mb-3">Pending Consults</div>
          <div class="text-xs font-semibold text-amber-400 flex items-center gap-1.5 bg-amber-500/10 w-fit px-2.5 py-1 rounded-lg">
            <i class="fas fa-history text-[10px]"></i>
            <span>Awaiting check-in</span>
          </div>
        </div>

        <!-- Stat 3: Completed -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-emerald-500/40 relative overflow-hidden group animate-scale-in animate-delay-200 transition-all duration-300">
          <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-emerald-500/10 blur-2xl pointer-events-none group-hover:bg-emerald-500/20 transition-all"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center text-xl shadow-inner shadow-emerald-500/10">
              <i class="fas fa-check-double"></i>
            </div>
            <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest bg-emerald-500/10 px-2 py-0.5 rounded-full">Done</span>
          </div>
          <div class="text-3xl font-black text-white tracking-tight mb-1"><%= stats.completed || 0 %></div>
          <div class="text-sm font-bold text-gray-400 tracking-wide mb-3">Completed Sessions</div>
          <div class="text-xs font-semibold text-emerald-400 flex items-center gap-1.5 bg-emerald-500/10 w-fit px-2.5 py-1 rounded-lg">
            <i class="fas fa-chart-line text-[10px]"></i>
            <span>High success rate</span>
          </div>
        </div>

        <!-- Stat 4: Today's List -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-cyan-500/40 relative overflow-hidden group animate-scale-in animate-delay-300 transition-all duration-300">
          <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-cyan-500/10 blur-2xl pointer-events-none group-hover:bg-cyan-500/20 transition-all"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-cyan-500/20 text-cyan-400 rounded-xl flex items-center justify-center text-xl shadow-inner shadow-cyan-500/10">
              <i class="fas fa-user-injured"></i>
            </div>
            <span class="text-[10px] font-bold text-cyan-400 uppercase tracking-widest bg-cyan-500/10 px-2 py-0.5 rounded-full">Today</span>
          </div>
          <div class="text-3xl font-black text-white tracking-tight mb-1"><%= todayAppointments.length %></div>
          <div class="text-sm font-bold text-gray-400 tracking-wide mb-3">Today's Appointment List</div>
          <div class="text-xs font-semibold text-cyan-400 flex items-center gap-1.5 bg-cyan-500/10 w-fit px-2.5 py-1 rounded-lg">
            <i class="fas fa-stethoscope text-[10px]"></i>
            <span>Active schedule</span>
          </div>
        </div>
      </div>

      <!-- Center Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Today's Schedule -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-white/10 transition-all animate-fade-in relative overflow-hidden">
          <div class="absolute -left-20 -top-20 w-48 h-48 rounded-full bg-indigo-500/5 blur-3xl pointer-events-none"></div>
          
          <div class="flex items-center justify-between mb-6 relative z-10">
            <h3 class="text-xl font-bold text-white flex items-center gap-2">
              <i class="fas fa-calendar-day text-indigo-400"></i> Today's Schedule
            </h3>
            <span class="hms-badge hms-badge-primary"><%= todayAppointments.length %> Scheduled</span>
          </div>
          
          <% if (todayAppointments.length === 0) { %>
            <div class="hms-empty-state py-8">
              <i class="fas fa-calendar-day hms-empty-state-icon text-indigo-400/40 mb-4 text-3xl"></i>
              <h4 class="hms-empty-state-title text-white font-bold mb-1">No Consultations Today</h4>
              <p class="hms-empty-state-description text-gray-400 text-sm">Your schedule is currently clear. Enjoy your day or double-check incoming telemedicine bookings!</p>
            </div>
          <% } else { %>
            <div class="space-y-3 relative z-10 max-h-[350px] overflow-y-auto pr-1">
              <% todayAppointments.forEach(app => { %>
                <div class="flex items-center gap-4 p-4 bg-white/5 rounded-2xl border border-white/5 hover:bg-white/10 hover:border-white/10 transition-all cursor-pointer group">
                  <div class="w-12 h-12 bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 rounded-xl flex items-center justify-center font-black text-sm shrink-0 group-hover:scale-105 transition-transform">
                    <%= app.time_slot.split(':')[0] || 'App' %>
                  </div>
                  <div class="flex-grow min-w-0">
                    <h5 class="text-white font-bold truncate"><%= app.patient_name %></h5>
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-wider flex items-center gap-1.5 mt-0.5">
                      <i class="far fa-clock text-indigo-400"></i> <%= app.time_slot %>
                    </p>
                  </div>
                  <span class="hms-badge hms-badge-<%= app.status === 'pending' ? 'warning' : app.status === 'confirmed' ? 'success' : 'info' %> capitalize shrink-0"><%= app.status %></span>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <!-- Recent Activity Table -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-white/10 transition-all animate-fade-in animate-delay-100 relative overflow-hidden">
          <div class="absolute -right-20 -bottom-20 w-48 h-48 rounded-full bg-purple-500/5 blur-3xl pointer-events-none"></div>

          <div class="flex items-center justify-between mb-6 relative z-10">
            <h3 class="text-xl font-bold text-white flex items-center gap-2">
              <i class="fas fa-clipboard-list text-purple-400"></i> Recent Visits
            </h3>
            <a href="/doctor/appointments" class="text-indigo-400 text-sm font-semibold hover:text-indigo-300 hover:underline transition-colors">View All</a>
          </div>
          
          <div class="hms-table-container relative z-10 max-h-[350px] overflow-y-auto">
            <table class="hms-table w-full">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Patient</th>
                  <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Date</th>
                  <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Status</th>
                </tr>
              </thead>
              <tbody>
                <% recentAppointments.forEach(app => { %>
                  <tr class="border-b border-white/5 hover:bg-white/5 transition-all">
                    <td class="py-3 px-4 font-bold text-white text-sm"><%= app.patient_name %></td>
                    <td class="py-3 px-4 text-gray-300 text-xs font-medium"><%= new Date(app.date).toLocaleDateString() %></td>
                    <td class="py-3 px-4">
                      <span class="hms-badge hms-badge-<%= app.status === 'pending' ? 'warning' : app.status === 'confirmed' ? 'success' : 'info' %> capitalize"><%= app.status %></span>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Recent Prescriptions section -->
      <div class="hms-card hms-card-glass hms-card-elevated hover:border-white/10 transition-all animate-fade-in animate-delay-200 relative overflow-hidden mb-6">
        <div class="absolute -right-20 -top-20 w-48 h-48 rounded-full bg-emerald-500/5 blur-3xl pointer-events-none"></div>

        <div class="flex items-center justify-between mb-6 relative z-10">
          <h3 class="text-xl font-bold text-white flex items-center gap-2">
            <i class="fas fa-file-prescription text-emerald-400"></i> Issued Prescriptions
          </h3>
          <a href="/doctor/prescription" class="hms-btn hms-btn-primary text-xs flex items-center gap-1.5 px-4 py-2 rounded-xl">
            <i class="fas fa-plus"></i> Create Prescription
          </a>
        </div>

        <div class="hms-table-container relative z-10">
          <table class="hms-table w-full">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Patient</th>
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Diagnosis / Disease</th>
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Date Issued</th>
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Action</th>
              </tr>
            </thead>
            <tbody>
              <% prescriptions.forEach(p => { %>
                <tr class="border-b border-white/5 hover:bg-white/5 transition-all">
                  <td class="py-3 px-4 font-bold text-white text-sm"><%= p.patient_name %></td>
                  <td class="py-3 px-4 text-gray-300 text-sm font-medium"><%= p.disease %></td>
                  <td class="py-3 px-4 text-gray-400 text-xs font-medium"><%= new Date(p.created_at).toLocaleDateString() %></td>
                  <td class="py-3 px-4">
                    <a href="<%= p.file_path %>" target="_blank" class="inline-flex items-center justify-center w-9 h-9 bg-white/5 border border-white/10 hover:bg-indigo-600 hover:border-indigo-500 text-white rounded-xl hover:scale-105 transition-all shadow-md hover:shadow-indigo-500/20" title="View PDF Document">
                      <i class="fas fa-file-pdf text-xs"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
  </div>
</div>

<script>
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  if (socket) {
    socket.on('doctor-notification', (data) => {
      if (typeof window.hmsShowToast === 'function') {
        window.hmsShowToast('Clinical', (data && data.message) ? data.message : 'New notification', 'warning');
      }
    });
  }
</script>

<%- include('../partials/footer') %>

<% var title = 'Chat - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/doctor-sidebar', { active: 'chat' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="mb-8 animate-fade-in">
      <h1 class="text-3xl font-black text-white mb-2">Chat with Patients</h1>
      <p class="text-gray-400 font-medium">Secure messaging with your patients</p>
    </div>

    <!-- Chat Interface -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <!-- Patient List -->
      <div class="lg:col-span-1">
        <div class="hms-card">
          <h3 class="text-lg font-bold text-white mb-4">Patients</h3>
          <div class="space-y-2" id="patientList">
            <% appointments.forEach(app => { %>
              <button class="w-full flex items-center gap-3 p-3 bg-white/5 rounded-xl hover:bg-white/10 transition-all text-left" onclick="selectPatient('<%= app.patient_id %>', '<%= app.patient_name %>')">
                <i class="fas fa-user-circle text-2xl text-indigo-400"></i>
                <div>
                  <h4 class="text-sm font-bold text-white"><%= app.patient_name %></h4>
                  <p class="text-xs text-gray-400"><%= app.symptoms || 'No symptoms' %></p>
                </div>
              </button>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Chat Box -->
      <div class="lg:col-span-3">
        <div class="hms-card h-[600px] flex flex-col">
          <div class="flex items-center justify-between p-4 border-b border-white/10">
            <h3 class="text-lg font-bold text-white" id="chatTitle">Select a patient to chat</h3>
            <span class="hms-badge hms-badge-success" id="onlineStatus" style="display:none">Online</span>
          </div>
          <div class="flex-1 overflow-y-auto p-4" id="chatBox">
            <div class="text-center text-gray-400 py-16">
              <i class="fas fa-comments text-4xl mb-4"></i>
              <p>Select a patient from the list to start chatting</p>
            </div>
          </div>
          <div class="p-4 border-t border-white/10" id="chatInput" style="display:none">
            <div class="flex gap-3">
              <input type="text" id="messageInput" class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:border-indigo-500" placeholder="Type your message...">
              <button onclick="sendMessage()" class="hms-btn hms-btn-primary px-6">
                <i class="fas fa-paper-plane"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  let currentPatientId = null;
  let currentPatientName = '';

  function selectPatient(id, name) {
    currentPatientId = id;
    currentPatientName = name;
    document.getElementById('chatTitle').textContent = `Chat with ${name}`;
    document.getElementById('onlineStatus').style.display = 'inline';
    document.getElementById('chatInput').style.display = 'flex';
    document.getElementById('chatBox').innerHTML = '';
    
    loadChatHistory(id);
    markAsRead(id);
  }

  async function loadChatHistory(patientId) {
    try {
      const res = await fetch(`/doctor/chat/history/${patientId}`);
      const data = await res.json();
      if (data.success) {
        data.messages.forEach(msg => {
          const type = msg.sender_id === '<%= user.id %>' ? 'sent' : 'received';
          appendChatMessage(msg.message, type, type === 'sent' ? 'You' : currentPatientName);
        });
      }
    } catch (err) {
      console.error('Error loading chat history:', err);
    }
  }

  async function markAsRead(senderId) {
    try {
      await fetch('/doctor/chat/mark-read', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sender_id: senderId })
      });
    } catch (err) {
      console.error('Error marking as read:', err);
    }
  }

  function appendChatMessage(message, type, fromName) {
    const chatBox = document.getElementById('chatBox');
    const div = document.createElement('div');
    div.className = `chat-message ${type}`;
    div.innerHTML = `<small class="d-block mb-1 ${type === 'sent' ? 'text-light' : 'text-muted'}">${fromName}</small>${message}`;
    chatBox.appendChild(div);
    chatBox.scrollTop = chatBox.scrollHeight;
  }

  async function sendMessage() {
    const input = document.getElementById('messageInput');
    const message = input.value.trim();
    if (!message || !currentPatientId) return;

    appendChatMessage(message, 'sent', 'You');
    input.value = '';

    try {
      const res = await fetch('/doctor/chat/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ receiver_id: currentPatientId, message })
      });
      const data = await res.json();
      if (!data.success) {
        if (typeof window.hmsShowToast === 'function') {
          window.hmsShowToast('Error', 'Failed to send message', 'error');
        } else {
          alert('Failed to send message');
        }
      }
    } catch (err) {
      console.error('Error sending message:', err);
      if (typeof window.hmsShowToast === 'function') {
        window.hmsShowToast('Error', 'Error sending message', 'error');
      } else {
        alert('Error sending message');
      }
    }
  }

  document.getElementById('messageInput').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') sendMessage();
  });

  // Socket.IO setup
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  if (socket) {
    socket.emit('user-online', '<%= user.id %>');
    socket.on('new-message', (data) => {
      if (data.sender_id === currentPatientId) {
        appendChatMessage(data.message, 'received', currentPatientName);
        markAsRead(data.sender_id);
      }
    });

    socket.on('typing-start', (data) => {
      if (data.from === currentPatientId) {
        document.getElementById('chatTitle').textContent = `${currentPatientName} is typing...`;
      }
    });

    socket.on('typing-stop', (data) => {
      if (data.from === currentPatientId) {
        document.getElementById('chatTitle').textContent = `Chat with ${currentPatientName}`;
      }
    });

    socket.on('user-came-online', (data) => {
      if (data.userId === currentPatientId) {
        document.getElementById('onlineStatus').classList.remove('bg-secondary');
        document.getElementById('onlineStatus').classList.add('bg-success');
      }
    });

    socket.on('user-went-offline', (data) => {
      if (data.userId === currentPatientId) {
        document.getElementById('onlineStatus').classList.remove('bg-success');
        document.getElementById('onlineStatus').classList.add('bg-secondary');
      }
    });
  }

  // Typing indicator
  let typingTimeout;
  document.getElementById('messageInput').addEventListener('input', () => {
    if (currentPatientId && socket) {
      socket.emit('typing-start', { to: currentPatientId, from: '<%= user.id %>', fromName: 'Dr. <%= user.name %>' });
      clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => {
        socket.emit('typing-stop', { to: currentPatientId, from: '<%= user.id %>' });
      }, 1000);
    }
  });

  window.addEventListener('beforeunload', () => {
    if (socket) {
      socket.emit('user-offline', '<%= user.id %>');
    }
  });
</script>

<%- include('../partials/footer') %>

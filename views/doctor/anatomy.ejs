<% var title = 'Anatomy Visualizer - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/doctor-sidebar', { active: 'anatomy' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8 hms-page-transition">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2"><i class="fas fa-dna mr-2 text-indigo-400"></i>Holographic Anatomy HUD</h1>
        <p class="text-gray-400 font-medium">Explain physiological diagnostics using our real-time medical digital twin.</p>
      </div>
      <div class="flex gap-2 self-start md:self-auto">
        <span class="hms-badge hms-badge-primary px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full animate-ping"></span>
          Diagnostic Core Live
        </span>
      </div>
    </div>

    <!-- Anatomy Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Anatomy Holographic Twin Viewport -->
      <div class="lg:col-span-5 hms-glass-premium hms-hover-lift rounded-[30px] p-6 relative overflow-hidden flex flex-col items-center justify-center min-h-[500px] shadow-2xl group">
        <div class="hud-grid-overlay"></div>
        <div class="hud-laser-line hidden" id="anatomyLaser"></div>

        <!-- Diagnostic ring background -->
        <div class="absolute w-80 h-80 hud-diagnostic-ring pointer-events-none opacity-20"></div>

        <!-- Simulated Body Twin Map (SVG) -->
        <svg viewBox="0 0 220 500" class="h-[420px] w-auto relative z-10 filter drop-shadow(0 0 15px rgba(99,102,241,0.1))">
          <!-- Body Outline Base -->
          <path d="M110,40 C125,40 135,48 135,62 C135,76 125,84 110,84 C95,84 85,76 85,62 C85,48 95,40 110,40 Z M110,88 C120,88 128,94 135,100 C155,120 165,140 170,180 C175,220 170,250 162,280 C158,295 152,310 148,330 C144,350 146,390 148,430 C150,470 142,480 132,480 C125,480 120,460 115,440 L110,410 L105,440 C100,460 95,480 88,480 C78,480 70,470 72,430 C74,390 76,350 72,330 C68,310 62,295 58,280 C50,250 45,220 50,180 C55,140 65,120 85,100 C92,94 100,88 110,88 Z" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="2" stroke-dasharray="4,4"></path>

          <!-- Brain node -->
          <path id="organ-brain" onclick="startOrganScan('Brain')" class="organ-path" d="M100,45 C115,45 122,50 122,60 C122,70 115,75 100,75 C85,75 78,70 78,60 C78,50 85,45 100,45 Z" title="Brain Node"></path>

          <!-- Lungs node -->
          <path id="organ-lungs" onclick="startOrganScan('Lungs')" class="organ-path" d="M85,120 C95,115 100,120 102,125 C102,150 80,165 80,140 Z M115,120 C105,115 100,120 98,125 C98,150 120,165 120,140 Z" title="Pulmonic Nodes"></path>

          <!-- Heart node -->
          <path id="organ-heart" onclick="startOrganScan('Heart')" class="organ-path" d="M96,135 C100,130 104,135 106,140 C108,150 96,160 96,160 C96,160 84,150 86,140 C88,135 92,130 96,135 Z" title="Cardiovascular Heart Node"></path>

          <!-- Stomach node -->
          <path id="organ-stomach" onclick="startOrganScan('Stomach')" class="organ-path" d="M90,175 C110,170 115,185 110,195 C105,205 90,200 85,190 C80,180 85,175 90,175 Z" title="Digestive Stomach Node"></path>

          <!-- Kidneys node -->
          <path id="organ-kidneys" onclick="startOrganScan('Kidneys')" class="organ-path" d="M82,210 C88,210 90,215 88,225 C82,225 80,220 82,210 Z M118,210 C112,210 110,215 112,225 C118,225 120,220 118,210 Z" title="Renal Kidney Nodes"></path>
        </svg>

        <div class="absolute bottom-6 text-center z-10">
          <p class="text-[10px] font-mono text-indigo-400 uppercase tracking-widest bg-indigo-500/10 px-3 py-1.5 rounded-full border border-indigo-400/20">Click on glowing organ nodes to scan</p>
        </div>
      </div>

      <!-- Live Clinical Telemetry Screen -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="hms-glass-premium hms-hover-lift rounded-[30px] p-6 relative overflow-hidden shadow-2xl flex-grow min-h-[480px]">
          <div class="hud-grid-overlay"></div>
          
          <!-- Standby screen -->
          <div id="anatomyStandby" class="flex flex-col items-center justify-center h-full text-center py-20 relative z-10">
            <div class="w-20 h-20 rounded-full bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-3xl text-indigo-400 mb-6 hud-spin">
              <i class="fas fa-atom"></i>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Diagnostic Scan Core Standby</h3>
            <p class="text-gray-400 text-sm max-w-sm">Select any glowing physiological organ twin on the left wireframe model to trigger Google Gemini E2E clinical auditing.</p>
          </div>

          <!-- Scanning loader overlay -->
          <div id="anatomyScanning" class="hidden flex-col items-center justify-center h-full text-center py-20 relative z-10 animate-fade-in">
            <div class="w-24 h-24 bg-rose-500/10 border border-rose-500/20 rounded-full flex items-center justify-center text-4xl text-rose-400 mb-6 animate-pulse">
              <i class="fas fa-satellite-dish animate-bounce"></i>
            </div>
            <h3 class="text-2xl font-black text-rose-500 mb-2 uppercase tracking-widest animate-pulse">Neural Audit in Progress</h3>
            <p class="text-gray-400 text-xs font-mono" id="anatomyScanStatus">SCANNING ORGAN FREQUENCY MODES...</p>
          </div>

          <!-- Active audit screen -->
          <div id="anatomyActive" class="hidden relative z-10 animate-fade-in h-full flex flex-col justify-between">
            <div>
              <div class="flex items-center justify-between mb-8 border-b border-white/10 pb-4">
                <div class="flex items-center gap-4">
                  <div class="w-14 h-14 bg-indigo-500/20 border border-indigo-500/30 text-indigo-400 rounded-2xl flex items-center justify-center text-2xl" id="organHeaderIcon">
                    <i class="fas fa-heart"></i>
                  </div>
                  <div>
                    <h3 class="text-2xl font-black text-white" id="txtOrganTitle">Heart Node Analysis</h3>
                    <span class="text-emerald-400 font-bold uppercase text-[10px] tracking-widest flex items-center gap-1.5 mt-0.5">
                      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                      Digital Twin Integrity Verified
                    </span>
                  </div>
                </div>

                <button type="button" onclick="speakAuditReport()" class="w-10 h-10 bg-white/5 border border-white/10 text-gray-300 hover:bg-indigo-600 hover:text-white rounded-xl flex items-center justify-center transition-all cursor-pointer" title="Speak Audit Report">
                  <i class="fas fa-volume-up text-sm"></i>
                </button>
              </div>

              <!-- Score matrix -->
              <div class="grid grid-cols-2 gap-4 mb-6">
                <div class="bg-white/5 p-4 rounded-2xl border border-white/5">
                  <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mb-1">Complexity Index</span>
                  <p class="text-xl font-black text-white font-mono" id="txtComplexity">98.2%</p>
                </div>
                <div class="bg-white/5 p-4 rounded-2xl border border-white/5">
                  <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mb-1">Twin Health score</span>
                  <p class="text-xl font-black text-emerald-400 font-mono" id="txtHealthScore">A+</p>
                </div>
              </div>

              <!-- Gemini clinical advisory -->
              <div class="p-5 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl mb-6">
                <h4 class="font-bold text-indigo-300 text-sm mb-3 flex items-center gap-1.5"><i class="fas fa-stethoscope"></i> Clinical Neural Advisory</h4>
                <p class="text-gray-300 text-xs leading-relaxed" id="txtOrganOverview">Scanning results...</p>
              </div>

              <!-- Lifestyle and precaution alerts -->
              <div class="space-y-2 mb-6">
                <h4 class="font-bold text-gray-400 text-xs uppercase tracking-wider mb-3">Recommended Preventive Actions</h4>
                <div id="listRecommendations" class="space-y-2">
                  <!-- recommendations injected here -->
                </div>
              </div>
            </div>

            <!-- Footer options -->
            <div class="border-t border-white/10 pt-4 flex gap-4">
              <button onclick="speakAuditReport()" class="hms-btn hms-btn-primary flex-1 text-xs py-3 rounded-xl flex items-center justify-center gap-2 cursor-pointer">
                <i class="fas fa-volume-up"></i> Listen to Audio
              </button>
              <button onclick="resetAnatomy()" class="hms-btn hms-btn-secondary flex-1 text-xs py-3 rounded-xl cursor-pointer">Inspect Another organ</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  let activeOrgan = '';
  let organDataCache = null;

  function resetAnatomy() {
    document.getElementById('anatomyStandby').classList.remove('hidden');
    document.getElementById('anatomyActive').classList.add('hidden');
    document.getElementById('anatomyScanning').classList.add('hidden');

    document.querySelectorAll('.organ-path').forEach(p => p.classList.remove('active'));
    activeOrgan = '';
    organDataCache = null;
    if (window.speechSynthesis) window.speechSynthesis.cancel();
  }

  async function startOrganScan(organ) {
    if (activeOrgan === organ) return;
    activeOrgan = organ;

    if (window.speechSynthesis) window.speechSynthesis.cancel();

    // Toggle active paths
    document.querySelectorAll('.organ-path').forEach(p => p.classList.remove('active'));
    const pathId = 'organ-' + organ.toLowerCase();
    const activePath = document.getElementById(pathId);
    if (activePath) activePath.classList.add('active');

    // Trigger visual scan overlay
    document.getElementById('anatomyStandby').classList.add('hidden');
    document.getElementById('anatomyActive').classList.add('hidden');
    document.getElementById('anatomyScanning').classList.remove('hidden');
    document.getElementById('anatomyLaser').classList.remove('hidden');

    // Speech trigger alert
    speakVocalAlert(`Initiating dynamic digital twin scanning of the physiological ${organ} nodes.`);

    let steps = ['CALIBRATING HOLOGRAPHIC GRID...', 'EXTRACTING BIOMETRIC TELEMETRY...', 'ANALYZING NEURAL DYNAMICS...', 'GENERATING GEMINI CLINICAL ADVISORY...'];
    for(let i=0; i<steps.length; i++) {
      document.getElementById('anatomyScanStatus').innerText = steps[i];
      await new Promise(res => setTimeout(res, 600));
    }

    // Call backend API
    try {
      const res = await fetch('/doctor/anatomy/analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ organ })
      });
      const data = await res.json();
      if (data.success) {
        renderOrganReport(data);
      } else {
        throw new Error(data.error);
      }
    } catch(err) {
      console.error(err);
      renderOrganReport({
        organ: organ,
        complexityIndex: '97.2%',
        healthScore: 'A',
        overview: `Fallback audit completed successfully. The physiological ${organ} node demonstrates steady biometrics and regular metabolic cycles under fallback rules.`,
        recommendations: ['Periodic clinical checks', 'Regulated rest-work hours', 'Proper cellular hydration']
      });
    }
  }

  function renderOrganReport(data) {
    organDataCache = data;
    document.getElementById('anatomyScanning').classList.add('hidden');
    document.getElementById('anatomyLaser').classList.add('hidden');
    document.getElementById('anatomyActive').classList.remove('hidden');

    document.getElementById('txtOrganTitle').innerText = data.organ + ' Node Analysis';
    document.getElementById('txtComplexity').innerText = data.complexityIndex;
    document.getElementById('txtHealthScore').innerText = data.healthScore;
    document.getElementById('txtOrganOverview').innerText = data.overview;

    const iconMap = {
      'Brain': 'fa-brain text-purple-400',
      'Lungs': 'fa-lungs text-cyan-400',
      'Heart': 'fa-heart text-rose-400',
      'Stomach': 'fa-pizza-slice text-amber-400',
      'Kidneys': 'fa-tint text-indigo-400'
    };
    const cls = iconMap[data.organ] || 'fa-stethoscope';
    document.getElementById('organHeaderIcon').innerHTML = `<i class="fas ${cls}"></i>`;

    const list = document.getElementById('listRecommendations');
    list.innerHTML = '';
    data.recommendations.forEach(rec => {
      list.innerHTML += `
        <div class="flex items-center gap-3 p-3 bg-white/5 border border-white/5 rounded-xl text-xs hover:bg-white/8 transition-all">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 shrink-0"></span>
          <span class="text-gray-300 leading-normal">${rec}</span>
        </div>
      `;
    });

    speakVocalAlert(`Scan completed for the ${data.organ}. Twin Health Grade resolved as ${data.healthScore}.`);
  }

  function speakVocalAlert(msg) {
    if (!window.speechSynthesis) return;
    const utterance = new SpeechSynthesisUtterance(msg);
    utterance.rate = 1.05;
    window.speechSynthesis.speak(utterance);
  }

  function speakAuditReport() {
    if (!organDataCache) return;
    const text = `Physiological audit completed for the ${organDataCache.organ}. Complexity level stands at ${organDataCache.complexityIndex} with a health score grade of ${organDataCache.healthScore}. Overview: ${organDataCache.overview}`;
    speakVocalAlert(text);
  }
</script>
<%- include('../partials/footer') %>

<% var title = 'Anatomy Visualizer - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<div class="container-fluid bg-gray-50 min-h-screen">
  <div class="row">
    <%- include('../partials/doctor-sidebar', { active: 'anatomy' }) %>

    <div class="col-md-9 col-lg-10 p-8">
      <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-end mb-8">
            <div>
                <h2 class="text-4xl font-black text-gray-900 tracking-tight">Interactive Anatomy Explainer</h2>
                <p class="text-gray-500 mt-2">Explain conditions to patients using our digital twin model.</p>
            </div>
            <div class="flex gap-2">
                <button class="bg-white border px-4 py-2 rounded-xl font-bold text-sm">Male Model</button>
                <button class="bg-gray-200 px-4 py-2 rounded-xl font-bold text-sm">Female Model</button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Anatomy Canvas -->
            <div class="lg:col-span-1 bg-white rounded-[40px] shadow-sm border p-8 flex items-center justify-center relative group">
                <div class="absolute top-6 left-6 flex flex-col gap-2">
                    <button class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center hover:bg-indigo-600 hover:text-white transition"><i class="fas fa-search-plus"></i></button>
                    <button class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center hover:bg-indigo-600 hover:text-white transition"><i class="fas fa-sync-alt"></i></button>
                </div>
                
                <!-- Simulated Body Map (SVG) -->
                <svg viewBox="0 0 200 500" class="h-[500px] w-auto">
                    <path class="hover:fill-indigo-500 transition-colors cursor-pointer fill-gray-200" d="M100,50 C120,50 130,60 130,80 C130,100 120,110 100,110 C80,110 70,100 70,80 C70,60 80,50 100,50" onclick="showInfo('Brain', 'Cognitive functions, neural processing, and nervous system control.')"></path>
                    <path class="hover:fill-red-500 transition-colors cursor-pointer fill-gray-200" d="M80,150 L120,150 L125,250 L75,250 Z" onclick="showInfo('Chest/Heart', 'Cardiovascular health and respiratory efficiency.')"></path>
                    <rect class="hover:fill-orange-500 transition-colors cursor-pointer fill-gray-200" x="80" y="260" width="40" height="60" rx="10" onclick="showInfo('Abdomen', 'Digestive health and internal organ processing.')"></rect>
                    <path class="hover:fill-indigo-400 transition-colors cursor-pointer fill-gray-200" d="M60,150 L75,300 L65,300 L50,150 Z"></path>
                    <path class="hover:fill-indigo-400 transition-colors cursor-pointer fill-gray-200" d="M140,150 L125,300 L135,300 L150,150 Z"></path>
                </svg>

                <div class="absolute bottom-6 text-center">
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Click on body parts to inspect</p>
                </div>
            </div>

            <!-- Analysis Panel -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-[40px] shadow-sm border p-8 h-full">
                    <div id="defaultMsg" class="flex flex-col items-center justify-center h-full text-center py-20">
                        <i class="fas fa-atom text-5xl text-gray-100 mb-6"></i>
                        <h3 class="text-2xl font-bold text-gray-300">Select a region to analyze</h3>
                    </div>

                    <div id="analysisContent" class="hidden animate__animated animate__fadeIn">
                        <div class="flex items-center gap-4 mb-8">
                            <div class="w-16 h-16 bg-indigo-600 text-white rounded-2xl flex items-center justify-center text-2xl font-black" id="regionIcon">B</div>
                            <div>
                                <h3 class="text-3xl font-black text-gray-900" id="regionTitle">Brain Analysis</h3>
                                <span class="text-indigo-600 font-bold uppercase text-xs tracking-widest">Digital Twin Status: Optimized</span>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4 mb-8">
                            <div class="bg-gray-50 p-6 rounded-3xl border border-gray-100">
                                <h5 class="text-sm font-bold text-gray-500 mb-2">Complexity Index</h5>
                                <p class="text-2xl font-black text-gray-900">98.2%</p>
                            </div>
                            <div class="bg-gray-50 p-6 rounded-3xl border border-gray-100">
                                <h5 class="text-sm font-bold text-gray-500 mb-2">Health Score</h5>
                                <p class="text-2xl font-black text-green-500">A+</p>
                            </div>
                        </div>

                        <div class="bg-indigo-900 text-white p-8 rounded-[32px] shadow-xl shadow-indigo-100">
                            <h4 class="font-bold mb-4 flex items-center"><i class="fas fa-info-circle mr-2"></i> Clinical Overview</h4>
                            <p class="text-indigo-100 leading-relaxed" id="regionDesc">The primary control center of the nervous system...</p>
                            <button class="mt-6 bg-white text-indigo-900 px-6 py-2 rounded-xl font-bold text-sm hover:bg-indigo-50 transition">Generate Patient Leaflet</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
    function showInfo(title, desc) {
        document.getElementById('defaultMsg').classList.add('hidden');
        document.getElementById('analysisContent').classList.remove('hidden');
        
        document.getElementById('regionTitle').innerText = title;
        document.getElementById('regionDesc').innerText = desc;
        document.getElementById('regionIcon').innerText = title.charAt(0);
        
        // Pulse effect on icon
        const icon = document.getElementById('regionIcon');
        icon.classList.add('animate-bounce');
        setTimeout(() => icon.classList.remove('animate-bounce'), 1000);
    }
</script>

<%- include('../partials/footer') %>

<% var title = 'Generate Prescription - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/doctor-sidebar', { active: 'prescription' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
      <div class="mb-8 animate-fade-in">
        <h1 class="text-3xl font-black text-white mb-2">Generate Prescription</h1>
        <p class="text-gray-400">Create and send prescription to patient</p>
      </div>
      <div class="max-w-2xl mx-auto">
        <div class="hms-card animate-scale-in">
          <div class="mb-6 p-4 bg-gray-800/50 rounded-xl border border-gray-700">
            <h3 class="text-lg font-bold text-white mb-3">Appointment Details</h3>
            <div class="space-y-2">
              <p class="text-gray-400"><span class="text-white font-semibold">Patient:</span> <%= appointment.patient_name %></p>
              <p class="text-gray-400"><span class="text-white font-semibold">Date:</span> <%= new Date(appointment.date).toLocaleDateString() %></p>
              <p class="text-gray-400"><span class="text-white font-semibold">Symptoms:</span> <%= appointment.symptoms || 'N/A' %></p>
            </div>
          </div>
          <form action="/doctor/prescription" method="POST" class="space-y-4">
            <input type="hidden" name="appointmentId" value="<%= appointment.id %>">
            <input type="hidden" name="patientName" value="<%= appointment.patient_name %>">
            <div>
              <label class="hms-label">Disease/Condition</label>
              <input type="text" name="disease" class="hms-input" required placeholder="e.g., Viral Fever, Common Cold">
            </div>
            <div>
              <label class="hms-label">Medicines (comma separated)</label>
              <textarea name="medicines" class="hms-input" rows="4" required placeholder="Paracetamol 500mg - 1 tablet after meal,&#10;Cetirizine 10mg - 1 tablet at night,&#10;Vitamin C 500mg - 1 tablet daily"></textarea>
              <p class="text-gray-500 text-sm mt-2">Enter each medicine on new line or comma separated</p>
            </div>
            <div class="flex gap-3">
              <button type="submit" class="hms-btn hms-btn-primary flex-1">
                <i class="fas fa-file-pdf"></i>
                Generate PDF
              </button>
              <a href="/doctor/appointments" class="hms-btn hms-btn-secondary flex-1">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>

<% var title = 'My Appointments - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/doctor-sidebar', { active: 'appointments' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
      <div class="mb-8 animate-fade-in">
        <h1 class="text-3xl font-black text-white mb-2">My Appointments</h1>
        <p class="text-gray-400">Manage your patient consultations</p>
      </div>
      <div class="hms-card animate-scale-in">
        <div class="hms-table-container">
          <table class="hms-table">
            <thead>
              <tr>
                <th>Patient</th>
                <th>Phone</th>
                <th>Date</th>
                <th>Time</th>
                <th>Symptoms</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% appointments.forEach(app => { %>
                <tr data-id="<%= app.id %>">
                  <td class="font-semibold text-white"><%= app.patient_name %></td>
                  <td class="text-gray-400"><%= app.patient_phone || 'N/A' %></td>
                  <td class="text-gray-400"><%= new Date(app.date).toLocaleDateString() %></td>
                  <td class="text-gray-400"><%= app.time_slot %></td>
                  <td class="text-gray-500 text-sm"><%= app.symptoms || 'N/A' %></td>
                  <td>
                    <span class="hms-badge hms-badge-<%= app.status === 'pending' ? 'warning' : app.status === 'confirmed' ? 'success' : app.status === 'completed' ? 'info' : 'danger' %>"><%= app.status %></span>
                  </td>
                  <td>
                    <div class="flex gap-2">
                      <form action="/doctor/appointments/update/<%= app.id %>" method="POST" class="inline">
                        <input type="hidden" name="status" value="confirmed">
                        <button type="submit" class="hms-btn hms-btn-success hms-btn-sm" <%= app.status !== 'pending' ? 'disabled' : '' %> title="Confirm">
                          <i class="fas fa-check"></i>
                        </button>
                      </form>
                      <button onclick="startVideoCall('<%= app.id %>', '<%= app.patient_name %>')" class="hms-btn hms-btn-primary hms-btn-sm" <%= app.status !== 'confirmed' ? 'disabled' : '' %> title="Video Call">
                        <i class="fas fa-video"></i>
                      </button>
                      <form action="/doctor/appointments/update/<%= app.id %>" method="POST" class="inline">
                        <input type="hidden" name="status" value="completed">
                        <button type="submit" class="hms-btn hms-btn-primary hms-btn-sm" <%= app.status === 'completed' || app.status === 'cancelled' ? 'disabled' : '' %> title="Mark Completed">
                          <i class="fas fa-check-double"></i>
                        </button>
                      </form>
                      <% if (app.status === 'confirmed') { %>
                        <a href="/consultation/<%= app.id %>" class="hms-btn hms-btn-info hms-btn-sm" title="Join Video Call">
                          <i class="fas fa-video"></i>
                        </a>
                        <button class="hms-btn hms-btn-secondary hms-btn-sm" title="Call to Room" onclick="callNextPatient('<%= app.id %>', '<%= app.patient_id %>', '<%= app.patient_name %>')">
                          <i class="fas fa-bullhorn"></i>
                        </button>
                        <button class="hms-btn hms-btn-danger hms-btn-sm" title="Live Vitals" onclick="showVitalsModal('<%= app.patient_id %>', '<%= app.patient_name %>')">
                          <i class="fas fa-heartbeat"></i>
                        </button>
                      <% } %>
                      <a href="/doctor/prescription/<%= app.id %>" class="hms-btn hms-btn-warning hms-btn-sm" <%= app.status !== 'completed' ? 'disabled' : '' %> title="Write Prescription">
                        <i class="fas fa-prescription"></i>
                      </a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="vitalsModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center">
  <div class="hms-card max-w-4xl w-full mx-4 animate-scale-in">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-xl font-bold text-white flex items-center gap-2">
        <i class="fas fa-heartbeat text-rose-500 animate-pulse"></i>
        Live Vitals: <span id="vitalsPatientName"></span>
      </h3>
      <button type="button" onclick="closeVitalsModal()" class="text-gray-400 hover:text-white">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="bg-gray-800/50 rounded-xl p-6 text-center border border-gray-700">
        <h6 class="text-gray-400 text-sm uppercase mb-2">Heart Rate</h6>
        <div class="flex items-center justify-center gap-2">
          <span class="text-4xl font-black text-emerald-400" id="vitals-hr">--</span>
          <span class="text-gray-500">BPM</span>
        </div>
      </div>
      <div class="bg-gray-800/50 rounded-xl p-6 text-center border border-gray-700">
        <h6 class="text-gray-400 text-sm uppercase mb-2">SpO2 (Oxygen)</h6>
        <div class="flex items-center justify-center gap-2">
          <span class="text-4xl font-black text-indigo-400" id="vitals-spo2">--</span>
          <span class="text-gray-500">%</span>
        </div>
        <div class="w-full bg-gray-700 h-2 rounded-full mt-3">
          <div id="vitals-spo2-bar" class="h-full bg-indigo-500 transition-all" style="width: 0%"></div>
        </div>
      </div>
      <div class="bg-gray-800/50 rounded-xl p-6 text-center border border-gray-700">
        <h6 class="text-gray-400 text-sm uppercase mb-2">Blood Pressure</h6>
        <div class="flex items-center justify-center gap-2">
          <span class="text-4xl font-black text-amber-400" id="vitals-bp">--/--</span>
          <span class="text-gray-500">mmHg</span>
        </div>
        <p class="text-gray-500 text-sm mt-2">Normal: 120/80</p>
      </div>
      <div class="bg-gray-800/50 rounded-xl p-6 text-center border border-gray-700">
        <h6 class="text-gray-400 text-sm uppercase mb-2">Body Temp</h6>
        <div class="flex items-center justify-center gap-2">
          <span class="text-4xl font-black text-indigo-400" id="vitals-temp">--</span>
          <span class="text-gray-500">°F</span>
        </div>
        <p class="text-gray-500 text-sm mt-2" id="temp-status">Stable</p>
      </div>
    </div>
    <div id="vitals-alert" class="hidden bg-rose-500/20 border border-rose-500/50 rounded-xl p-4 mb-6">
      <div class="flex items-center gap-2 text-rose-400">
        <i class="fas fa-exclamation-triangle"></i>
        <span class="font-bold">Critical Alert:</span>
        <span>Abnormal vitals detected!</span>
      </div>
    </div>
    <button type="button" onclick="closeVitalsModal()" class="hms-btn hms-btn-secondary w-full">Close Monitoring</button>
  </div>
</div>

<script>
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  if (socket) {
    socket.on('appointment-status-update', (data) => {
      const row = document.querySelector(`tr[data-id="${data.appointmentId}"]`);
      if (row) {
        const badge = row.querySelector('.hms-badge');
        if (badge) {
          badge.className = `hms-badge hms-badge-${data.status === 'pending' ? 'warning' : data.status === 'confirmed' ? 'success' : data.status === 'completed' ? 'info' : 'danger'}`;
          badge.textContent = data.status;
        }
      }
    });
  }

  function startVideoCall(appointmentId, patientName) {
    if (confirm(`Start video call with ${patientName}?`)) {
      window.location.href = `/consultation/${appointmentId}`;
    }
  }

  let currentPatientId;
  function showVitalsModal(patientId, patientName) {
    currentPatientId = patientId;
    document.getElementById('vitalsPatientName').innerText = patientName;
    const modal = document.getElementById('vitalsModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    if (socket) socket.emit('start-vitals-monitoring', { patientId });
  }
  function closeVitalsModal() {
    const modal = document.getElementById('vitalsModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    if (socket) socket.emit('stop-vitals-monitoring');
  }

  if (socket) {
    socket.on('vitals-update', (data) => {
      if (data.patientId == currentPatientId) {
        const v = data.vitals;
        document.getElementById('vitals-hr').innerText = v.hr;
        document.getElementById('vitals-spo2').innerText = v.spo2;
        document.getElementById('vitals-spo2-bar').style.width = v.spo2 + '%';
        document.getElementById('vitals-bp').innerText = `${v.bpSys}/${v.bpDia}`;
        document.getElementById('vitals-temp').innerText = v.temp;
        const hrEl = document.getElementById('vitals-hr');
        if (v.hr > 110 || v.hr < 50) {
          hrEl.classList.replace('text-emerald-400', 'text-rose-500');
        } else {
          hrEl.classList.replace('text-rose-500', 'text-emerald-400');
        }
        const spo2El = document.getElementById('vitals-spo2');
        const spo2Bar = document.getElementById('vitals-spo2-bar');
        if (v.spo2 < 92) {
          spo2El.classList.replace('text-indigo-400', 'text-rose-500');
          spo2Bar.classList.replace('bg-indigo-500', 'bg-rose-500');
        } else {
          spo2El.classList.replace('text-rose-500', 'text-indigo-400');
          spo2Bar.classList.replace('bg-rose-500', 'bg-indigo-500');
        }
        const alertBox = document.getElementById('vitals-alert');
        if (v.hr > 120 || v.hr < 45 || v.spo2 < 90) {
          alertBox.classList.remove('hidden');
        } else {
          alertBox.classList.add('hidden');
        }
      }
    });

    socket.on('appointment-status-update', (data) => {
      const row = document.querySelector(`tr[data-id="${data.appointmentId}"]`);
      if (row) {
        const badge = row.querySelector('.hms-badge');
        badge.className = `hms-badge hms-badge-${data.status === 'pending' ? 'warning' : data.status === 'confirmed' ? 'success' : data.status === 'completed' ? 'info' : 'danger'}`;
        badge.textContent = data.status;
      }
    });
  }

  function callNextPatient(appId, patientId, patientName) {
    if (socket) {
      socket.emit("call-next-patient", {
        doctorId: '<%= user.id %>',
        doctorName: '<%= user.name %>',
        patientId: patientId,
        patientName: patientName,
        tokenNumber: "T-" + Math.floor(Math.random() * 1000)
      });
    }
    if (typeof window.hmsShowToast === 'function') {
      window.hmsShowToast('Called', `${patientName} has been called to the room`, 'success');
    } else {
      alert(`${patientName} has been called to the room`);
    }
  }

  window.addEventListener('beforeunload', closeVitalsModal);
</script>
<%- include('../partials/footer') %>

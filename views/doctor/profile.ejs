<% var title = 'My Profile - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/doctor-sidebar', { active: 'profile' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="mb-8 animate-fade-in">
      <h1 class="text-3xl font-black text-white mb-2">My Profile</h1>
      <p class="text-gray-400">Manage your professional information</p>
    </div>

    <!-- Profile Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <!-- Profile Card -->
      <div class="hms-card animate-scale-in text-center">
        <img src="<%= doctor.photo || '/images/default-doctor.jpg' %>" alt="Profile" class="w-32 h-32 rounded-2xl mx-auto mb-4 object-cover border-4 border-indigo-500/30">
        <h3 class="text-xl font-bold text-white mb-1">Dr. <%= doctor.name %></h3>
        <p class="text-gray-400 mb-4"><%= doctor.specialization %></p>
        <div class="space-y-2 text-sm">
          <p class="text-gray-400"><i class="fas fa-map-marker-alt text-rose-400 mr-2"></i><%= doctor.location || 'Location not set' %></p>
          <p class="text-gray-400"><i class="fas fa-rupee-sign text-emerald-400 mr-2"></i>₹<%= doctor.fees %> per consultation</p>
        </div>
      </div>

      <!-- Edit Profile Form -->
      <div class="lg:col-span-2 hms-card animate-fade-in">
        <h3 class="text-xl font-bold text-white mb-6">Edit Profile</h3>
        <form action="/doctor/profile" method="POST" enctype="multipart/form-data" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="hms-label">Full Name</label>
              <input type="text" name="name" class="hms-input" value="<%= doctor.name %>" required>
            </div>
            <div>
              <label class="hms-label">Specialization</label>
              <select name="specialization" class="hms-input">
                <option <%= doctor.specialization === 'General Physician' ? 'selected' : '' %>>General Physician</option>
                <option <%= doctor.specialization === 'Cardiologist' ? 'selected' : '' %>>Cardiologist</option>
                <option <%= doctor.specialization === 'Dermatologist' ? 'selected' : '' %>>Dermatologist</option>
                <option <%= doctor.specialization === 'Neurologist' ? 'selected' : '' %>>Neurologist</option>
                <option <%= doctor.specialization === 'Orthopedic' ? 'selected' : '' %>>Orthopedic</option>
                <option <%= doctor.specialization === 'ENT' ? 'selected' : '' %>>ENT</option>
                <option <%= doctor.specialization === 'Pediatrician' ? 'selected' : '' %>>Pediatrician</option>
                <option <%= doctor.specialization === 'Gynecologist' ? 'selected' : '' %>>Gynecologist</option>
              </select>
            </div>
          </div>
          <div>
            <label class="hms-label">Location/Clinic</label>
            <input type="text" name="location" class="hms-input" value="<%= doctor.location || '' %>">
          </div>
          <div>
            <label class="hms-label">Consultation Fees (₹)</label>
            <input type="number" name="fees" class="hms-input" value="<%= doctor.fees || 500 %>">
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="hms-label">Available From</label>
              <input type="time" name="available_from" class="hms-input" value="<%= doctor.available_from || '09:00' %>">
            </div>
            <div>
              <label class="hms-label">Available To</label>
              <input type="time" name="available_to" class="hms-input" value="<%= doctor.available_to || '17:00' %>">
            </div>
          </div>
          <div>
            <label class="hms-label">Profile Photo</label>
            <input type="file" name="photo" class="hms-input" accept="image/*">
          </div>
          <button type="submit" class="hms-btn hms-btn-primary">
            <i class="fas fa-save mr-2"></i>Save Changes
          </button>
        </form>
      </div>
    </div>

    <!-- Leave Management -->
    <div class="hms-card animate-fade-in">
      <h3 class="text-xl font-bold text-white mb-6"><i class="fas fa-calendar-times text-rose-400 mr-2"></i>Manage Leaves</h3>
      <form action="/doctor/leaves" method="POST" class="flex gap-4 mb-6">
        <input type="date" name="leave_date" class="hms-input flex-1" required>
        <button type="submit" class="hms-btn hms-btn-warning">
          <i class="fas fa-plus mr-2"></i>Mark as Leave
        </button>
      </form>

      <% if (leaves && leaves.length > 0) { %>
        <div class="hms-table-container">
          <table class="hms-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Added On</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% leaves.forEach(l => { %>
                <tr>
                  <td class="text-white"><%= new Date(l.date).toLocaleDateString() %></td>
                  <td class="text-gray-400"><%= new Date(l.created_at).toLocaleDateString() %></td>
                  <td>
                    <form action="/doctor/leaves/delete/<%= l.id %>" method="POST" class="inline">
                      <button class="hms-btn hms-btn-danger hms-btn-sm"><i class="fas fa-trash"></i></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-gray-400 text-center py-8">No upcoming leaves marked</p>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<% var title = 'Hospital Navigator - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<div class="container-fluid bg-gray-50 min-h-screen">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'navigator' }) %>

    <div class="col-md-9 col-lg-10 p-12">
      <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-end mb-12">
            <div>
                <h2 class="text-5xl font-black text-gray-900 tracking-tight">Smart Navigator</h2>
                <p class="text-gray-500 mt-2 text-xl">Navigate the hospital floors with our real-time digital twin.</p>
            </div>
            <div class="flex bg-white p-2 rounded-2xl shadow-sm border">
                <button class="bg-indigo-600 text-white px-4 py-2 rounded-xl font-bold text-sm">Floor 0</button>
                <button class="px-4 py-2 text-gray-500 font-bold text-sm">Floor 1</button>
                <button class="px-4 py-2 text-gray-500 font-bold text-sm">Floor 2</button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            <!-- Navigation Sidebar -->
            <div class="lg:col-span-1 space-y-4">
                <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
                    <h3 class="font-bold text-gray-800 mb-6">Quick Find</h3>
                    <div class="space-y-2">
                        <button class="w-full text-left p-4 rounded-2xl bg-indigo-50 border border-indigo-100 flex items-center gap-4 transition">
                            <i class="fas fa-hospital-user text-indigo-600"></i>
                            <span class="text-sm font-bold text-indigo-900">OPD Block</span>
                        </button>
                        <button class="w-full text-left p-4 rounded-2xl hover:bg-gray-50 flex items-center gap-4 transition">
                            <i class="fas fa-flask text-gray-400"></i>
                            <span class="text-sm font-bold text-gray-700">Pathology Lab</span>
                        </button>
                        <button class="w-full text-left p-4 rounded-2xl hover:bg-gray-50 flex items-center gap-4 transition">
                            <i class="fas fa-vial text-gray-400"></i>
                            <span class="text-sm font-bold text-gray-700">Pharmacy</span>
                        </button>
                        <button class="w-full text-left p-4 rounded-2xl hover:bg-gray-50 flex items-center gap-4 transition">
                            <i class="fas fa-coffee text-gray-400"></i>
                            <span class="text-sm font-bold text-gray-700">Cafeteria</span>
                        </button>
                    </div>
                </div>

                <div class="bg-indigo-900 rounded-3xl p-6 text-white text-center">
                    <i class="fas fa-qrcode text-4xl mb-4"></i>
                    <p class="text-sm font-bold mb-4">Scan QR at any kiosk to sync this map to your phone.</p>
                    <button class="bg-white text-indigo-900 px-6 py-2 rounded-xl font-bold text-xs uppercase">Get QR Code</button>
                </div>
            </div>

            <!-- Interactive Map Canvas -->
            <div class="lg:col-span-3 bg-white rounded-[40px] shadow-sm border border-gray-100 p-12 relative overflow-hidden group">
                <div class="absolute inset-0 bg-gray-50 flex items-center justify-center p-12">
                    <!-- Floor Plan SVG -->
                    <svg viewBox="0 0 800 600" class="w-full h-full drop-shadow-2xl">
                        <!-- Corridors -->
                        <path d="M100 100 H700 V500 H100 Z" fill="#fff" stroke="#e5e7eb" stroke-width="2"></path>
                        <!-- Rooms -->
                        <rect x="150" y="150" width="120" height="100" class="fill-indigo-100 stroke-indigo-300 hover:fill-indigo-600 transition-colors cursor-pointer" rx="10"></rect>
                        <text x="210" y="205" text-anchor="middle" class="text-xs font-black pointer-events-none fill-indigo-900 group-hover:fill-white">ROOM 101</text>
                        
                        <rect x="300" y="150" width="200" height="100" class="fill-green-100 stroke-green-300 hover:fill-green-600 transition-colors cursor-pointer" rx="10"></rect>
                        <text x="400" y="205" text-anchor="middle" class="text-xs font-black pointer-events-none fill-green-900">PATHOLOGY</text>

                        <rect x="530" y="150" width="120" height="100" class="fill-red-100 stroke-red-300 hover:fill-red-600 transition-colors cursor-pointer" rx="10"></rect>
                        <text x="590" y="205" text-anchor="middle" class="text-xs font-black pointer-events-none fill-red-900">EMERGENCY</text>

                        <rect x="150" y="300" width="120" height="150" class="fill-blue-100 stroke-blue-300 hover:fill-blue-600 transition-colors cursor-pointer" rx="10"></rect>
                        <text x="210" y="380" text-anchor="middle" class="text-xs font-black pointer-events-none fill-blue-900">OPD 1</text>

                        <rect x="300" y="300" width="350" height="150" class="fill-gray-100 stroke-gray-300 hover:fill-gray-600 transition-colors cursor-pointer" rx="10"></rect>
                        <text x="475" y="380" text-anchor="middle" class="text-xs font-black pointer-events-none fill-gray-900">CENTRAL ATRIUM</text>
                    </svg>
                </div>
                
                <div class="absolute bottom-8 right-8 flex gap-2">
                    <button class="w-12 h-12 bg-white shadow-lg rounded-2xl flex items-center justify-center text-indigo-600 hover:scale-110 transition"><i class="fas fa-plus"></i></button>
                    <button class="w-12 h-12 bg-white shadow-lg rounded-2xl flex items-center justify-center text-indigo-600 hover:scale-110 transition"><i class="fas fa-minus"></i></button>
                </div>

                <div class="absolute top-8 right-8 bg-white/80 backdrop-blur-md px-4 py-2 rounded-full border shadow-sm flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                    <span class="text-xs font-bold text-gray-700 uppercase tracking-widest">You are here</span>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

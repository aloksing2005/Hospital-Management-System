<% var title = 'AI Voice Assistant - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<style>
    .hologram-pulse {
        animation: hologram 4s ease-in-out infinite;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.2) 0%, transparent 70%);
    }
    @keyframes hologram {
        0%, 100% { transform: scale(1); opacity: 0.5; }
        50% { transform: scale(1.1); opacity: 0.8; }
    }
    .voice-bars span {
        width: 4px; height: 20px; background: #6366f1; border-radius: 2px; display: inline-block;
        margin: 0 2px; animation: voice 1s infinite;
    }
    @keyframes voice {
        0%, 100% { height: 10px; }
        50% { height: 30px; }
    }
</style>

<div class="container-fluid bg-gray-950 min-h-screen text-white">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'ai-voice' }) %>

    <div class="col-md-9 col-lg-10 p-12 flex flex-col items-center justify-center relative overflow-hidden">
        <!-- Hologram Background Effect -->
        <div class="absolute inset-0 hologram-pulse pointer-events-none"></div>

        <div class="relative z-10 text-center max-w-2xl">
            <div class="w-48 h-48 rounded-full bg-indigo-500/20 border-2 border-indigo-500/50 flex items-center justify-center mx-auto mb-10 relative">
                <div class="absolute inset-0 rounded-full border-4 border-indigo-500/20 animate-ping"></div>
                <i class="fas fa-microchip text-6xl text-indigo-400"></i>
            </div>
            
            <h1 class="text-5xl font-black mb-4 tracking-tight">Meet <span class="text-indigo-400">AURA</span></h1>
            <p class="text-gray-400 text-xl mb-12">Your Futuristic AI Medical Companion. <br/> Just say <span class="text-indigo-400 font-bold">"Hey Aura"</span> to begin.</p>

            <div id="voiceIndicator" class="hidden flex justify-center items-center h-12 mb-8 voice-bars">
                <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
            </div>

            <div id="aiResponse" class="bg-white/5 backdrop-blur-xl border border-white/10 p-8 rounded-[40px] text-left mb-8 min-h-[100px] transition-all">
                <p class="text-gray-500 italic">"Waiting for your voice command..."</p>
            </div>

            <div class="flex gap-4 justify-center">
                <button id="startBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-3xl font-bold transition-all shadow-xl shadow-indigo-500/20">
                    <i class="fas fa-microphone mr-2"></i> Activate AURA
                </button>
                <button onclick="window.location.reload()" class="bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-3xl font-bold transition-all">
                    Reset
                </button>
            </div>
        </div>

        <!-- Futuristic Floating Cards -->
        <div class="grid grid-cols-3 gap-6 mt-16 relative z-10 w-full max-w-4xl">
            <div class="bg-white/5 border border-white/5 p-6 rounded-3xl backdrop-blur-sm">
                <i class="fas fa-clock text-indigo-400 mb-3 text-2xl"></i>
                <h4 class="font-bold">Next Meds</h4>
                <p class="text-gray-500 text-sm">Paracetamol in 2 hrs</p>
            </div>
            <div class="bg-white/5 border border-white/5 p-6 rounded-3xl backdrop-blur-sm">
                <i class="fas fa-heartbeat text-red-400 mb-3 text-2xl"></i>
                <h4 class="font-bold">Vitals</h4>
                <p class="text-gray-500 text-sm">Normal: 72 BPM</p>
            </div>
            <div class="bg-white/5 border border-white/5 p-6 rounded-3xl backdrop-blur-sm">
                <i class="fas fa-calendar-alt text-green-400 mb-3 text-2xl"></i>
                <h4 class="font-bold">Appointment</h4>
                <p class="text-gray-500 text-sm">Dr. Smith tomorrow</p>
            </div>
        </div>
    </div>
  </div>
</div>

<script>
    const startBtn = document.getElementById('startBtn');
    const aiResponse = document.getElementById('aiResponse');
    const voiceIndicator = document.getElementById('voiceIndicator');

    // Web Speech API
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    const recognition = new SpeechRecognition();
    const synth = window.speechSynthesis;

    recognition.continuous = false;
    recognition.lang = 'en-US';

    startBtn.onclick = () => {
        recognition.start();
        voiceIndicator.classList.remove('hidden');
        aiResponse.innerHTML = '<p class="text-indigo-400 animate-pulse">Listening...</p>';
    };

    recognition.onresult = (event) => {
        const transcript = event.results[0][0].transcript.toLowerCase();
        voiceIndicator.classList.add('hidden');
        processCommand(transcript);
    };

    function processCommand(text) {
        let response = "";
        
        if (text.includes("hello") || text.includes("aura")) {
            response = "Hello! I am Aura, your futuristic medical assistant. How can I help you today?";
        } else if (text.includes("appointments")) {
            response = "You have one appointment scheduled with Dr. Smith for tomorrow at 10 AM.";
        } else if (text.includes("vitals")) {
            response = "Your current heart rate is 72 beats per minute, and your oxygen levels are at 98 percent. You are in excellent health!";
        } else if (text.includes("ambulance")) {
            response = "Emergency mode activated. I am notifying the nearest ambulance unit and sharing your current GPS coordinates. Please stay calm.";
        } else {
            response = "I heard you say: " + text + ". I am processing this information and updating your health records.";
        }

        aiResponse.innerHTML = `<p class="text-gray-300">You said: <span class="text-white font-bold">"${text}"</span></p>
                                <p class="text-indigo-400 mt-4 font-medium">${response}</p>`;
        
        speak(response);
    }

    function speak(text) {
        const utter = new SpeechSynthesisUtterance(text);
        utter.pitch = 1.2;
        utter.rate = 1.0;
        synth.speak(utter);
    }
</script>

<%- include('../partials/footer') %>

  let lastDnaFrameTime = 0;
  function renderDnaLoop(timestamp) {
    if (!dnaCtx || !dnaCanvas) return;
    
    // Performance Frame Throttling Check
    const elapsed = timestamp - lastDnaFrameTime;
    const frameInterval = 1000 / HMSLifecycle.fpsLimit;
    if (lastDnaFrameTime && elapsed < frameInterval) {
      dnaAnimationId = HMSLifecycle.requestAnimationFrame(renderDnaLoop);
      return;
    }
    lastDnaFrameTime = timestamp - (elapsed % frameInterval);
    
    dnaCtx.clearRect(0, 0, dnaCanvas.width, dnaCanvas.height);
    
    // Tech background grid lines
    dnaCtx.strokeStyle = 'rgba(6, 182, 212, 0.05)';
    dnaCtx.lineWidth = 1;
    for(let i=0; i<dnaCanvas.width; i+=15) {
      dnaCtx.beginPath(); dnaCtx.moveTo(i, 0); dnaCtx.lineTo(i, dnaCanvas.height); dnaCtx.stroke();
    }
    for(let j=0; j<dnaCanvas.height; j+=15) {
      dnaCtx.beginPath(); dnaCtx.moveTo(0, j); dnaCtx.lineTo(dnaCanvas.width, j); dnaCtx.stroke();
    }
    
    // Rotate DNA speed
    const baseSpeed = 0.015;
    const boostSpeed = isDecompiling ? 0.08 : 0;
    dnaAngle += (baseSpeed + boostSpeed);
    
    const centerX = dnaCanvas.width / 2;
    const radius = 50;
    const spacing = 14;
    const pointsCount = Math.floor((dnaCanvas.height - 40) / spacing);
    
    // Draw the helix rungs (horizontal connections) first so nodes render on top
    for (let i = 0; i < pointsCount; i++) {
      const y = 20 + i * spacing;
      const angle = i * 0.4 + dnaAngle;
      
      const cosVal = Math.cos(angle);
      const x1 = centerX + cosVal * radius;
      const x2 = centerX - cosVal * radius;
      
      // Determine colors based on active profile and status
      let basePairColor = 'rgba(6, 182, 212, 0.2)';
      if (isDecompiling) {
        basePairColor = `rgba(6, 182, 212, ${0.4 + Math.sin(decompileProgress * Math.PI) * 0.4})`;
      } else if (activeDnaProfile === 'cognitive') {
        basePairColor = 'rgba(168, 85, 247, 0.2)';
      } else if (activeDnaProfile === 'cardio') {
        basePairColor = 'rgba(244, 63, 94, 0.2)';
      } else if (activeDnaProfile === 'metabolic') {
        basePairColor = 'rgba(234, 179, 8, 0.2)';
      }
      
      // Draw rung line
      dnaCtx.strokeStyle = basePairColor;
      dnaCtx.lineWidth = 2;
      dnaCtx.beginPath();
      dnaCtx.moveTo(x1, y);
      dnaCtx.lineTo(x2, y);
      dnaCtx.stroke();
    }
    
    // Draw the backbone nodes (nucleotides)
    for (let i = 0; i < pointsCount; i++) {
      const y = 20 + i * spacing;
      const angle = i * 0.4 + dnaAngle;
      
      const cosVal = Math.cos(angle);
      const sinVal = Math.sin(angle); // depth representation: -1 is background, 1 is foreground
      
      const x1 = centerX + cosVal * radius;
      const x2 = centerX - cosVal * radius;
      
      // Scale node radius and opacity for realistic 3D depth effect
      const depthScale1 = (sinVal + 1) / 2; // ranges from 0 to 1
      const depthScale2 = (-sinVal + 1) / 2; // opposite phase
      
      const r1 = 4.5 + depthScale1 * 4;
      const r2 = 4.5 + depthScale2 * 4;
      
      const op1 = 0.25 + depthScale1 * 0.75;
      const op2 = 0.25 + depthScale2 * 0.75;
      
      // Node 1 & 2 Colors
      let c1 = `rgba(6, 182, 212, ${op1})`;       // Cyan (Adenine / Thymine)
      let c2 = `rgba(99, 102, 241, ${op2})`;      // Indigo (Guanine / Cytosine)
      
      if (activeDnaProfile === 'cognitive') {
        c1 = `rgba(168, 85, 247, ${op1})`;        // Purple
        c2 = `rgba(236, 72, 153, ${op2})`;        // Pink
      } else if (activeDnaProfile === 'cardio') {
        c1 = `rgba(244, 63, 94, ${op1})`;         // Rose
        c2 = `rgba(99, 102, 241, ${op2})`;        // Indigo
      } else if (activeDnaProfile === 'metabolic') {
        c1 = `rgba(234, 179, 8, ${op1})`;         // Amber
        c2 = `rgba(16, 185, 129, ${op2})`;        // Emerald
      }
      
      // Draw Node 1
      dnaCtx.fillStyle = c1;
      dnaCtx.shadowBlur = isDecompiling ? 12 : 3;
      dnaCtx.shadowColor = c1;
      dnaCtx.beginPath();
      dnaCtx.arc(x1, y, r1, 0, Math.PI * 2);
      dnaCtx.fill();
      
      // Draw Node 2
      dnaCtx.fillStyle = c2;
      dnaCtx.shadowColor = c2;
      dnaCtx.beginPath();
      dnaCtx.arc(x2, y, r2, 0, Math.PI * 2);
      dnaCtx.fill();
      
      dnaCtx.shadowBlur = 0; // Reset shadow
    }
    
    // Decompiling diagnostics text rendering
    if (isDecompiling) {
      decompileProgress += 0.005;
      if (decompileProgress >= 1.0) {
        completeDnaDecompile();
      }
      
      // Neon target sweeps and progress bars on canvas
      dnaCtx.fillStyle = 'rgba(6, 182, 212, 0.9)';
      dnaCtx.font = '8px monospace';
      dnaCtx.textAlign = 'left';
      dnaCtx.fillText(`DECOMPILING SEQUENCE: ${Math.floor(decompileProgress * 100)}%`, 15, 22);
      dnaCtx.fillText(`VOLTAGE RATE: 4.88 eV`, 15, 34);
      
      // Glowing target box
      dnaCtx.strokeStyle = 'rgba(6, 182, 212, 0.4)';
      dnaCtx.strokeRect(10, 10, dnaCanvas.width - 20, dnaCanvas.height - 20);
    } else {
      dnaCtx.fillStyle = 'rgba(255, 255, 255, 0.3)';
      dnaCtx.font = '9px monospace';
      dnaCtx.textAlign = 'center';
      dnaCtx.fillText('GENOMIC TELEMETRY FEED ACTIVE', centerX, dnaCanvas.height - 10);
    }
    
    dnaAnimationId = HMSLifecycle.requestAnimationFrame(renderDnaLoop);
  }

  function startDnaSequenceScroller() {
    if (dnaSequenceInterval) {
      clearInterval(dnaSequenceInterval);
      HMSLifecycle.intervals.delete(dnaSequenceInterval);
    }
    
    const seqContainer = document.getElementById('genePairSequence');
    if (!seqContainer) return;
    
    const updateRate = isDecompiling ? 60 : 300;
    
    dnaSequenceInterval = HMSLifecycle.setInterval(() => {
      let currentSeq = seqContainer.innerText.split(' • ');
      if (currentSeq.length === 0 || currentSeq[0] === '') return;
      currentSeq.shift();
      const newPair = nucleotidePairs[Math.floor(Math.random() * nucleotidePairs.length)];
      currentSeq.push(newPair);
      seqContainer.innerText = currentSeq.join(' • ');
    }, updateRate);
  }


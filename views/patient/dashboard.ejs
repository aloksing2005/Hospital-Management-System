  function renderNutriLoop(timestamp) {
    if (!nutriCtx || !nutriCanvas) return;
    
    // Performance Frame Throttling Check
    const elapsed = timestamp - lastNutriFrameTime;
    const frameInterval = 1000 / HMSLifecycle.fpsLimit;
    if (lastNutriFrameTime && elapsed < frameInterval) {
      nutriAnimationId = HMSLifecycle.requestAnimationFrame(renderNutriLoop);
      return;
    }
    lastNutriFrameTime = timestamp - (elapsed % frameInterval);
    
    nutriCtx.clearRect(0, 0, nutriCanvas.width, nutriCanvas.height);
    
    // Tech background grid lines in amber/orange
    nutriCtx.strokeStyle = 'rgba(245, 158, 11, 0.04)';
    nutriCtx.lineWidth = 1;
    for(let i=0; i<nutriCanvas.width; i+=15) {
      nutriCtx.beginPath(); nutriCtx.moveTo(i, 0); nutriCtx.lineTo(i, nutriCanvas.height); nutriCtx.stroke();
    }
    for(let j=0; j<nutriCanvas.height; j+=15) {
      nutriCtx.beginPath(); nutriCtx.moveTo(0, j); nutriCtx.lineTo(nutriCanvas.width, j); nutriCtx.stroke();
    }
    
    const centerX = nutriCanvas.width / 2;
    const centerY = nutriCanvas.height / 2;
    
    // Rotate speed
    const baseSpeed = 0.005;
    const boostSpeed = isNutriScanning ? 0.05 : 0;
    nutriAngle += (baseSpeed + boostSpeed);
    
    // Draw concentric rings
    // Ring 1 (Inner)
    nutriCtx.strokeStyle = 'rgba(245, 158, 11, 0.1)';
    nutriCtx.lineWidth = 1;
    nutriCtx.beginPath();
    nutriCtx.arc(centerX, centerY, 35, 0, Math.PI * 2);
    nutriCtx.stroke();
    
    // Ring 2 (Middle) - dashed
    nutriCtx.strokeStyle = 'rgba(249, 115, 22, 0.15)';
    nutriCtx.lineWidth = 1.5;
    nutriCtx.setLineDash([4, 8]);
    nutriCtx.beginPath();
    nutriCtx.arc(centerX, centerY, 55, 0, Math.PI * 2);
    nutriCtx.stroke();
    nutriCtx.setLineDash([]);
    
    // Ring 3 (Outer) - dotted with ticks
    nutriCtx.strokeStyle = 'rgba(245, 158, 11, 0.25)';
    nutriCtx.lineWidth = 1;
    nutriCtx.beginPath();
    nutriCtx.arc(centerX, centerY, 75, 0, Math.PI * 2);
    nutriCtx.stroke();
    
    // Draw period anchor nodes on the outer ring
    const anchorPoints = [
      { angle: -Math.PI/2, label: 'FAST', active: activeNutriPeriod === 'fasting', color: 'rgba(245, 158, 11, ' },
      { angle: 0, label: 'RISE', active: activeNutriPeriod === 'breakfast', color: 'rgba(251, 191, 36, ' },
      { angle: Math.PI/2, label: 'PEAK', active: activeNutriPeriod === 'noon', color: 'rgba(249, 115, 22, ' },
      { angle: Math.PI, label: 'REST', active: activeNutriPeriod === 'evening', color: 'rgba(217, 119, 6, ' }
    ];
    
    anchorPoints.forEach(pt => {
      const px = centerX + Math.cos(pt.angle) * 75;
      const py = centerY + Math.sin(pt.angle) * 75;
      
      // Node circle
      nutriCtx.fillStyle = pt.active ? pt.color + '0.9)' : pt.color + '0.3)';
      nutriCtx.beginPath();
      nutriCtx.arc(px, py, pt.active ? 6 : 4, 0, Math.PI * 2);
      nutriCtx.fill();
      
      if (pt.active) {
        nutriCtx.shadowBlur = 8;
        nutriCtx.shadowColor = pt.color + '0.8)';
        nutriCtx.strokeStyle = '#fff';
        nutriCtx.lineWidth = 1.5;
        nutriCtx.beginPath();
        nutriCtx.arc(px, py, 6, 0, Math.PI * 2);
        nutriCtx.stroke();
        nutriCtx.shadowBlur = 0; // reset
      }
      
      // Label text
      nutriCtx.fillStyle = pt.active ? '#fff' : 'rgba(255, 255, 255, 0.4)';
      nutriCtx.font = pt.active ? 'bold 8px monospace' : '7px monospace';
      nutriCtx.textAlign = 'center';
      nutriCtx.fillText(pt.label, px + (Math.cos(pt.angle) * 15), py + (Math.sin(pt.angle) * 12) + 3);
    });
    
    // Draw the main sweeping clock hand (representing time/chrono progression)
    const handLength = 75;
    const hx = centerX + Math.cos(nutriAngle) * handLength;
    const hy = centerY + Math.sin(nutriAngle) * handLength;
    
    nutriCtx.strokeStyle = 'rgba(245, 158, 11, 0.7)';
    nutriCtx.lineWidth = 2;
    nutriCtx.beginPath();
    nutriCtx.moveTo(centerX, centerY);
    nutriCtx.lineTo(hx, hy);
    nutriCtx.stroke();
    
    // Sweep hand tip circle
    nutriCtx.fillStyle = '#fff';
    nutriCtx.beginPath();
    nutriCtx.arc(hx, hy, 3.5, 0, Math.PI * 2);
    nutriCtx.fill();
    
    // Center pin
    nutriCtx.fillStyle = 'rgba(245, 158, 11, 0.9)';
    nutriCtx.beginPath();
    nutriCtx.arc(centerX, centerY, 5, 0, Math.PI * 2);
    nutriCtx.fill();
    
    // Calibration scan overlay
    if (isNutriScanning) {
      nutriProgress += 0.006;
      if (nutriProgress >= 1.0) {
        completeNutriScan();
      }
      
      // Draw progress arc
      nutriCtx.strokeStyle = 'rgba(245, 158, 11, 0.5)';
      nutriCtx.lineWidth = 6;
      nutriCtx.beginPath();
      nutriCtx.arc(centerX, centerY, 65, -Math.PI/2, -Math.PI/2 + (Math.PI * 2 * nutriProgress));
      nutriCtx.stroke();
      
      // Floating data readouts
      nutriCtx.fillStyle = 'rgba(245, 158, 11, 0.95)';
      nutriCtx.font = '8px monospace';
      nutriCtx.textAlign = 'center';
      nutriCtx.fillText(`SYNCHRONIZING DIAL: ${Math.floor(nutriProgress * 100)}%`, centerX, centerY + 95);
      nutriCtx.fillText(`SIRT1 EXPRESSION RATE: ${(1.2 + nutriProgress * 0.8).toFixed(2)}x`, centerX, centerY - 95);
    } else {
      nutriCtx.fillStyle = 'rgba(255, 255, 255, 0.35)';
      nutriCtx.font = '8px monospace';
      nutriCtx.textAlign = 'center';
      nutriCtx.fillText('EPIGENETIC CHRONO-FEED ACTIVE', centerX, centerY + 95);
    }
    
    nutriAnimationId = HMSLifecycle.requestAnimationFrame(renderNutriLoop);
  }

  function initCanvas() {
    canvas = document.getElementById('hudScannerCanvas');
    if (!canvas) return;
    ctx = canvas.getContext('2d');
    if (!ctx) throw new Error("Could not acquire 2D scanner context");
    const parent = canvas.parentElement;
    const w = parent.clientWidth || 300;
    const h = 220;
    if (w > 0 && h > 0) {
      scaleCanvas(canvas, ctx, w, h);
    }
  }

  function safeInitCanvas() {
    try {
      initCanvas();
    } catch (e) {
      console.warn("Scanner Canvas failed to mount:", e.message);
      drawFallbackStatic('hudScannerCanvas', 'SCANNER ACTIVE (SOFTWARE GOVERNOR)');
    }
  }

  function setScanMode(mode) {
    if (isScanning) return;
    activeScanMode = mode;
    const btnXray = document.getElementById('btnModeXray');
    const btnMri = document.getElementById('btnModeMri');
    if (mode === 'xray') {
      btnXray.className = 'px-3 py-2.5 bg-indigo-600 text-white border border-indigo-400/30 rounded-xl text-xs font-black transition-all flex items-center justify-center gap-1.5 hover:scale-105 cursor-pointer shadow-lg shadow-indigo-600/20';
      btnMri.className = 'px-3 py-2.5 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-xs font-black transition-all flex items-center justify-center gap-1.5 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer';
      document.getElementById('txtAnomalyIndex').innerHTML = '0.01% (NOMINAL)';
      document.getElementById('txtAnomalyIndex').className = 'text-emerald-400 font-bold tracking-wider';
      document.getElementById('txtScanResult').innerHTML = 'Switched to Chest X-Ray mode. Ready to scan pulmonic regions.';
    } else {
      btnMri.className = 'px-3 py-2.5 bg-indigo-600 text-white border border-indigo-400/30 rounded-xl text-xs font-black transition-all flex items-center justify-center gap-1.5 hover:scale-105 cursor-pointer shadow-lg shadow-indigo-600/20';
      btnXray.className = 'px-3 py-2.5 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-xs font-black transition-all flex items-center justify-center gap-1.5 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer';
      document.getElementById('txtAnomalyIndex').innerHTML = '0.00% (STANDBY)';
      document.getElementById('txtAnomalyIndex').className = 'text-gray-400 font-bold tracking-wider';
      document.getElementById('txtScanResult').innerHTML = 'Switched to Brain MRI mode. Ready to scan cerebral lobes.';
    }
  }

  let lastScannerFrameTime = 0;
  function renderScannerLoop(timestamp) {
    if (!ctx || !canvas) return;
    
    // Performance Frame Throttling Check
    const elapsed = timestamp - lastScannerFrameTime;
    const frameInterval = 1000 / HMSLifecycle.fpsLimit;
    if (lastScannerFrameTime && elapsed < frameInterval) {
      animationId = HMSLifecycle.requestAnimationFrame(renderScannerLoop);
      return;
    }
    lastScannerFrameTime = timestamp - (elapsed % frameInterval);

    // Frame logging rate monitor
    HMSLifecycle.performanceMetrics.renderedFrames++;
    const metricsNow = performance.now();
    if (metricsNow - HMSLifecycle.performanceMetrics.lastMetricsTime >= 15000) {
      const seconds = (metricsNow - HMSLifecycle.performanceMetrics.lastMetricsTime) / 1000;
      const computedFps = HMSLifecycle.performanceMetrics.renderedFrames / seconds;
      console.log(`📊 HMS Diagnostic HUD: ~${computedFps.toFixed(1)} FPS | Active RAF handles: ${HMSLifecycle.rafIds.size} | Unload Registry handles: ${HMSLifecycle.intervals.size}`);
      HMSLifecycle.performanceMetrics.renderedFrames = 0;
      HMSLifecycle.performanceMetrics.lastMetricsTime = metricsNow;
    }
    
    // Clear canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Increment animation states
    rotationAngle += isScanning ? 0.04 : 0.008;
    ecgIndex = (ecgIndex + 1.5) % 360;
    
    // Draw background tech grid
    ctx.strokeStyle = 'rgba(99, 102, 241, 0.06)';
    ctx.lineWidth = 1;
    for(let i=0; i<canvas.width; i+=15) {
      ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvas.height); ctx.stroke();
    }
    for(let j=0; j<canvas.height; j+=15) {
      ctx.beginPath(); ctx.moveTo(0, j); ctx.lineTo(canvas.width, j); ctx.stroke();
    }
    
    // Draw concentric rotating diagnostic rings in center
    ctx.save();
    ctx.translate(canvas.width/2, canvas.height/2 - 10);
    ctx.rotate(rotationAngle);
    
    // Outer dashed ring
    ctx.strokeStyle = isScanning ? 'rgba(239, 68, 68, 0.4)' : 'rgba(99, 102, 241, 0.25)';
    ctx.lineWidth = 1.5;
    ctx.setLineDash([5, 10]);
    ctx.beginPath();
    ctx.arc(0, 0, 60, 0, Math.PI * 2);
    ctx.stroke();
    
    // Inner dashed ring rotating opposite way
    ctx.rotate(-rotationAngle * 2.5);
    ctx.strokeStyle = isScanning ? 'rgba(239, 68, 68, 0.6)' : 'rgba(14, 165, 233, 0.3)';
    ctx.setLineDash([8, 6]);
    ctx.beginPath();
    ctx.arc(0, 0, 45, 0, Math.PI * 2);
    ctx.stroke();
    ctx.restore();
    
    ctx.setLineDash([]); // Reset dash
    
    // Draw crosshair center
    ctx.strokeStyle = isScanning ? 'rgba(239, 68, 68, 0.3)' : 'rgba(14, 165, 233, 0.2)';
    ctx.beginPath();
    ctx.moveTo(canvas.width/2 - 15, canvas.height/2 - 10);
    ctx.lineTo(canvas.width/2 + 15, canvas.height/2 - 10);
    ctx.moveTo(canvas.width/2, canvas.height/2 - 25);
    ctx.lineTo(canvas.width/2, canvas.height/2 + 5);
    ctx.stroke();
    
    // Draw organ structure (always present, but low opacity in standby, glowing/active in scanning)
    ctx.save();
    if (activeScanMode === 'xray') {
      ctx.strokeStyle = isScanning ? 'rgba(14, 165, 233, 0.75)' : 'rgba(14, 165, 233, 0.22)';
      ctx.lineWidth = 2;
      ctx.beginPath();
      // Left Lung
      ctx.ellipse(canvas.width/2 - 26, canvas.height/2 - 10, 16, 42, 0.08, 0, Math.PI*2);
      // Right Lung
      ctx.ellipse(canvas.width/2 + 26, canvas.height/2 - 10, 16, 42, -0.08, 0, Math.PI*2);
      ctx.stroke();
      
      // Trachea
      ctx.beginPath();
      ctx.moveTo(canvas.width/2, canvas.height/2 - 55);
      ctx.lineTo(canvas.width/2, canvas.height/2 - 20);
      ctx.stroke();
    } else {
      ctx.strokeStyle = isScanning ? 'rgba(168, 85, 247, 0.75)' : 'rgba(168, 85, 247, 0.22)';
      ctx.lineWidth = 2;
      ctx.beginPath();
      // Brain outer
      ctx.arc(canvas.width/2, canvas.height/2 - 10, 36, 0, Math.PI*2);
      ctx.stroke();
      // Brain inner lobes
      ctx.beginPath();
      ctx.ellipse(canvas.width/2, canvas.height/2 - 7, 18, 26, 0, 0, Math.PI*2);
      ctx.stroke();
    }
    ctx.restore();
    
    // Draw ECG crawling heartbeat line at the bottom
    ctx.strokeStyle = isScanning ? 'rgba(239, 68, 68, 0.65)' : 'rgba(99, 102, 241, 0.35)';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    for (let x = 0; x < canvas.width; x++) {
      let phase = (x + ecgIndex) % 180;
      let yOffset = 0;
      if (phase > 40 && phase < 46) yOffset = -5; // P wave
      else if (phase >= 46 && phase < 50) yOffset = 0;
      else if (phase === 52) yOffset = -18; // R wave high spike
      else if (phase === 55) yOffset = 10;  // S wave low spike
      else if (phase > 57 && phase < 70) yOffset = -3; // T wave
      
      let y = canvas.height - 25 + yOffset;
      if (x === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.stroke();
    
    // Standby Text or Scanning UI
    if (!isScanning) {
      ctx.fillStyle = 'rgba(255, 255, 255, 0.4)';
      ctx.font = '9px monospace';
      ctx.textAlign = 'center';
      ctx.fillText('NEURAL HUD DIAGNOSTIC READY', canvas.width/2, canvas.height/2 + 82);
    } else {
      // Progress Scanning mode active!
      scanProgress += 0.008;
      if (scanProgress >= 1.0) {
        completeNeuralScan();
      }
      
      let scanY = canvas.height * (scanProgress % 1.0);
      
      // Target lock box
      if (scanProgress > 0.3 && scanProgress < 0.8) {
        ctx.strokeStyle = 'rgba(239, 68, 68, 0.7)';
        ctx.lineWidth = 1.5;
        let targetX = canvas.width/2 + (activeScanMode === 'xray' ? 22 : 6);
        let targetY = canvas.height/2 + (activeScanMode === 'xray' ? 4 : -20);
        
        // Animated corner targets
        ctx.strokeRect(targetX - 10, targetY - 10, 20, 20);
        ctx.fillStyle = 'rgba(239, 68, 68, 0.9)';
        ctx.font = '8px monospace';
        ctx.textAlign = 'center';
        ctx.fillText('TARGET LOCKING', targetX, targetY - 14);
      }
      
      // Floating data readouts
      ctx.fillStyle = 'rgba(14, 165, 233, 0.95)';
      ctx.font = '9px monospace';
      ctx.textAlign = 'left';
      ctx.fillText(`NEURAL SCAN Y-COORD: ${Math.floor(scanY)}px`, 15, 22);
      ctx.fillText(`ANOMALY SCAN: ${(scanProgress*100).toFixed(0)}%`, 15, 36);
      
      // Sweep Laser line
      ctx.strokeStyle = 'rgba(14, 165, 233, 0.75)';
      ctx.lineWidth = 2.5;
      ctx.beginPath();
      ctx.moveTo(0, scanY);
      ctx.lineTo(canvas.width, scanY);
      ctx.stroke();
      
      // Draw dynamic laser glow reflection
      let gradient = ctx.createLinearGradient(0, scanY - 8, 0, scanY + 8);
      gradient.addColorStop(0, 'rgba(14, 165, 233, 0)');
      gradient.addColorStop(0.5, 'rgba(14, 165, 233, 0.15)');
      gradient.addColorStop(1, 'rgba(14, 165, 233, 0)');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, scanY - 8, canvas.width, 16);
    }
    
    // Loop
    animationId = HMSLifecycle.requestAnimationFrame(renderScannerLoop);
  }

  function triggerNeuralScan() {
    if (isScanning) return;
    isScanning = true;
    scanProgress = 0;
    document.getElementById('scanStatusText').innerText = 'HUD: ACTIVE SCANNING';
    document.getElementById('scanStatusIndicator').className = 'w-1.5 h-1.5 rounded-full bg-rose-500 animate-ping';
    document.getElementById('scanBtnText').innerText = 'SCANNING IN PROGRESS...';
    document.getElementById('scanIcon').className = 'fas fa-spinner animate-spin text-rose-400';
    
    const laser = document.getElementById('hudLaser');
    if (laser) laser.classList.remove('hidden');
  }

  function completeNeuralScan() {
    isScanning = false;
    document.getElementById('scanStatusText').innerText = 'HUD: SCAN COMPLETED';
    document.getElementById('scanStatusIndicator').className = 'w-1.5 h-1.5 rounded-full bg-emerald-400';
    document.getElementById('scanBtnText').innerText = 'RE-SCAN NEURAL CORE';
    document.getElementById('scanIcon').className = 'fas fa-satellite-dish';
    
    const laser = document.getElementById('hudLaser');
    if (laser) laser.classList.add('hidden');

    if (activeScanMode === 'xray') {
      document.getElementById('txtAnomalyIndex').innerHTML = '0.02% (NOMINAL)';
      document.getElementById('txtAnomalyIndex').className = 'text-emerald-400 font-bold tracking-wider';
      document.getElementById('txtScanResult').innerHTML = '<strong>LUNG VENTILATION CONFIRMED:</strong> AI Model flags perfectly clear bronchial chambers with 99.8% structural aeration. No lesions or congestions found.';
    } else {
      document.getElementById('txtAnomalyIndex').innerHTML = '0.08% (STABLE - MILD)';
      document.getElementById('txtAnomalyIndex').className = 'text-amber-400 font-bold tracking-wider';
      document.getElementById('txtScanResult').innerHTML = '<strong>CEREBRAL BLOOD FLOW NOMINAL:</strong> Scans demonstrate symmetrical grey-white matter borders. Minor visual stress detected in the occipital cortex. Rest advised.';
    }

    throttleShowToast('Diagnostic Scan', 'Neural target analysis has resolved successfully!', 'success');
  }

  document.addEventListener('DOMContentLoaded', function() {
    HMSLifecycle.init();
    
    initQrCode();
    safeInitCanvas();
    safeInitDnaCanvas();
    safeInitNutriCanvas();
    
    // Start active rendering handles
    if (ctx && canvas) {
      animationId = HMSLifecycle.requestAnimationFrame(renderScannerLoop);
    }
    if (dnaCtx && dnaCanvas) {
      dnaAnimationId = HMSLifecycle.requestAnimationFrame(renderDnaLoop);
    }
    if (nutriCtx && nutriCanvas) {
      nutriAnimationId = HMSLifecycle.requestAnimationFrame(renderNutriLoop);
    }
    
    startDnaSequenceScroller();
    
    // Centralized resize listener registered to registry
    HMSLifecycle.addEventListener(window, 'resize', () => {
      safeInitCanvas();
      safeInitDnaCanvas();
      safeInitNutriCanvas();
    });
    
    // Page Visibility API support registered to registry
    HMSLifecycle.addEventListener(document, 'visibilitychange', () => {
      if (document.hidden) {
        console.log('💤 tab hidden: freezing render loops and scrollers');
        HMSLifecycle.cancelAnimationFrame(animationId);
        HMSLifecycle.cancelAnimationFrame(dnaAnimationId);
        HMSLifecycle.cancelAnimationFrame(nutriAnimationId);
        animationId = null;
        dnaAnimationId = null;
        nutriAnimationId = null;
        
        if (dnaSequenceInterval) {
          clearInterval(dnaSequenceInterval);
          HMSLifecycle.intervals.delete(dnaSequenceInterval);
          dnaSequenceInterval = null;
        }
      } else {
        console.log('🌞 tab active: resuming render loops and scrollers');
        if (ctx && canvas && !animationId) {
          animationId = HMSLifecycle.requestAnimationFrame(renderScannerLoop);
        }
        if (dnaCtx && dnaCanvas && !dnaAnimationId) {
          dnaAnimationId = HMSLifecycle.requestAnimationFrame(renderDnaLoop);
        }
        if (nutriCtx && nutriCanvas && !nutriAnimationId) {
          nutriAnimationId = HMSLifecycle.requestAnimationFrame(renderNutriLoop);
        }
        startDnaSequenceScroller();
      }
    });

    // Navigation and unmount cleanups registered to registry
    HMSLifecycle.addEventListener(window, 'beforeunload', () => HMSLifecycle.destroy());
    HMSLifecycle.addEventListener(window, 'pagehide', () => HMSLifecycle.destroy());
  });

  const patientDashboardSocket = window.hmsSocket ? window.hmsSocket() : null;
  if (patientDashboardSocket) {
    patientDashboardSocket.emit('join', { userId: '<%= user.id %>', role: 'patient' });
    
    patientDashboardSocket.on('vitals-update', (data) => {
      if (data.patientId === '<%= user.id %>') {
        const v = data.vitals;
        const hrEl = document.querySelector('.hms-stat-value');
        if (hrEl && hrEl.parentElement.querySelector('.fa-heartbeat')) {
          hrEl.textContent = v.hr + ' BPM';
        }
        const spo2El = document.querySelectorAll('.hms-stat-value')[1];
        if (spo2El && spo2El.parentElement.querySelector('.fa-wind')) {
          spo2El.textContent = v.spo2 + ' %';
        }
        const bpEl = document.querySelectorAll('.hms-stat-value')[2];
        if (bpEl && bpEl.parentElement.querySelector('.fa-tint')) {
          bpEl.textContent = v.bpSys + '/' + v.bpDia;
        }
        const tempEl = document.querySelectorAll('.hms-stat-value')[3];
        if (tempEl && tempEl.parentElement.querySelector('.fa-thermometer-half')) {
          tempEl.textContent = v.temp + ' °F';
        }
      }
    });

    patientDashboardSocket.on('appointment-update', (data) => {
      throttleShowToast('Update', `Your appointment is now ${data.status}`, 'success');
    });
  }

</script>

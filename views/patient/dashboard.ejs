<script>
  // --- HMS ENTERPRISE LIFECYCLE & PERFORMANCE MANAGER ---
  const HMSLifecycle = {
    rafIds: new Set(),
    intervals: new Set(),
    timeouts: new Set(),
    listeners: [],
    
    fpsLimit: 60,
    isLowEndDevice: false,
    performanceMetrics: {
      renderedFrames: 0,
      fps: 60,
      lastMetricsTime: performance.now()
    },
    
    isInitialized: false,
    
    init() {
      if (this.isInitialized) this.destroy();
      this.isInitialized = true;
      
      // Hardware-capability & low-end governor detection
      if (navigator.deviceMemory && navigator.deviceMemory < 4) {
        this.isLowEndDevice = true;
        this.fpsLimit = 30;
      }
      if (navigator.hardwareConcurrency && navigator.hardwareConcurrency < 4) {
        this.isLowEndDevice = true;
        this.fpsLimit = 30;
      }
      
      console.log(`⚡ central lifecycle: initialized (GPU Throttling: ${this.isLowEndDevice ? 'ACTIVE (30 FPS limit)' : 'INACTIVE (60 FPS limit)'})`);
    },
    
    requestAnimationFrame(cb) {
      const id = requestAnimationFrame((timestamp) => {
        this.rafIds.delete(id);
        cb(timestamp);
      });
      this.rafIds.add(id);
      return id;
    },
    
    cancelAnimationFrame(id) {
      if (id) {
        cancelAnimationFrame(id);
        this.rafIds.delete(id);
      }
    },
    
    setInterval(cb, delay) {
      const id = setInterval(cb, delay);
      this.intervals.add(id);
      return id;
    },
    
    clearInterval(id) {
      if (id) {
        clearInterval(id);
        this.intervals.delete(id);
      }
    },
    
    setTimeout(cb, delay) {
      const id = setTimeout(() => {
        this.timeouts.delete(id);
        cb();
      }, delay);
      this.timeouts.add(id);
      return id;
    },
    
    clearTimeout(id) {
      if (id) {
        clearTimeout(id);
        this.timeouts.delete(id);
      }
    },
    
    addEventListener(element, type, listener, options) {
      if (!element) return;
      element.addEventListener(type, listener, options);
      this.listeners.push({ element, type, listener, options });
    },
    
    destroy() {
      console.log('⚡ central lifecycle: purging active registry resources...');
      
      // Clear RAF loops
      for (const id of this.rafIds) {
        cancelAnimationFrame(id);
      }
      this.rafIds.clear();
      
      // Clear intervals
      for (const id of this.intervals) {
        clearInterval(id);
      }
      this.intervals.clear();
      
      // Clear timeouts
      for (const id of this.timeouts) {
        clearTimeout(id);
      }
      this.timeouts.clear();
      
      // Remove event listeners
      this.listeners.forEach(({ element, type, listener, options }) => {
        if (element) {
          element.removeEventListener(type, listener, options);
        }
      });
      this.listeners = [];
      
      // Clean up Socket.IO listeners specifically
      if (patientDashboardSocket) {
        patientDashboardSocket.off('vitals-update');
        patientDashboardSocket.off('appointment-update');
      }
      
      this.isInitialized = false;
    }
  };

  // --- High-DPI & Retina Sharp Scaling Optimizer ---
  function scaleCanvas(canvas, ctx, width, height) {
    if (!canvas || !ctx) return;
    const dpr = window.devicePixelRatio || 1;
    const maxDpr = HMSLifecycle.isLowEndDevice ? 1 : 2;
    const activeDpr = Math.min(dpr, maxDpr);
    
    canvas.width = width * activeDpr;
    canvas.height = height * activeDpr;
    canvas.style.width = width + 'px';
    canvas.style.height = height + 'px';
    
    ctx.scale(activeDpr, activeDpr);
  }

  // --- Safe Static Fallback for low-end or disabled Canvas contexts ---
  function drawFallbackStatic(canvasId, text) {
    const canv = document.getElementById(canvasId);
    if (!canv) return;
    const context = canv.getContext('2d');
    if (!context) {
      canv.parentElement.innerHTML = `<div class="font-mono text-[10px] text-gray-500 flex items-center justify-center h-full w-full border border-dashed border-gray-700 p-4 text-center uppercase">${text}</div>`;
      return;
    }
    context.fillStyle = '#020617';
    context.fillRect(0, 0, canv.width, canv.height);
    context.fillStyle = 'rgba(255, 255, 255, 0.4)';
    context.font = '10px monospace';
    context.textAlign = 'center';
    context.fillText(text, canv.width / 2, canv.height / 2);
  }

  // --- Dynamic Toast Rate Limiter / Anti-Spam Governor ---
  let lastToastTime = 0;
  const TOAST_THROTTLE_LIMIT = 2000;
  function throttleShowToast(title, message, type) {
    const now = Date.now();
    if (now - lastToastTime < TOAST_THROTTLE_LIMIT) return;
    lastToastTime = now;
    if (typeof window.hmsShowToast === 'function') {
      window.hmsShowToast(title, message, type);
    }
  }

  // Generate QR Code dynamically from real patient data
  function initQrCode() {
    const qrcodeContainer = document.getElementById('qrcodeContainer');
    if (qrcodeContainer) {
      qrcodeContainer.innerHTML = ''; // prevent duplicate appends
      if (typeof QRCode !== 'undefined') {
        new QRCode(qrcodeContainer, {
          text: "HMS_PATIENT_<%= user.id %>",
          width: 70,
          height: 70,
          colorDark : "#0f172a",
          colorLight : "#ffffff",
          correctLevel : QRCode.CorrectLevel.H
        });
      } else {
        console.warn("QRCode library not loaded yet or offline. Generating fallback text.");
        qrcodeContainer.innerHTML = `<div class="text-[9px] text-gray-500 font-mono flex items-center justify-center h-full w-full border border-dashed border-gray-300 p-1 text-center">QR CODE STANDBY</div>`;
      }
    }
  }

  function printHealthCard() {
    // Add print class to body to isolate printing
    document.body.classList.add('hms-printing-active');
    
    // Print original card element to avoid browser canvas-cloning bugs (preserving QR code)
    window.print();
    
    // Clean up
    setTimeout(() => {
      document.body.classList.remove('hms-printing-active');
    }, 500);
  }

  // --- Neural X-Ray & MRI HUD Scanner Logic ---
  let activeScanMode = 'xray';
  let isScanning = false;
  let scanProgress = 0;
  let animationId = null;

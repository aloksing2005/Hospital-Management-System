<% var title = 'Patient Dashboard - HMS Premium'; %>
<%- include('../partials/header') %>
<%- include('../partials/incoming-call-modal') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
  /* Premium Cyberpunk Holographic Card Styling */
  .hms-cybercard-glow {
    position: relative;
    animation: hms-card-float 6s ease-in-out infinite;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(30, 27, 75, 0.8) 50%, rgba(15, 23, 42, 0.9) 100%) !important;
    border: 2px solid rgba(99, 102, 241, 0.25) !important;
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.1), inset 0 0 20px rgba(255, 255, 255, 0.05) !important;
  }
  .hms-cybercard-glow:hover {
    transform: translateY(-8px) scale(1.02) rotate(0.5deg) !important;
    border-color: rgba(99, 102, 241, 0.5) !important;
    box-shadow: 0 10px 40px rgba(99, 102, 241, 0.25), inset 0 0 30px rgba(255, 255, 255, 0.1) !important;
  }
  @keyframes hms-card-float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-6px) rotate(0.3deg); }
  }

  /* Scoped Print Classes for Flawless Printing */
  @media print {
    @page {
      size: A4 portrait;
      margin: 0;
    }
    body.hms-printing-active {
      background: #020617 !important;
      background-color: #020617 !important;
      margin: 0 !important;
      padding: 0 !important;
      overflow: hidden !important;
      height: 100vh !important;
    }
    body.hms-printing-active * {
      visibility: hidden !important;
    }
    body.hms-printing-active #healthCardToPrint,
    body.hms-printing-active #healthCardToPrint * {
      visibility: visible !important;
    }
    body.hms-printing-active #healthCardToPrint {
      position: absolute !important;
      left: 50% !important;
      top: 40% !important;
      transform: translate(-50%, -50%) scale(1.2) !important;
      transform-origin: center !important;
      width: 500px !important;
      height: 310px !important;
      border: 2px solid #6366f1 !important; /* solid Indigo border for defined printable shape */
      background: linear-gradient(135deg, #020617 0%, #0f172a 100%) !important;
      background-color: #020617 !important;
      color: white !important;
      border-radius: 28px !important;
      box-shadow: none !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      padding: 24px !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: space-between !important;
    }
    /* Hide decorative items in print */
    body.hms-printing-active #healthCardToPrint .hud-shine-sweep,
    body.hms-printing-active #healthCardToPrint .hud-grid-overlay {
      display: none !important;
    }
  }
</style>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'dashboard' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8 hms-page-transition">
      <!-- Welcome Header -->
      <div class="mb-8 animate-fade-in flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-black text-white mb-2">Welcome back, <%= user.name %></h1>
          <p class="text-gray-400 font-medium">Here's your health summary for today.</p>
        </div>
        <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-xl border border-white/10 shrink-0 self-start md:self-auto">
          <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse"></div>
          <span class="text-sm font-bold text-gray-300">Biometric Uplink stable</span>
        </div>
      </div>

      <!-- Neural HUD Diagnostic Core & Health Score Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
         <!-- Health Score -->
         <div class="hms-glass-premium hms-hover-lift rounded-[24px] p-6 flex flex-col justify-between shadow-xl animate-scale-in">
           <div>
             <div class="flex items-center justify-between mb-4">
               <span class="text-xs font-black uppercase tracking-wider text-indigo-400">Health Diagnostics</span>
               <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse"></div>
             </div>
             <div class="flex items-center gap-6 my-6">
               <div class="relative w-24 h-24">
                 <svg class="w-full h-full transform -rotate-90">
                   <circle cx="48" cy="48" r="40" stroke="currentColor" stroke-width="8" fill="transparent" class="text-gray-700" />
                   <circle cx="48" cy="48" r="40" stroke="currentColor" stroke-width="8" fill="transparent" class="<%= healthScore > 80 ? 'text-emerald-400' : 'text-amber-400' %>" stroke-dasharray="251" stroke-dashoffset="<%= 251 - (251 * healthScore) / 100 %>" />
                 </svg>
                 <span class="absolute inset-0 flex items-center justify-center text-3xl font-black text-white"><%= healthScore %></span>
               </div>
               <div>
                 <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Global Status</span>
                 <h3 class="text-xl font-black text-white mt-1"><%= healthScore > 80 ? 'EXCELLENT' : 'STABLE' %></h3>
                 <p class="text-xs text-gray-500 mt-0.5">Biometrics within standard bounds.</p>
               </div>
             </div>
           </div>
           <div class="p-3 bg-white/5 rounded-xl border border-white/5 text-xs text-gray-400 flex items-center gap-2">
             <i class="fas fa-fingerprint text-indigo-400 text-sm"></i>
             <span>Identity Secure (AES-256 Enabled)</span>
           </div>
         </div>

         <!-- Neural X-Ray HUD Scanner -->
         <div class="lg:col-span-2 hms-glass-premium hms-hover-lift rounded-[24px] p-6 relative overflow-hidden shadow-xl animate-scale-in animate-delay-100 flex flex-col md:flex-row gap-6 border border-white/10 shadow-[0_0_50px_rgba(99,102,241,0.05)]">
           <div class="hud-grid-overlay"></div>
           <!-- Scanner Display Panel -->
           <div class="w-full md:w-1/2 relative bg-slate-950/90 rounded-2xl border border-white/10 h-56 md:h-auto overflow-hidden flex items-center justify-center group/scan shadow-inner shadow-indigo-500/10">
             <div class="hud-laser-line hidden" id="hudLaser"></div>
             <!-- Scanning Canvas drawing -->
             <canvas id="hudScannerCanvas" class="w-full h-full object-cover max-h-64" style="min-height: 220px;"></canvas>
             <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent pointer-events-none"></div>
             
             <!-- Glowing corner brackets -->
             <div class="absolute top-3 left-3 w-4 h-4 border-t-2 border-l-2 border-indigo-500/40 pointer-events-none transition-all duration-300 group-hover/scan:border-indigo-400"></div>
             <div class="absolute top-3 right-3 w-4 h-4 border-t-2 border-r-2 border-indigo-500/40 pointer-events-none transition-all duration-300 group-hover/scan:border-indigo-400"></div>
             <div class="absolute bottom-3 left-3 w-4 h-4 border-b-2 border-l-2 border-indigo-500/40 pointer-events-none transition-all duration-300 group-hover/scan:border-indigo-400"></div>
             <div class="absolute bottom-3 right-3 w-4 h-4 border-b-2 border-r-2 border-indigo-500/40 pointer-events-none transition-all duration-300 group-hover/scan:border-indigo-400"></div>
             
             <!-- Scanners status badge -->
             <div class="absolute top-3 left-3 bg-slate-900/90 text-white font-mono text-[9px] px-2.5 py-1.5 rounded-lg border border-indigo-500/30 tracking-widest flex items-center gap-1.5 uppercase shadow-lg shadow-black/50 z-20">
               <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" id="scanStatusIndicator"></span>
               <span id="scanStatusText">HUD: STANDBY</span>
             </div>
           </div>

           <!-- Scanner Command Controls & Insights -->
           <div class="w-full md:w-1/2 flex flex-col justify-between relative z-10 py-1">
             <div>
               <div class="flex items-center gap-2 mb-1.5">
                 <div class="w-2.5 h-2.5 rounded-full bg-indigo-500 animate-pulse"></div>
                 <h4 class="text-lg font-black text-white tracking-tight flex items-center gap-2"><i class="fas fa-microscope text-indigo-400"></i>Neural Diagnostics Core</h4>
               </div>
               <p class="text-xs text-gray-400 mb-4 leading-relaxed font-medium">Select target biological vector and trigger automated deep neural scanner pass.</p>
               
               <div class="grid grid-cols-2 gap-2 mb-4">
                 <button type="button" onclick="setScanMode('xray')" id="btnModeXray" class="px-3 py-2.5 bg-indigo-600 text-white border border-indigo-400/30 rounded-xl text-xs font-black transition-all flex items-center justify-center gap-1.5 hover:scale-105 cursor-pointer shadow-lg shadow-indigo-600/20">
                   <i class="fas fa-lungs"></i> Chest X-Ray
                 </button>
                 <button type="button" onclick="setScanMode('mri')" id="btnModeMri" class="px-3 py-2.5 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-xs font-black transition-all flex items-center justify-center gap-1.5 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer">
                   <i class="fas fa-brain"></i> Brain MRI
                 </button>
               </div>

               <!-- Active Scanned Insights Panel -->
               <div class="p-4 bg-slate-950/70 border border-white/5 rounded-2xl text-xs space-y-2.5 mb-4 shadow-inner">
                 <div class="flex justify-between font-mono">
                   <span class="text-gray-500 font-medium">Anomaly Index:</span>
                   <span id="txtAnomalyIndex" class="text-emerald-400 font-bold tracking-wider">0.01% (NOMINAL)</span>
                 </div>
                 <div class="flex justify-between font-mono">
                   <span class="text-gray-500 font-medium">Scan Resolution:</span>
                   <span class="text-indigo-400 font-bold">4096px px-HUD</span>
                 </div>
                 <div id="txtScanResult" class="text-gray-400 leading-relaxed border-t border-white/5 pt-2.5 italic text-[11px] min-h-[56px] font-medium">
                   Ready to initiate diagnostic analysis.
                 </div>
               </div>
             </div>

             <button type="button" onclick="triggerNeuralScan()" id="btnStartScan" class="hms-btn hms-btn-primary w-full text-xs font-black tracking-wider uppercase py-3.5 rounded-xl flex items-center justify-center gap-2 cursor-pointer shadow-xl shadow-indigo-600/10 hover:shadow-indigo-600/20 hover:scale-[1.02] active:scale-95 transition-all">
               <i class="fas fa-satellite-dish" id="scanIcon"></i>
               <span id="scanBtnText">Initiate Neural Scan</span>
             </button>
           </div>
         </div>
      </div>

      <!-- Quantum Genomic DNA Sequence Auditor HUD -->
      <div class="hms-glass-premium hms-hover-lift rounded-[24px] p-6 relative overflow-hidden shadow-xl mb-8 border border-white/10 shadow-[0_0_50px_rgba(99,102,241,0.05)] animate-fade-in flex flex-col lg:flex-row gap-6">
        <div class="hud-grid-overlay"></div>
        <!-- DNA rotating helix canvas -->
        <div class="w-full lg:w-1/3 relative bg-slate-950/90 rounded-2xl border border-white/10 h-56 lg:h-auto overflow-hidden flex items-center justify-center group/dna shadow-inner shadow-cyan-500/10">
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent pointer-events-none"></div>
          
          <!-- Glowing corner brackets -->
          <div class="absolute top-3 left-3 w-4 h-4 border-t-2 border-l-2 border-cyan-500/40 pointer-events-none transition-all duration-300 group-hover/dna:border-cyan-400"></div>
          <div class="absolute top-3 right-3 w-4 h-4 border-t-2 border-r-2 border-cyan-500/40 pointer-events-none transition-all duration-300 group-hover/dna:border-cyan-400"></div>
          <div class="absolute bottom-3 left-3 w-4 h-4 border-b-2 border-l-2 border-cyan-500/40 pointer-events-none transition-all duration-300 group-hover/dna:border-cyan-400"></div>
          <div class="absolute bottom-3 right-3 w-4 h-4 border-b-2 border-r-2 border-cyan-500/40 pointer-events-none transition-all duration-300 group-hover/dna:border-cyan-400"></div>
          
          <!-- Canvas drawing rotating helix -->
          <canvas id="dnaCanvas" class="w-full h-full object-cover max-h-64" style="min-height: 220px;"></canvas>
          
          <!-- Badge -->
          <div class="absolute top-3 left-3 bg-slate-900/90 text-white font-mono text-[9px] px-2.5 py-1.5 rounded-lg border border-cyan-500/30 tracking-widest flex items-center gap-1.5 uppercase shadow-lg shadow-black/50 z-20">
            <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse" id="dnaStatusIndicator"></span>
            <span id="dnaStatusText">GENE: LINKED (FOXO3/SIRT1)</span>
          </div>
        </div>

        <!-- Genomic HUD audit panel & selectors -->
        <div class="w-full lg:w-2/3 flex flex-col justify-between relative z-10 py-1">
          <div>
            <div class="flex items-center gap-2 mb-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-cyan-500 animate-pulse"></div>
              <h4 class="text-lg font-black text-white tracking-tight flex items-center gap-2">
                <i class="fas fa-dna text-cyan-400"></i>Quantum Genomic DNA Sequence Auditor HUD
              </h4>
            </div>
            <p class="text-xs text-gray-400 mb-4 leading-relaxed font-medium">Decompile and analyze your local nucleotide sequence structures, identifying premium epigenetic longevity markers and neuro-resilience indicators.</p>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-4 font-sans">
              <button type="button" onclick="selectGenomicProfile('longevity')" id="btnProfileLongevity" class="px-3 py-2 bg-cyan-600 text-white border border-cyan-400/30 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:scale-105 cursor-pointer shadow-lg shadow-cyan-600/20">
                <i class="fas fa-hourglass-half"></i> Longevity Factors
              </button>
              <button type="button" onclick="selectGenomicProfile('cognitive')" id="btnProfileCognitive" class="px-3 py-2 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer">
                <i class="fas fa-brain"></i> BDNF Resilience
              </button>
              <button type="button" onclick="selectGenomicProfile('cardio')" id="btnProfileCardio" class="px-3 py-2 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer">
                <i class="fas fa-heart"></i> NOS3 Vascular
              </button>
              <button type="button" onclick="selectGenomicProfile('metabolic')" id="btnProfileMetabolic" class="px-3 py-2 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer">
                <i class="fas fa-bolt"></i> Metabolic Rate
              </button>
            </div>

            <!-- Dynamic scrolling base pair display stream -->
            <div class="p-4 bg-slate-950/70 border border-white/5 rounded-2xl text-xs mb-4 shadow-inner">
              <div class="flex justify-between items-center mb-2 pb-2 border-b border-white/5 font-mono text-[10px]">
                <span class="text-gray-500 uppercase tracking-wider font-bold">Base Pair Telemetry Stream:</span>
                <span id="txtDnaSpeed" class="text-cyan-400 font-bold tracking-wider">SYNCED (60 FPS)</span>
              </div>
              
              <!-- scrolling nucleotide pairs -->
              <div id="genePairSequence" class="font-mono text-cyan-400/80 tracking-widest text-[13px] overflow-hidden whitespace-nowrap text-center py-2 bg-black/40 rounded-lg border border-cyan-500/10 min-h-[38px] select-all shadow-inner">
                A-T • G-C • C-G • T-A • T-A • C-G • G-C • A-T • T-A • G-C • C-G • T-A • G-C • A-T
              </div>
              
              <div class="mt-2.5 flex justify-between font-mono text-[11px] leading-relaxed">
                <span class="text-gray-500 font-medium">Gene Locus Target:</span>
                <span id="dnaLocusText" class="text-cyan-400 font-bold">FOXO3 Chromosome 6 (rs2802292)</span>
              </div>
              <div id="txtDnaAuditResult" class="text-gray-400 leading-relaxed border-t border-white/5 pt-2 mt-2 italic text-[11px] min-h-[48px] font-medium">
                Genomic sequence synced with active biomarkers. Ready to decompile and audit DNA double-helix structures.
              </div>
            </div>
          </div>

          <button type="button" onclick="triggerDnaDecompile()" id="btnDnaDecompile" class="hms-btn hms-btn-primary w-full text-xs font-black tracking-wider uppercase py-3.5 rounded-xl flex items-center justify-center gap-2 cursor-pointer shadow-xl shadow-cyan-600/10 hover:shadow-cyan-600/20 hover:scale-[1.02] active:scale-95 transition-all bg-gradient-to-r from-cyan-600 to-indigo-600 border-none font-sans">
            <i class="fas fa-terminal" id="dnaIcon"></i>
            <span id="dnaBtnText">Decompile Nucleotide Sequence</span>
          </button>
        </div>
      </div>

      <!-- Live Vitals Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        
        <!-- Heart Rate -->
        <div class="hms-glass-premium hms-hover-lift hover:border-rose-500/30 rounded-[24px] p-6 relative overflow-hidden group shadow-xl">
          <div class="absolute -right-8 -top-8 w-20 h-20 rounded-full bg-rose-500/5 blur-2xl pointer-events-none group-hover:bg-rose-500/10 transition-all"></div>
          
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-rose-500/10 border border-rose-500/20 text-rose-400 rounded-2xl flex items-center justify-center shadow-inner group-hover:scale-110 transition-transform">
              <i class="fas fa-heartbeat text-xl animate-pulse"></i>
            </div>
            <span class="px-2.5 py-0.5 rounded-full text-[9px] font-black uppercase bg-rose-500/20 border border-rose-500/30 text-rose-400 tracking-wider animate-pulse">Live HUD</span>
          </div>
          
          <div class="text-3xl font-black text-white tracking-tight hms-stat-value flex items-baseline gap-1" id="hudHeartRate">
            72 <span class="text-xs text-gray-400 font-bold uppercase tracking-wider">BPM</span>
          </div>
          <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1 hms-stat-label">Heart Rate</div>
          
          <!-- Animated ECG Heartbeat Line Trace underneath the stats -->
          <div class="w-full h-8 mt-3 pointer-events-none opacity-40 group-hover:opacity-75 transition-opacity">
            <svg viewBox="0 0 300 40" class="w-full h-full stroke-rose-500 fill-none stroke-[2]">
              <path class="ecg-line" d="M 0 20 L 50 20 L 60 10 L 70 30 L 80 20 L 140 20 L 150 5 L 160 35 L 170 20 L 220 20 L 230 10 L 240 30 L 250 20 L 300 20" />
            </svg>
          </div>
        </div>

        <!-- SpO2 Level -->
        <div class="hms-glass-premium hms-hover-lift-cyan rounded-[24px] p-6 relative overflow-hidden group shadow-xl">
          <div class="absolute -right-8 -top-8 w-20 h-20 rounded-full bg-cyan-500/5 blur-2xl pointer-events-none group-hover:bg-cyan-500/10 transition-all"></div>
          
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 rounded-2xl flex items-center justify-center shadow-inner group-hover:scale-110 transition-transform">
              <i class="fas fa-wind text-xl"></i>
            </div>
            <span class="px-2.5 py-0.5 rounded-full text-[9px] font-black uppercase bg-cyan-500/20 border border-cyan-500/30 text-cyan-400 tracking-wider animate-pulse">Live HUD</span>
          </div>
          
          <div class="text-3xl font-black text-white tracking-tight hms-stat-value flex items-baseline gap-1" id="hudSpo2">
            98 <span class="text-xs text-gray-400 font-bold uppercase tracking-wider">%</span>
          </div>
          <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1 hms-stat-label">SpO2 Level</div>
          
          <!-- Animated rotating loading/wind ring overlay -->
          <div class="absolute right-6 bottom-4 w-12 h-12 border border-dashed border-cyan-500/20 rounded-full animate-[spin_10s_linear_infinite] flex items-center justify-center pointer-events-none">
            <div class="w-8 h-8 border border-cyan-500/30 rounded-full border-t-transparent animate-[spin_3s_linear_infinite_reverse]"></div>
          </div>
        </div>

        <!-- Blood Pressure -->
        <div class="hms-glass-premium hms-hover-lift hover:border-indigo-500/30 rounded-[24px] p-6 relative overflow-hidden group shadow-xl">
          <div class="absolute -right-8 -top-8 w-20 h-20 rounded-full bg-indigo-500/5 blur-2xl pointer-events-none group-hover:bg-indigo-500/10 transition-all"></div>
          
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 rounded-2xl flex items-center justify-center shadow-inner group-hover:scale-110 transition-transform">
              <i class="fas fa-tint text-xl"></i>
            </div>
            <span class="px-2.5 py-0.5 rounded-full text-[9px] font-black uppercase bg-indigo-500/20 border border-indigo-500/30 text-indigo-300 tracking-wider">Stable</span>
          </div>
          
          <div class="text-3xl font-black text-white tracking-tight hms-stat-value flex items-baseline gap-1" id="hudBloodPressure">
            120/80 <span class="text-xs text-gray-400 font-bold uppercase tracking-wider font-semibold"></span>
          </div>
          <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1 hms-stat-label">Blood Pressure</div>
          
          <!-- Cyberpunk HUD grid accent line -->
          <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden mt-6 border border-white/5 relative z-10 pointer-events-none">
            <div class="h-full w-2/3 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full animate-pulse"></div>
          </div>
        </div>

        <!-- Body Temp -->
        <div class="hms-glass-premium hms-hover-lift-amber rounded-[24px] p-6 relative overflow-hidden group shadow-xl">
          <div class="absolute -right-8 -top-8 w-20 h-20 rounded-full bg-amber-500/5 blur-2xl pointer-events-none group-hover:bg-amber-500/10 transition-all"></div>
          
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-amber-500/10 border border-amber-500/20 text-amber-400 rounded-2xl flex items-center justify-center shadow-inner group-hover:scale-110 transition-transform">
              <i class="fas fa-thermometer-half text-xl"></i>
            </div>
            <span class="px-2.5 py-0.5 rounded-full text-[9px] font-black uppercase bg-amber-500/20 border border-amber-500/30 text-amber-400 tracking-wider">Normal</span>
          </div>
          
          <div class="text-3xl font-black text-white tracking-tight hms-stat-value flex items-baseline gap-1" id="hudBodyTemp">
            98.6 <span class="text-xs text-gray-400 font-bold uppercase tracking-wider">°F</span>
          </div>
          <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1 hms-stat-label">Body Temp</div>
          
          <!-- Mini thermometer filling effect -->
          <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden mt-6 border border-white/5 relative z-10 pointer-events-none">
            <div class="h-full w-[45%] bg-gradient-to-r from-amber-500 to-orange-500 rounded-full"></div>
          </div>
        </div>

      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Content Area -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Digital Health ID Card (Wallet HUD style) -->

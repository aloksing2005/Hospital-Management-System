<% var title = 'Billing & Invoices - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'bills' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex justify-between items-end mb-10 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">Finances & Billing</h1>
        <p class="text-gray-400 font-medium">Clear overview of your medical expenses and invoices</p>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="hms-card animate-scale-in">
        <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Total Outstanding</p>
        <h3 class="text-3xl font-black text-rose-400">₹<%= bills.filter(b => b.payment_status === 'pending').reduce((sum, b) => sum + parseFloat(b.total_amount), 0).toFixed(2) %></h3>
      </div>
      <div class="hms-card animate-scale-in">
        <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Total Paid</p>
        <h3 class="text-3xl font-black text-emerald-400">₹<%= bills.filter(b => b.payment_status === 'paid').reduce((sum, b) => sum + parseFloat(b.total_amount), 0).toFixed(2) %></h3>
      </div>
      <div class="hms-card animate-scale-in">
        <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-2">Total Bills</p>
        <h3 class="text-3xl font-black text-indigo-400"><%= bills.length %></h3>
      </div>
    </div>

    <!-- Bills Table -->
    <div class="hms-card animate-fade-in">
      <div class="hms-table-container">
        <table class="hms-table">
          <thead>
            <tr>
              <th>Bill ID</th>
              <th>Date</th>
              <th>Description</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (bills.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center py-12 text-gray-400">No bills found</td>
              </tr>
            <% } else { %>
              <% bills.forEach(bill => { %>
                <tr>
                  <td><%= bill.id %></td>
                  <td><%= new Date(bill.created_at).toLocaleDateString() %></td>
                  <td><%= bill.description || 'Medical Services' %></td>
                  <td>₹<%= parseFloat(bill.total_amount).toFixed(2) %></td>
                  <td>
                    <span class="hms-badge hms-badge-<%= bill.payment_status === 'paid' ? 'success' : 'warning' %>">
                      <%= bill.payment_status %>
                    </span>
                  </td>
                  <td>
                    <button class="text-indigo-400 hover:text-indigo-300 mr-3">View</button>
                    <% if (bill.payment_status === 'pending') { %>
                      <button class="text-emerald-400 hover:text-emerald-300">Pay</button>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

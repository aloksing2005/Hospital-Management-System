<% var title = 'AI Video Health Assistant - HMS'; %>
<%- include('../partials/header') %>

<div class="flex min-h-screen bg-slate-950">
  <%- include('../partials/patient-sidebar', { active: 'ai-consultation' }) %>
  
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header with high-tech badge -->
    <div class="mb-8 animate-fade-in flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <div class="px-3 py-1 text-xs font-bold uppercase tracking-widest text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 rounded-full">
            Autonomous Medical Agent v2.5
          </div>
          <div class="w-2 h-2 rounded-full bg-indigo-500 animate-ping"></div>
        </div>
        <h1 class="text-3xl font-black text-white tracking-tight">AI Video Consultation Portal</h1>
        <p class="text-gray-400 text-sm mt-1">Engage in real-time bilingual voice diagnostics. Describe symptoms in English or Hinglish.</p>
      </div>
      
      <button type="button" id="saveConsultBtn" class="hidden hms-btn bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-3 rounded-2xl transition-all flex items-center gap-2 shadow-lg shadow-indigo-600/30">
        <i class="fas fa-file-medical-alt"></i>
        <span>Save Medical Report</span>
      </button>
    </div>

    <!-- Main Grid Layout -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
      
      <!-- Video Consultation Console -->
      <div class="xl:col-span-2 space-y-6">
        <!-- Glass Video Card -->
        <div class="bg-slate-900/60 backdrop-blur-xl border border-white/10 rounded-3xl overflow-hidden shadow-2xl relative group transition-all duration-300 hover:border-indigo-500/20">
          
          <style>
            @keyframes scan-sweep {
              0% { top: 0%; }
              50% { top: 100%; }
              100% { top: 0%; }
            }
            .laser-scanning {
              animation: scan-sweep 3s linear infinite;
            }
            @keyframes pulse-mesh {
              0%, 100% { transform: translate(-50%, -50%) scale(0.96); opacity: 0.25; }
              50% { transform: translate(-50%, -50%) scale(1.04); opacity: 0.5; }
            }
            .hologram-pulse {
              animation: pulse-mesh 4s ease-in-out infinite;
            }
          </style>

          <!-- Call Frame Panel -->
          <div class="relative bg-slate-950 aspect-video rounded-t-3xl overflow-hidden border-b border-white/5">
            <!-- Local User Webcam Stream -->
            <video id="localVideo" autoplay muted playsinline class="w-full h-full object-cover opacity-70 transition-opacity duration-300"></video>
            
            <!-- Floating audio canvas wave overlay -->
            <canvas id="audioVisualizer" class="absolute inset-0 w-full h-full pointer-events-none opacity-30"></canvas>

            <!-- Interactive Holographic Face-Mesh & Target Scope HUD -->
            <div id="aiTargetMesh" class="hidden absolute inset-0 pointer-events-none z-10">
              <!-- Animated Target Scope Center -->
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 border border-dashed border-emerald-500/20 rounded-full animate-[spin_20s_linear_infinite] flex items-center justify-center">
                <div class="w-40 h-40 border border-emerald-500/35 rounded-full border-t-transparent border-b-transparent animate-[spin_6s_linear_infinite_reverse]"></div>
              </div>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 border border-emerald-500/15 rounded-full hologram-pulse"></div>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center">
                <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-ping"></div>
                <div class="absolute w-6 h-[1px] bg-emerald-500/40"></div>
                <div class="absolute h-6 w-[1px] bg-emerald-500/40"></div>
              </div>
              
              <!-- Floating HUD Scan Tech Overlay -->
              <div class="absolute bottom-6 left-6 font-mono text-[9px] text-emerald-400/80 space-y-1 bg-slate-950/80 p-3 rounded-xl border border-emerald-500/20 backdrop-blur-xs shadow-lg">
                <div class="flex items-center gap-1.5 text-emerald-400 font-black">
                  <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                  <span>TARGET LOCK ACTIVE</span>
                </div>
                <div class="pt-1 border-t border-emerald-500/10">NODE ID: <span class="text-white">HMS-AI-V2.5</span></div>
                <div>COORD X: <span id="meshCoordX" class="text-white">45.2890 px</span></div>
                <div>COORD Y: <span id="meshCoordY" class="text-white">62.1582 px</span></div>
                <div>RESOLUTION: <span class="text-white">1080P / 60FPS</span></div>
                <div>STATE: <span id="meshTrackState" class="text-emerald-400 font-bold">LOCK_STABLE</span></div>
              </div>
            </div>
            
            <!-- Sci-fi camera scan line overlay -->
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none opacity-10 animate-pulse"></div>
            
            <!-- Glowing camera target corner corners -->
            <div class="absolute top-6 left-6 w-6 h-6 border-t-2 border-l-2 border-indigo-500/40 pointer-events-none"></div>
            <div class="absolute top-6 right-6 w-6 h-6 border-t-2 border-r-2 border-indigo-500/40 pointer-events-none"></div>
            <div class="absolute bottom-6 left-6 w-6 h-6 border-b-2 border-l-2 border-indigo-500/40 pointer-events-none"></div>
            <div class="absolute bottom-6 right-6 w-6 h-6 border-b-2 border-r-2 border-indigo-500/40 pointer-events-none"></div>

            <!-- Translucent Holographic Bio-Sensory Panel -->
            <div id="bioSensoryHud" class="hidden absolute top-6 left-6 md:left-24 bg-slate-900/85 backdrop-blur-md border border-indigo-500/35 rounded-2xl p-4 w-44 md:w-56 shadow-lg shadow-indigo-500/10 animate-fade-in text-[11px] space-y-3 z-20">
              <div class="flex justify-between items-center border-b border-indigo-500/25 pb-2">
                <span class="text-indigo-400 font-black tracking-widest uppercase text-[10px]">Bio-Sensory Suite</span>
                <span id="bioSensoryActiveDot" class="w-2.5 h-2.5 rounded-full bg-gray-500"></span>
              </div>
              
              <!-- PPG Optical Waveform -->
              <div class="space-y-1">
                <div class="flex justify-between items-center text-gray-300">
                  <span>PPG Optical Wave:</span>
                  <span id="ppgBpmText" class="text-indigo-400 font-mono font-black text-xs">-- BPM</span>
                </div>
                <canvas id="ppgCanvas" class="w-full h-10 bg-slate-950/80 border border-indigo-500/10 rounded-lg mt-1.5" role="img" aria-label="Scrolling Camera PPG Optical Pulse waveform"></canvas>
              </div>

              <!-- Solfeggio Soundscape Controls -->
              <div class="space-y-2 border-t border-indigo-500/10 pt-2.5">
                <div class="flex justify-between items-center">
                  <span class="text-gray-300">Solfeggio Soundscape:</span>
                  <span id="solfeggioFreqText" class="text-[9px] text-indigo-400 font-bold tracking-wider">OFF</span>
                </div>
                
                <div class="flex items-center gap-2">
                  <button type="button" id="solfeggioToggleBtn" class="flex-1 py-1.5 bg-indigo-600/20 hover:bg-indigo-600/40 text-indigo-300 font-black text-[9px] uppercase border border-indigo-500/30 rounded-lg transition-all flex items-center justify-center gap-1" aria-label="Toggle Solfeggio binaural audio soundscape" aria-live="polite">
                    <i class="fas fa-play text-[8px]"></i><span>Muted</span>
                  </button>
                </div>
                
                <div class="space-y-1">
                  <div class="flex justify-between text-[8px] text-gray-400">
                    <span>Volume</span>
                    <span id="solfeggioVolPercent">50%</span>
                  </div>
                  <input type="range" id="solfeggioVolSlider" min="0" max="1" step="0.05" value="0.5" class="w-full accent-indigo-500 h-1 bg-slate-950 rounded-lg appearance-none cursor-pointer" aria-label="Solfeggio soundscape volume slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50">
                </div>
              </div>

              <!-- Real-time Diagnostics Sensor Output -->
              <div class="space-y-1 border-t border-indigo-500/10 pt-2 text-[9px] font-mono text-gray-400">
                <div>HRV (SDNN): <span id="diagHrv" class="text-white">-- ms</span></div>
                <div>RESPIRATION: <span id="diagBreathing" class="text-white">-- rpm</span></div>
                <div>SIGNAL: <span id="diagSignal" class="text-white">--</span></div>
                <div>LIGHTING: <span id="diagLight" class="text-white">--</span></div>
              </div>
            </div>

            <!-- Translucent Holographic Vitals HUD Box -->
            <div id="vitalsHud" class="hidden absolute top-6 right-6 md:right-48 bg-slate-900/85 backdrop-blur-md border border-emerald-500/35 rounded-2xl p-4 w-44 md:w-52 shadow-lg shadow-emerald-500/10 animate-fade-in text-[11px] space-y-3 z-20">
              <div class="flex justify-between items-center border-b border-emerald-500/25 pb-2">
                <span class="text-emerald-400 font-black tracking-widest uppercase text-[10px]">Real-Time Vitals</span>
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-ping"></span>
              </div>
              
              <!-- Heart Rate -->
              <div class="space-y-1">
                <div class="flex justify-between items-center text-gray-300">
                  <span>Heart Rate:</span>
                  <span id="hudBpm" class="text-emerald-400 font-mono font-black text-xs">-- BPM</span>
                </div>
                <div class="w-full h-1 bg-slate-950 rounded-full overflow-hidden border border-white/5">
                  <div id="barBpm" class="h-full bg-gradient-to-r from-emerald-500 to-teal-400 transition-all duration-300" style="width: 0%"></div>
                </div>
                <canvas id="ecgCanvas" class="w-full h-8 bg-slate-950/80 border border-emerald-500/10 rounded-lg mt-1.5" role="img" aria-label="Heartbeat Electrocardiogram sweep trace"></canvas>
              </div>

              <!-- Oxygen SpO2 -->
              <div class="space-y-1">
                <div class="flex justify-between items-center text-gray-300">
                  <span>Oxygen SpO2:</span>
                  <span id="hudSpo2" class="text-emerald-400 font-mono font-black text-xs">-- %</span>
                </div>
                <div class="w-full h-1 bg-slate-950 rounded-full overflow-hidden border border-white/5">
                  <div id="barSpo2" class="h-full bg-gradient-to-r from-teal-400 to-cyan-500 transition-all duration-300" style="width: 0%"></div>
                </div>
              </div>

              <!-- Blood Pressure -->
              <div class="space-y-1">
                <div class="flex justify-between items-center text-gray-300">
                  <span>Blood Pressure:</span>
                  <span id="hudBp" class="text-emerald-400 font-mono font-black text-xs">-- mmHg</span>
                </div>
                <div class="w-full h-1 bg-slate-950 rounded-full overflow-hidden border border-white/5">
                  <div id="barBp" class="h-full bg-gradient-to-r from-cyan-500 to-indigo-500 transition-all duration-300" style="width: 0%"></div>
                </div>
              </div>

              <!-- Stress Level -->
              <div class="space-y-1">
                <div class="flex justify-between items-center text-gray-300">
                  <span>Stress Level:</span>
                  <span id="hudStress" class="text-emerald-400 font-bold uppercase text-[10px]">--</span>
                </div>
                <div class="w-full h-1 bg-slate-950 rounded-full overflow-hidden border border-white/5">
                  <div id="barStress" class="h-full bg-gradient-to-r from-emerald-500 to-teal-400 transition-all duration-300" style="width: 0%"></div>
                </div>
              </div>
              
              <!-- Touch Fingerprint Scanner Pad -->
              <div id="fingerprintZone" class="border-t border-emerald-500/25 pt-2.5 mt-2.5 flex flex-col items-center justify-center cursor-pointer group select-none">
                <div id="fingerprintIconContainer" class="w-11 h-11 rounded-full bg-emerald-500/5 border border-emerald-500/25 flex items-center justify-center transition-all duration-300 group-hover:scale-105 group-hover:border-emerald-400/50 group-hover:bg-emerald-500/10 group-hover:shadow-[0_0_12px_rgba(16,185,129,0.25)] relative overflow-hidden">
                  <div class="absolute inset-0 bg-emerald-500/10 rounded-full scale-0 group-hover:animate-ping opacity-35 pointer-events-none"></div>
                  <i id="fingerprintIcon" class="fas fa-fingerprint text-base text-emerald-400/80 group-hover:text-emerald-300 transition-colors"></i>
                </div>
                <span id="fingerprintText" class="text-[9px] text-emerald-400/60 font-black tracking-widest uppercase mt-1.5 transition-colors group-hover:text-emerald-300">Biometric Sensor</span>
              </div>
            </div>

            <!-- Sweeping laser line overlays -->
            <div id="laserScanLine" class="hidden absolute left-0 right-0 h-1.5 bg-emerald-500 shadow-[0_0_12px_#10b981,0_0_24px_#10b981] pointer-events-none z-10 transition-all duration-300"></div>

            <!-- Bot interactive avatar bubble -->
            <div id="aiAvatar" class="absolute bottom-6 right-6 w-32 h-32 md:w-40 md:h-40 rounded-2xl bg-gradient-to-br from-indigo-900/90 via-purple-950/90 to-indigo-950/90 flex flex-col items-center justify-center shadow-2xl border border-indigo-500/30 overflow-hidden group/avatar transition-all duration-500 hover:border-indigo-500 z-10">
              <canvas id="avatarVisualizer" class="absolute inset-0 w-full h-full pointer-events-none opacity-50"></canvas>
              <div class="relative z-10 flex flex-col items-center">
                <div class="w-12 h-12 rounded-full bg-indigo-500/20 flex items-center justify-center border border-indigo-500/30 mb-2 group-hover/avatar:scale-110 transition-transform">
                  <i class="fas fa-user-md text-2xl text-indigo-400"></i>
                </div>
                <span class="text-[10px] font-bold tracking-widest text-indigo-300 uppercase">AI Doctor</span>
              </div>
            </div>

            <!-- Dashboard status badge -->
            <div class="absolute top-6 left-6 flex items-center gap-2 z-10">
              <span id="callStatus" class="px-3 py-1.5 rounded-xl text-xs font-black tracking-widest uppercase bg-slate-900/80 border border-white/10 text-gray-300 flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-gray-500 animate-pulse"></span>
                <span>Standby</span>
              </span>
            </div>
          </div>

          <!-- Futuristic Call Controls -->
          <div class="p-6 bg-slate-900/40 flex flex-wrap gap-4 items-center justify-between">
            <div class="flex items-center gap-3">
              <button type="button" id="startCallBtn" class="px-6 py-3.5 bg-gradient-to-r from-indigo-600 to-indigo-700 hover:from-indigo-700 hover:to-indigo-800 text-white font-bold rounded-2xl shadow-lg shadow-indigo-600/30 transition-all flex items-center gap-2">
                <i class="fas fa-phone-alt"></i>
                <span>Initiate Diagnostics Call</span>
              </button>
              <button type="button" id="endCallBtn" class="hidden px-6 py-3.5 bg-gradient-to-r from-red-600 to-red-700 hover:from-red-700 hover:to-red-800 text-white font-bold rounded-2xl shadow-lg shadow-red-600/30 transition-all flex items-center gap-2">
                <i class="fas fa-phone-slash"></i>
                <span>Disconnect Call</span>
              </button>
              
              <!-- Biometric Vital Scan Trigger Button -->
              <button type="button" id="scanBtn" class="hidden px-5 py-3.5 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-2xl border border-emerald-500/20 hover:border-emerald-500/40 transition-all flex items-center gap-2">
                <i class="fas fa-heartbeat text-emerald-400 animate-pulse"></i>
                <span class="text-emerald-300">Biometric Scan</span>
              </button>

              <!-- Camera-PPG Optical Scanner Toggle Button -->
              <button type="button" id="togglePpgBtn" class="hidden px-5 py-3.5 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-2xl border border-indigo-500/20 hover:border-indigo-500/40 transition-all flex items-center gap-2">
                <i class="fas fa-eye text-indigo-400"></i>
                <span class="text-indigo-300">PPG Camera Sensor</span>
              </button>
            </div>
            
            <div class="flex items-center gap-3">
              <button type="button" id="micBtn" class="px-5 py-3.5 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-2xl border border-white/10 transition-all flex items-center gap-2">
                <i class="fas fa-microphone"></i>
                <span>Voice Capture</span>
              </button>
              <button type="button" id="speakBtn" class="hidden px-5 py-3.5 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-2xl border border-white/10 transition-all flex items-center gap-2">
                <i class="fas fa-volume-up text-indigo-400"></i>
                <span>Speak Out</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Voice Live Transcript Console -->
        <div class="bg-slate-900/60 backdrop-blur-xl border border-white/10 rounded-3xl p-6 shadow-xl">
          <div class="flex justify-between items-center mb-4">
            <div class="flex items-center gap-2">
              <i class="fas fa-align-left text-indigo-400"></i>
              <h3 class="text-lg font-bold text-white">Live Diagnostics Transcript</h3>
            </div>
            <span class="text-xs text-gray-500 font-medium">Bilingual Speech-to-Text Enabled</span>
          </div>
          
          <div id="transcriptBox" class="min-h-[100px] text-gray-300 text-sm bg-slate-950/60 rounded-2xl p-5 border border-white/5 leading-relaxed">
            Diagnoses details will appear here as you speak. Press "Voice Capture" to talk.
          </div>
          
          <div class="mt-4 flex gap-3">
            <input type="text" id="symptomInput" class="flex-1 bg-slate-950/80 border border-white/10 rounded-2xl px-5 py-3 text-white text-sm focus:outline-none focus:border-indigo-500 transition-colors" placeholder="Manually input symptoms or describe how you feel (e.g. mujhe bukhar hai)...">
            <button type="button" id="analyzeBtn" class="px-6 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-2xl shadow-lg transition-all">
              Analyze Symptoms
            </button>
          </div>
        </div>
      </div>

      <!-- Sidebar Analytical Panel -->
      <div class="space-y-6">
        
        <!-- Live AI Diagnostics Result -->
        <div class="bg-slate-900/60 backdrop-blur-xl border border-white/10 rounded-3xl p-6 shadow-xl relative overflow-hidden">
          <div class="absolute top-0 right-0 w-24 h-24 bg-indigo-500/5 rounded-full blur-2xl pointer-events-none"></div>
          <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
            <i class="fas fa-wave-square text-indigo-400"></i>
            <span>Real-time Clinical Insights</span>
          </h3>
          
          <div id="analysisContent" class="text-gray-400 text-sm min-h-[150px] bg-slate-950/40 border border-white/5 rounded-2xl p-4">
            <div class="flex flex-col items-center justify-center h-32 text-center">
              <i class="fas fa-stethoscope text-3xl text-slate-700 mb-3 animate-pulse"></i>
              <p>Awaiting symptom input to render medical metrics.</p>
            </div>
          </div>
        </div>

        <!-- Companion Consultation Room Chat -->
        <div class="bg-slate-900/60 backdrop-blur-xl border border-white/10 rounded-3xl p-6 shadow-xl flex flex-col h-[320px]">
          <h3 class="text-lg font-bold text-white mb-3 flex items-center gap-2">
            <i class="fas fa-comments-medical text-indigo-400"></i>
            <span>Consultation Session logs</span>
          </h3>
          
          <div id="aiChatBox" class="flex-1 overflow-y-auto space-y-3 mb-4 pr-1 text-sm scrollbar-thin scrollbar-thumb-white/10"></div>
          
          <div class="relative">
            <input type="text" id="aiChatInput" class="w-full bg-slate-950/80 border border-white/10 rounded-2xl pl-4 pr-10 py-3 text-white text-sm focus:outline-none focus:border-indigo-500" placeholder="Ask AI Doctor about prescription/side effects...">
            <button type="button" id="sendChatBtn" class="absolute right-3 top-1/2 -translate-y-1/2 text-indigo-400 hover:text-white transition-colors">
              <i class="fas fa-paper-plane text-sm"></i>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Historical Logs -->
    <% if (history && history.length) { %>
    <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-6 mt-8 shadow-xl">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <i class="fas fa-history text-indigo-400"></i>
        <span>Archived AI Consultations</span>
      </h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <% history.slice(0, 6).forEach(h => { %>
        <div class="p-4 bg-slate-950/60 rounded-2xl border border-white/5 hover:border-indigo-500/20 transition-colors text-sm flex flex-col justify-between">
          <div>
            <div class="flex justify-between items-start mb-2">
              <span class="text-[10px] font-bold text-indigo-400 uppercase tracking-wider"><%= new Date(h.created_at).toLocaleDateString() %></span>
              <span class="text-[10px] bg-indigo-500/10 px-2 py-0.5 rounded text-indigo-300 font-semibold uppercase"><%= h.duration_secs ? h.duration_secs + 's' : 'Text' %></span>
            </div>
            <p class="text-white font-semibold truncate mb-1">Symptoms: <%= h.symptoms %></p>
            <p class="text-gray-400 text-xs line-clamp-3 leading-relaxed"><%= h.summary || h.symptoms %></p>
          </div>
          <% if (h.medicines && h.medicines.length) { %>
          <div class="mt-3 pt-3 border-t border-white/5 flex flex-wrap gap-1">
            <% h.medicines.slice(0, 3).forEach(med => { %>
            <span class="bg-indigo-500/5 border border-indigo-500/10 text-indigo-300 text-[10px] px-2 py-0.5 rounded-full"><%= med %></span>
            <% }) %>
          </div>
          <% } %>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
<script src="/js/ai-consultation.js"></script>

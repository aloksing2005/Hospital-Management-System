<% var title = 'Medical History - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'lab-reports' }) %>

  <!-- Main Content -->
  <div class="flex-grow overflow-y-auto p-6 lg:p-12 hms-page-transition">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-10 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white tracking-tight flex items-center gap-3">
          <i class="fas fa-notes-medical text-indigo-400"></i>Medical History
        </h1>
        <p class="text-gray-400 font-medium text-sm mt-1">Your consolidated records, diagnoses, and treatments.</p>
      </div>
      <button class="hms-btn hms-btn-outline font-bold flex items-center gap-2" onclick="window.print()">
        <i class="fas fa-download"></i>Download Record
      </button>
    </div>

    <!-- Past Diagnoses Card -->
    <div class="hms-card mb-8 animate-scale-in">
      <h3 class="text-xl font-bold text-white mb-6 pb-3 border-b border-white/10">Past Diagnoses & Prescriptions</h3>
      <div class="hms-table-container">
        <table class="hms-table w-full text-left border-collapse">
          <thead>
            <tr>
              <th>Date</th>
              <th>Doctor</th>
              <th>Specialization</th>
              <th>Disease/Diagnosis</th>
              <th>Medicines Prescribed</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (prescriptions.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center text-gray-500 py-8">No medical history found.</td>
              </tr>
            <% } else { %>
              <% prescriptions.forEach(p => { %>
                <tr>
                  <td class="text-white font-medium"><%= new Date(p.created_at).toLocaleDateString() %></td>
                  <td class="text-white font-semibold">Dr. <%= p.doctor_name %></td>
                  <td><span class="hms-badge hms-badge-primary"><%= p.specialization || 'Doctor' %></span></td>
                  <td class="font-bold text-rose-400"><%= p.disease %></td>
                  <td class="text-gray-400 max-w-xs truncate"><%= p.medicines %></td>
                  <td>
                    <a href="<%= p.file_path %>" target="_blank" class="hms-btn hms-btn-secondary hms-btn-sm inline-flex items-center gap-1.5">
                      <i class="fas fa-file-pdf"></i> View
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
    
    <!-- Completed Appointments -->
    <div class="hms-card animate-scale-in">
      <h3 class="text-xl font-bold text-white mb-6 pb-3 border-b border-white/10">Completed Appointments Overview</h3>
      <div class="space-y-4">
        <% const completedApps = appointments.filter(a => a.status === 'completed'); %>
        <% if (completedApps.length === 0) { %>
          <p class="text-gray-500 text-center py-6">No completed appointments found.</p>
        <% } else { %>
          <% completedApps.forEach(app => { %>
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 p-5 bg-white/5 rounded-2xl border border-white/5 hover:border-white/10 transition-all">
              <div>
                <h4 class="font-bold text-white text-base">Dr. <%= app.doctor_name %></h4>
                <p class="text-gray-400 text-sm mt-1">
                  <i class="fas fa-calendar-alt mr-1.5 text-indigo-400"></i><%= new Date(app.date).toLocaleDateString() %> 
                  <span class="mx-2">•</span> 
                  <i class="fas fa-stethoscope mr-1.5 text-indigo-400"></i><%= app.symptoms || 'General visit' %>
                </p>
              </div>
              <span class="hms-badge hms-badge-success self-start sm:self-auto">Completed</span>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>

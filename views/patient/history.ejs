<% var title = 'Medical History - HMS'; %>
<%- include('../partials/header') %>

<div class="container-fluid">
  <div class="row">
    <div class="col-md-3 col-lg-2 sidebar p-0">
      <div class="p-3 text-white">
        <h5 class="fw-bold"><i class="fas fa-heartbeat me-2"></i>Patient Panel</h5>
      </div>
      <nav class="nav flex-column">
        <a class="nav-link" href="/patient/dashboard"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a>
        <a class="nav-link" href="/patient/doctors"><i class="fas fa-user-md me-2"></i>Find Doctors</a>
        <a class="nav-link" href="/patient/appointments"><i class="fas fa-calendar-check me-2"></i>Appointments</a>
        <a class="nav-link" href="/patient/prescriptions"><i class="fas fa-file-prescription me-2"></i>Prescriptions</a>
        <a class="nav-link active" href="/patient/history"><i class="fas fa-history me-2"></i>Medical History</a>
        <a class="nav-link" href="/patient/symptom-checker"><i class="fas fa-brain me-2"></i>AI Symptom Checker</a>
        <a class="nav-link" href="/patient/ai-chat"><i class="fas fa-robot me-2"></i>AI Assistant (Book)</a>
        <a class="nav-link" href="/patient/chat"><i class="fas fa-comments me-2"></i>Chat</a>
      </nav>
    </div>

    <div class="col-md-9 col-lg-10 p-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-notes-medical me-2"></i>Medical History</h2>
        <button class="btn btn-outline-primary" onclick="window.print()">
          <i class="fas fa-download me-2"></i>Download Record
        </button>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="fw-bold border-bottom pb-2 mb-3">Past Diagnoses & Prescriptions</h5>
          <div class="table-responsive">
            <table class="table table-striped table-hover">
              <thead class="table-dark">
                <tr>
                  <th>Date</th>
                  <th>Doctor</th>
                  <th>Specialization</th>
                  <th>Disease/Diagnosis</th>
                  <th>Medicines Prescribed</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (prescriptions.length === 0) { %>
                  <tr><td colspan="6" class="text-center text-muted">No medical history found.</td></tr>
                <% } else { %>
                  <% prescriptions.forEach(p => { %>
                    <tr>
                      <td><%= new Date(p.created_at).toLocaleDateString() %></td>
                      <td>Dr. <%= p.doctor_name %></td>
                      <td><%= p.specialization || 'Doctor' %></td>
                      <td class="fw-bold text-danger"><%= p.disease %></td>
                      <td><small><%= p.medicines %></small></td>
                      <td>
                        <a href="<%= p.file_path %>" target="_blank" class="btn btn-sm btn-info text-white">
                          <i class="fas fa-file-pdf"></i> View
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <div class="card">
        <div class="card-body">
          <h5 class="fw-bold border-bottom pb-2 mb-3">Completed Appointments Overview</h5>
          <ul class="list-group list-group-flush">
            <% appointments.filter(a => a.status === 'completed').forEach(app => { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <h6 class="mb-0">Dr. <%= app.doctor_name %></h6>
                  <small class="text-muted"><%= new Date(app.date).toLocaleDateString() %> • <%= app.symptoms || 'General visit' %></small>
                </div>
                <span class="badge bg-success">Completed</span>
              </li>
            <% }) %>
          </ul>
        </div>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>

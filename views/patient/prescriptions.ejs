<% var title = 'My Prescriptions - HMS'; %>
<%- include('../partials/header') %>

<div class="container-fluid">
  <div class="row">
    <div class="col-md-3 col-lg-2 sidebar p-0">
      <div class="p-3 text-white">
        <h5 class="fw-bold"><i class="fas fa-heartbeat me-2"></i>Patient Panel</h5>
      </div>
      <nav class="nav flex-column">
        <a class="nav-link" href="/patient/dashboard"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a>
        <a class="nav-link" href="/patient/doctors"><i class="fas fa-user-md me-2"></i>Find Doctors</a>
        <a class="nav-link" href="/patient/appointments"><i class="fas fa-calendar-check me-2"></i>My Appointments</a>
        <a class="nav-link active" href="/patient/prescriptions"><i class="fas fa-file-prescription me-2"></i>Prescriptions</a>
        <a class="nav-link" href="/patient/symptom-checker"><i class="fas fa-brain me-2"></i>AI Symptom Checker</a>
        <a class="nav-link" href="/patient/chat"><i class="fas fa-comments me-2"></i>Chat</a>
      </nav>
    </div>

    <div class="col-md-9 col-lg-10 p-4">
      <h2 class="fw-bold mb-4"><i class="fas fa-file-prescription me-2"></i>My Prescriptions</h2>

      <div class="row g-4">
        <% if (prescriptions.length === 0) { %>
          <div class="col-12 text-center py-5">
            <i class="fas fa-file-medical fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">No prescriptions yet</h4>
            <p class="text-muted">Your prescriptions will appear here after doctor visits</p>
          </div>
        <% } else { %>
          <% prescriptions.forEach(p => { %>
            <div class="col-md-6 col-lg-4">
              <div class="card h-100">
                <div class="card-header bg-white">
                  <h6 class="fw-bold mb-0">Dr. <%= p.doctor_name %></h6>
                  <small class="text-muted"><%= new Date(p.appointment_date).toLocaleDateString() %></small>
                </div>
                <div class="card-body">
                  <p class="mb-2"><strong>Disease:</strong> <%= p.disease %></p>
                  <p class="mb-2"><strong>Medicines:</strong></p>
                  <ul class="list-unstyled">
                    <% p.medicines.split(',').forEach(med => { %>
                      <li><i class="fas fa-pills me-2 text-primary"></i><%= med.trim() %></li>
                    <% }) %>
                  </ul>
                </div>
                <div class="card-footer bg-white">
                  <a href="<%= p.file_path %>" target="_blank" class="btn btn-primary w-100">
                    <i class="fas fa-download me-2"></i>Download PDF
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  socket.on('new-prescription', (data) => {
    showToast('New Prescription!', `Dr. ${data.doctorName} generated your prescription`, 'success');
  });
</script>

<%- include('../partials/footer') %>

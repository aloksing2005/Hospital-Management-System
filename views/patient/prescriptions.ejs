<% var title = 'My Prescriptions - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'prescriptions' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
      <div class="mb-8 animate-fade-in">
        <h1 class="text-3xl font-black text-white mb-2">My Prescriptions</h1>
        <p class="text-gray-400 font-medium">View and download your medical prescriptions</p>
      </div>

      <!-- Prescriptions Grid -->
      <% if (prescriptions.length === 0) { %>
        <div class="hms-card text-center py-16 animate-fade-in">
          <i class="fas fa-file-medical text-5xl text-gray-600 mb-4 block"></i>
          <h3 class="text-xl font-bold text-white mb-2">No prescriptions yet</h3>
          <p class="text-gray-400">Your prescriptions will appear here after doctor visits</p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% prescriptions.forEach(p => { %>
            <div class="hms-card animate-scale-in">
              <div class="mb-6">
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 rounded-xl flex items-center justify-center">
                    <i class="fas fa-user-md text-xl"></i>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-white">Dr. <%= p.doctor_name %></h3>
                    <p class="text-gray-400 text-sm"><%= new Date(p.appointment_date).toLocaleDateString() %></p>
                  </div>
                </div>
              </div>

              <div class="space-y-4 mb-6">
                <div>
                  <span class="text-gray-500 text-sm font-medium">Diagnosis</span>
                  <p class="text-white font-semibold"><%= p.disease %></p>
                </div>
                <div>
                  <span class="text-gray-500 text-sm font-medium">Medicines</span>
                  <ul class="space-y-2 mt-2">
                    <% p.medicines.split(',').forEach(med => { %>
                      <li class="flex items-center gap-2 text-gray-300">
                        <i class="fas fa-pills text-indigo-400"></i>
                        <span><%= med.trim() %></span>
                      </li>
                    <% }) %>
                  </ul>
                </div>
              </div>

              <a href="<%= p.file_path %>" target="_blank" class="hms-btn hms-btn-primary w-full">
                <i class="fas fa-download"></i>
                Download PDF
              </a>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  if (socket) {
    socket.on('new-prescription', (data) => {
      if (String(data.patientId || '') === '<%= user.id %>') {
        if (typeof window.hmsShowToast === 'function') {
          window.hmsShowToast('New Prescription', 'Dr. ' + (data.doctorName || '') + ' issued a new prescription', 'success');
        }
        location.reload();
      }
    });
  }
</script>

<%- include('../partials/footer') %>

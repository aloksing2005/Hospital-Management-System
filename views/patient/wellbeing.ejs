<% var title = 'Well-being Hub - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<div class="container-fluid bg-white min-h-screen">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'wellbeing' }) %>

    <div class="col-md-9 col-lg-10 p-12">
      <div class="max-w-4xl mx-auto">
        <div class="mb-12 text-center">
            <h2 class="text-5xl font-black text-gray-900 mb-4 tracking-tight">Mindful <span class="text-indigo-600">Well-being</span></h2>
            <p class="text-gray-500 text-xl">A healthy mind leads to a healthy body. Take a moment for yourself.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <!-- Mood Check-in -->
            <div class="bg-gray-50 rounded-[40px] p-10 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-500">
                <h3 class="text-2xl font-bold text-gray-800 mb-6">How are you feeling?</h3>
                <div class="grid grid-cols-4 gap-4">
                    <button class="flex flex-col items-center gap-2 p-4 rounded-3xl hover:bg-white hover:shadow-md transition group">
                        <span class="text-4xl group-hover:scale-125 transition">😊</span>
                        <span class="text-xs font-bold text-gray-400 uppercase">Great</span>
                    </button>
                    <button class="flex flex-col items-center gap-2 p-4 rounded-3xl hover:bg-white hover:shadow-md transition group">
                        <span class="text-4xl group-hover:scale-125 transition">😐</span>
                        <span class="text-xs font-bold text-gray-400 uppercase">Okay</span>
                    </button>
                    <button class="flex flex-col items-center gap-2 p-4 rounded-3xl hover:bg-white hover:shadow-md transition group">
                        <span class="text-4xl group-hover:scale-125 transition">😔</span>
                        <span class="text-xs font-bold text-gray-400 uppercase">Low</span>
                    </button>
                    <button class="flex flex-col items-center gap-2 p-4 rounded-3xl hover:bg-white hover:shadow-md transition group">
                        <span class="text-4xl group-hover:scale-125 transition">😫</span>
                        <span class="text-xs font-bold text-gray-400 uppercase">Stressed</span>
                    </button>
                </div>
                <div class="mt-8 bg-indigo-600 text-white p-6 rounded-3xl shadow-lg shadow-indigo-100">
                    <p class="text-sm font-medium italic">"Based on your check-ins, we recommend a 5-minute breathing exercise today."</p>
                </div>
            </div>

            <!-- Meditation / Audio -->
            <div class="bg-indigo-900 rounded-[40px] p-10 text-white relative overflow-hidden">
                <div class="relative z-10">
                    <h3 class="text-2xl font-bold mb-6">Zen Sessions</h3>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-4 bg-indigo-800/50 rounded-2xl border border-indigo-700/50">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-indigo-600 rounded-full flex items-center justify-center"><i class="fas fa-play text-xs"></i></div>
                                <div>
                                    <p class="text-sm font-bold">Deep Breathing</p>
                                    <p class="text-xs text-indigo-300">5 Mins • Calming</p>
                                </div>
                            </div>
                            <i class="fas fa-heart text-indigo-400"></i>
                        </div>
                        <div class="flex items-center justify-between p-4 bg-indigo-800/50 rounded-2xl border border-indigo-700/50">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-indigo-600 rounded-full flex items-center justify-center"><i class="fas fa-play text-xs"></i></div>
                                <div>
                                    <p class="text-sm font-bold">Rainforest Sounds</p>
                                    <p class="text-xs text-indigo-300">15 Mins • Nature</p>
                                </div>
                            </div>
                            <i class="fas fa-heart text-indigo-400"></i>
                        </div>
                    </div>
                    <button class="mt-8 w-full py-4 bg-white text-indigo-900 rounded-2xl font-black text-sm uppercase tracking-widest shadow-xl shadow-indigo-950">Explore Library</button>
                </div>
                <i class="fas fa-moon absolute -bottom-10 -right-10 text-[180px] text-white/5"></i>
            </div>
        </div>

        <!-- Mental Health Resources -->
        <div class="bg-gray-50 rounded-[40px] p-10 border border-gray-100">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-3xl font-black text-gray-900">Recommended Doctors</h3>
                <a href="#" class="text-indigo-600 font-bold">View All</a>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex items-center gap-4">
                    <img src="https://i.pravatar.cc/100?u=psych1" class="w-16 h-16 rounded-2xl object-cover shadow-sm">
                    <div>
                        <h4 class="font-bold text-gray-900">Dr. Sarah Johnson</h4>
                        <p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Psychiatrist • 12yrs Exp</p>
                    </div>
                    <button class="ml-auto w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center"><i class="fas fa-calendar"></i></button>
                </div>
                <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex items-center gap-4">
                    <img src="https://i.pravatar.cc/100?u=psych2" class="w-16 h-16 rounded-2xl object-cover shadow-sm">
                    <div>
                        <h4 class="font-bold text-gray-900">Dr. Michael Chen</h4>
                        <p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Clinical Psychologist</p>
                    </div>
                    <button class="ml-auto w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center"><i class="fas fa-calendar"></i></button>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<% var title = 'Well-being Hub - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <%- include('../partials/patient-sidebar', { active: 'wellbeing' }) %>
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <div class="mb-12 text-center animate-fade-in">
      <h1 class="text-4xl font-black text-white mb-4 tracking-tight">Mindful <span class="text-indigo-400">Well-being</span></h1>
      <p class="text-gray-400 text-xl">Track mood, meditate, and build healthy habits</p>
    </div>

    </div>

    <!-- Solfeggio Somatic Audio Harmonizer & Brainwave Visualizer -->
    <div class="hms-glass-premium hms-hover-lift rounded-[24px] p-6 relative overflow-hidden shadow-xl mb-8 border border-white/10 shadow-[0_0_50px_rgba(99,102,241,0.05)] animate-fade-in flex flex-col lg:flex-row gap-6">
      <div class="hud-grid-overlay"></div>
      
      <!-- Interactive audio frequency visualizer -->
      <div class="w-full lg:w-1/3 relative bg-slate-950/90 rounded-2xl border border-white/10 h-56 lg:h-auto overflow-hidden flex items-center justify-center group/audio shadow-inner shadow-indigo-500/10">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent pointer-events-none"></div>
        
        <!-- Glowing corner brackets -->
        <div class="absolute top-3 left-3 w-4 h-4 border-t-2 border-l-2 border-indigo-500/40 pointer-events-none transition-all duration-300 group-hover/audio:border-indigo-400"></div>
        <div class="absolute top-3 right-3 w-4 h-4 border-t-2 border-r-2 border-indigo-500/40 pointer-events-none transition-all duration-300 group-hover/audio:border-indigo-400"></div>
        <div class="absolute bottom-3 left-3 w-4 h-4 border-b-2 border-l-2 border-indigo-500/40 pointer-events-none transition-all duration-300 group-hover/audio:border-indigo-400"></div>
        <div class="absolute bottom-3 right-3 w-4 h-4 border-b-2 border-r-2 border-indigo-500/40 pointer-events-none transition-all duration-300 group-hover/audio:border-indigo-400"></div>
        
        <canvas id="audioVisualizerCanvas" class="w-full h-full object-cover max-h-64" style="min-height: 220px;"></canvas>
        
        <!-- Badge -->
        <div class="absolute top-3 left-3 bg-slate-900/90 text-white font-mono text-[9px] px-2.5 py-1.5 rounded-lg border border-indigo-500/30 tracking-widest flex items-center gap-1.5 uppercase shadow-lg shadow-black/50 z-20">
          <span class="w-1.5 h-1.5 rounded-full bg-rose-500" id="audioStatusIndicator"></span>
          <span id="audioStatusText">SYNTH: STANDBY</span>
        </div>
      </div>

      <!-- Controls & settings -->
      <div class="w-full lg:w-2/3 flex flex-col justify-between relative z-10 py-1">
        <div>
          <div class="flex items-center gap-2 mb-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-indigo-500 animate-pulse"></div>
            <h4 class="text-lg font-black text-white tracking-tight flex items-center gap-2">
              <i class="fas fa-wave-square text-indigo-400"></i>Somatic Solfeggio & Brainwave Harmonizer
            </h4>
          </div>
          <p class="text-xs text-gray-400 mb-4 leading-relaxed font-medium">Synthesize medical-grade audio waves tailored to cellular DNA repair, neural cortisol grounding, and stress relief mapping using live Web Audio resonators.</p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-4">
            <button type="button" onclick="selectFrequency('396')" id="btnFreq396" class="px-3 py-2 bg-indigo-600 text-white border border-indigo-400/30 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:scale-105 cursor-pointer shadow-lg shadow-indigo-600/20 animate-[pulse_3s_infinite]">
              <i class="fas fa-shield-alt"></i> 396Hz Release
            </button>
            <button type="button" onclick="selectFrequency('432')" id="btnFreq432" class="px-3 py-2 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer">
              <i class="fas fa-globe-americas"></i> 432Hz Cosmic
            </button>
            <button type="button" onclick="selectFrequency('528')" id="btnFreq528" class="px-3 py-2 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer">
              <i class="fas fa-dna"></i> 528Hz Repair
            </button>
            <button type="button" onclick="selectFrequency('639')" id="btnFreq639" class="px-3 py-2 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer">
              <i class="fas fa-heart"></i> 639Hz Connect
            </button>
          </div>

          <!-- detailed readouts -->
          <div class="p-4 bg-slate-950/70 border border-white/5 rounded-2xl text-xs mb-4 shadow-inner">
            <div class="flex justify-between items-center mb-2 pb-2 border-b border-white/5 font-mono text-[10px]">
              <span class="text-gray-500 uppercase tracking-wider font-bold">Resonator Audio profile:</span>
              <span id="txtAudioAlignment" class="text-indigo-400 font-bold tracking-wider">THETA STRESS CLEARANCE ACTIVE</span>
            </div>
            
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-2 font-mono text-[11px] leading-relaxed">
              <div>
                <span class="text-gray-500 block mb-0.5">Solfeggio Freq</span>
                <span id="lblAudioFreq" class="text-indigo-400 font-bold">396 Hz</span>
              </div>
              <div>
                <span class="text-gray-500 block mb-0.5">Entrainment Mode</span>
                <span id="lblAudioBrainwave" class="text-emerald-400 font-bold">Theta Hum (6 Hz)</span>
              </div>
              <div>
                <span class="text-gray-500 block mb-0.5">Auditory Volume</span>
                <span id="lblAudioVolume" class="text-indigo-400 font-bold">50%</span>
              </div>
              <div>
                <span class="text-gray-500 block mb-0.5">Target Gene Locus</span>
                <span id="lblAudioTarget" class="text-emerald-400 font-bold">CREB / Cortisol Release</span>
              </div>
            </div>
            
            <div id="txtAudioAuditResult" class="text-gray-400 leading-relaxed border-t border-white/5 pt-2 mt-2 italic text-[11px] min-h-[48px] font-medium font-sans">
              396Hz tone generated. Combined with Theta frequency binaural beat to downregulate sympathetic fight-or-flight signaling, reducing systemic cortisol indices.
            </div>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="w-1/2 flex items-center gap-2 bg-slate-900 border border-white/10 px-4 py-2 rounded-xl">
            <i class="fas fa-volume-up text-indigo-400"></i>
            <input type="range" id="audioVolumeSlider" min="0" max="100" value="50" class="w-full cursor-pointer accent-indigo-500" oninput="adjustVolume(this.value)">
          </div>
          
          <button type="button" onclick="toggleAudioSynth()" id="btnAudioToggle" class="w-1/2 hms-btn hms-btn-primary text-xs font-black tracking-wider uppercase py-3.5 rounded-xl flex items-center justify-center gap-2 cursor-pointer shadow-xl shadow-indigo-600/10 hover:shadow-indigo-600/20 hover:scale-[1.02] active:scale-95 transition-all">
            <i class="fas fa-play" id="audioToggleIcon"></i>
            <span id="audioToggleText">Activate Resonator</span>
          </button>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      <div class="hms-card animate-scale-in">
        <h3 class="text-2xl font-bold text-white mb-6">How are you feeling?</h3>
        <div class="grid grid-cols-4 gap-4" id="moodButtons">
          <button type="button" data-mood="great" class="mood-btn flex flex-col items-center gap-2 p-4 rounded-2xl hover:bg-emerald-500/20 transition group">
            <span class="text-4xl group-hover:scale-125 transition">😊</span>
            <span class="text-xs font-bold text-gray-400 uppercase">Great</span>
          </button>
          <button type="button" data-mood="okay" class="mood-btn flex flex-col items-center gap-2 p-4 rounded-2xl hover:bg-white/10 transition group">
            <span class="text-4xl group-hover:scale-125 transition">😐</span>
            <span class="text-xs font-bold text-gray-400 uppercase">Okay</span>
          </button>
          <button type="button" data-mood="sad" class="mood-btn flex flex-col items-center gap-2 p-4 rounded-2xl hover:bg-blue-500/20 transition group">
            <span class="text-4xl group-hover:scale-125 transition">😔</span>
            <span class="text-xs font-bold text-gray-400 uppercase">Sad</span>
          </button>
          <button type="button" data-mood="anxious" class="mood-btn flex flex-col items-center gap-2 p-4 rounded-2xl hover:bg-amber-500/20 transition group">
            <span class="text-4xl group-hover:scale-125 transition">😰</span>
            <span class="text-xs font-bold text-gray-400 uppercase">Anxious</span>
          </button>
        </div>
        <p id="moodSaved" class="text-emerald-400 text-sm mt-4 hidden">Mood logged successfully!</p>
      </div>

      <div class="hms-card animate-scale-in">
        <h3 class="text-2xl font-bold text-white mb-6">Breathing Exercise</h3>
        <p class="text-gray-400 mb-4">4-7-8 technique: inhale 4s, hold 7s, exhale 8s</p>
        <div id="breathCircle" class="w-24 h-24 mx-auto mb-4 rounded-full bg-indigo-500/30 flex items-center justify-center text-white font-bold text-lg">Ready</div>
        <button type="button" id="startBreathing" class="hms-btn hms-btn-primary w-full">Start 4-7-8 Breathing</button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <button type="button" class="wellbeing-action hms-card text-center hover:border-indigo-500/50 transition" data-activity="meditation">
        <i class="fas fa-headphones text-3xl text-indigo-400 mb-4 block"></i>
        <h4 class="text-lg font-bold text-white mb-2">Meditation</h4>
        <p class="text-gray-400 text-sm">5-min guided session</p>
      </button>
      <button type="button" class="wellbeing-action hms-card text-center hover:border-emerald-500/50 transition" data-activity="journal">
        <i class="fas fa-book-open text-3xl text-emerald-400 mb-4 block"></i>
        <h4 class="text-lg font-bold text-white mb-2">Journal</h4>
        <p class="text-gray-400 text-sm">Log your thoughts</p>
      </button>
      <div class="hms-card text-center">
        <i class="fas fa-chart-line text-3xl text-rose-400 mb-4 block"></i>
        <h4 class="text-lg font-bold text-white mb-2">Stress Level</h4>
        <input type="range" id="stressSlider" min="1" max="10" value="5" class="w-full mt-2">
        <p class="text-gray-400 text-sm mt-2">Current: <span id="stressVal">5</span>/10</p>
        <button type="button" id="saveStress" class="hms-btn hms-btn-secondary w-full mt-3 text-sm">Save</button>
      </div>
    </div>

    <% if (logs && logs.length) { %>
    <div class="hms-card">
      <h3 class="text-xl font-bold text-white mb-4">Recent Activity</h3>
      <div class="space-y-2 max-h-48 overflow-y-auto">
        <% logs.forEach(l => { %>
          <div class="flex justify-between p-3 bg-white/5 rounded-lg text-sm">
            <span class="text-white capitalize"><%= l.activity %> <%= l.mood ? '— ' + l.mood : '' %></span>
            <span class="text-gray-500"><%= new Date(l.created_at).toLocaleDateString() %></span>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
<script>
  // --- Audio Synth State variables ---
  let audioCtx = null;
  let solfeggioOsc = null;
  let binauralOsc = null;
  let gainNode = null;
  let analyserNode = null;
  let isAudioPlaying = false;
  let activeFreq = '396';
  let audioCanvas = null;
  let audioCtx2D = null;
  let audioAnimId = null;

  function initVisualizerCanvas() {
    audioCanvas = document.getElementById('audioVisualizerCanvas');
    if (!audioCanvas) return;
    audioCtx2D = audioCanvas.getContext('2d');
    if (!audioCtx2D) throw new Error("Could not acquire 2D visualizer context");
    
    // Scale for high-DPI displays
    const dpr = window.devicePixelRatio || 1;
    const parent = audioCanvas.parentElement;
    const w = parent.clientWidth || 300;
    const h = 220;
    
    audioCanvas.width = w * dpr;
    audioCanvas.height = h * dpr;
    audioCanvas.style.width = w + 'px';
    audioCanvas.style.height = h + 'px';
    
    audioCtx2D.scale(dpr, dpr);
  }

  function renderVisualizer() {
    if (!audioCtx2D || !audioCanvas) return;
    
    audioAnimId = requestAnimationFrame(renderVisualizer);
    
    const bufferLength = analyserNode ? analyserNode.frequencyBinCount : 64;
    const dataArray = new Uint8Array(bufferLength);
    
    if (analyserNode) {
      analyserNode.getByteFrequencyData(dataArray);
    } else {
      // Standby waves
      for (let i = 0; i < bufferLength; i++) {
        dataArray[i] = Math.abs(Math.sin(i * 0.15 + Date.now() * 0.003)) * 60;
      }
    }
    
    audioCtx2D.clearRect(0, 0, audioCanvas.width, audioCanvas.height);
    
    // Background tech grid
    audioCtx2D.strokeStyle = 'rgba(99, 102, 241, 0.03)';
    audioCtx2D.lineWidth = 1;
    for(let i=0; i<audioCanvas.width; i+=15) {
      audioCtx2D.beginPath(); audioCtx2D.moveTo(i, 0); audioCtx2D.lineTo(i, audioCanvas.height); audioCtx2D.stroke();
    }
    for(let j=0; j<audioCanvas.height; j+=15) {
      audioCtx2D.beginPath(); audioCtx2D.moveTo(0, j); audioCtx2D.lineTo(audioCanvas.width, j); audioCtx2D.stroke();
    }
    
    const centerX = audioCanvas.width / (2 * (window.devicePixelRatio || 1));
    const centerY = audioCanvas.height / (2 * (window.devicePixelRatio || 1)) - 10;
    
    // Draw concentric audio visualizer rings in the center
    for (let j = 0; j < 3; j++) {
      let baseRadius = 30 + j * 16;
      let sumFreq = 0;
      const count = Math.min(10, bufferLength);
      
      for (let i = 0; i < count; i++) {
        sumFreq += dataArray[(i + j * 4) % bufferLength];
      }
      let avgFreq = sumFreq / count;
      let ampRadius = baseRadius + (avgFreq / 255) * 20;
      
      audioCtx2D.strokeStyle = `rgba(99, 102, 241, ${0.1 + (avgFreq/255) * 0.4})`;
      audioCtx2D.lineWidth = 1.5 + j * 0.5;
      
      if (j === 1) {
        audioCtx2D.strokeStyle = `rgba(168, 85, 247, ${0.1 + (avgFreq/255) * 0.4})`;
        audioCtx2D.setLineDash([4, 6]);
      } else if (j === 2) {
        audioCtx2D.strokeStyle = `rgba(244, 63, 94, ${0.1 + (avgFreq/255) * 0.4})`;
      }
      
      audioCtx2D.beginPath();
      audioCtx2D.arc(centerX, centerY, ampRadius, 0, Math.PI * 2);
      audioCtx2D.stroke();
      audioCtx2D.setLineDash([]);
    }
    
    // Oscillating bars along the bottom
    const barWidth = (audioCanvas.width / (window.devicePixelRatio || 1) / bufferLength) * 1.5;
    let barHeight;
    let x = 0;
    
    for (let i = 0; i < bufferLength; i++) {
      barHeight = (dataArray[i] / 255) * 45;
      
      let r = 99 + (i * 2);
      let g = 102 + i;
      let b = 241 - (i * 2);
      audioCtx2D.fillStyle = `rgba(${r}, ${g}, ${b}, 0.55)`;
      
      audioCtx2D.fillRect(x, audioCanvas.height / (window.devicePixelRatio || 1) - barHeight, barWidth - 1.5, barHeight);
      x += barWidth;
    }
  }

  function startAudioSynth() {
    try {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      }
      
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
      
      solfeggioOsc = audioCtx.createOscillator();
      binauralOsc = audioCtx.createOscillator();
      gainNode = audioCtx.createGain();
      analyserNode = audioCtx.createAnalyser();
      
      analyserNode.fftSize = 64;
      
      const freqVal = parseInt(activeFreq, 10);
      solfeggioOsc.type = 'sine';
      solfeggioOsc.frequency.value = freqVal;
      
      binauralOsc.type = 'sine';
      binauralOsc.frequency.value = freqVal + 6; // Theta entrainment
      
      const merger = audioCtx.createChannelMerger(2);
      
      const leftPanner = audioCtx.createStereoPanner ? audioCtx.createStereoPanner() : null;
      const rightPanner = audioCtx.createStereoPanner ? audioCtx.createStereoPanner() : null;
      
      if (leftPanner && rightPanner) {
        leftPanner.pan.value = -0.8;
        rightPanner.pan.value = 0.8;
        solfeggioOsc.connect(leftPanner);
        binauralOsc.connect(rightPanner);
        leftPanner.connect(merger, 0, 0);
        rightPanner.connect(merger, 0, 1);
      } else {
        solfeggioOsc.connect(merger, 0, 0);
        binauralOsc.connect(merger, 0, 1);
      }
      
      const volSlider = document.getElementById('audioVolumeSlider');
      const volVal = volSlider ? parseInt(volSlider.value, 10) / 100 : 0.5;
      gainNode.gain.value = volVal;
      
      merger.connect(gainNode);
      gainNode.connect(analyserNode);
      analyserNode.connect(audioCtx.destination);
      
      solfeggioOsc.start();
      binauralOsc.start();
      
      isAudioPlaying = true;
      
      document.getElementById('audioStatusText').innerText = 'SYNTH: RESONATING';
      document.getElementById('audioStatusIndicator').className = 'w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse';
      document.getElementById('audioToggleText').innerText = 'Pause Resonator';
      document.getElementById('audioToggleIcon').className = 'fas fa-pause';
      
      window.hmsShowToast('Resonator Active', `Entrained to ${activeFreq}Hz Solfeggio frequency`, 'success');
      
    } catch (e) {
      console.error("Failed to start audio resonator:", e);
      window.hmsShowToast('Audio Error', 'Could not initialize AudioContext.', 'error');
    }
  }

  function stopAudioSynth() {
    if (solfeggioOsc) {
      try { solfeggioOsc.stop(); } catch(e) {}
      solfeggioOsc.disconnect();
      solfeggioOsc = null;
    }
    if (binauralOsc) {
      try { binauralOsc.stop(); } catch(e) {}
      binauralOsc.disconnect();
      binauralOsc = null;
    }
    if (gainNode) {
      gainNode.disconnect();
      gainNode = null;
    }
    if (analyserNode) {
      analyserNode.disconnect();
      analyserNode = null;
    }
    
    isAudioPlaying = false;
    
    document.getElementById('audioStatusText').innerText = 'SYNTH: STANDBY';
    document.getElementById('audioStatusIndicator').className = 'w-1.5 h-1.5 rounded-full bg-rose-500';
    document.getElementById('audioToggleText').innerText = 'Activate Resonator';
    document.getElementById('audioToggleIcon').className = 'fas fa-play';
  }

  function toggleAudioSynth() {
    if (isAudioPlaying) {
      stopAudioSynth();
    } else {
      startAudioSynth();
    }
  }

  function adjustVolume(val) {
    document.getElementById('lblAudioVolume').innerText = val + '%';
    if (gainNode) {
      gainNode.gain.value = parseInt(val, 10) / 100;
    }
  }

  function selectFrequency(freq) {
    activeFreq = freq;
    
    const freqs = ['396', '432', '528', '639'];
    freqs.forEach(f => {
      const btn = document.getElementById(`btnFreq${f}`);
      if (btn) {
        if (f === freq) {
          btn.className = 'px-3 py-2 bg-indigo-600 text-white border border-indigo-400/30 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:scale-105 cursor-pointer shadow-lg shadow-indigo-600/20';
        } else {
          btn.className = 'px-3 py-2 bg-white/5 text-gray-400 border border-white/10 rounded-xl text-[10px] font-black transition-all flex items-center justify-center gap-1 hover:bg-white/10 hover:text-white hover:scale-105 cursor-pointer';
        }
      }
    });

    const lblFreq = document.getElementById('lblAudioFreq');
    const lblBrainwave = document.getElementById('lblAudioBrainwave');
    const lblTarget = document.getElementById('lblAudioTarget');
    const txtAlignment = document.getElementById('txtAudioAlignment');
    const txtResult = document.getElementById('txtAudioAuditResult');

    if (freq === '396') {
      lblFreq.innerText = '396 Hz';
      lblBrainwave.innerText = 'Theta Hum (6 Hz)';
      lblTarget.innerText = 'CREB / Cortisol Release';
      txtAlignment.innerText = 'THETA STRESS CLEARANCE ACTIVE';
      txtResult.innerHTML = '396Hz tone generated. Combined with Theta frequency binaural beat to downregulate sympathetic fight-or-flight signaling, reducing systemic cortisol indices.';
    } else if (freq === '432') {
      lblFreq.innerText = '432 Hz';
      lblBrainwave.innerText = 'Alpha Wave (10 Hz)';
      lblTarget.innerText = 'BDNF / Synaptic Focus';
      txtAlignment.innerText = 'ALPHA BRAINWAVE SYNC INDUCED';
      txtResult.innerHTML = '432Hz organic frequency tone generated. Resonates at natural cosmic harmonic cycles, increasing neural BDNF receptor sensitivity to build calm mental focus.';
    } else if (freq === '528') {
      lblFreq.innerText = '528 Hz';
      lblBrainwave.innerText = 'Delta Deep Sleep (2 Hz)';
      lblTarget.innerText = 'SIRT1 / DNA Integrity';
      txtAlignment.innerText = 'MITOCHONDRIAL DNA REPAIR WAVE';
      txtResult.innerHTML = '528Hz transformation tone generated. Encourages cellular repair cycles, increasing FOXO3/SIRT1 gene transcription velocity to trigger structural autophagy.';
    } else if (freq === '639') {
      lblFreq.innerText = '639 Hz';
      lblBrainwave.innerText = 'Theta Empathy (4.5 Hz)';
      lblTarget.innerText = 'Oxytocin / Core Comfort';
      txtAlignment.innerText = 'ENDOGENOUS OXYTOCIN TRANSITION';
      txtResult.innerHTML = '639Hz integration tone generated. Activates empathy networks and downregulates amygdala hyperactivity, encouraging deep emotional grounding and comfort.';
    }

    if (isAudioPlaying && solfeggioOsc && binauralOsc) {
      const fVal = parseInt(freq, 10);
      solfeggioOsc.frequency.value = fVal;
      binauralOsc.frequency.value = fVal + 6;
    }
  }

  // --- Core EJS Wellbeing features ---
  async function logWellbeing(payload) {
    const res = await fetch('/patient/wellbeing/log', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    return res.json();
  }

  document.addEventListener('DOMContentLoaded', () => {
    initVisualizerCanvas();
    renderVisualizer();
    
    window.addEventListener('resize', initVisualizerCanvas);
  });
document.querySelectorAll('.mood-btn').forEach(btn => {
  btn.addEventListener('click', async function() {
    const data = await logWellbeing({ mood: this.dataset.mood, activity: 'mood' });
    if (data.success) {
      document.getElementById('moodSaved').classList.remove('hidden');
      window.hmsShowToast('Mood', 'Logged: ' + this.dataset.mood, 'success');
      setTimeout(() => { location.reload(); }, 1200);
    }
  });
});
document.getElementById('stressSlider').addEventListener('input', function() {
  document.getElementById('stressVal').textContent = this.value;
});
document.getElementById('saveStress').addEventListener('click', async function() {
  const v = document.getElementById('stressSlider').value;
  await logWellbeing({ activity: 'tip', stress_level: parseInt(v, 10), notes: 'Stress check-in' });
  window.hmsShowToast('Saved', 'Stress level recorded', 'success');
  setTimeout(() => { location.reload(); }, 1200);
});
document.querySelectorAll('.wellbeing-action').forEach(btn => {
  btn.addEventListener('click', async function() {
    const act = this.dataset.activity;
    if (act === 'journal') {
      const notes = prompt('Journal entry:');
      if (notes) {
        await logWellbeing({ activity: 'journal', notes });
        window.hmsShowToast('Journal', 'Entry saved successfully', 'success');
        setTimeout(() => { location.reload(); }, 1200);
      }
    } else {
      await logWellbeing({ activity: 'meditation', duration_mins: 5 });
      window.hmsShowToast('Meditation', '5-minute session logged', 'success');
      setTimeout(() => { location.reload(); }, 1200);
    }
  });
});
let breathTimer;
document.getElementById('startBreathing').addEventListener('click', function() {
  const circle = document.getElementById('breathCircle');
  let step = 0;
  const phases = ['Inhale 4s', 'Hold 7s', 'Exhale 8s'];
  const durations = [4000, 7000, 8000];
  function next() {
    circle.textContent = phases[step % 3];
    circle.classList.toggle('scale-125', step % 3 === 0);
    setTimeout(() => { 
      step++; 
      if (step < 9) {
        next(); 
      } else { 
        circle.textContent = 'Done'; 
        logWellbeing({ activity: 'breathing', duration_mins: 2 }); 
        window.hmsShowToast('Breathing', 'Exercise logged successfully', 'success');
        setTimeout(() => { location.reload(); }, 1500);
      }
    }, durations[step % 3]);
  }
  next();
});
</script>

<% var title = 'Notifications - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'notifications' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex justify-between items-end mb-10 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">Center of Activity</h1>
        <p class="text-gray-400 font-medium">Keep track of your health journey updates</p>
      </div>
      <button class="text-sm font-bold text-indigo-400 hover:text-indigo-300 transition" onclick="markAllRead()">Mark all as read</button>
    </div>

    <!-- Notifications List -->
    <div class="space-y-4">
      <% if (notifications.length === 0) { %>
        <div class="hms-card p-20 text-center">
          <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-400">
            <i class="fas fa-bell-slash text-3xl"></i>
          </div>
          <h3 class="text-2xl font-black text-white mb-2">Silence is Golden</h3>
          <p class="text-gray-400 font-medium">You don't have any notifications at the moment</p>
        </div>
      <% } else { %>
        <% notifications.forEach(notif => { %>
          <div class="hms-card <%= notif.is_read || notif.read ? 'opacity-60' : '' %> animate-scale-in" data-id="<%= notif.id %>">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 <%= notif.type === 'appointment' ? 'bg-indigo-500/20 text-indigo-400' : notif.type === 'prescription' ? 'bg-emerald-500/20 text-emerald-400' : 'bg-amber-500/20 text-amber-400' %> rounded-xl flex items-center justify-center flex-shrink-0">
                <i class="fas <%= notif.type === 'appointment' ? 'fa-calendar-check' : notif.type === 'prescription' ? 'fa-file-prescription' : 'fa-bell' %> text-xl"></i>
              </div>
              <div class="flex-grow">
                <h4 class="text-lg font-bold text-white mb-1"><%= notif.title %></h4>
                <p class="text-gray-400 text-sm mb-2"><%= notif.message %></p>
                <p class="text-xs text-gray-500"><%= new Date(notif.created_at).toLocaleString() %></p>
              </div>
              <% if (!notif.is_read && !notif.read) { %>
                <div class="w-3 h-3 bg-indigo-500 rounded-full flex-shrink-0"></div>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<% var title = 'Ambulance Tracking - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="container-fluid min-h-screen bg-gray-100">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'ambulance' }) %>

    <div class="col-md-9 col-lg-10 p-6">
      <div class="max-w-4xl mx-auto">
        <!-- Status Header -->
        <div class="bg-white rounded-3xl shadow-sm p-8 mb-6 border border-gray-100">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight">Ambulance Service</h2>
                    <p class="text-gray-500 mt-1" id="statusDescription">Need medical transport? Request now.</p>
                </div>
                <div class="w-16 h-16 bg-red-100 rounded-2xl flex items-center justify-center text-red-600">
                    <i class="fas fa-ambulance text-2xl"></i>
                </div>
            </div>

            <!-- Request Section -->
            <div id="requestForm" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Emergency Type</label>
                        <select id="emergencyType" class="w-full bg-gray-50 border-gray-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-red-500 outline-none transition">
                            <option>General Emergency</option>
                            <option>Cardiac Arrest</option>
                            <option>Accident / Trauma</option>
                            <option>Pregnancy</option>
                            <option>Respiratory Distress</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Pickup Address</label>
                        <input type="text" id="pickupAddress" placeholder="Enter your full address" class="w-full bg-gray-50 border-gray-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-red-500 outline-none transition">
                    </div>
                </div>
                <button onclick="requestAmbulance()" class="w-full bg-red-600 text-white py-4 rounded-2xl font-bold text-lg hover:bg-red-700 shadow-xl shadow-red-100 transition transform active:scale-95">
                    <i class="fas fa-paper-plane mr-2"></i> Request Ambulance Now
                </button>
            </div>

            <!-- Active Trip Details (Hidden initially) -->
            <div id="activeTrip" class="hidden">
                <div class="flex items-center p-6 bg-indigo-50 rounded-3xl mb-6">
                    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-indigo-600 shadow-sm mr-4">
                        <i class="fas fa-user-ninja"></i>
                    </div>
                    <div class="flex-grow">
                        <p class="text-xs text-indigo-600 font-bold uppercase tracking-widest mb-1">Assigned Driver</p>
                        <h4 class="text-lg font-bold text-gray-900" id="driverName">--</h4>
                    </div>
                    <div class="text-right">
                        <p class="text-xs text-gray-500 font-medium mb-1">Vehicle No.</p>
                        <span class="bg-indigo-600 text-white px-3 py-1 rounded-lg text-sm font-bold" id="vehicleNo">--</span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <a id="driverCall" href="#" class="flex items-center justify-center bg-gray-900 text-white py-4 rounded-2xl font-bold hover:bg-gray-800 transition">
                        <i class="fas fa-phone-alt mr-2"></i> Call Driver
                    </a>
                    <div class="bg-white border-2 border-indigo-100 flex items-center justify-center py-4 rounded-2xl">
                        <span class="text-gray-500 text-sm font-medium mr-2">ETA:</span>
                        <span class="text-indigo-600 font-bold" id="etaText">8-10 Mins</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Map Tracking -->
        <div class="bg-white rounded-3xl shadow-sm p-4 h-[500px] border border-gray-100 overflow-hidden relative">
            <div id="map" class="h-full w-full rounded-2xl"></div>
            <div id="findingOverlay" class="hidden absolute inset-0 bg-white/80 backdrop-blur-sm z-50 flex flex-col items-center justify-center p-8 text-center">
                <div class="relative w-24 h-24 mb-6">
                    <div class="absolute inset-0 border-4 border-red-100 rounded-full"></div>
                    <div class="absolute inset-0 border-4 border-red-600 rounded-full border-t-transparent animate-spin"></div>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Searching for Ambulances</h3>
                <p class="text-gray-500 max-w-xs">Connecting you to the nearest available driver. Please stay on this page...</p>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<%- include('../partials/footer') %>
<script>
(function () {
  var HMS_PATIENT_ID = '<%= user.id %>';
  var map, patientMarker, driverMarker;
  var patientCoords = [28.6139, 77.2090];

  function initMap() {
    map = L.map('map').setView(patientCoords, 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);
    patientMarker = L.marker(patientCoords).addTo(map).bindPopup('Your Pickup Location').openPopup();
  }

  initMap();

  if ("geolocation" in navigator) {
    navigator.geolocation.getCurrentPosition(function (pos) {
      patientCoords = [pos.coords.latitude, pos.coords.longitude];
      if (patientMarker && map) {
        patientMarker.setLatLng(patientCoords);
        map.setView(patientCoords, 15);
      }
    });
  }

  window.requestAmbulance = function () {
    var address = document.getElementById('pickupAddress').value;
    var type = document.getElementById('emergencyType').value;
    if (!address) { alert("Please enter pickup address"); return; }

    document.getElementById('findingOverlay').classList.remove('hidden');
    document.getElementById('statusDescription').innerText = "Locating nearby emergency services...";

    fetch('/patient/ambulance/request', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        pickup_address: address,
        emergency_type: type,
        pickup_lat: patientCoords[0],
        pickup_lng: patientCoords[1]
      })
    }).then(function (res) { return res.json(); }).then(function (data) {
      if (!data.success) {
        alert(data.error || 'Request failed');
        document.getElementById('findingOverlay').classList.add('hidden');
        return;
      }
      if (window.hmsSocket && data.requestId) {
        window.hmsSocket().emit('join-trip', data.requestId);
      }
      fetch('/api/emergency-priority', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ emergency_type: type })
      }).then(function (r) { return r.json(); }).then(function (prio) {
        if (prio.success) {
          document.getElementById('statusDescription').innerText =
            'Priority band: ' + prio.band + ' (score ' + prio.score + '). Waiting for driver…';
        }
      }).catch(function () {});
    });
  };

  function bindSocket() {
    if (!window.hmsSocket || window.__hmsAmbulanceListeners) return;
    window.__hmsAmbulanceListeners = true;
    var sock = window.hmsSocket();
    sock.on('ambulance-request-accepted', function (data) {
      if (!data || String(data.patient_id) !== String(HMS_PATIENT_ID)) return;
      document.getElementById('findingOverlay').classList.add('hidden');
      document.getElementById('requestForm').classList.add('hidden');
      document.getElementById('activeTrip').classList.remove('hidden');
      document.getElementById('statusDescription').innerText = "Ambulance is on the way!";
      document.getElementById('driverName').innerText = data.driver_name || '—';
      document.getElementById('vehicleNo').innerText = data.vehicle_no || '—';
      var tel = document.getElementById('driverCall');
      if (tel) tel.href = 'tel:' + (data.driver_phone || '');
      var lat = data.current_lat != null ? Number(data.current_lat) : 28.6;
      var lng = data.current_lng != null ? Number(data.current_lng) : 77.2;
      if (map) {
        if (driverMarker) map.removeLayer(driverMarker);
        driverMarker = L.marker([lat, lng]).addTo(map);
        try {
          map.fitBounds(L.featureGroup([patientMarker, driverMarker]).getBounds().pad(0.2));
        } catch (e) {}
      }
      if (window.hmsShowToast) window.hmsShowToast('Ambulance', 'Driver accepted your request.', 'success');
    });

    sock.on('ambulance-location-sync', function (data) {
      if (!driverMarker || !map || !patientMarker) return;
      driverMarker.setLatLng([data.lat, data.lng]);
      try {
        map.fitBounds(L.featureGroup([patientMarker, driverMarker]).getBounds().pad(0.2));
      } catch (e) {}
    });

    sock.on('ambulance-trip-completed', function () {
      if (window.hmsShowToast) window.hmsShowToast('Trip complete', 'Thank you — take care.', 'info');
      setTimeout(function () { window.location.reload(); }, 2500);
    });
  }

  document.addEventListener('DOMContentLoaded', bindSocket);
})();
</script>


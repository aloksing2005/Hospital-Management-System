<% var title = 'Ambulance Tracking - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
  /* Cyberspace Map filters for tactical matrix HUD layout */
  #map .leaflet-tile {
    filter: invert(100%) hue-rotate(180deg) brightness(85%) contrast(95%) !important;
  }
  .leaflet-container {
    background: #090d16 !important;
  }
  .leaflet-bar a {
    background-color: #0f172a !important;
    color: #f43f5e !important;
    border-color: rgba(255, 255, 255, 0.1) !important;
  }
  
  /* Urgency CTA Glow */
  .urgency-pulse-btn {
    position: relative;
    background: linear-gradient(135deg, #e11d48 0%, #be123c 100%) !important;
    box-shadow: 0 0 20px rgba(225, 29, 72, 0.3) !important;
    animation: hms-urgent-pulse 2s infinite !important;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }
  .urgency-pulse-btn:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 0 35px rgba(225, 29, 72, 0.6) !important;
  }
  @keyframes hms-urgent-pulse {
    0% { box-shadow: 0 0 15px rgba(225, 29, 72, 0.3); }
    50% { box-shadow: 0 0 35px rgba(225, 29, 72, 0.6); }
    100% { box-shadow: 0 0 15px rgba(225, 29, 72, 0.3); }
  }

  /* Pulse animation on marker icons */
  @keyframes marker-pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.1); opacity: 0.85; }
    100% { transform: scale(1); opacity: 1; }
  }
  .leaflet-marker-icon {
    animation: marker-pulse 2s infinite ease-in-out !important;
  }
</style>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'ambulance' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="mb-8 animate-fade-in">
      <h1 class="text-3xl font-black text-white mb-2">Ambulance Service</h1>
      <p class="text-gray-400 font-medium">Need medical transport? Request now</p>
    </div>

    <!-- Status Card -->
    <div class="hms-card mb-8 animate-scale-in">
      <div class="flex justify-between items-center mb-6">
        <div>
          <h2 class="text-3xl font-black text-white tracking-tight">Ambulance Service</h2>
          <p class="text-gray-400 mt-1" id="statusDescription">Need medical transport? Request now</p>
        </div>
        <div class="w-16 h-16 bg-rose-500/20 text-rose-400 rounded-2xl flex items-center justify-center">
          <i class="fas fa-ambulance text-2xl"></i>
        </div>
      </div>

      <!-- Request Section -->
      <div id="requestForm" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
          <div class="relative">
            <label class="block text-sm font-bold text-gray-300 mb-2">Emergency Type</label>
            <!-- Hidden Input to preserve 100% backend form state compatibility -->
            <input type="hidden" id="emergencyType" value="General Emergency">
            
            <!-- Custom Trigger Button -->
            <button type="button" id="emergencyDropdownBtn" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3.5 text-left text-white flex items-center justify-between focus:border-rose-500 focus:ring-1 focus:ring-rose-500/50 outline-none transition cursor-pointer hover:bg-white/10">
              <span id="emergencyDropdownValue" class="font-bold text-sm">General Emergency</span>
              <i class="fas fa-chevron-down text-gray-400 text-xs transition-transform duration-300" id="emergencyDropdownIcon"></i>
            </button>
            
            <!-- Custom Dropdown Menu -->
            <div id="emergencyDropdownMenu" class="hidden absolute top-full left-0 right-0 mt-2 bg-slate-950/95 border border-white/15 rounded-xl shadow-2xl z-50 overflow-hidden backdrop-blur-xl animate-fade-in max-h-60 overflow-y-auto">
              <div onclick="selectEmergencyOption('General Emergency')" class="px-4 py-3.5 text-xs font-black uppercase tracking-wider text-gray-300 hover:bg-rose-500/10 hover:text-rose-400 cursor-pointer flex items-center gap-2.5 border-b border-white/5 transition-colors">
                <i class="fas fa-kit-medical text-rose-500 text-sm"></i> General Emergency
              </div>
              <div onclick="selectEmergencyOption('Cardiac Arrest')" class="px-4 py-3.5 text-xs font-black uppercase tracking-wider text-gray-300 hover:bg-rose-500/10 hover:text-rose-400 cursor-pointer flex items-center gap-2.5 border-b border-white/5 transition-colors">
                <i class="fas fa-heart-circle-exclamation text-rose-500 text-sm animate-pulse"></i> Cardiac Arrest
              </div>
              <div onclick="selectEmergencyOption('Accident / Trauma')" class="px-4 py-3.5 text-xs font-black uppercase tracking-wider text-gray-300 hover:bg-rose-500/10 hover:text-rose-400 cursor-pointer flex items-center gap-2.5 border-b border-white/5 transition-colors">
                <i class="fas fa-car-burst text-rose-500 text-sm"></i> Accident / Trauma
              </div>
              <div onclick="selectEmergencyOption('Pregnancy')" class="px-4 py-3.5 text-xs font-black uppercase tracking-wider text-gray-300 hover:bg-rose-500/10 hover:text-rose-400 cursor-pointer flex items-center gap-2.5 border-b border-white/5 transition-colors">
                <i class="fas fa-baby text-rose-500 text-sm"></i> Pregnancy
              </div>
              <div onclick="selectEmergencyOption('Respiratory Distress')" class="px-4 py-3.5 text-xs font-black uppercase tracking-wider text-gray-300 hover:bg-rose-500/10 hover:text-rose-400 cursor-pointer flex items-center gap-2.5 transition-colors">
                <i class="fas fa-lungs-virus text-rose-500 text-sm"></i> Respiratory Distress
              </div>
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-bold text-gray-300 mb-2">Pickup Address</label>
            <input type="text" id="pickupAddress" placeholder="Enter your full address" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3.5 focus:border-rose-500 outline-none transition text-white placeholder-gray-500 text-sm font-semibold">
          </div>
        </div>
        <button onclick="requestAmbulance()" class="w-full urgency-pulse-btn py-4 text-md font-black tracking-widest text-white uppercase rounded-xl flex items-center justify-center gap-2 cursor-pointer">
          <i class="fas fa-truck-lightning animate-bounce mr-2 text-lg"></i> Request Emergency Ambulance
        </button>
      </div>

      <!-- Active Trip Details (Hidden initially) -->
      <div id="activeTrip" class="hidden">
        <div class="flex items-center p-6 bg-indigo-500/10 rounded-2xl mb-6">
          <div class="w-12 h-12 bg-indigo-500/20 rounded-full flex items-center justify-center text-indigo-400 mr-4">
            <i class="fas fa-user-ninja"></i>
          </div>
          <div class="flex-grow">
            <p class="text-xs text-indigo-400 font-bold uppercase tracking-widest mb-1">Assigned Driver</p>
            <h4 class="text-lg font-bold text-white" id="driverName">--</h4>
          </div>
          <div class="text-right">
            <p class="text-xs text-gray-400 font-medium mb-1">Vehicle No.</p>
            <span class="bg-indigo-600 text-white px-3 py-1 rounded-lg text-sm font-bold" id="vehicleNo">--</span>
          </div>
        </div>

        <!-- Status Badge -->
        <div class="mb-6">
          <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-white/10">
            <div class="flex items-center">
              <div id="statusIndicator" class="w-3 h-3 rounded-full bg-yellow-400 mr-3 animate-pulse"></div>
              <span class="text-sm font-medium text-gray-300">Status:</span>
            </div>
            <span id="tripStatus" class="text-lg font-bold text-indigo-400">Accepted</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <a id="driverCall" href="#" class="flex items-center justify-center bg-slate-800 text-white py-4 rounded-xl font-bold hover:bg-slate-700 transition">
            <i class="fas fa-phone-alt mr-2"></i> Call Driver
          </a>
          <div class="bg-white/5 border border-indigo-500/30 flex items-center justify-center py-4 rounded-xl">
            <span class="text-gray-400 text-sm font-medium mr-2">ETA:</span>
            <span class="text-indigo-400 font-bold" id="etaText">8-10 Mins</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Map Tracking -->
    <div class="hms-card p-4 h-[500px] overflow-hidden relative border border-white/10 shadow-[0_0_50px_rgba(244,63,94,0.02)]">
      <!-- Tactical overlay on map -->
      <div class="absolute top-6 right-6 z-[1000] bg-slate-950/90 backdrop-blur-md border border-rose-500/30 px-3.5 py-2 rounded-xl text-[10px] font-mono text-rose-400 flex items-center gap-2 pointer-events-none shadow-lg shadow-black/80">
        <span class="w-1.5 h-1.5 rounded-full bg-rose-500 animate-ping"></span>
        <span>HUD: MAP RADAR LINK ACTIVE</span>
      </div>
      
      <!-- Glowing bracket corners -->
      <div class="absolute top-6 left-6 w-4 h-4 border-t-2 border-l-2 border-rose-500/30 pointer-events-none z-[1000]"></div>
      <div class="absolute bottom-6 left-6 w-4 h-4 border-b-2 border-l-2 border-rose-500/30 pointer-events-none z-[1000]"></div>
      <div class="absolute bottom-6 right-6 w-4 h-4 border-b-2 border-r-2 border-rose-500/30 pointer-events-none z-[1000]"></div>

      <div id="map" class="h-full w-full rounded-xl"></div>
      
      <div id="findingOverlay" class="hidden absolute inset-0 bg-slate-900/80 backdrop-blur-sm z-[2000] flex flex-col items-center justify-center p-8 text-center">
        <div class="relative w-24 h-24 mb-6">
          <div class="absolute inset-0 border-4 border-rose-500/20 rounded-full animate-ping"></div>
          <div class="absolute inset-0 border-4 border-rose-500 rounded-full border-t-transparent animate-spin"></div>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">Searching for Ambulances</h3>
        <p class="text-gray-400 max-w-xs text-sm">Connecting you to the nearest available driver. Please stay on this page...</p>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<%- include('../partials/footer') %>
<script>
(function () {
  // Custom Select Dropdown Toggle
  document.addEventListener('DOMContentLoaded', () => {
    const dropdownBtn = document.getElementById('emergencyDropdownBtn');
    const dropdownMenu = document.getElementById('emergencyDropdownMenu');
    const dropdownIcon = document.getElementById('emergencyDropdownIcon');
    
    if (dropdownBtn && dropdownMenu) {
      dropdownBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdownMenu.classList.toggle('hidden');
        if (dropdownIcon) dropdownIcon.classList.toggle('rotate-180');
      });
      
      document.addEventListener('click', () => {
        dropdownMenu.classList.add('hidden');
        if (dropdownIcon) dropdownIcon.classList.remove('rotate-180');
      });
    }
  });

  window.selectEmergencyOption = function(val) {
    const hiddenInput = document.getElementById('emergencyType');
    const displayVal = document.getElementById('emergencyDropdownValue');
    
    if (hiddenInput && displayVal) {
      hiddenInput.value = val;
      displayVal.textContent = val;
    }
    
    // Close menu
    const dropdownMenu = document.getElementById('emergencyDropdownMenu');
    const dropdownIcon = document.getElementById('emergencyDropdownIcon');
    if (dropdownMenu) dropdownMenu.classList.add('hidden');
    if (dropdownIcon) dropdownIcon.classList.remove('rotate-180');
  };

  function bindSocket() {
    var sock = window.hmsSocket();
    if (!sock) return;
    HMS_PATIENT_ID = '<%= user.id %>';
    sock.emit('join', { userId: '<%= user.id %>', role: 'patient' });
    
    var patientCoords = [28.6139, 77.2090];

    function initMap() {
      map = L.map('map').setView(patientCoords, 13);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);
      patientMarker = L.marker(patientCoords).addTo(map).bindPopup('Your Pickup Location').openPopup();
    }

    initMap();

    if ("geolocation" in navigator) {
      navigator.geolocation.getCurrentPosition(function (pos) {
        patientCoords = [pos.coords.latitude, pos.coords.longitude];
        if (patientMarker && map) {
          patientMarker.setLatLng(patientCoords);
          map.setView(patientCoords, 15);
        }
      });
    }

    window.requestAmbulance = async function () {
    var address = document.getElementById('pickupAddress').value;
    var type = document.getElementById('emergencyType').value;
    if (!address) { alert("Please enter pickup address"); return; }

    document.getElementById('findingOverlay').classList.remove('hidden');
    document.getElementById('statusDescription').innerText = "Locating nearby emergency services...";

    try {
      const res = await fetch('/patient/ambulance/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          pickup_address: address,
          emergency_type: type,
          pickup_lat: patientCoords[0],
          pickup_lng: patientCoords[1]
        })
      });
      const data = await res.json();
      if (!data.success) {
        alert(data.error || 'Request failed');
        document.getElementById('findingOverlay').classList.add('hidden');
        return;
      }
      if (window.hmsSocket && data.requestId) {
        window.hmsSocket().emit('join-trip', data.requestId);
      }
      const prioRes = await fetch('/api/emergency-priority', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ emergency_type: type })
      });
      const prio = await prioRes.json();
      if (prio.success) {
        document.getElementById('statusDescription').innerText =
          'Priority band: ' + prio.band + ' (score ' + prio.score + '). Waiting for driver…';
      }
    } catch (err) {
      console.error('Error requesting ambulance:', err);
      alert('Failed to request ambulance. Please try again.');
      document.getElementById('findingOverlay').classList.add('hidden');
    }
  };

  // Socket event listeners
  if (!window.__hmsAmbulanceListeners) {
    window.__hmsAmbulanceListeners = true;
    sock.on('ambulance-request-accepted', function (data) {
      if (!data || String(data.patient_id) !== String(HMS_PATIENT_ID)) return;
      document.getElementById('findingOverlay').classList.add('hidden');
      document.getElementById('requestForm').classList.add('hidden');
      document.getElementById('activeTrip').classList.remove('hidden');
      document.getElementById('statusDescription').innerText = "Ambulance is on the way!";
      document.getElementById('driverName').innerText = data.driver_name || '—';
      document.getElementById('vehicleNo').innerText = data.vehicle_no || '—';
      var tel = document.getElementById('driverCall');
      if (tel) tel.href = 'tel:' + (data.driver_phone || '');
      var lat = data.current_lat != null ? Number(data.current_lat) : 28.6;
      var lng = data.current_lng != null ? Number(data.current_lng) : 77.2;
      if (map) {
        if (driverMarker) map.removeLayer(driverMarker);
        driverMarker = L.marker([lat, lng]).addTo(map);
        try {
          map.fitBounds(L.featureGroup([patientMarker, driverMarker]).getBounds().pad(0.2));
        } catch (e) {}
      }
      if (window.hmsShowToast) window.hmsShowToast('Ambulance', 'Driver accepted your request.', 'success');
    });

    sock.on('ambulance-status-update', function (data) {
      if (!data || String(data.request.patient_id) !== String(HMS_PATIENT_ID)) return;
      
      const statusText = data.status === 'on_the_way' ? 'On The Way' : data.status === 'arrived' ? 'Arrived at Location' : data.status;
      document.getElementById('tripStatus').innerText = statusText;
      
      if (data.eta) {
        document.getElementById('etaText').innerText = data.eta;
      }
      
      // Update status indicator color
      const indicator = document.getElementById('statusIndicator');
      if (data.status === 'on_the_way') {
        indicator.className = 'w-3 h-3 rounded-full bg-blue-400 mr-3 animate-pulse';
      } else if (data.status === 'arrived') {
        indicator.className = 'w-3 h-3 rounded-full bg-green-400 mr-3 animate-pulse';
      }
      
      if (window.hmsShowToast) window.hmsShowToast('Status Update', `Ambulance is ${statusText}`, 'info');
    });

    sock.on('ambulance-location-sync', function (data) {
      if (!driverMarker || !map || !patientMarker) return;
      driverMarker.setLatLng([data.lat, data.lng]);
      try {
        map.fitBounds(L.featureGroup([patientMarker, driverMarker]).getBounds().pad(0.2));
      } catch (e) {}
    });

    sock.on('ambulance-trip-completed', function () {
      if (window.hmsShowToast) window.hmsShowToast('Trip complete', 'Thank you — take care.', 'info');
      setTimeout(function () { window.location.reload(); }, 2500);
    });
  }
}

document.addEventListener('DOMContentLoaded', bindSocket);
})();
</script>


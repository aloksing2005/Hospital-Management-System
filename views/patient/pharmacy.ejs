<% var title = 'Pharmacy - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <%- include('../partials/patient-sidebar', { active: 'pharmacy' }) %>
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-6 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">Digital Pharmacy</h1>
        <p class="text-gray-400 font-medium">Order medicines with cart & tracking</p>
      </div>
      <div class="flex gap-3 items-center">
        <button type="button" id="viewCartBtn" class="hms-btn hms-btn-secondary relative">
          <i class="fas fa-shopping-cart mr-2"></i>Cart (<span id="cartCount">0</span>)
        </button>
        <form action="/patient/pharmacy" method="GET" class="relative">
          <input type="text" name="search" value="<%= query %>" placeholder="Search medicine..." class="w-full md:w-64 bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:border-indigo-500 outline-none text-white placeholder-gray-400">
        </form>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if (medicines.length === 0) { %>
        <div class="col-span-full py-20 text-center">
          <h4 class="text-xl font-bold text-white">No medicines found</h4>
        </div>
      <% } else { %>
        <% medicines.forEach(med => { %>
          <div class="hms-card animate-scale-in">
            <div class="flex justify-between items-start mb-4">
              <div class="w-12 h-12 bg-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center">
                <i class="fas fa-capsules text-xl"></i>
              </div>
              <span class="hms-badge hms-badge-<%= med.stock > 0 ? 'success' : 'danger' %>">
                <%= med.stock > 0 ? 'In Stock' : 'Out of Stock' %>
              </span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2"><%= med.name %></h3>
            <p class="text-gray-400 text-sm mb-4"><%= med.description %></p>
            <div class="flex justify-between items-center pt-4 border-t border-white/10 mb-3">
              <span class="text-indigo-400 font-bold">₹<%= med.price %></span>
              <span class="text-gray-400 text-sm">Stock: <%= med.stock %></span>
            </div>
            <% if (med.stock > 0) { %>
              <button type="button" class="hms-btn hms-btn-primary w-full add-cart-btn"
                data-id="<%= med.id %>" data-name="<%= med.name %>" data-price="<%= med.price %>">
                Add to Cart
              </button>
            <% } %>
          </div>
        <% }) %>
      <% } %>
    </div>

    <div id="ordersSection" class="hms-card mt-8 hidden">
      <h3 class="text-xl font-bold text-white mb-4">Your Orders</h3>
      <div id="ordersList"></div>
    </div>
  </div>
</div>

<div id="cartModal" class="hidden fixed inset-0 z-[9998] flex items-center justify-center bg-black/60 p-4">
  <div class="bg-slate-900 border border-white/10 rounded-2xl p-6 max-w-lg w-full max-h-[80vh] overflow-y-auto">
    <h3 class="text-xl font-bold text-white mb-4">Cart</h3>
    <div id="cartItems" class="space-y-3 mb-4"></div>
    <p class="text-white font-bold mb-4">Total: ₹<span id="cartTotal">0</span></p>
    <label class="flex items-center gap-2 text-gray-300 text-sm mb-4">
      <input type="checkbox" id="rxRequired"> Prescription required
    </label>
    <div class="flex gap-3">
      <button type="button" id="checkoutBtn" class="hms-btn hms-btn-primary flex-1">Place Order</button>
      <button type="button" onclick="document.getElementById('cartModal').classList.add('hidden')" class="hms-btn hms-btn-secondary">Close</button>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<script>
let cart = JSON.parse(localStorage.getItem('hmsPharmacyCart') || '[]');
function saveCart() { localStorage.setItem('hmsPharmacyCart', JSON.stringify(cart)); updateCartUI(); }
function updateCartUI() {
  document.getElementById('cartCount').textContent = cart.reduce((s,i) => s + i.quantity, 0);
}
document.querySelectorAll('.add-cart-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    const id = this.dataset.id;
    const existing = cart.find(c => c.medicine_id === id);
    if (existing) existing.quantity++;
    else cart.push({ medicine_id: id, medicine_name: this.dataset.name, price: parseFloat(this.dataset.price), quantity: 1 });
    saveCart();
    window.hmsShowToast('Cart', this.dataset.name + ' added', 'success');
  });
});
document.getElementById('viewCartBtn').addEventListener('click', function() {
  const modal = document.getElementById('cartModal');
  const list = document.getElementById('cartItems');
  list.innerHTML = '';
  let total = 0;
  cart.forEach((item, idx) => {
    const line = item.price * item.quantity;
    total += line;
    list.innerHTML += '<div class="flex justify-between text-white text-sm"><span>' + item.medicine_name + ' x' + item.quantity + '</span><span>₹' + line.toFixed(2) + '</span></div>';
  });
  document.getElementById('cartTotal').textContent = total.toFixed(2);
  modal.classList.remove('hidden');
});
document.getElementById('checkoutBtn').addEventListener('click', async function() {
  if (!cart.length) return;
  const res = await fetch('/patient/pharmacy/order', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: cart, prescription_required: document.getElementById('rxRequired').checked })
  });
  const data = await res.json();
  if (data.success) {
    cart = [];
    saveCart();
    document.getElementById('cartModal').classList.add('hidden');
    window.hmsShowToast('Order Placed', 'Tracking: ' + data.trackingId, 'success');
    loadOrders();
  } else {
    window.hmsShowToast('Error', data.error, 'error');
  }
});
async function loadOrders() {
  const res = await fetch('/patient/pharmacy/orders');
  const data = await res.json();
  if (!data.success || !data.orders.length) return;
  document.getElementById('ordersSection').classList.remove('hidden');
  document.getElementById('ordersList').innerHTML = data.orders.map(o =>
    '<div class="p-3 bg-white/5 rounded-lg mb-2 text-sm"><span class="text-white font-bold">' + o.tracking_id + '</span> — ₹' + o.total_amount + ' <span class="hms-badge hms-badge-info ml-2">' + o.status + '</span></div>'
  ).join('');
}
updateCartUI();
loadOrders();
</script>

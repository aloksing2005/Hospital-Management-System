<% var title = 'Pharmacy - HMS'; %>
<%- include('../partials/header') %>

<div class="container-fluid bg-gray-50 min-h-screen">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'pharmacy' }) %>

    <div class="col-md-9 col-lg-10 p-8">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-6">
            <div>
                <h2 class="text-4xl font-black text-gray-900 tracking-tight">Digital Pharmacy</h2>
                <p class="text-gray-500 mt-2 font-medium">Real-time stock of critical medications.</p>
            </div>
            <div class="w-full md:w-auto">
                <form action="/patient/pharmacy" method="GET" class="relative group">
                    <input type="text" name="search" value="<%= query %>" placeholder="Search medicine..." class="w-full md:w-80 bg-white border border-gray-100 rounded-2xl px-6 py-4 shadow-sm focus:ring-2 focus:ring-indigo-600 outline-none transition group-hover:shadow-md">
                    <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 group-hover:text-indigo-600 transition">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% if (medicines.length === 0) { %>
                <div class="col-span-full py-20 text-center">
                    <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-300">
                        <i class="fas fa-pills text-3xl"></i>
                    </div>
                    <h3 class="text-2xl font-black text-gray-900 mb-2">Medicine Not Found</h3>
                    <p class="text-gray-400 font-medium">We couldn't find any results for "<%= query %>".</p>
                </div>
            <% } else { %>
                <% medicines.forEach(med => { %>
                    <div class="bg-white p-8 rounded-[40px] border border-gray-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 group">
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-16 h-16 bg-indigo-50 text-indigo-500 rounded-3xl flex items-center justify-center text-2xl transition-transform group-hover:rotate-12">
                                <i class="fas fa-capsules"></i>
                            </div>
                            <span class="px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest
                                <%= med.stock_quantity > 100 ? 'bg-emerald-50 text-emerald-500' : 'bg-rose-50 text-rose-500' %>">
                                <%= med.stock_quantity > 100 ? 'In Stock' : 'Low Stock' %>
                            </span>
                        </div>
                        <h3 class="text-xl font-black text-gray-900 mb-1"><%= med.medicine_name %></h3>
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6"><%= med.category %></p>
                        
                        <div class="flex justify-between items-end">
                            <div>
                                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Price per unit</p>
                                <p class="text-2xl font-black text-gray-900">₹<%= med.price %></p>
                            </div>
                            <div class="text-right">
                                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Available</p>
                                <p class="text-sm font-bold text-gray-900"><%= med.stock_quantity %> units</p>
                            </div>
                        </div>

                        <button class="w-full mt-8 py-4 bg-gray-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-black transition-all active:scale-95">Request Medicine</button>
                    </div>
                <% }) %>
            <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

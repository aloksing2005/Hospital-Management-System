<% var title = 'Donation Heroes - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<div class="container-fluid bg-white min-h-screen">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'heroes' }) %>

    <div class="col-md-9 col-lg-10 p-12">
      <div class="max-w-5xl mx-auto">
        <div class="bg-indigo-600 rounded-[50px] p-12 text-white relative overflow-hidden mb-12 shadow-2xl shadow-indigo-100">
            <div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
                <div class="text-center md:text-left flex-grow">
                    <h2 class="text-5xl font-black mb-4 leading-tight">Donation <span class="text-indigo-300">Heroes</span></h2>
                    <p class="text-indigo-100 text-xl max-w-lg">Celebrate our community's life-savers. Every donation counts towards a healthier world.</p>
                </div>
                <div class="bg-white/20 backdrop-blur-xl p-8 rounded-[40px] border border-white/10 text-center">
                    <p class="text-xs font-black uppercase tracking-widest text-indigo-200 mb-2">My Rank</p>
                    <h4 class="text-5xl font-black">#12</h4>
                    <p class="text-sm font-bold mt-2">Level 3 Saver</p>
                </div>
            </div>
            <i class="fas fa-trophy absolute -bottom-10 -right-10 text-[220px] text-white/5"></i>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <!-- Leaderboard -->
            <div class="lg:col-span-2 space-y-6">
                <h3 class="text-3xl font-black text-gray-900 mb-8">Global Leaderboard</h3>
                
                <div class="space-y-4">
                    <% const heroes = [
                        { name: 'Amit Sharma', points: 2450, type: 'Blood', avatar: '1' },
                        { name: 'Priya Singh', points: 1980, type: 'Organ', avatar: '2' },
                        { name: 'Rahul Verma', points: 1560, type: 'Blood', avatar: '3' },
                        { name: 'Sneha Kapur', points: 1200, type: 'Stem Cell', avatar: '4' }
                    ]; %>
                    <% heroes.forEach((hero, index) => { %>
                        <div class="flex items-center gap-6 p-6 bg-gray-50 rounded-[32px] border border-gray-100 group hover:bg-white hover:shadow-xl transition-all duration-500">
                            <div class="w-12 h-12 flex items-center justify-center font-black text-2xl <%= index === 0 ? 'text-yellow-500' : 'text-gray-300' %>">
                                <%= index + 1 %>
                            </div>
                            <img src="https://i.pravatar.cc/100?u=<%= hero.avatar %>" class="w-16 h-16 rounded-2xl object-cover shadow-sm">
                            <div class="flex-grow">
                                <h4 class="text-xl font-bold text-gray-900"><%= hero.name %></h4>
                                <p class="text-xs font-black text-indigo-500 uppercase tracking-widest"><%= hero.type %> Donor</p>
                            </div>
                            <div class="text-right">
                                <p class="text-2xl font-black text-gray-900"><%= hero.points %></p>
                                <p class="text-[10px] font-black text-gray-400 uppercase">Points</p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Rewards Panel -->
            <div class="lg:col-span-1">
                <div class="bg-gray-900 rounded-[40px] p-10 text-white sticky top-8">
                    <h3 class="text-2xl font-bold mb-8">Unlocked Badges</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-white/5 p-4 rounded-3xl text-center border border-white/5">
                            <div class="w-12 h-12 bg-yellow-500/20 text-yellow-500 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-heart"></i>
                            </div>
                            <p class="text-[10px] font-black uppercase">Life Saver</p>
                        </div>
                        <div class="bg-white/5 p-4 rounded-3xl text-center border border-white/5">
                            <div class="w-12 h-12 bg-indigo-500/20 text-indigo-500 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-tint"></i>
                            </div>
                            <p class="text-[10px] font-black uppercase">Blood Hero</p>
                        </div>
                        <div class="bg-white/5 p-4 rounded-3xl text-center border border-white/5 opacity-30">
                            <div class="w-12 h-12 bg-gray-500/20 text-gray-500 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="fas fa-medal"></i>
                            </div>
                            <p class="text-[10px] font-black uppercase">Elite Donor</p>
                        </div>
                    </div>
                    
                    <div class="mt-10 pt-10 border-t border-white/10">
                        <p class="text-sm text-gray-400 mb-6">Earn points by donating blood or registering for organ donation. Points can be redeemed for hospital cafe vouchers!</p>
                        <button class="w-full bg-white text-gray-900 py-4 rounded-2xl font-black text-sm uppercase tracking-widest hover:scale-105 transition">Redeem Points</button>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<% var title = 'Donation Heroes - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'wellbeing' }) %>

  <!-- Main Content -->
  <div class="flex-grow overflow-y-auto p-6 lg:p-12 hms-page-transition">
    <!-- Hero Header Panel -->
    <div class="bg-indigo-600 rounded-[32px] p-8 lg:p-12 text-white relative overflow-hidden mb-12 shadow-xl shadow-indigo-600/10 animate-fade-in">
      <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="text-center md:text-left">
          <h2 class="text-3xl lg:text-5xl font-black mb-4 leading-tight">Donation <span class="text-indigo-200">Heroes</span></h2>
          <p class="text-indigo-100 text-base lg:text-lg max-w-xl">Celebrating our community's life-savers. Every contribution brings hope and heals lives.</p>
        </div>
        <div class="bg-white/15 backdrop-blur-xl p-6 lg:p-8 rounded-2xl border border-white/10 text-center shrink-0 w-full md:w-auto">
          <p class="text-xs font-black uppercase tracking-widest text-indigo-200 mb-1">My Rank</p>
          <h4 class="text-4xl lg:text-5xl font-black text-white">#12</h4>
          <p class="text-xs font-semibold text-indigo-100 mt-2">Level 3 Saver</p>
        </div>
      </div>
      <i class="fas fa-trophy absolute -bottom-10 -right-10 text-[200px] text-white/5 pointer-events-none"></i>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Leaderboard -->
      <div class="lg:col-span-8 space-y-6 animate-scale-in">
        <h3 class="text-2xl font-black text-white mb-6">Global Leaderboard</h3>
        
        <div class="space-y-4">
          <% const heroes = [
              { name: 'Amit Sharma', points: 2450, type: 'Blood', avatar: '1' },
              { name: 'Priya Singh', points: 1980, type: 'Organ', avatar: '2' },
              { name: 'Rahul Verma', points: 1560, type: 'Blood', avatar: '3' },
              { name: 'Sneha Kapur', points: 1200, type: 'Stem Cell', avatar: '4' }
          ]; %>
          <% heroes.forEach((hero, index) => { %>
            <div class="flex items-center gap-4 lg:gap-6 p-5 bg-white/5 rounded-2xl border border-white/5 hover:border-white/10 hover:bg-white/10 transition-all duration-300">
              <div class="w-10 h-10 flex items-center justify-center font-black text-xl lg:text-2xl shrink-0 <%= index === 0 ? 'text-yellow-400' : 'text-gray-500' %>">
                <%= index + 1 %>
              </div>
              <img src="https://i.pravatar.cc/100?u=<%= hero.avatar %>" class="w-12 h-12 lg:w-16 lg:h-16 rounded-xl object-cover shadow-md shrink-0">
              <div class="flex-grow min-w-0">
                <h4 class="text-base lg:text-lg font-bold text-white truncate"><%= hero.name %></h4>
                <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mt-0.5"><%= hero.type %> Donor</p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-lg lg:text-2xl font-black text-white"><%= hero.points %></p>
                <p class="text-[9px] font-black text-gray-400 uppercase tracking-wider">Points</p>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Rewards Panel -->
      <div class="lg:col-span-4 animate-scale-in">
        <div class="hms-card sticky top-8">
          <h3 class="text-xl font-bold text-white mb-6">Unlocked Badges</h3>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white/5 p-4 rounded-2xl text-center border border-white/5">
              <div class="w-12 h-12 bg-yellow-500/20 text-yellow-400 rounded-full flex items-center justify-center mx-auto mb-3 text-lg">
                <i class="fas fa-heart"></i>
              </div>
              <p class="text-[9px] font-black uppercase text-gray-300 tracking-wider">Life Saver</p>
            </div>
            <div class="bg-white/5 p-4 rounded-2xl text-center border border-white/5">
              <div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 rounded-full flex items-center justify-center mx-auto mb-3 text-lg">
                <i class="fas fa-tint"></i>
              </div>
              <p class="text-[9px] font-black uppercase text-gray-300 tracking-wider">Blood Hero</p>
            </div>
            <div class="bg-white/5 p-4 rounded-2xl text-center border border-white/5 opacity-30">
              <div class="w-12 h-12 bg-gray-500/20 text-gray-400 rounded-full flex items-center justify-center mx-auto mb-3 text-lg">
                <i class="fas fa-medal"></i>
              </div>
              <p class="text-[9px] font-black uppercase text-gray-400 tracking-wider">Elite Donor</p>
            </div>
          </div>
          
          <div class="mt-8 pt-8 border-t border-white/10">
            <p class="text-xs text-gray-400 leading-relaxed mb-6">Earn rank points by donating blood or registering for the organ donation index. Points can be redeemed for hospital cafe vouchers and wellness benefits.</p>
            <button class="hms-btn hms-btn-primary w-full text-xs uppercase py-3.5 tracking-wider font-bold">Redeem Points</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<% var title = 'Insurance Assistant - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<div class="container-fluid bg-gray-50 min-h-screen">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'insurance' }) %>

    <div class="col-md-9 col-lg-10 p-12">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-[50px] shadow-sm border border-gray-100 p-12 mb-8">
            <div class="flex justify-between items-start mb-12">
                <div>
                    <h2 class="text-4xl font-black text-gray-900 tracking-tight">Claim Assistant</h2>
                    <p class="text-gray-500 mt-2 text-lg">Hassle-free insurance claims processing.</p>
                </div>
                <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-2xl">
                    <i class="fas fa-shield-alt"></i>
                </div>
            </div>

            <!-- Claim Progress -->
            <div class="flex justify-between items-center mb-16 relative">
                <div class="absolute h-1 bg-gray-100 top-1/2 left-0 right-0 -translate-y-1/2 z-0"></div>
                <div class="absolute h-1 bg-blue-500 top-1/2 left-0 w-1/3 -translate-y-1/2 z-0"></div>
                <div class="relative z-10 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
                <div class="relative z-10 w-10 h-10 bg-gray-200 text-gray-500 rounded-full flex items-center justify-center font-bold">2</div>
                <div class="relative z-10 w-10 h-10 bg-gray-200 text-gray-500 rounded-full flex items-center justify-center font-bold">3</div>
            </div>

            <form class="space-y-8">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-4">Select Linked Appointment</label>
                    <div class="grid grid-cols-1 gap-4">
                        <label class="relative flex items-center p-6 bg-gray-50 rounded-3xl border-2 border-transparent hover:border-blue-500 cursor-pointer transition has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500">
                            <input type="radio" name="appt" class="sr-only peer" checked>
                            <div class="flex-grow">
                                <p class="font-bold text-gray-900">General Consultation - Dr. Sharma</p>
                                <p class="text-sm text-gray-500">Yesterday, 10:30 AM • $120.00</p>
                            </div>
                            <div class="w-6 h-6 border-2 border-gray-300 rounded-full peer-checked:border-blue-600 peer-checked:bg-blue-600 flex items-center justify-center">
                                <div class="w-2 h-2 bg-white rounded-full"></div>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-4">Insurance Provider</label>
                        <select class="w-full bg-gray-50 border-0 rounded-2xl px-6 py-4 outline-none focus:ring-2 focus:ring-blue-600 transition">
                            <option>Star Health Insurance</option>
                            <option>HDFC ERGO</option>
                            <option>ICICI Lombard</option>
                            <option>Niva Bupa</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-4">Policy Number</label>
                        <input type="text" placeholder="POL-987654321" class="w-full bg-gray-50 border-0 rounded-2xl px-6 py-4 outline-none focus:ring-2 focus:ring-blue-600 transition">
                    </div>
                </div>

                <div class="p-8 bg-blue-900 rounded-[32px] text-white">
                    <h4 class="font-bold mb-4 flex items-center"><i class="fas fa-magic mr-2"></i> AI Auto-Fill Active</h4>
                    <p class="text-blue-100 text-sm mb-6">Our AI has detected your bills and prescriptions. We have pre-filled 80% of the claim form for you.</p>
                    <div class="flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-blue-300">
                        <span class="flex items-center gap-1"><i class="fas fa-check-circle"></i> Bill Detected</span>
                        <span class="flex items-center gap-1"><i class="fas fa-check-circle"></i> ID Verified</span>
                        <span class="flex items-center gap-1"><i class="fas fa-check-circle"></i> Reports Ready</span>
                    </div>
                </div>

                <button type="submit" class="w-full bg-blue-600 text-white py-5 rounded-[30px] font-black text-xl hover:bg-blue-700 transition shadow-xl shadow-blue-100">
                    Submit Digital Claim
                </button>
            </form>
        </div>

        <div class="bg-white rounded-[40px] shadow-sm border border-gray-100 p-8">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Recent Claims</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-6 bg-gray-50 rounded-3xl border border-gray-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-green-100 text-green-600 rounded-full flex items-center justify-center"><i class="fas fa-check"></i></div>
                        <div>
                            <p class="font-bold text-gray-900">Dental Surgery - Claim #882</p>
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Approved • $450.00</p>
                        </div>
                    </div>
                    <button class="text-blue-600 font-bold">View PDF</button>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

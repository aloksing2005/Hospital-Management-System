<% var title = 'My Appointments - HMS Premium'; %>
<%- include('../partials/header') %>

<%
  // Compute appointment metrics dynamically
  const totalScheduled = appointments.length;
  const activeConfirmed = appointments.filter(a => a.status === 'confirmed' || a.status === 'checked_in').length;
  const completedCount = appointments.filter(a => a.status === 'completed').length;
  const cancelledCount = appointments.filter(a => a.status === 'cancelled').length;
%>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'appointments' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">My Appointments</h1>
        <p class="text-gray-400 font-medium">Manage your scheduled consultations and check in early</p>
      </div>
      <a href="/patient/doctors" class="hms-btn hms-btn-primary flex items-center gap-2">
        <i class="fas fa-plus"></i>
        <span>Book New</span>
      </a>
    </div>

    <!-- Clinical Statistics Panel -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <!-- Total Scheduled -->
      <div class="hms-card p-4 flex items-center justify-between border-l-4 border-indigo-500 hover:scale-[1.02] transition-transform duration-200">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Total Scheduled</p>
          <h3 class="text-2xl font-black text-white mt-1"><%= totalScheduled %></h3>
        </div>
        <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 text-lg">
          <i class="fas fa-calendar-alt"></i>
        </div>
      </div>

      <!-- Active & Confirmed -->
      <div class="hms-card p-4 flex items-center justify-between border-l-4 border-emerald-500 hover:scale-[1.02] transition-transform duration-200">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Active / Confirmed</p>
          <h3 class="text-2xl font-black text-white mt-1"><%= activeConfirmed %></h3>
        </div>
        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 text-lg relative">
          <i class="fas fa-check-circle animate-pulse"></i>
        </div>
      </div>

      <!-- Completed -->
      <div class="hms-card p-4 flex items-center justify-between border-l-4 border-sky-500 hover:scale-[1.02] transition-transform duration-200">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Completed Sessions</p>
          <h3 class="text-2xl font-black text-white mt-1"><%= completedCount %></h3>
        </div>
        <div class="w-12 h-12 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center text-sky-400 text-lg">
          <i class="fas fa-clipboard-check"></i>
        </div>
      </div>

      <!-- Cancelled -->
      <div class="hms-card p-4 flex items-center justify-between border-l-4 border-rose-500 hover:scale-[1.02] transition-transform duration-200">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Cancelled Requests</p>
          <h3 class="text-2xl font-black text-white mt-1"><%= cancelledCount %></h3>
        </div>
        <div class="w-12 h-12 rounded-xl bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-400 text-lg">
          <i class="fas fa-calendar-times"></i>
        </div>
      </div>
    </div>

    <!-- Countdown & Dispatch Center -->
    <div id="countdownPanel" class="hms-card p-6 mb-8 border border-emerald-500/30 bg-gradient-to-r from-slate-900 via-slate-950 to-emerald-950/20 shadow-lg shadow-emerald-500/5 hidden relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-emerald-500/5 via-transparent to-transparent pointer-events-none"></div>
      
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6 relative z-10">
        <div class="flex items-center gap-4 flex-1">
          <div class="w-16 h-16 rounded-2xl bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-400 text-2xl shadow-inner shadow-emerald-500/20 relative flex-shrink-0">
            <i class="fas fa-video animate-pulse"></i>
            <span class="absolute top-0 right-0 w-3 h-3 bg-emerald-400 border-2 border-slate-900 rounded-full animate-ping"></span>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-extrabold text-emerald-400 uppercase tracking-widest bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded-md">Clinical Live Dispatch</span>
              <span id="countdownBadge" class="text-xs font-bold text-gray-400">Syncing...</span>
            </div>
            <h2 id="countdownDocName" class="text-xl font-black text-white mt-1">Dr. Doctor Name</h2>
            <p id="countdownSpecialty" class="text-xs font-bold text-emerald-400/80">Specialization</p>
          </div>
        </div>
        
        <!-- Live Countdown Timer -->
        <div class="flex items-center gap-2 md:gap-4 bg-slate-900/80 backdrop-blur-md px-6 py-3 rounded-2xl border border-white/5 shadow-2xl">
          <div class="text-center min-w-[45px] md:min-w-[60px]">
            <span id="cdDays" class="text-2xl md:text-3xl font-black text-white font-mono tracking-tight">00</span>
            <p class="text-[9px] font-bold text-gray-500 uppercase tracking-wider mt-0.5">Days</p>
          </div>
          <span class="text-gray-700 font-black text-xl mb-4">:</span>
          <div class="text-center min-w-[45px] md:min-w-[60px]">
            <span id="cdHours" class="text-2xl md:text-3xl font-black text-white font-mono tracking-tight">00</span>
            <p class="text-[9px] font-bold text-gray-500 uppercase tracking-wider mt-0.5">Hours</p>
          </div>
          <span class="text-gray-700 font-black text-xl mb-4">:</span>
          <div class="text-center min-w-[45px] md:min-w-[60px]">
            <span id="cdMins" class="text-2xl md:text-3xl font-black text-white font-mono tracking-tight">00</span>
            <p class="text-[9px] font-bold text-gray-500 uppercase tracking-wider mt-0.5">Mins</p>
          </div>
          <span class="text-gray-700 font-black text-xl mb-4">:</span>
          <div class="text-center min-w-[45px] md:min-w-[60px]">
            <span id="cdSecs" class="text-2xl md:text-3xl font-black text-emerald-400 font-mono tracking-tight animate-pulse">00</span>
            <p class="text-[9px] font-bold text-gray-500 uppercase tracking-wider mt-0.5">Secs</p>
          </div>
        </div>
        
        <!-- Live Dispatch Actions -->
        <div class="flex flex-wrap gap-3 items-center justify-end w-full lg:w-auto">
          <!-- Calendar Dropdown -->
          <div class="relative inline-block text-left" id="cdCalendarWrapper">
            <button type="button" id="cdCalendarBtn" class="hms-btn hms-btn-secondary text-xs font-bold flex items-center gap-2 py-2 px-3">
              <i class="fas fa-calendar-plus text-sm"></i> Add to Calendar
            </button>
            <div id="cdCalendarDropdown" class="hidden absolute right-0 bottom-full lg:bottom-auto lg:top-full mt-2 w-48 rounded-xl bg-slate-950 border border-white/10 shadow-2xl z-50 overflow-hidden backdrop-blur-xl transition-all duration-200">
              <button id="cdGoogleCal" class="w-full text-left px-4 py-2.5 text-xs font-semibold text-gray-300 hover:bg-white/10 flex items-center gap-2 border-b border-white/5">
                <i class="fab fa-google text-rose-400"></i> Google Calendar
              </button>
              <button id="cdICal" class="w-full text-left px-4 py-2.5 text-xs font-semibold text-gray-300 hover:bg-white/10 flex items-center gap-2">
                <i class="fas fa-file-invoice text-indigo-400"></i> iCal / Outlook (.ics)
              </button>
            </div>
          </div>
          <button id="cdActionBtn" class="hms-btn hms-btn-primary flex items-center gap-2 text-xs font-bold py-2 px-4 shadow-lg shadow-indigo-500/20">
            <i class="fas fa-video animate-pulse"></i> Join Call
          </button>
        </div>
      </div>
    </div>

    <!-- Fallback if no Confirmed Appointments -->
    <div id="countdownFallback" class="hms-card p-6 mb-8 border border-white/5 bg-slate-900/30 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 text-lg flex-shrink-0">
          <i class="fas fa-info-circle"></i>
        </div>
        <div>
          <h4 class="text-sm font-bold text-white">No active upcoming consultations</h4>
          <p class="text-xs text-gray-500 font-medium mt-0.5">Schedule a consult with one of our certified clinical specialists to synchronize this feed.</p>
        </div>
      </div>
      <a href="/patient/doctors" class="hms-btn hms-btn-primary text-xs font-bold py-2.5 px-4 flex-shrink-0">
        <i class="fas fa-search-plus"></i> Search Doctors
      </a>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 items-start">
      <!-- Appointments Left Column -->
      <div class="xl:col-span-2 space-y-6">
        <div class="hms-card p-6">
          
          <!-- Filters & Live Search Panel -->
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
            <!-- Dynamic Search input -->
            <div class="relative flex-1 max-w-md">
              <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs"></i>
              <input type="text" id="appointmentSearch" placeholder="Search by doctor name, specialization, or symptoms..." class="hms-input pl-10 pr-4 py-2 w-full text-xs" autocomplete="off">
              <button id="searchClearBtn" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white hidden">
                <i class="fas fa-times-circle text-xs"></i>
              </button>
            </div>
            
            <!-- Filters pills -->
            <div class="flex flex-wrap gap-2 items-center" id="statusFilterGroup">
              <button data-filter="all" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-indigo-500 text-white shadow-lg shadow-indigo-500/20 transition-all border border-indigo-500/20 active-filter">
                All
              </button>
              <button data-filter="pending" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white transition-all border border-white/5">
                Pending <span class="ml-1 px-1.5 py-0.5 rounded bg-amber-500/20 text-amber-400 text-[9px]"><%= appointments.filter(a => a.status === 'pending').length %></span>
              </button>
              <button data-filter="confirmed" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white transition-all border border-white/5">
                Confirmed <span class="ml-1 px-1.5 py-0.5 rounded bg-emerald-500/20 text-emerald-400 text-[9px]"><%= appointments.filter(a => a.status === 'confirmed').length %></span>
              </button>
              <button data-filter="checked_in" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white transition-all border border-white/5">
                Checked In <span class="ml-1 px-1.5 py-0.5 rounded bg-teal-500/20 text-teal-400 text-[9px]"><%= appointments.filter(a => a.status === 'checked_in').length %></span>
              </button>
              <button data-filter="completed" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white transition-all border border-white/5">
                Completed <span class="ml-1 px-1.5 py-0.5 rounded bg-sky-500/20 text-sky-400 text-[9px]"><%= appointments.filter(a => a.status === 'completed').length %></span>
              </button>
              <button data-filter="cancelled" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white transition-all border border-white/5">
                Cancelled <span class="ml-1 px-1.5 py-0.5 rounded bg-rose-500/20 text-rose-400 text-[9px]"><%= appointments.filter(a => a.status === 'cancelled').length %></span>
              </button>
            </div>
          </div>

          <!-- Appointments List View -->
          <div class="hms-table-container min-h-[300px]">
            <table class="hms-table w-full text-left border-collapse" id="appointmentsTable">
              <thead>
                <tr class="border-b border-white/5 text-xs text-gray-400 uppercase font-black">
                  <th class="py-4 px-4">Doctor</th>
                  <th class="py-4 px-4">Specialization</th>
                  <th class="py-4 px-4">Date & Time</th>
                  <th class="py-4 px-4">Symptoms</th>
                  <th class="py-4 px-4">Status</th>
                  <th class="py-4 px-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (appointments.length === 0) { %>
                  <tr id="noAppointmentsRow">
                    <td colspan="6" class="text-center py-16 text-gray-500 font-medium">
                      <i class="fas fa-calendar-minus text-3xl mb-3 block text-gray-600"></i>
                      No appointments scheduled yet.
                    </td>
                  </tr>
                <% } else { %>
                  <% appointments.forEach(app => { %>
                    <tr data-id="<%= app.id %>" data-status="<%= app.status %>" data-doctor="<%= app.doctor_name.toLowerCase() %>" data-specialty="<%= app.specialization.toLowerCase() %>" data-symptoms="<%= (app.symptoms || '').toLowerCase() %>" class="border-b border-white/5 hover:bg-white/[0.02] transition-colors duration-150 appointment-row">
                      <td class="py-4 px-4">
                        <div class="flex items-center gap-3">
                          <div class="relative">
                            <img src="<%= app.photo || 'https://i.pravatar.cc/40?u=' + app.doctor_id %>" class="w-10 h-10 rounded-xl object-cover border border-white/10">
                            <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border border-slate-900 <%= app.status === 'completed' ? 'bg-gray-500' : app.status === 'cancelled' ? 'bg-rose-500' : 'bg-emerald-500' %> shadow-lg"></span>
                          </div>
                          <div>
                            <span class="font-bold text-white text-sm block">Dr. <%= app.doctor_name %></span>
                            <span class="text-[10px] text-gray-500 font-bold tracking-wider uppercase">ID: <%= String(app.doctor_id).substring(18) %></span>
                          </div>
                        </div>
                      </td>
                      <td class="py-4 px-4">
                        <span class="px-2.5 py-0.5 rounded bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 text-xs font-bold"><%= app.specialization %></span>
                      </td>
                      <td class="py-4 px-4">
                        <div class="flex flex-col">
                          <span class="text-xs font-bold text-white"><%= new Date(app.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                          <span class="text-[10px] text-gray-400 font-bold mt-0.5 flex items-center gap-1"><i class="far fa-clock text-gray-500"></i><%= app.time_slot %></span>
                        </div>
                      </td>
                      <td class="py-4 px-4">
                        <div class="max-w-[150px] truncate text-xs text-gray-400 font-medium" title="<%= app.symptoms || 'General Consultation' %>">
                          <%= app.symptoms || 'General Consultation' %>
                        </div>
                      </td>
                      <td class="py-4 px-4">
                        <% if (app.status === 'pending') { %>
                          <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold text-amber-400 bg-amber-500/10 border border-amber-500/20 flex items-center gap-1.5 w-fit uppercase">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> Pending
                          </span>
                        <% } else if (app.status === 'confirmed') { %>
                          <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 flex items-center gap-1.5 w-fit uppercase">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span> Confirmed
                          </span>
                        <% } else if (app.status === 'checked_in') { %>
                          <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold text-teal-400 bg-teal-500/10 border border-teal-500/20 flex items-center gap-1.5 w-fit shadow-md shadow-teal-500/5 animate-pulse uppercase">
                            <span class="w-1.5 h-1.5 rounded-full bg-teal-400"></span> Checked In
                          </span>
                        <% } else if (app.status === 'completed') { %>
                          <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold text-sky-400 bg-sky-500/10 border border-sky-500/20 flex items-center gap-1.5 w-fit uppercase">
                            <span class="w-1.5 h-1.5 rounded-full bg-sky-400"></span> Completed
                          </span>
                        <% } else { %>
                          <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold text-rose-400 bg-rose-500/10 border border-rose-500/20 flex items-center gap-1.5 w-fit uppercase">
                            <span class="w-1.5 h-1.5 rounded-full bg-rose-400"></span> Cancelled
                          </span>
                        <% } %>
                      </td>
                      <td class="py-4 px-4 text-right">
                        <div class="flex items-center justify-end gap-2">
                          <!-- Row Calendar dropdown -->
                          <% if (app.status === 'confirmed' || app.status === 'pending' || app.status === 'checked_in') { %>
                            <div class="relative row-calendar-wrapper">
                              <button type="button" class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 text-gray-400 hover:text-white flex items-center justify-center transition-all row-calendar-btn" title="Add to Calendar">
                                <i class="far fa-calendar-plus text-xs"></i>
                              </button>
                              <!-- Calendar choices -->
                              <div class="hidden absolute right-0 top-full mt-1 w-44 rounded-xl bg-slate-950 border border-white/10 shadow-2xl z-40 overflow-hidden backdrop-blur-xl">
                                <button onclick="exportGoogleCalendar('<%= encodeURIComponent(JSON.stringify(app)) %>')" class="w-full text-left px-3 py-2 text-xs font-semibold text-gray-300 hover:bg-white/10 flex items-center gap-2 border-b border-white/5">
                                  <i class="fab fa-google text-rose-400"></i> Google Calendar
                                </button>
                                <button onclick="exportICalCalendar('<%= encodeURIComponent(JSON.stringify(app)) %>')" class="w-full text-left px-3 py-2 text-xs font-semibold text-gray-300 hover:bg-white/10 flex items-center gap-2">
                                  <i class="fas fa-file-invoice text-indigo-400"></i> iCal / Outlook
                                </button>
                              </div>
                            </div>
                          <% } %>

                          <% if (app.status === 'pending') { %>
                            <button onclick="triggerCheckInEarly('<%= app.id %>')" class="px-3 py-1.5 rounded-lg bg-indigo-500 hover:bg-indigo-600 text-white font-bold text-[11px] transition-all">
                              Check In
                            </button>
                            <form action="/patient/appointments/cancel/<%= app.id %>" method="POST" class="inline" onsubmit="return confirm('Cancel this appointment?')">
                              <button type="submit" class="w-8 h-8 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white flex items-center justify-center transition-all" title="Cancel Appointment">
                                <i class="fas fa-times text-xs"></i>
                              </button>
                            </form>
                          <% } else if (app.status === 'confirmed') { %>
                            <button onclick="triggerCheckInEarly('<%= app.id %>')" class="px-3 py-1.5 rounded-lg bg-teal-500/10 hover:bg-teal-500/20 text-teal-400 border border-teal-500/20 text-[11px] font-bold transition-all">
                              Check In
                            </button>
                            <a href="/consultation/<%= app.id %>" class="hms-btn hms-btn-primary py-1.5 px-3 rounded-lg text-[11px] font-bold flex items-center gap-1.5">
                              <i class="fas fa-video text-xs"></i> Join
                            </a>
                          <% } else if (app.status === 'checked_in') { %>
                            <a href="/consultation/<%= app.id %>" class="hms-btn hms-btn-primary py-1.5 px-3 rounded-lg text-[11px] font-bold flex items-center gap-1.5 animate-pulse">
                              <i class="fas fa-video text-xs"></i> Join Call
                            </a>
                          <% } else if (app.status === 'completed') { %>
                            <button class="px-3 py-1.5 rounded-lg bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white border border-white/10 text-[11px] font-bold transition-all flex items-center gap-1" onclick="openReviewModal('<%= app.id %>', '<%= app.doctor_id %>')">
                              <i class="fas fa-star text-amber-400 text-xs"></i> Rate
                            </button>
                          <% } else { %>
                            <span class="text-gray-600 text-xs">-</span>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
                
                <!-- Filters fallback matches nothing -->
                <tr id="noMatchesRow" class="hidden">
                  <td colspan="6" class="text-center py-16 text-gray-500 font-medium">
                    <i class="fas fa-search-minus text-3xl mb-3 block text-gray-600"></i>
                    No appointments matches your filters.
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Preparation & Diagnostics Checklist Sidebar -->
      <div class="xl:col-span-1 space-y-6">
        <!-- Diagnostic Status HUD -->
        <div class="hms-card p-6 border border-indigo-500/10">
          <h3 class="text-md font-black text-white flex items-center gap-2 mb-4">
            <i class="fas fa-user-shield text-indigo-400"></i> Consultation Prep Center
          </h3>
          <p class="text-xs text-gray-400 font-medium mb-5 leading-relaxed">Ensure your local telemetry systems and hardware components are fully authenticated before your call starts.</p>
          
          <div class="space-y-3 mb-6">
            <!-- Camera Detector -->
            <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400 text-sm" id="camIcon">
                  <i class="fas fa-video"></i>
                </div>
                <div>
                  <p class="text-xs font-bold text-white">Camera Device</p>
                  <p class="text-[10px] text-gray-500 font-semibold" id="camDesc">Permissions pending...</p>
                </div>
              </div>
              <div id="camStatusDot" class="w-2 h-2 rounded-full bg-gray-500 animate-pulse"></div>
            </div>
            
            <!-- Microphone Detector -->
            <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400 text-sm" id="micIcon">
                  <i class="fas fa-microphone"></i>
                </div>
                <div>
                  <p class="text-xs font-bold text-white">Microphone Input</p>
                  <p class="text-[10px] text-gray-500 font-semibold" id="micDesc">Permissions pending...</p>
                </div>
              </div>
              <div id="micStatusDot" class="w-2 h-2 rounded-full bg-gray-500 animate-pulse"></div>
            </div>

            <!-- Encrypted Signal Sync -->
            <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400 text-sm">
                  <i class="fas fa-server"></i>
                </div>
                <div>
                  <p class="text-xs font-bold text-white">Encrypted Server Connection</p>
                  <p class="text-[10px] text-emerald-400 font-semibold">Active & Secured</p>
                </div>
              </div>
              <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
            </div>
          </div>

          <button onclick="requestHardwareAccess()" class="hms-btn hms-btn-primary w-full text-xs font-bold mb-4 py-2.5 flex items-center justify-center gap-2" id="reqHardwareBtn">
            <i class="fas fa-shield-alt"></i> Run Diagnostics Pass
          </button>

          <hr class="border-white/5 my-4">

          <!-- Telehealth widgets visual shortcut -->
          <div class="grid grid-cols-2 gap-3">
            <a href="/patient/vitals" class="p-3 rounded-xl bg-slate-900 border border-white/5 hover:border-indigo-500/30 text-center transition-all group">
              <i class="fas fa-heartbeat text-rose-500 text-lg mb-1.5 block group-hover:scale-110 transition-transform"></i>
              <span class="text-[9px] font-extrabold text-white uppercase tracking-wider block">Vitals HUD</span>
            </a>
            <a href="/patient/ai-consultation" class="p-3 rounded-xl bg-slate-900 border border-white/5 hover:border-indigo-500/30 text-center transition-all group">
              <i class="fas fa-brain text-emerald-400 text-lg mb-1.5 block group-hover:scale-110 transition-transform"></i>
              <span class="text-[9px] font-extrabold text-white uppercase tracking-wider block">Bio Suite</span>
            </a>
          </div>
        </div>

        <!-- Consultation Preparation Checklist -->
        <div class="hms-card p-6 border border-white/5">
          <h3 class="text-xs font-black text-white uppercase tracking-wider flex items-center gap-2 mb-3">
            <i class="fas fa-list-check text-indigo-400"></i> Pre-Consultation Checklist
          </h3>
          <p class="text-[11px] text-gray-500 font-medium mb-4">Check these items to finalize patient reports prior to consultation call.</p>
          
          <div class="space-y-3" id="checklistForm">
            <label class="flex items-start gap-3 p-2.5 rounded-lg bg-white/[0.02] border border-white/5 hover:bg-white/[0.04] transition-colors cursor-pointer select-none">
              <input type="checkbox" id="chkSymptoms" class="mt-0.5 rounded border-white/10 bg-slate-950 text-indigo-500 focus:ring-indigo-500 focus:ring-offset-slate-900" onchange="saveChecklistState()">
              <div>
                <span class="text-xs font-bold text-white block">Symptoms Catalogued</span>
                <span class="text-[10px] text-gray-500 font-medium">Chief concerns accurately logged.</span>
              </div>
            </label>
            <label class="flex items-start gap-3 p-2.5 rounded-lg bg-white/[0.02] border border-white/5 hover:bg-white/[0.04] transition-colors cursor-pointer select-none">
              <input type="checkbox" id="chkMeds" class="mt-0.5 rounded border-white/10 bg-slate-950 text-indigo-500 focus:ring-indigo-500 focus:ring-offset-slate-900" onchange="saveChecklistState()">
              <div>
                <span class="text-xs font-bold text-white block">Active Prescriptions Synced</span>
                <span class="text-[10px] text-gray-500 font-medium">Logged medication safety review list.</span>
              </div>
            </label>
            <label class="flex items-start gap-3 p-2.5 rounded-lg bg-white/[0.02] border border-white/5 hover:bg-white/[0.04] transition-colors cursor-pointer select-none">
              <input type="checkbox" id="chkVitals" class="mt-0.5 rounded border-white/10 bg-slate-950 text-indigo-500 focus:ring-indigo-500 focus:ring-offset-slate-900" onchange="saveChecklistState()">
              <div>
                <span class="text-xs font-bold text-white block">Telemetry Connected</span>
                <span class="text-[10px] text-gray-500 font-medium">Webcam PPG and heart vitals primed.</span>
              </div>
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Review Modal -->
<div id="reviewModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center">
  <div class="hms-card max-w-md w-full mx-4 animate-scale-in">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-xl font-bold text-white">Rate & Review</h3>
      <button type="button" onclick="closeReviewModal()" class="text-gray-400 hover:text-white transition-colors">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form action="/patient/review" method="POST" class="space-y-4">
      <input type="hidden" name="appointment_id" id="rev_app_id">
      <input type="hidden" name="doctor_id" id="rev_doc_id">
      <div>
        <label class="hms-label">Rating (1-5)</label>
        <select name="rating" class="hms-input hms-select" required>
          <option value="5">5 - Excellent</option>
          <option value="4">4 - Good</option>
          <option value="3">3 - Average</option>
          <option value="2">2 - Poor</option>
          <option value="1">1 - Terrible</option>
        </select>
      </div>
      <div>
        <label class="hms-label">Review</label>
        <textarea name="review" class="hms-input" rows="3" required placeholder="Share your experience..."></textarea>
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="closeReviewModal()" class="hms-btn hms-btn-secondary flex-1">Close</button>
        <button type="submit" class="hms-btn hms-btn-primary flex-1">Submit Review</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Dynamic datasets injected safely from server template variables
  const rawAppointments = <%- JSON.stringify(appointments) %>;
  const socket = window.hmsSocket ? window.hmsSocket() : null;

  if (socket) {
    // Prevent duplicate event bindings
    socket.off('appointment-update');
    socket.on('appointment-update', (data) => {
      if (String(data.patientId || '') === '<%= user.id %>') {
        const row = document.querySelector(`tr[data-id="${data.appointmentId}"]`);
        if (row) {
          const badge = row.querySelector('.hms-badge') || row.querySelector('span[class*="rounded-full"]');
          if (badge) {
            let className = '';
            let innerHTML = '';
            
            if (data.status === 'pending') {
              className = 'px-2.5 py-1 rounded-full text-[10px] font-extrabold text-amber-400 bg-amber-500/10 border border-amber-500/20 flex items-center gap-1.5 w-fit uppercase';
              innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> Pending';
            } else if (data.status === 'confirmed') {
              className = 'px-2.5 py-1 rounded-full text-[10px] font-extrabold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 flex items-center gap-1.5 w-fit uppercase';
              innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span> Confirmed';
            } else if (data.status === 'checked_in') {
              className = 'px-2.5 py-1 rounded-full text-[10px] font-extrabold text-teal-400 bg-teal-500/10 border border-teal-500/20 flex items-center gap-1.5 w-fit shadow-md shadow-teal-500/5 animate-pulse uppercase';
              innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-teal-400"></span> Checked In';
            } else if (data.status === 'completed') {
              className = 'px-2.5 py-1 rounded-full text-[10px] font-extrabold text-sky-400 bg-sky-500/10 border border-sky-500/20 flex items-center gap-1.5 w-fit uppercase';
              innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-sky-400"></span> Completed';
            } else {
              className = 'px-2.5 py-1 rounded-full text-[10px] font-extrabold text-rose-400 bg-rose-500/10 border border-rose-500/20 flex items-center gap-1.5 w-fit uppercase';
              innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-rose-400"></span> Cancelled';
            }
            
            badge.className = className;
            badge.innerHTML = innerHTML;
          }
          
          row.setAttribute('data-status', data.status);
          
          if (typeof window.hmsShowToast === 'function') {
            const docNameSpan = row.querySelector('.text-white');
            const docName = docNameSpan ? docNameSpan.textContent.trim() : 'Doctor';
            window.hmsShowToast('Notification Update', `Appointment with ${docName} is now ${data.status.replace('_', ' ')}.`, 'success');
          }
          
          setTimeout(() => { location.reload(); }, 1500);
        }
      }
    });
  }

  // Google Calendar / iCal exporters
  function parseAppointmentDateTime(dateStr, timeSlotStr) {
    const apptDate = new Date(dateStr);
    let startTime = timeSlotStr.split('-')[0].trim();
    
    let hours = 0;
    let minutes = 0;
    const isPM = startTime.toUpperCase().includes('PM');
    const isAM = startTime.toUpperCase().includes('AM');
    
    startTime = startTime.replace(/(AM|PM)/i, '').trim();
    const parts = startTime.split(':');
    hours = parseInt(parts[0], 10);
    minutes = parseInt(parts[1] || '0', 10);
    
    if (isPM && hours < 12) hours += 12;
    if (isAM && hours === 12) hours = 0;
    
    apptDate.setHours(hours, minutes, 0, 0);
    return apptDate;
  }

  function getGoogleCalendarUrl(app) {
    const start = parseAppointmentDateTime(app.date, app.time_slot);
    const end = new Date(start.getTime() + 30 * 60 * 1000);
    const formatStr = (d) => d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
    const title = encodeURIComponent(`Consultation with Dr. ${app.doctor_name}`);
    const details = encodeURIComponent(`Virtual Consultation via HMS Premium Clinic.\nSpecialization: ${app.specialization}\nSymptoms: ${app.symptoms || 'General Checkup'}`);
    const dates = `${formatStr(start)}/${formatStr(end)}`;
    return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${dates}&details=${details}&location=HMS+Virtual+Clinic`;
  }

  function downloadICal(app) {
    const start = parseAppointmentDateTime(app.date, app.time_slot);
    const end = new Date(start.getTime() + 30 * 60 * 1000);
    const formatStr = (d) => d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
    const icsContent = [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//HMS Premium//NONSGML Consultation//EN',
      'BEGIN:VEVENT',
      `UID:appt-${app.id || app._id}@hms-premium.com`,
      `DTSTAMP:${formatStr(new Date())}`,
      `DTSTART:${formatStr(start)}`,
      `DTEND:${formatStr(end)}`,
      `SUMMARY:Consultation with Dr. ${app.doctor_name}`,
      `DESCRIPTION:Virtual Consultation via HMS Premium Clinic. Specialization: ${app.specialization}. Symptoms: ${app.symptoms || 'General Checkup'}`,
      'LOCATION:HMS Virtual Clinic',
      'END:VEVENT',
      'END:VCALENDAR'
    ].join('\r\n');
    
    const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.setAttribute('download', `consultation-dr-${app.doctor_name.replace(/\s+/g, '-')}.ics`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  window.exportGoogleCalendar = function(appEscaped) {
    const app = JSON.parse(decodeURIComponent(appEscaped));
    const url = getGoogleCalendarUrl(app);
    window.open(url, '_blank');
  };

  window.exportICalCalendar = function(appEscaped) {
    const app = JSON.parse(decodeURIComponent(appEscaped));
    downloadICal(app);
  };

  // Review Modal controllers
  function openReviewModal(appId, docId) {
    document.getElementById('rev_app_id').value = appId;
    document.getElementById('rev_doc_id').value = docId;
    const modal = document.getElementById('reviewModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeReviewModal() {
    const modal = document.getElementById('reviewModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  // Trigger early check-in
  window.triggerCheckInEarly = function(apptId) {
    if (window.checkInEarly) {
      window.checkInEarly(apptId);
    } else {
      if (confirm("Check in for your upcoming appointment?")) {
        fetch("/patient/appointments/check-in", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ appointmentId: apptId })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            if (window.hmsShowToast) window.hmsShowToast("Checked In", "You have been checked in successfully.", "success");
            setTimeout(() => { location.reload(); }, 1200);
          } else {
            if (window.hmsShowToast) window.hmsShowToast("Check-in Failed", data.error || "Failed", "error");
          }
        })
        .catch(err => {
          if (window.hmsShowToast) window.hmsShowToast("Error", err.message, "error");
        });
      }
    }
  };

  // Diagnostics camera and mic verification
  window.requestHardwareAccess = async function() {
    const camDesc = document.getElementById('camDesc');
    const camStatusDot = document.getElementById('camStatusDot');
    const camIcon = document.getElementById('camIcon');
    const micDesc = document.getElementById('micDesc');
    const micStatusDot = document.getElementById('micStatusDot');
    const micIcon = document.getElementById('micIcon');
    const reqBtn = document.getElementById('reqHardwareBtn');

    reqBtn.disabled = true;
    reqBtn.innerHTML = `<i class="fas fa-spinner animate-spin"></i> Checking Permissions...`;

    try {
      const stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
      
      camDesc.textContent = "Access Granted & Active";
      camDesc.className = "text-[10px] text-emerald-400 font-semibold";
      camStatusDot.className = "w-2 h-2 rounded-full bg-emerald-500 animate-none";
      camIcon.className = "w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-sm";

      micDesc.textContent = "Signal Calibrated";
      micDesc.className = "text-[10px] text-emerald-400 font-semibold";
      micStatusDot.className = "w-2 h-2 rounded-full bg-emerald-500 animate-none";
      micIcon.className = "w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-sm";

      stream.getTracks().forEach(track => track.stop());

      if (window.hmsShowToast) window.hmsShowToast("Diagnostics Pass", "Camera and microphone permissions verified successfully.", "success");
    } catch (e) {
      console.error(e);
      if (e.name === 'NotAllowedError' || e.name === 'PermissionDeniedError') {
        camDesc.textContent = "Access Blocked";
        camDesc.className = "text-[10px] text-rose-400 font-semibold";
        camStatusDot.className = "w-2 h-2 rounded-full bg-rose-500 animate-none";
        camIcon.className = "w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center text-rose-400 text-sm";

        micDesc.textContent = "Access Blocked";
        micDesc.className = "text-[10px] text-rose-400 font-semibold";
        micStatusDot.className = "w-2 h-2 rounded-full bg-rose-500 animate-none";
        micIcon.className = "w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center text-rose-400 text-sm";
        
        if (window.hmsShowToast) window.hmsShowToast("Access Denied", "Enable hardware access in your browser preferences.", "error");
      } else {
        camDesc.textContent = "Device Unreachable";
        camDesc.className = "text-[10px] text-rose-400 font-semibold";
        camStatusDot.className = "w-2 h-2 rounded-full bg-rose-500 animate-none";

        micDesc.textContent = "Device Unreachable";
        micDesc.className = "text-[10px] text-rose-400 font-semibold";
        micStatusDot.className = "w-2 h-2 rounded-full bg-rose-500 animate-none";
        
        if (window.hmsShowToast) window.hmsShowToast("Diagnostics Error", "Compatible capture devices could not be found.", "error");
      }
    } finally {
      reqBtn.disabled = false;
      reqBtn.innerHTML = `<i class="fas fa-shield-alt"></i> Run Diagnostics Pass`;
    }
  };

  // Pre-Consultation checklist state savers
  window.saveChecklistState = function() {
    const chkSymptoms = document.getElementById('chkSymptoms').checked;
    const chkMeds = document.getElementById('chkMeds').checked;
    const chkVitals = document.getElementById('chkVitals').checked;
    
    localStorage.setItem('hms_appt_checklist', JSON.stringify({
      chkSymptoms,
      chkMeds,
      chkVitals
    }));
  };

  function loadChecklistState() {
    try {
      const saved = localStorage.getItem('hms_appt_checklist');
      if (saved) {
        const data = JSON.parse(saved);
        document.getElementById('chkSymptoms').checked = !!data.chkSymptoms;
        document.getElementById('chkMeds').checked = !!data.chkMeds;
        document.getElementById('chkVitals').checked = !!data.chkVitals;
      }
    } catch (e) {
      // Ignored gracefully
    }
  }

  // Interactive Live Countdown
  let activeCountdownInterval = null;

  function initCountdownHUD() {
    const eligible = rawAppointments.filter(app => (app.status === 'confirmed' || app.status === 'checked_in'));
    
    if (eligible.length === 0) {
      document.getElementById('countdownPanel').classList.add('hidden');
      document.getElementById('countdownFallback').classList.remove('hidden');
      return;
    }

    const sorted = eligible.map(app => {
      try {
        const targetTime = parseAppointmentDateTime(app.date, app.time_slot);
        return { app, targetTime };
      } catch (e) {
        return null;
      }
    }).filter(item => item && item.targetTime > new Date())
      .sort((a, b) => a.targetTime - b.targetTime);

    if (sorted.length === 0) {
      document.getElementById('countdownPanel').classList.add('hidden');
      document.getElementById('countdownFallback').classList.remove('hidden');
      return;
    }

    const nextAppt = sorted[0];
    
    document.getElementById('countdownPanel').classList.remove('hidden');
    document.getElementById('countdownFallback').classList.add('hidden');
    
    document.getElementById('countdownDocName').textContent = `Dr. ${nextAppt.app.doctor_name}`;
    document.getElementById('countdownSpecialty').textContent = nextAppt.app.specialization;
    
    const badge = document.getElementById('countdownBadge');
    if (nextAppt.app.status === 'checked_in') {
      badge.textContent = 'CHECKED IN & QUEUED';
      badge.className = 'text-[10px] font-extrabold text-teal-400 uppercase tracking-widest bg-teal-500/10 border border-teal-500/20 px-2 py-0.5 rounded-md animate-pulse';
    } else {
      badge.textContent = 'CONFIRMED DISPATCH';
      badge.className = 'text-[10px] font-extrabold text-emerald-400 uppercase tracking-widest bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded-md';
    }

    const actionBtn = document.getElementById('cdActionBtn');
    actionBtn.onclick = () => {
      window.location.href = `/consultation/${nextAppt.app.id}`;
    };
    actionBtn.innerHTML = `<i class="fas fa-video animate-pulse"></i> Join Call`;

    const cdCalendarBtn = document.getElementById('cdCalendarBtn');
    const cdCalendarDropdown = document.getElementById('cdCalendarDropdown');
    cdCalendarBtn.onclick = (e) => {
      e.stopPropagation();
      cdCalendarDropdown.classList.toggle('hidden');
    };

    document.getElementById('cdGoogleCal').onclick = () => {
      const url = getGoogleCalendarUrl(nextAppt.app);
      window.open(url, '_blank');
      cdCalendarDropdown.classList.add('hidden');
    };

    document.getElementById('cdICal').onclick = () => {
      downloadICal(nextAppt.app);
      cdCalendarDropdown.classList.add('hidden');
    };

    if (activeCountdownInterval) clearInterval(activeCountdownInterval);
    
    function updateClock() {
      const now = new Date().getTime();
      const dist = nextAppt.targetTime.getTime() - now;
      
      if (dist < 0) {
        clearInterval(activeCountdownInterval);
        document.getElementById('cdDays').textContent = '00';
        document.getElementById('cdHours').textContent = '00';
        document.getElementById('cdMins').textContent = '00';
        document.getElementById('cdSecs').textContent = '00';
        badge.textContent = 'CONSULTATION ACTIVE';
        badge.className = 'text-[10px] font-extrabold text-rose-400 uppercase tracking-widest bg-rose-500/10 border border-rose-500/20 px-2 py-0.5 rounded-md animate-pulse';
        return;
      }

      const days = Math.floor(dist / (1000 * 60 * 60 * 24));
      const hours = Math.floor((dist % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const mins = Math.floor((dist % (1000 * 60 * 60)) / (1000 * 60));
      const secs = Math.floor((dist % (1000 * 60)) / 1000);

      document.getElementById('cdDays').textContent = String(days).padStart(2, '0');
      document.getElementById('cdHours').textContent = String(hours).padStart(2, '0');
      document.getElementById('cdMins').textContent = String(mins).padStart(2, '0');
      document.getElementById('cdSecs').textContent = String(secs).padStart(2, '0');
    }

    updateClock();
    activeCountdownInterval = setInterval(updateClock, 1000);
  }

  // Instant Client-side Search and Status Filters
  document.addEventListener('DOMContentLoaded', () => {
    loadChecklistState();
    initCountdownHUD();
    
    // Check permission silently if query API exists
    try {
      if (navigator.permissions && navigator.permissions.query) {
        navigator.permissions.query({ name: 'camera' }).then(camPermission => {
          updateHardwareUI('camera', camPermission.state);
          camPermission.onchange = () => updateHardwareUI('camera', camPermission.state);
        }).catch(() => {});

        navigator.permissions.query({ name: 'microphone' }).then(micPermission => {
          updateHardwareUI('microphone', micPermission.state);
          micPermission.onchange = () => updateHardwareUI('microphone', micPermission.state);
        }).catch(() => {});
      }
    } catch (e) {}

    function updateHardwareUI(device, state) {
      const desc = document.getElementById(device === 'camera' ? 'camDesc' : 'micDesc');
      const dot = document.getElementById(device === 'camera' ? 'camStatusDot' : 'micStatusDot');
      const icon = document.getElementById(device === 'camera' ? 'camIcon' : 'micIcon');

      if (state === 'granted') {
        desc.textContent = device === 'camera' ? "Access Active" : "Signal Calibrated";
        desc.className = "text-[10px] text-emerald-400 font-semibold";
        dot.className = "w-2 h-2 rounded-full bg-emerald-500 animate-none";
        icon.className = "w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-sm";
      } else if (state === 'denied') {
        desc.textContent = "Permission Blocked";
        desc.className = "text-[10px] text-rose-400 font-semibold";
        dot.className = "w-2 h-2 rounded-full bg-rose-500 animate-none";
        icon.className = "w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center text-rose-400 text-sm";
      } else {
        desc.textContent = "Permissions Pending";
        desc.className = "text-[10px] text-gray-500 font-semibold";
        dot.className = "w-2 h-2 rounded-full bg-gray-500 animate-pulse";
        icon.className = "w-8 h-8 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400 text-sm";
      }
    }

    const searchInput = document.getElementById('appointmentSearch');
    const searchClearBtn = document.getElementById('searchClearBtn');
    const rows = document.querySelectorAll('.appointment-row');
    const noMatchesRow = document.getElementById('noMatchesRow');
    const noAppointmentsRow = document.getElementById('noAppointmentsRow');
    const filterButtons = document.querySelectorAll('#statusFilterGroup button');

    function filterAppointments() {
      const query = searchInput.value.toLowerCase().trim();
      const activeFilterBtn = document.querySelector('#statusFilterGroup .active-filter');
      const activeFilter = activeFilterBtn ? activeFilterBtn.getAttribute('data-filter') : 'all';
      let matchedCount = 0;

      rows.forEach(row => {
        const docName = row.getAttribute('data-doctor') || '';
        const specialty = row.getAttribute('data-specialty') || '';
        const symptoms = row.getAttribute('data-symptoms') || '';
        const status = row.getAttribute('data-status') || '';

        const matchesQuery = !query || docName.includes(query) || specialty.includes(query) || symptoms.includes(query);
        const matchesFilter = activeFilter === 'all' || status === activeFilter;

        if (matchesQuery && matchesFilter) {
          row.classList.remove('hidden');
          matchedCount++;
        } else {
          row.classList.add('hidden');
        }
      });

      if (searchInput.value) {
        searchClearBtn.classList.remove('hidden');
      } else {
        searchClearBtn.classList.add('hidden');
      }

      if (matchedCount === 0 && rows.length > 0) {
        noMatchesRow.classList.remove('hidden');
      } else {
        noMatchesRow.classList.add('hidden');
      }
    }

    searchInput.addEventListener('input', filterAppointments);

    searchClearBtn.addEventListener('click', () => {
      searchInput.value = '';
      filterAppointments();
    });

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        filterButtons.forEach(b => {
          b.className = "px-3 py-1.5 rounded-lg text-xs font-bold bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white transition-all border border-white/5";
          b.classList.remove('active-filter');
        });
        btn.className = "px-3 py-1.5 rounded-lg text-xs font-bold bg-indigo-500 text-white shadow-lg shadow-indigo-500/20 transition-all border border-indigo-500/20 active-filter";
        filterAppointments();
      });
    });

    // Close all open calendar dropdowns on global click
    document.addEventListener('click', (e) => {
      document.querySelectorAll('.row-calendar-wrapper div').forEach(div => {
        div.classList.add('hidden');
      });
      const cdCalendarDropdown = document.getElementById('cdCalendarDropdown');
      if (cdCalendarDropdown && !e.target.closest('#cdCalendarWrapper')) {
        cdCalendarDropdown.classList.add('hidden');
      }

      // If clicked row calendar button, toggle dropdown
      const rowBtn = e.target.closest('.row-calendar-btn');
      if (rowBtn) {
        e.stopPropagation();
        const wrapper = rowBtn.closest('.row-calendar-wrapper');
        if (wrapper) {
          const dropdown = wrapper.querySelector('div');
          if (dropdown) dropdown.classList.toggle('hidden');
        }
      }
    });
  });
</script>


<% var title = 'My Lab Reports - HMS'; %>
<%- include('../partials/header') %>

<div class="container-fluid">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'lab-reports' }) %>

    <div class="col-md-9 col-lg-10 p-4">
      <h2 class="fw-bold mb-4"><i class="fas fa-flask text-primary me-2"></i>My Lab Reports</h2>

      <div class="row g-4">
        <% if (reports.length === 0) { %>
          <div class="col-12 text-center py-5">
            <div class="card p-5 border-0 shadow-sm">
              <i class="fas fa-flask fa-4x text-muted mb-3"></i>
              <h4 class="text-muted">No lab reports found</h4>
              <p class="text-muted">Your reports will appear here once the hospital uploads them.</p>
            </div>
          </div>
        <% } %>

        <% reports.forEach(report => { %>
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 border-top border-primary border-4">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <span class="badge bg-primary"><%= report.test_type %></span>
                  <small class="text-muted"><%= new Date(report.created_at).toLocaleDateString() %></small>
                </div>
                <h5 class="card-title fw-bold mb-3"><%= report.report_name %></h5>
                <div class="d-grid">
                  <a href="<%= report.file_path %>" target="_blank" class="btn btn-outline-primary">
                    <i class="fas fa-download me-2"></i>Download / View PDF
                  </a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<script>
  socket.on('new-lab-report', (data) => {
    if (data.patientId == currentUser.id) {
      showToast('New Lab Report Available!', `Your ${data.testType} report "${data.reportName}" has been uploaded.`, 'success');
      // Optionally reload or append to UI
      setTimeout(() => location.reload(), 3000);
    }
  });
</script>

<%- include('../partials/footer') %>

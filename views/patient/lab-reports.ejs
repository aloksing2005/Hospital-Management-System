<% var title = 'My Lab Reports - HMS Premium'; %>
<%- include('../partials/header') %>

<style>
  /* Diagnostic SaaS widgets */
  .lab-widget {
    background: rgba(15, 23, 42, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
  }
  .lab-widget:hover {
    transform: translateY(-5px);
    border-color: rgba(99, 102, 241, 0.35);
    box-shadow: 0 10px 35px rgba(99, 102, 241, 0.15);
  }
  .lab-icon-container {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
    border: 1px solid rgba(99, 102, 241, 0.2);
    transition: all 0.3s ease;
  }
  .lab-widget:hover .lab-icon-container {
    transform: scale(1.08) rotate(5deg);
    border-color: rgba(99, 102, 241, 0.5);
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.2) 0%, rgba(139, 92, 246, 0.2) 100%);
  }
  .download-btn {
    position: relative;
    overflow: hidden;
    background: linear-gradient(90deg, #4f46e5 0%, #6366f1 100%);
    transition: all 0.3s ease;
  }
  .download-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
    transition: all 0.5s ease;
  }
  .download-btn:hover::before {
    left: 100%;
  }
  .download-btn:hover {
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
    transform: scale(1.02);
  }
</style>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'lab-reports' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="mb-8 animate-fade-in flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">My Lab Reports</h1>
        <p class="text-gray-400 font-medium">View and download your laboratory test results</p>
      </div>
      <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-xl border border-white/10 shrink-0 self-start md:self-auto">
        <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse"></div>
        <span class="text-sm font-bold text-gray-300">Lab Uplink synced</span>
      </div>
    </div>

    <!-- Clinical Telemetry Header Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8 animate-fade-in">
      <div class="hms-card p-4 flex items-center justify-between border-l-4 border-indigo-500">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Total Reports</p>
          <h3 class="text-2xl font-black text-white mt-1"><%= reports.length %></h3>
        </div>
        <div class="w-10 h-10 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 text-base">
          <i class="fas fa-file-medical"></i>
        </div>
      </div>
      <div class="hms-card p-4 flex items-center justify-between border-l-4 border-emerald-500">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Secured Status</p>
          <h3 class="text-2xl font-black text-white mt-1">VERIFIED</h3>
        </div>
        <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 text-base">
          <i class="fas fa-shield-check"></i>
        </div>
      </div>
      <div class="hms-card p-4 flex items-center justify-between border-l-4 border-cyan-500">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Diagnostic Quality</p>
          <h3 class="text-2xl font-black text-white mt-1">4K px-HUD</h3>
        </div>
        <div class="w-10 h-10 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 text-base">
          <i class="fas fa-dna"></i>
        </div>
      </div>
    </div>

    <!-- Lab Reports Grid -->
    <% if (reports.length === 0) { %>
      <div class="hms-card text-center py-20 animate-fade-in relative overflow-hidden">
        <div class="hud-grid-overlay"></div>
        <i class="fas fa-flask text-6xl text-slate-700 mb-4 block animate-pulse"></i>
        <h3 class="text-xl font-bold text-white mb-2">No clinical reports available</h3>
        <p class="text-gray-400 text-sm max-w-sm mx-auto leading-relaxed">Your lab reports will synchronize here automatically once clinical processing has resolved.</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% reports.forEach(report => { %>
          <div class="lab-widget rounded-3xl p-6 relative overflow-hidden animate-scale-in flex flex-col justify-between group">
            <div class="hud-grid-overlay"></div>
            
            <div>
              <div class="flex justify-between items-center mb-5 relative z-10">
                <span class="px-2.5 py-1 text-[10px] font-black uppercase tracking-wider bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 rounded-lg"><%= report.test_type %></span>
                <span class="text-[10px] text-gray-400 font-bold font-mono"><%= new Date(report.created_at).toLocaleDateString() %></span>
              </div>
              
              <div class="flex items-start gap-4 mb-6 relative z-10">
                <div class="lab-icon-container w-12 h-12 rounded-2xl flex items-center justify-center text-indigo-400 text-lg shrink-0 shadow-lg">
                  <i class="fas fa-file-waveform"></i>
                </div>
                <div>
                  <h3 class="text-md font-bold text-white leading-tight mb-1 group-hover:text-indigo-400 transition-colors"><%= report.report_name %></h3>
                  <span class="text-[9px] text-gray-500 uppercase tracking-widest font-bold font-mono block">Size: 1.2 MB • AI Audited</span>
                </div>
              </div>
            </div>
            
            <a href="<%= report.file_path %>" target="_blank" class="download-btn w-full py-3.5 rounded-2xl text-xs font-black text-white uppercase tracking-wider flex items-center justify-center gap-2 cursor-pointer shadow-lg z-10 hover:shadow-indigo-500/20 active:scale-95 transition-all">
              <i class="fas fa-download mr-1 transition-transform group-hover:translate-y-0.5"></i> Download report
            </a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<script>
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  if (socket) {
    socket.on('new-lab-report', (data) => {
      if (String(data.patientId || '') === '<%= user.id %>') {
        if (typeof window.hmsShowToast === 'function') {
          window.hmsShowToast('Lab Report', (data.reportName || 'New report') + ' uploaded', 'info');
        }
        location.reload();
      }
    });
  }
</script>

<%- include('../partials/footer') %>

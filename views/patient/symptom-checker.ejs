<% var title = 'AI Symptom Checker - HMS'; %>
<%- include('../partials/header') %>

<div class="container-fluid">
  <div class="row">
    <div class="col-md-3 col-lg-2 sidebar p-0">
      <div class="p-3 text-white">
        <h5 class="fw-bold"><i class="fas fa-heartbeat me-2"></i>Patient Panel</h5>
      </div>
      <nav class="nav flex-column">
        <a class="nav-link" href="/patient/dashboard"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a>
        <a class="nav-link" href="/patient/doctors"><i class="fas fa-user-md me-2"></i>Find Doctors</a>
        <a class="nav-link" href="/patient/appointments"><i class="fas fa-calendar-check me-2"></i>My Appointments</a>
        <a class="nav-link" href="/patient/prescriptions"><i class="fas fa-file-prescription me-2"></i>Prescriptions</a>
        <a class="nav-link active" href="/patient/symptom-checker"><i class="fas fa-brain me-2"></i>AI Symptom Checker</a>
        <a class="nav-link" href="/patient/chat"><i class="fas fa-comments me-2"></i>Chat</a>
      </nav>
    </div>

    <div class="col-md-9 col-lg-10 p-4">
      <h2 class="fw-bold mb-4"><i class="fas fa-brain me-2"></i>AI Symptom Checker</h2>

      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="card p-4 mb-4">
            <h5 class="fw-bold mb-3">Describe Your Symptoms</h5>
            <form action="/patient/symptom-checker" method="POST">
              <div class="mb-3">
                <textarea name="symptoms" class="form-control" rows="4" required 
                  placeholder="Example: I have fever, headache, and cough since yesterday..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="fas fa-stethoscope me-2"></i>Analyze Symptoms
              </button>
            </form>

            <div class="mt-3 p-3 bg-light rounded">
              <small class="text-muted">
                <i class="fas fa-info-circle me-1"></i>
                Common symptoms: fever, cough, cold, headache, stomach pain, chest pain, skin rash, eye pain, toothache, back pain
              </small>
            </div>
          </div>

          <% if (result) { %>
            <div class="card p-4 border-primary" style="border-left: 4px solid var(--primary)">
              <h5 class="fw-bold text-primary mb-3"><i class="fas fa-clipboard-list me-2"></i>Analysis Result</h5>

              <div class="mb-3">
                <h6 class="fw-bold">Detected Symptoms:</h6>
                <p class="text-muted"><%= result.symptoms %></p>
              </div>

              <% if (result.specialization) { %>
                <div class="mb-3 p-3 bg-info bg-opacity-10 rounded">
                  <h6 class="fw-bold text-info"><i class="fas fa-user-md me-2"></i>Recommended Specialist:</h6>
                  <p class="mb-0 fs-5"><%= result.specialization %></p>
                </div>
              <% } %>

              <div class="mb-3">
                <h6 class="fw-bold"><i class="fas fa-pills me-2"></i>Suggested Medicines:</h6>
                <ul class="list-group">
                  <% result.medicines.forEach(med => { %>
                    <li class="list-group-item"><i class="fas fa-capsules me-2 text-success"></i><%= med %></li>
                  <% }) %>
                </ul>
              </div>

              <div class="alert alert-warning" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Important:</strong> <%= result.recommendation %> This is AI-based suggestion only. Please consult a doctor for proper diagnosis.
              </div>

              <a href="/patient/doctors?specialization=<%= result.specialization %>" class="btn btn-primary">
                <i class="fas fa-user-md me-2"></i>Find <%= result.specialization %>
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

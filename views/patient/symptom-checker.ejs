<% var title = 'AI Symptom Checker - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'ai-chat' }) %>

  <!-- Main Content -->
  <div class="flex-grow overflow-y-auto p-6 lg:p-12 hms-page-transition">
    <div class="mb-10 animate-fade-in">
      <h1 class="text-3xl font-black text-white tracking-tight flex items-center gap-3">
        <i class="fas fa-brain text-indigo-400"></i>AI Symptom Checker
      </h1>
      <p class="text-gray-400 font-medium text-sm mt-1">Get instant insights about your symptoms powered by clinical intelligence.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Input Card -->
      <div class="lg:col-span-6 hms-card animate-scale-in">
        <h3 class="text-xl font-bold text-white mb-4">Describe Your Symptoms</h3>
        <p class="text-gray-400 text-sm mb-6">Type how you feel in plain language. Mention severity, duration, and any factors that make it better or worse.</p>
        
        <form action="/patient/symptom-checker" method="POST" class="space-y-6">
          <div>
            <textarea 
              name="symptoms" 
              class="hms-input min-h-[140px] resize-none" 
              required 
              placeholder="Example: I have a high fever, sharp headache behind the eyes, and dry cough for the last two days..."
            ></textarea>
          </div>
          <button type="submit" class="hms-btn hms-btn-primary w-full py-4 text-base flex items-center justify-center gap-2">
            <i class="fas fa-stethoscope"></i>Analyze Symptoms
          </button>
        </form>

        <div class="mt-6 p-4 rounded-2xl bg-white/5 border border-white/5">
          <small class="text-gray-400 leading-relaxed block">
            <i class="fas fa-info-circle text-indigo-400 mr-1"></i>
            <strong>Common symptoms:</strong> fever, cough, runny nose, headache, stomach ache, chest pain, rash, sore throat, joint pain
          </small>
        </div>
      </div>

      <!-- Result Card -->
      <div class="lg:col-span-6">
        <% if (result) { %>
          <div class="hms-card border-l-4 border-indigo-500 animate-scale-in space-y-6">
            <h3 class="text-xl font-bold text-white flex items-center gap-2">
              <i class="fas fa-clipboard-list text-indigo-400"></i>Analysis Result
            </h3>

            <div>
              <span class="text-xs font-black text-gray-400 uppercase tracking-widest block mb-2">Detected Symptoms</span>
              <p class="text-gray-200 bg-white/5 p-4 rounded-xl border border-white/5"><%= result.symptoms %></p>
            </div>

            <% if (result.specialization) { %>
              <div class="p-5 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl">
                <span class="text-xs font-black text-indigo-300 uppercase tracking-widest block mb-1">Recommended Specialist</span>
                <p class="text-white text-xl font-black tracking-tight"><%= result.specialization %></p>
              </div>
            <% } %>

            <div>
              <span class="text-xs font-black text-gray-400 uppercase tracking-widest block mb-3">Suggested Over-The-Counter Medicines</span>
              <ul class="space-y-2">
                <% result.medicines.forEach(med => { %>
                  <li class="flex items-center gap-3 text-gray-300 bg-white/5 px-4 py-3 rounded-xl border border-white/5">
                    <i class="fas fa-capsules text-emerald-400"></i>
                    <span class="font-medium"><%= med %></span>
                  </li>
                <% }) %>
              </ul>
            </div>

            <div class="p-4 bg-amber-500/10 border border-amber-500/20 rounded-2xl text-amber-300 text-sm flex gap-3">
              <i class="fas fa-exclamation-triangle mt-0.5 shrink-0"></i>
              <p class="leading-relaxed"><strong>Important clinical disclaimer:</strong> <%= result.recommendation %> This is an AI assessment. Always consult a healthcare professional for proper medical diagnostics.</p>
            </div>

            <a href="/patient/doctors?specialization=<%= result.specialization %>" class="hms-btn hms-btn-primary w-full py-4 text-center block">
              <i class="fas fa-user-md mr-1.5"></i>Find <%= result.specialization %>
            </a>
          </div>
        <% } else { %>
          <div class="hms-glass-premium rounded-[32px] p-10 text-center flex flex-col items-center justify-center min-h-[350px]">
            <div class="w-16 h-16 bg-white/5 border border-white/10 text-gray-400 rounded-2xl flex items-center justify-center text-2xl mb-4">
              <i class="fas fa-heartbeat"></i>
            </div>
            <h4 class="text-lg font-bold text-white mb-2">Awaiting Diagnosis Input</h4>
            <p class="text-gray-400 text-sm max-w-xs mx-auto">Fill in the symptoms form on the left to invoke our AI diagnosis assistant and fetch recommendations.</p>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>

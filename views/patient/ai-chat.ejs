<% var title = 'AI Chat Assistant - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <%- include('../partials/patient-sidebar', { active: 'ai-chat' }) %>
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <div class="mb-8 animate-fade-in flex justify-between items-start">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">AI Smart Appointment Assistant</h1>
        <p class="text-gray-400 font-medium">Describe symptoms — get specialty, medicines & book appointments</p>
      </div>
      <a href="/patient/ai-consultation" class="hms-btn hms-btn-secondary text-sm"><i class="fas fa-video mr-2"></i>Video AI Call</a>
    </div>

    <div class="hms-card animate-fade-in">
      <div class="chat-box" id="chatBox" style="height: 60vh; overflow-y: auto; padding: 20px;">
        <div class="chat-message bot-msg mb-3">
          <div class="bg-white/10 p-4 rounded-2xl rounded-tl-none max-w-[80%]">
            <p class="text-white">Hello! Describe your symptoms and I'll recommend a specialist, suggest care steps, and help you book an appointment.</p>
          </div>
        </div>
      </div>
      <div class="input-area p-4 border-t border-white/10 flex gap-3">
        <input type="text" id="userInput" class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-indigo-500 text-white placeholder-gray-400" placeholder="Describe your symptoms...">
        <button type="button" id="sendBtn" class="hms-btn hms-btn-primary">Send</button>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<script>
  let chatStep = 0;
  let sessionData = {};

  document.getElementById('sendBtn').addEventListener('click', sendMessage);
  document.getElementById('userInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') sendMessage();
  });

  function appendMsg(text, isUser) {
    const chatBox = document.getElementById('chatBox');
    const div = document.createElement('div');
    div.className = 'chat-message mb-3 ' + (isUser ? 'user-msg text-right' : 'bot-msg');
    const formatted = escapeHtml(text).replace(/\n/g, '<br>');
    div.innerHTML = '<div class="' + (isUser ? 'bg-indigo-600 ml-auto' : 'bg-white/10') + ' p-4 rounded-2xl inline-block max-w-[80%]"><p class="text-white text-sm leading-relaxed">' + formatted + '</p></div>';
    chatBox.appendChild(div);
    chatBox.scrollTop = chatBox.scrollHeight;
  }

  function escapeHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  async function sendMessage() {
    const input = document.getElementById('userInput');
    const message = input.value.trim();
    if (!message && chatStep !== 0) return;
    if (message) { appendMsg(message, true); input.value = ''; }
    appendMsg('Analyzing...', false);

    try {
      const res = await fetch('/patient/ai-chat/process', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: message || 'hello', step: chatStep, sessionData })
      });
      const data = await res.json();
      const chatBox = document.getElementById('chatBox');
      if (chatBox.lastChild) chatBox.removeChild(chatBox.lastChild);

      if (data.reply) appendMsg(data.reply.replace(/<[^>]+>/g, ''), false);
      chatStep = data.step !== undefined ? data.step : (data.nextStep || chatStep + 1);
      if (data.sessionData) sessionData = data.sessionData;

      if (data.doctors && data.doctors.length) {
        let docList = 'Recommended doctors — visit Find Doctors to book:\n';
        data.doctors.forEach(d => {
          docList += '• Dr. ' + d.name + ' (' + d.specialization + ') — ₹' + d.fees + '\n';
        });
        appendMsg(docList, false);
      }
    } catch (e) {
      const chatBox = document.getElementById('chatBox');
      if (chatBox.lastChild) chatBox.removeChild(chatBox.lastChild);
      appendMsg('Sorry, I could not process that. Please try again.', false);
    }
  }

  sendMessage();
</script>

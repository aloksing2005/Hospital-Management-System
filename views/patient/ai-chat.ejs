<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Appointment Assistant</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <style>
        .chat-container { max-width: 600px; margin: auto; height: 70vh; display: flex; flex-direction: column; background: #fff; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .chat-box { flex-grow: 1; overflow-y: auto; padding: 20px; }
        .chat-message { margin-bottom: 15px; max-width: 80%; }
        .bot-msg { background: #f1f1f1; padding: 10px 15px; border-radius: 15px 15px 15px 0; align-self: flex-start; }
        .user-msg { background: #007bff; color: white; padding: 10px 15px; border-radius: 15px 15px 0 15px; align-self: flex-end; margin-left: auto; }
        .input-area { padding: 15px; border-top: 1px solid #ddd; display: flex; }
    </style>
</head>
<body class="bg-light">
    <%- include('../partials/header') %>

    <div class="container mt-4">
        <h2 class="text-center mb-4">🤖 AI Smart Appointment Assistant</h2>
        <div class="chat-container">
            <div class="chat-box" id="chatBox">
                <!-- Messages will appear here -->
            </div>
            <div class="input-area">
                <input type="text" id="userInput" class="form-control me-2" placeholder="Describe your symptoms...">
                <button id="sendBtn" class="btn btn-primary">Send</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentStep = 0;
        let appointmentData = {};
        const chatBox = document.getElementById('chatBox');
        const userInput = document.getElementById('userInput');
        const sendBtn = document.getElementById('sendBtn');

        function appendMessage(text, sender) {
            const div = document.createElement('div');
            div.className = `chat-message ${sender === 'user' ? 'user-msg' : 'bot-msg'}`;
            div.innerHTML = text;
            chatBox.appendChild(div);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        async function sendMessageToServer(message, data = {}) {
            try {
                const res = await fetch('/patient/ai-chat/process', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message, step: currentStep, data })
                });
                const response = await res.json();
                
                appendMessage(response.reply, 'bot');
                currentStep = response.nextStep;
                
                if (response.symptoms) {
                    appointmentData.symptoms = response.symptoms;
                }
            } catch (err) {
                console.error(err);
                appendMessage("Sorry, an error occurred.", "bot");
            }
        }

        // Initialize chat
        sendMessageToServer("");

        sendBtn.addEventListener('click', () => {
            const msg = userInput.value.trim();
            if (!msg) return;
            appendMessage(msg, 'user');
            userInput.value = '';
            
            if (currentStep === 1) {
                sendMessageToServer(msg);
            } else if (currentStep === 2) {
                // If step is 2, expecting user to click a doctor button. Text input is fallback.
                appendMessage("Please select a doctor from the list above.", "bot");
            } else if (currentStep === 3) {
                 // Date picking fallback
                 const dateRegex = /^\d{4}-\d{2}-\d{2}$/;
                 if(dateRegex.test(msg)){
                     appointmentData.date = msg;
                     sendMessageToServer("Date selected", appointmentData);
                 } else {
                     appendMessage("Please provide a valid date (YYYY-MM-DD)", "bot");
                 }
            }
        });

        userInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendBtn.click();
        });

        // Event delegation for dynamic buttons
        chatBox.addEventListener('click', (e) => {
            if (e.target.classList.contains('doc-select-btn')) {
                const btn = e.target;
                appointmentData.doctorId = btn.dataset.id;
                appointmentData.fromTime = btn.dataset.from;
                appointmentData.toTime = btn.dataset.to;
                appendMessage(`Selected Dr. ${btn.dataset.name}`, 'user');
                appendMessage(`Please enter a date for your appointment (YYYY-MM-DD):`, 'bot');
                currentStep = 3; // Manually advance to date selection
            }
            if (e.target.classList.contains('slot-select-btn')) {
                const btn = e.target;
                appointmentData.timeSlot = btn.dataset.slot;
                appendMessage(`Selected time: ${appointmentData.timeSlot}`, 'user');
                sendMessageToServer("Slot selected", appointmentData);
            }
        });
    </script>
</body>
</html>

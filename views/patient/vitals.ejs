<% var title = title || 'Live Vitals'; %>
<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'vitals' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex flex-wrap justify-between items-center gap-3 mb-8 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2"><i class="fas fa-wave-square mr-2 text-emerald-400"></i>Live Vitals</h1>
        <p class="text-gray-400 font-medium">Simulated stream for monitoring demo — use "Start monitoring" below</p>
      </div>
      <div class="flex gap-3">
        <button type="button" class="hms-btn hms-btn-success rounded-full px-6" id="btnStartVitals">Start monitoring</button>
        <button type="button" class="hms-btn hms-btn-outline rounded-full px-6" id="btnStopVitals">Stop</button>
      </div>
    </div>

    <!-- Vitals Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8 animate-scale-in">
      <div class="hms-card text-center p-6">
        <p class="text-gray-400 text-sm mb-2">Heart Rate</p>
        <h3 class="text-3xl font-black text-rose-400 mb-0" id="vHr">—</h3>
        <p class="text-xs text-gray-500 mt-1">BPM</p>
      </div>
      <div class="hms-card text-center p-6">
        <p class="text-gray-400 text-sm mb-2">SpO₂</p>
        <h3 class="text-3xl font-black text-cyan-400 mb-0" id="vSpo2">—</h3>
        <p class="text-xs text-gray-500 mt-1">%</p>
      </div>
      <div class="hms-card text-center p-6">
        <p class="text-gray-400 text-sm mb-2">BP</p>
        <h3 class="text-3xl font-black text-indigo-400 mb-0" id="vBp">—</h3>
        <p class="text-xs text-gray-500 mt-1">mmHg</p>
      </div>
      <div class="hms-card text-center p-6">
        <p class="text-gray-400 text-sm mb-2">Temp</p>
        <h3 class="text-3xl font-black text-amber-400 mb-0" id="vTemp">—</h3>
        <p class="text-xs text-gray-500 mt-1">°F</p>
      </div>
    </div>

    <!-- Vitals Chart -->
    <div class="hms-card p-6 animate-fade-in">
      <canvas id="vitalsChart" height="120"></canvas>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<script>
(function () {
  var pid = '<%= user.id %>';
  var chart;
  var socket;
  
  function initVitals() {
    var ctx = document.getElementById('vitalsChart');
    if (ctx && window.Chart) {
      chart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: [],
          datasets: [
            { label: 'HR', data: [], borderColor: '#a78bfa', tension: 0.35, fill: false },
            { label: 'SpO2', data: [], borderColor: '#22d3ee', tension: 0.35, fill: false }
          ]
        },
        options: {
          plugins: { legend: { labels: { color: '#e2e8f0' } } },
          scales: {
            x: { ticks: { color: '#94a3b8', maxTicksLimit: 8 }, grid: { color: 'rgba(148,163,184,0.08)' } },
            y: { ticks: { color: '#94a3b8' }, grid: { color: 'rgba(148,163,184,0.08)' }, beginAtZero: false }
          }
        }
      });
    }
    
    socket = window.hmsSocket ? window.hmsSocket() : null;
    if (socket) {
      socket.on('vitals-update', function (payload) {
        if (payload.patientId === '<%= user.id %>') {
          const v = payload.vitals;
          const hrEl = document.getElementById('vHr');
          const spo2El = document.getElementById('vSpo2');
          const bpEl = document.getElementById('vBp');
          const tempEl = document.getElementById('vTemp');
          if (hrEl) hrEl.textContent = v.hr + ' BPM';
          if (spo2El) spo2El.textContent = v.spo2 + ' %';
          if (bpEl) bpEl.textContent = v.bpSys + '/' + v.bpDia;
          if (tempEl) tempEl.textContent = v.temp + ' °F';
          
          if (chart) {
            var t = new Date().toLocaleTimeString();
            chart.data.labels.push(t);
            chart.data.datasets[0].data.push(v.hr);
            chart.data.datasets[1].data.push(v.spo2);
            if (chart.data.labels.length > 12) {
              chart.data.labels.shift();
              chart.data.datasets[0].data.shift();
              chart.data.datasets[1].data.shift();
            }
            chart.update('none');
          }
        }
      });
      
      const btnStart = document.getElementById('btnStartVitals');
      if (btnStart) {
        btnStart.addEventListener('click', function () {
          socket.emit('start-vitals-monitoring', { patientId: pid });
          if (window.hmsShowToast) window.hmsShowToast('Vitals', 'Monitoring stream started', 'success');
        });
      }
      
      const btnStop = document.getElementById('btnStopVitals');
      if (btnStop) {
        btnStop.addEventListener('click', function () {
          socket.emit('stop-vitals-monitoring');
          if (window.hmsShowToast) window.hmsShowToast('Vitals', 'Stopped', 'info');
        });
      }
    }
  }
  
  document.addEventListener('DOMContentLoaded', initVitals);
})();
</script>

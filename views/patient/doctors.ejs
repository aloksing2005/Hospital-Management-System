<% var title = 'Find Doctors - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'doctors' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
      <div class="mb-8 animate-fade-in">
        <h1 class="text-3xl font-black text-white mb-2">Find Doctors</h1>
        <p class="text-gray-400 font-medium">Search and book appointments with our healthcare professionals</p>
      </div>

      <!-- Advanced Search -->
      <div class="hms-card mb-8 animate-scale-in">
        <form action="/patient/doctors" method="GET" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
            <div>
              <label class="hms-label">Search Name</label>
              <input type="text" name="search" class="hms-input" placeholder="Doctor's name..." value="<%= search || '' %>">
            </div>
            <div>
              <label class="hms-label">Specialization</label>
              <select name="specialization" class="hms-input hms-select">
                <option value="">All Specializations</option>
                <option value="General Physician" <%= specialization === 'General Physician' ? 'selected' : '' %>>General Physician</option>
                <option value="Cardiologist" <%= specialization === 'Cardiologist' ? 'selected' : '' %>>Cardiologist</option>
                <option value="Dermatologist" <%= specialization === 'Dermatologist' ? 'selected' : '' %>>Dermatologist</option>
                <option value="Neurologist" <%= specialization === 'Neurologist' ? 'selected' : '' %>>Neurologist</option>
                <option value="Orthopedic" <%= specialization === 'Orthopedic' ? 'selected' : '' %>>Orthopedic</option>
                <option value="ENT" <%= specialization === 'ENT' ? 'selected' : '' %>>ENT</option>
                <option value="Pediatrician" <%= specialization === 'Pediatrician' ? 'selected' : '' %>>Pediatrician</option>
                <option value="Gynecologist" <%= specialization === 'Gynecologist' ? 'selected' : '' %>>Gynecologist</option>
              </select>
            </div>
            <div>
              <label class="hms-label">Max Fees (₹)</label>
              <input type="number" name="maxFees" class="hms-input" placeholder="E.g. 1000" value="<%= typeof maxFees !== 'undefined' ? maxFees : '' %>">
            </div>
            <div>
              <label class="hms-label">Min Rating</label>
              <select name="minRating" class="hms-input hms-select">
                <option value="">Any</option>
                <option value="4" <%= typeof minRating !== 'undefined' && minRating === '4' ? 'selected' : '' %>>4+ Stars</option>
                <option value="3" <%= typeof minRating !== 'undefined' && minRating === '3' ? 'selected' : '' %>>3+ Stars</option>
              </select>
            </div>
            <div>
              <label class="hms-label">Sort By</label>
              <select name="sort" class="hms-input hms-select">
                <option value="">Name A-Z</option>
                <option value="top_rated" <%= typeof sort !== 'undefined' && sort === 'top_rated' ? 'selected' : '' %>>Top Rated</option>
                <option value="lowest_fees" <%= typeof sort !== 'undefined' && sort === 'lowest_fees' ? 'selected' : '' %>>Lowest Fees</option>
              </select>
            </div>
          </div>
          <div class="flex justify-end gap-3">
            <a href="/patient/doctors" class="hms-btn hms-btn-secondary">Clear</a>
            <button type="submit" class="hms-btn hms-btn-primary">
              <i class="fas fa-filter"></i>
              Apply Filters
            </button>
          </div>
        </form>
      </div>

      <!-- Doctors Grid -->
      <% if (doctors.length === 0) { %>
        <div class="hms-card text-center py-16 animate-fade-in">
          <i class="fas fa-search text-5xl text-gray-600 mb-4 block"></i>
          <h3 class="text-xl font-bold text-white mb-2">No doctors found</h3>
          <p class="text-gray-400">Try adjusting your search filters</p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% doctors.forEach(doc => { %>
            <div class="hms-card animate-scale-in">
              <div class="text-center">
                <img src="<%= doc.photo || 'https://i.pravatar.cc/150?u=' + doc.id %>" alt="<%= doc.name %>" class="w-24 h-24 rounded-2xl mx-auto mb-4 object-cover shadow-lg">
                <h3 class="text-xl font-bold text-white mb-2"><%= doc.name.startsWith('Dr.') ? doc.name : 'Dr. ' + doc.name %></h3>
                <span class="hms-badge hms-badge-primary mb-4 inline-block"><%= doc.specialization %></span>
                
                <div class="mb-4">
                  <% if (doc.rating > 0) { %>
                    <div class="flex items-center justify-center gap-2">
                      <div class="flex text-amber-400">
                        <% for(let i=0; i<5; i++) { %>
                          <i class="fas fa-star <%= i < Math.floor(doc.rating) ? '' : 'opacity-30' %>"></i>
                        <% } %>
                      </div>
                      <span class="text-white font-semibold"><%= parseFloat(doc.rating).toFixed(1) %></span>
                      <span class="text-gray-500 text-sm">(<%= doc.review_count %> reviews)</span>
                    </div>
                  <% } else { %>
                    <span class="text-gray-500 text-sm">No reviews yet</span>
                  <% } %>
                </div>

                <div class="space-y-3 mb-6">
                  <div class="flex items-center justify-center gap-2 text-gray-400 text-sm">
                    <i class="fas fa-map-marker-alt text-indigo-400"></i>
                    <span><%= doc.location || 'Location not set' %></span>
                  </div>
                  <div class="flex items-center justify-center gap-2 text-emerald-400 font-bold">
                    <i class="fas fa-rupee-sign"></i>
                    <span><%= doc.fees %> per visit</span>
                  </div>
                  <div class="flex items-center justify-center gap-2 text-gray-400 text-sm">
                    <i class="fas fa-clock text-indigo-400"></i>
                    <span><%= doc.available_from %> - <%= doc.available_to %></span>
                  </div>
                </div>

                <a href="/patient/doctors/<%= doc.id %>" class="hms-btn hms-btn-primary w-full">
                  <i class="fas fa-calendar-plus"></i>
                  Book Appointment
                </a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

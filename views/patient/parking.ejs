<% var title = 'Smart Parking - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <%- include('../partials/patient-sidebar', { active: 'parking' }) %>
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <div class="flex justify-between items-center mb-12 animate-fade-in">
      <div>
        <h1 class="text-4xl font-black text-white mb-2 tracking-tight">Smart Parking</h1>
        <p class="text-gray-400 text-xl">Reserve your spot before you arrive</p>
      </div>
      <div class="bg-emerald-500/20 text-emerald-400 px-6 py-2 rounded-xl font-bold text-sm">
        <i class="fas fa-car mr-2"></i> Available: <span id="availCount"><%= availableCount %></span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12" id="parkingGrid">
      <% slots.forEach((slot, idx) => { %>
        <div class="hms-card animate-scale-in" data-slot-id="<%= slot.id %>">
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 <%= slot.status === 'available' ? 'bg-emerald-500/20 text-emerald-400' : 'bg-rose-500/20 text-rose-400' %> rounded-xl flex items-center justify-center">
              <i class="fas fa-parking text-xl"></i>
            </div>
            <span class="hms-badge hms-badge-<%= slot.status === 'available' ? 'success' : 'danger' %> slot-status">
              <%= slot.status === 'available' ? 'Available' : slot.status === 'reserved' ? 'Reserved' : 'Occupied' %>
            </span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2"><%= slot.spot_code %></h3>
          <p class="text-gray-400 text-sm mb-4"><%= slot.zone %></p>
          <% if (slot.status === 'available') { %>
            <button type="button" class="hms-btn hms-btn-primary w-full reserve-btn" data-slot-id="<%= slot.id %>" data-spot="<%= slot.spot_code %>">Reserve Spot</button>
          <% } else { %>
            <button type="button" class="hms-btn hms-btn-disabled w-full" disabled>Unavailable</button>
          <% } %>
        </div>
      <% }) %>
    </div>

    <div class="hms-card animate-fade-in">
      <h3 class="text-2xl font-bold text-white mb-6">Your Reservations</h3>
      <% if (reservations.length === 0) { %>
        <div class="text-center py-12 text-gray-400" id="noReservations">
          <i class="fas fa-calendar-check text-4xl mb-4"></i>
          <p>No active reservations</p>
        </div>
      <% } else { %>
        <div class="space-y-4" id="reservationList">
          <% reservations.forEach(r => { %>
            <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-white/10">
              <div>
                <p class="text-white font-bold"><%= r.spot_code %></p>
                <p class="text-gray-400 text-sm"><%= new Date(r.created_at).toLocaleString() %></p>
              </div>
              <button type="button" class="hms-btn hms-btn-danger text-sm cancel-parking" data-id="<%= r.id %>">Cancel</button>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<script>
document.querySelectorAll('.reserve-btn').forEach(btn => {
  btn.addEventListener('click', async function() {
    const slotId = this.dataset.slotId;
    const spot = this.dataset.spot;
    if (!confirm('Reserve ' + spot + '?')) return;
    try {
      const res = await fetch('/patient/parking/book', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slot_id: slotId })
      });
      const data = await res.json();
      if (data.success) {
        window.hmsShowToast('Reserved', spot + ' booked successfully', 'success');
        setTimeout(() => location.reload(), 1000);
      } else {
        window.hmsShowToast('Error', data.error, 'error');
      }
    } catch (e) { window.hmsShowToast('Error', e.message, 'error'); }
  });
});
document.querySelectorAll('.cancel-parking').forEach(btn => {
  btn.addEventListener('click', async function() {
    if (!confirm('Cancel this reservation?')) return;
    const res = await fetch('/patient/parking/cancel/' + this.dataset.id, { method: 'POST' });
    const data = await res.json();
    if (data.success) location.reload();
  });
});
</script>

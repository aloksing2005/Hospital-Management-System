<% var title = 'Smart Parking - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<div class="container-fluid bg-gray-50 min-h-screen">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'parking' }) %>

    <div class="col-md-9 col-lg-10 p-12">
      <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-12">
            <div>
                <h2 class="text-5xl font-black text-gray-900 tracking-tight">Smart Parking</h2>
                <p class="text-gray-500 mt-2 text-xl">Reserve your spot before you arrive at the hospital.</p>
            </div>
            <div class="flex gap-4">
                <div class="bg-green-100 text-green-600 px-6 py-2 rounded-2xl font-bold text-sm">
                    <i class="fas fa-car mr-2"></i> 42 Slots Available
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Parking Grid -->
            <div class="lg:col-span-2 bg-white rounded-[40px] shadow-sm border border-gray-100 p-10">
                <div class="flex justify-between items-center mb-10">
                    <h3 class="text-2xl font-bold text-gray-800">Select a Slot</h3>
                    <div class="flex gap-4 text-xs font-bold uppercase tracking-widest text-gray-400">
                        <span class="flex items-center gap-2"><div class="w-3 h-3 bg-gray-100 rounded"></div> Available</span>
                        <span class="flex items-center gap-2"><div class="w-3 h-3 bg-indigo-600 rounded"></div> Selected</span>
                        <span class="flex items-center gap-2"><div class="w-3 h-3 bg-gray-900 rounded"></div> Occupied</span>
                    </div>
                </div>

                <div class="grid grid-cols-6 gap-4">
                    <% for(let i=1; i<=24; i++) { %>
                        <% const isOccupied = [3, 7, 12, 15, 18, 22].includes(i); %>
                        <button onclick="selectSlot(<%= i %>)" id="slot-<%= i %>" 
                            class="aspect-square rounded-2xl flex flex-col items-center justify-center transition-all duration-300 <%= isOccupied ? 'bg-gray-900 text-white cursor-not-allowed' : 'bg-gray-50 text-gray-400 hover:bg-indigo-50 hover:text-indigo-600 border border-transparent' %>">
                            <i class="fas fa-car-side mb-1"></i>
                            <span class="text-[10px] font-black">P-<%= i %></span>
                        </button>
                    <% } %>
                </div>
            </div>

            <!-- Booking Panel -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-[40px] shadow-sm border border-gray-100 p-8 sticky top-8">
                    <h3 class="text-2xl font-bold text-gray-900 mb-8">Booking Details</h3>
                    <div id="bookingInfo" class="space-y-6 mb-8">
                        <div class="p-6 bg-gray-50 rounded-3xl border border-gray-100 text-center py-12" id="noSlot">
                            <i class="fas fa-info-circle text-gray-200 text-4xl mb-4 block"></i>
                            <p class="text-gray-400 font-medium">Please select a parking slot to proceed.</p>
                        </div>
                        <div id="slotDetails" class="hidden animate__animated animate__fadeIn">
                            <div class="flex items-center justify-between p-6 bg-indigo-600 text-white rounded-3xl mb-6">
                                <div>
                                    <p class="text-xs font-bold opacity-70 uppercase">Selected Slot</p>
                                    <h4 class="text-3xl font-black" id="selectedSlotID">P-00</h4>
                                </div>
                                <i class="fas fa-check-circle text-3xl"></i>
                            </div>
                            <div class="space-y-4">
                                <input type="text" placeholder="Vehicle Number (e.g. DL 1C 1234)" class="w-full bg-gray-50 border-0 rounded-2xl px-6 py-4 outline-none focus:ring-2 focus:ring-indigo-600 transition">
                                <div class="grid grid-cols-2 gap-4">
                                    <input type="time" class="w-full bg-gray-50 border-0 rounded-2xl px-6 py-4 outline-none">
                                    <select class="w-full bg-gray-50 border-0 rounded-2xl px-6 py-4 outline-none">
                                        <option>1 Hour</option>
                                        <option>2 Hours</option>
                                        <option>4 Hours</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mt-8 border-t border-gray-50 pt-8">
                                <div class="flex justify-between text-2xl font-black text-gray-900">
                                    <span>Total</span>
                                    <span>$5.00</span>
                                </div>
                                <button class="mt-6 w-full bg-gray-900 text-white py-5 rounded-[30px] font-black text-lg hover:bg-black transition-all">Confirm Booking</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
    function selectSlot(id) {
        // Reset all buttons
        document.querySelectorAll('button[id^="slot-"]').forEach(btn => {
            if(!btn.classList.contains('bg-gray-900')) {
                btn.classList.remove('bg-indigo-600', 'text-white');
                btn.classList.add('bg-gray-50', 'text-gray-400');
            }
        });

        const btn = document.getElementById(`slot-${id}`);
        if(btn.classList.contains('bg-gray-900')) return;

        btn.classList.remove('bg-gray-50', 'text-gray-400');
        btn.classList.add('bg-indigo-600', 'text-white');

        document.getElementById('noSlot').classList.add('hidden');
        document.getElementById('slotDetails').classList.remove('hidden');
        document.getElementById('selectedSlotID').innerText = `P-${id}`;
    }
</script>

<%- include('../partials/footer') %>

<% var title = 'AI Diet Planner - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'diet' }) %>

  <!-- Main Content -->
  <div class="flex-grow overflow-y-auto p-6 lg:p-12 hms-page-transition">
    
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white tracking-tight flex items-center gap-3">
          <i class="fas fa-apple-alt text-indigo-400"></i>AI Smart Diet Planner
        </h1>
        <p class="text-gray-400 font-medium text-sm mt-1">Personalized nutrition and macro plans tailored to your health goals.</p>
      </div>
      <div class="w-12 h-12 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 rounded-2xl flex items-center justify-center text-xl shrink-0 shadow-lg">
        <i class="fas fa-utensils animate-pulse"></i>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Diet Inputs -->
      <div class="lg:col-span-4 space-y-6 animate-scale-in">
        <div class="hms-card">
          <h3 class="text-lg font-bold text-white mb-6">Health Profile</h3>
          <div class="space-y-4">
            <div>
              <label class="hms-label">Dietary Objective</label>
              <select id="dietGoal" class="hms-input hms-select">
                <option>Recovery from Fever</option>
                <option>Weight Management</option>
                <option>Diabetic Friendly</option>
                <option>Heart Healthy</option>
              </select>
            </div>
            <div>
              <label class="hms-label">Daily Activity Level</label>
              <select id="activity" class="hms-input hms-select">
                <option>Sedentary</option>
                <option>Moderate</option>
                <option>Active</option>
              </select>
            </div>
            <button onclick="generateDiet()" class="hms-btn hms-btn-primary w-full py-4 text-sm font-bold shadow-lg shadow-indigo-600/20 mt-2">
              Generate Plan
            </button>
          </div>
        </div>

        <div class="hms-card bg-gradient-to-br from-indigo-950 to-indigo-900 border border-indigo-500/20 text-white">
          <h4 class="font-bold mb-4 flex items-center gap-2"><i class="fas fa-chart-pie text-indigo-400"></i>Nutrient Ratio</h4>
          <div class="space-y-4 mt-6">
            <div>
              <div class="flex justify-between text-xs font-bold mb-1.5 text-gray-300">
                <span>Protein</span>
                <span id="macroProteinPct" class="text-white">--%</span>
              </div>
              <div class="w-full bg-slate-900 h-2 rounded-full border border-white/5">
                <div id="macroProteinBar" class="bg-indigo-500 h-full transition-all duration-500 rounded-full" style="width: 0%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-xs font-bold mb-1.5 text-gray-300">
                <span>Carbs</span>
                <span id="macroCarbsPct" class="text-white">--%</span>
              </div>
              <div class="w-full bg-slate-900 h-2 rounded-full border border-white/5">
                <div id="macroCarbsBar" class="bg-indigo-500 h-full transition-all duration-500 rounded-full" style="width: 0%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-xs font-bold mb-1.5 text-gray-300">
                <span>Fats</span>
                <span id="macroFatsPct" class="text-white">--%</span>
              </div>
              <div class="w-full bg-slate-900 h-2 rounded-full border border-white/5">
                <div id="macroFatsBar" class="bg-indigo-500 h-full transition-all duration-500 rounded-full" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Diet Output -->
      <div class="lg:col-span-8 animate-scale-in">
        <div class="hms-card min-h-[400px] flex flex-col justify-between relative overflow-hidden">
          <div id="dietPlaceholder" class="flex flex-col items-center justify-center my-auto text-center py-12">
            <div class="w-16 h-16 bg-white/5 border border-white/10 text-gray-400 rounded-2xl flex items-center justify-center text-2xl mb-4">
              <i class="fas fa-apple-alt animate-pulse"></i>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Set goals to generate your nutrition plan</h3>
            <p class="text-gray-400 text-sm max-w-xs mx-auto">Use the health profile controls on the left to initialize AI diet generation.</p>
          </div>

          <!-- Loading Spinner -->
          <div id="dietLoading" class="hidden flex flex-col items-center justify-center my-auto text-center py-12">
            <div class="relative w-20 h-20 mb-6">
              <div class="absolute inset-0 rounded-full border-4 border-white/5"></div>
              <div class="absolute inset-0 rounded-full border-4 border-indigo-500 border-t-transparent animate-spin"></div>
              <div class="absolute inset-4 bg-slate-900 rounded-full flex items-center justify-center text-indigo-400">
                <i class="fas fa-apple-alt animate-bounce"></i>
              </div>
            </div>
            <h3 class="text-lg font-bold text-white">Customizing Nutrition Plan...</h3>
            <p class="text-gray-400 mt-2 text-xs max-w-xs mx-auto">Calculating clinical caloric requirements and active macro splits for targeting.</p>
          </div>

          <div id="dietResult" class="hidden space-y-8">
            <h3 class="text-xl font-black text-white flex items-center gap-3 border-b border-white/10 pb-4">
              <i class="fas fa-calendar-day text-indigo-400"></i>Your Daily Meal Plan
            </h3>
            
            <div id="mealsContainer" class="space-y-4">
              <!-- Dynamic meal cards loaded via js -->
            </div>

            <!-- Clinical advice -->
            <div class="pt-6 border-t border-white/10">
              <h4 class="font-bold text-white mb-4 flex items-center gap-2">
                <i class="fas fa-stethoscope text-emerald-400 text-base"></i>Clinical & Nutritionist Advice
              </h4>
              <ul id="clinicalTipsList" class="space-y-3">
                <!-- Dynamic advice list -->
              </ul>
            </div>

            <!-- Redesigned footer statistics panel -->
            <div class="p-6 bg-slate-950 rounded-2xl border border-white/5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
              <div>
                <p class="text-[10px] font-black uppercase tracking-widest text-gray-400">Target Daily Calories</p>
                <p id="targetCalories" class="text-2xl font-black text-white mt-0.5">-- kcal</p>
              </div>
              <button class="hms-btn hms-btn-primary text-xs uppercase py-3.5 px-6 font-bold flex items-center gap-2 shadow-lg shadow-indigo-600/10">
                <i class="fas fa-mobile-alt"></i> Save to Mobile
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
    function recoverActivePlan(plan) {
        if (!plan) return;
        
        const placeholder = document.getElementById('dietPlaceholder');
        const result = document.getElementById('dietResult');
        
        placeholder.classList.add('hidden');
        result.classList.remove('hidden');

        // Set input fields if they exist
        const dietGoalSelect = document.getElementById('dietGoal');
        const activitySelect = document.getElementById('activity');
        if (dietGoalSelect && plan.goal) dietGoalSelect.value = plan.goal;
        if (activitySelect && plan.activity) activitySelect.value = plan.activity;

        // Update ratios
        const protein = plan.macros?.protein || 0;
        const carbs = plan.macros?.carbs || 0;
        const fats = plan.macros?.fats || 0;

        document.getElementById('macroProteinPct').innerText = protein + '%';
        document.getElementById('macroProteinBar').style.width = protein + '%';

        document.getElementById('macroCarbsPct').innerText = carbs + '%';
        document.getElementById('macroCarbsBar').style.width = carbs + '%';

        document.getElementById('macroFatsPct').innerText = fats + '%';
        document.getElementById('macroFatsBar').style.width = fats + '%';

        // Calories
        document.getElementById('targetCalories').innerText = (plan.calories || 0).toLocaleString() + ' kcal';

        // Meals
        const mealsContainer = document.getElementById('mealsContainer');
        mealsContainer.innerHTML = '';

        if (plan.meals && plan.meals.length > 0) {
            const colors = [
              'text-amber-400 bg-amber-500/10 border-amber-500/20', 
              'text-indigo-400 bg-indigo-500/10 border-indigo-500/20', 
              'text-emerald-400 bg-emerald-500/10 border-emerald-500/20', 
              'text-cyan-400 bg-cyan-500/10 border-cyan-500/20'
            ];
            plan.meals.forEach((meal, index) => {
                const colorClass = colors[index % colors.length];
                const mealHtml = `
                    <div class="flex flex-col sm:flex-row items-start gap-4 p-5 bg-white/5 rounded-2xl border border-white/5 hover:bg-white/10 transition-all">
                        <div class="px-4 py-2 rounded-xl text-xs font-bold shrink-0 border uppercase tracking-wider ${colorClass}">
                            ${meal.time || 'Meal'}
                        </div>
                        <div class="min-w-0">
                            <h4 class="font-bold text-white text-base">${meal.name || ''}</h4>
                            <p class="text-gray-400 text-sm mt-1 leading-relaxed">${meal.desc || ''}</p>
                        </div>
                    </div>
                `;
                mealsContainer.insertAdjacentHTML('beforeend', mealHtml);
            });
        } else {
            mealsContainer.innerHTML = '<p class="text-gray-500 text-center py-6">No meal details found.</p>';
        }

        // Clinical Tips
        const tipsList = document.getElementById('clinicalTipsList');
        tipsList.innerHTML = '';
        if (plan.advice && plan.advice.length > 0) {
            plan.advice.forEach(tip => {
                const tipHtml = `
                    <li class="flex items-start gap-3 text-xs text-gray-300 leading-relaxed">
                        <i class="fas fa-check-circle text-emerald-400 mt-0.5 shrink-0"></i>
                        <span>${tip}</span>
                    </li>
                `;
                tipsList.insertAdjacentHTML('beforeend', tipHtml);
            });
        } else {
            tipsList.innerHTML = '<li class="text-gray-500 text-xs">Follow general healthy eating habits.</li>';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const activePlan = <%- typeof activePlan !== 'undefined' && activePlan ? JSON.stringify(activePlan) : 'null' %>;
        if (activePlan) {
            recoverActivePlan(activePlan);
        }
    });

    async function generateDiet() {
        const goal = document.getElementById('dietGoal').value;
        const activity = document.getElementById('activity').value;

        const placeholder = document.getElementById('dietPlaceholder');
        const loading = document.getElementById('dietLoading');
        const result = document.getElementById('dietResult');

        placeholder.classList.add('hidden');
        result.classList.add('hidden');
        loading.classList.remove('hidden');

        try {
            const response = await fetch('/patient/diet-planner/generate', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ goal, activity })
            });

            const data = await response.json();
            if (!data.success || !data.plan) {
                throw new Error(data.error || 'Failed to generate plan');
            }

            const plan = data.plan;

            // Update ratios
            const protein = plan.macros?.protein || 0;
            const carbs = plan.macros?.carbs || 0;
            const fats = plan.macros?.fats || 0;

            document.getElementById('macroProteinPct').innerText = protein + '%';
            document.getElementById('macroProteinBar').style.width = protein + '%';

            document.getElementById('macroCarbsPct').innerText = carbs + '%';
            document.getElementById('macroCarbsBar').style.width = carbs + '%';

            document.getElementById('macroFatsPct').innerText = fats + '%';
            document.getElementById('macroFatsBar').style.width = fats + '%';

            // Calories
            document.getElementById('targetCalories').innerText = (plan.calories || 0).toLocaleString() + ' kcal';

            // Meals
            const mealsContainer = document.getElementById('mealsContainer');
            mealsContainer.innerHTML = '';

            if (plan.meals && plan.meals.length > 0) {
                const colors = [
                  'text-amber-400 bg-amber-500/10 border-amber-500/20', 
                  'text-indigo-400 bg-indigo-500/10 border-indigo-500/20', 
                  'text-emerald-400 bg-emerald-500/10 border-emerald-500/20', 
                  'text-cyan-400 bg-cyan-500/10 border-cyan-500/20'
                ];
                plan.meals.forEach((meal, index) => {
                    const colorClass = colors[index % colors.length];
                    const mealHtml = `
                        <div class="flex flex-col sm:flex-row items-start gap-4 p-5 bg-white/5 rounded-2xl border border-white/5 hover:bg-white/10 transition-all">
                            <div class="px-4 py-2 rounded-xl text-xs font-bold shrink-0 border uppercase tracking-wider ${colorClass}">
                                ${meal.time || 'Meal'}
                            </div>
                            <div class="min-w-0">
                                <h4 class="font-bold text-white text-base">${meal.name || ''}</h4>
                                <p class="text-gray-400 text-sm mt-1 leading-relaxed">${meal.desc || ''}</p>
                            </div>
                        </div>
                    `;
                    mealsContainer.insertAdjacentHTML('beforeend', mealHtml);
                });
            } else {
                mealsContainer.innerHTML = '<p class="text-gray-500 text-center py-6">No meal details found.</p>';
            }

            // Clinical Advice
            const tipsList = document.getElementById('clinicalTipsList');
            tipsList.innerHTML = '';
            if (plan.advice && plan.advice.length > 0) {
                plan.advice.forEach(tip => {
                    const tipHtml = `
                        <li class="flex items-start gap-3 text-xs text-gray-300 leading-relaxed">
                            <i class="fas fa-check-circle text-emerald-400 mt-0.5 shrink-0"></i>
                            <span>${tip}</span>
                        </li>
                    `;
                    tipsList.insertAdjacentHTML('beforeend', tipHtml);
                });
            } else {
                tipsList.innerHTML = '<li class="text-gray-500 text-xs">Follow general healthy eating habits.</li>';
            }

            loading.classList.add('hidden');
            result.classList.remove('hidden');

        } catch (err) {
            console.error('Diet planner generation error:', err);
            alert('Could not customize your diet plan. Please try again.');
            loading.classList.add('hidden');
            placeholder.classList.remove('hidden');
        }
    }
</script>

<%- include('../partials/footer') %>

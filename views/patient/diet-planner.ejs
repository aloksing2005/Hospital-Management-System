<% var title = 'AI Diet Planner - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<div class="container-fluid bg-gray-50 min-h-screen">
  <div class="row">
    <%- include('../partials/patient-sidebar', { active: 'diet' }) %>

    <div class="col-md-9 col-lg-10 p-12">
      <div class="max-w-5xl mx-auto">
        <div class="flex justify-between items-center mb-12">
            <div>
                <h2 class="text-5xl font-black text-gray-900 tracking-tight">AI Smart Diet Planner</h2>
                <p class="text-gray-500 mt-2 text-xl">Personalized nutrition based on your health profile.</p>
            </div>
            <div class="w-20 h-20 bg-green-100 text-green-600 rounded-3xl flex items-center justify-center text-3xl">
                <i class="fas fa-apple-alt"></i>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Diet Inputs -->
            <div class="lg:col-span-1 space-y-6">
                <div class="bg-white rounded-[40px] shadow-sm border border-gray-100 p-8">
                    <h3 class="text-xl font-bold mb-6">Health Profile</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="text-xs font-bold text-gray-400 uppercase">Goal</label>
                            <select id="dietGoal" class="w-full bg-gray-50 border-0 rounded-2xl px-4 py-3 mt-1 outline-none">
                                <option>Recovery from Fever</option>
                                <option>Weight Management</option>
                                <option>Diabetic Friendly</option>
                                <option>Heart Healthy</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400 uppercase">Activity Level</label>
                            <select id="activity" class="w-full bg-gray-50 border-0 rounded-2xl px-4 py-3 mt-1 outline-none">
                                <option>Sedentary</option>
                                <option>Moderate</option>
                                <option>Active</option>
                            </select>
                        </div>
                        <button onclick="generateDiet()" class="w-full bg-indigo-600 text-white py-4 rounded-2xl font-bold shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition">Generate Plan</button>
                    </div>
                </div>

                <div class="bg-indigo-900 rounded-[40px] p-8 text-white">
                    <h4 class="font-bold mb-2">Nutrient Ratio</h4>
                    <div class="space-y-4 mt-6">
                        <div>
                            <div class="flex justify-between text-xs mb-1"><span>Protein</span><span id="macroProteinPct">--%</span></div>
                            <div class="w-full bg-indigo-800 h-2 rounded-full"><div id="macroProteinBar" class="bg-white h-full transition-all duration-500" style="width: 0%"></div></div>
                        </div>
                        <div>
                            <div class="flex justify-between text-xs mb-1"><span>Carbs</span><span id="macroCarbsPct">--%</span></div>
                            <div class="w-full bg-indigo-800 h-2 rounded-full"><div id="macroCarbsBar" class="bg-white h-full transition-all duration-500" style="width: 0%"></div></div>
                        </div>
                        <div>
                            <div class="flex justify-between text-xs mb-1"><span>Fats</span><span id="macroFatsPct">--%</span></div>
                            <div class="w-full bg-indigo-800 h-2 rounded-full"><div id="macroFatsBar" class="bg-white h-full transition-all duration-500" style="width: 0%"></div></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Diet Output -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-[40px] shadow-sm border border-gray-100 p-10 h-full min-h-[400px] flex flex-col justify-between">
                    <div id="dietPlaceholder" class="flex flex-col items-center justify-center my-auto text-center">
                        <i class="fas fa-utensils text-6xl text-gray-100 mb-6 animate-pulse"></i>
                        <h3 class="text-2xl font-bold text-gray-300">Set your goals to see your plan</h3>
                    </div>

                    <!-- Beautiful Animated Loader -->
                    <div id="dietLoading" class="hidden flex flex-col items-center justify-center my-auto text-center py-12">
                        <div class="relative w-24 h-24 mb-6">
                            <div class="absolute inset-0 rounded-full border-4 border-indigo-50"></div>
                            <div class="absolute inset-0 rounded-full border-4 border-indigo-600 border-t-transparent animate-spin"></div>
                            <div class="absolute inset-4 bg-indigo-50 rounded-full flex items-center justify-center text-indigo-600">
                                <i class="fas fa-apple-alt text-2xl animate-bounce"></i>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-gray-800">Customizing Your Nutrition Plan...</h3>
                        <p class="text-gray-400 mt-2 text-sm max-w-sm mx-auto">Evaluating health objective and physical active modifier for precision macro targeting.</p>
                    </div>

                    <div id="dietResult" class="hidden animate__animated animate__fadeIn space-y-8">
                        <h3 class="text-2xl font-black text-gray-900 mb-6 flex items-center">
                            <i class="fas fa-calendar-day text-indigo-600 mr-4"></i>
                            Your Daily Meal Plan
                        </h3>
                        
                        <div id="mealsContainer" class="space-y-6">
                            <!-- Dynamic meal plan cards -->
                        </div>

                        <!-- Empathetic doctor-advised tips -->
                        <div class="mt-8 border-t border-gray-100 pt-8">
                            <h4 class="font-bold text-gray-800 mb-4 flex items-center">
                                <i class="fas fa-stethoscope text-green-500 mr-3 text-lg"></i>
                                Nutritionist & Clinical Tips
                            </h4>
                            <ul id="clinicalTipsList" class="space-y-3 pl-1">
                                <!-- Dynamic advice items -->
                            </ul>
                        </div>

                        <div class="mt-8 p-6 bg-indigo-950 rounded-[32px] text-white flex items-center justify-between shadow-xl">
                            <div>
                                <p class="text-xs font-bold uppercase tracking-widest text-indigo-300">Target Daily Calories</p>
                                <p id="targetCalories" class="text-3xl font-black tracking-tight mt-1">-- kcal</p>
                            </div>
                            <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold text-sm transition shadow-lg shadow-indigo-900/40">
                                <i class="fas fa-mobile-alt mr-2"></i> Save to Mobile
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
    async function generateDiet() {
        const goal = document.getElementById('dietGoal').value;
        const activity = document.getElementById('activity').value;

        const placeholder = document.getElementById('dietPlaceholder');
        const loading = document.getElementById('dietLoading');
        const result = document.getElementById('dietResult');

        // Show loading spinner
        placeholder.classList.add('hidden');
        result.classList.add('hidden');
        loading.classList.remove('hidden');

        try {
            const response = await fetch('/patient/diet-planner/generate', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ goal, activity })
            });

            const data = await response.json();
            if (!data.success || !data.plan) {
                throw new Error(data.error || 'Failed to generate plan');
            }

            const plan = data.plan;

            // Update Nutrient Ratios
            const protein = plan.macros?.protein || 0;
            const carbs = plan.macros?.carbs || 0;
            const fats = plan.macros?.fats || 0;

            document.getElementById('macroProteinPct').innerText = protein + '%';
            document.getElementById('macroProteinBar').style.width = protein + '%';

            document.getElementById('macroCarbsPct').innerText = carbs + '%';
            document.getElementById('macroCarbsBar').style.width = carbs + '%';

            document.getElementById('macroFatsPct').innerText = fats + '%';
            document.getElementById('macroFatsBar').style.width = fats + '%';

            // Update Calories
            document.getElementById('targetCalories').innerText = (plan.calories || 0).toLocaleString() + ' kcal';

            // Render Meal Cards
            const mealsContainer = document.getElementById('mealsContainer');
            mealsContainer.innerHTML = '';

            if (plan.meals && plan.meals.length > 0) {
                const colors = ['text-orange-500 bg-orange-50', 'text-indigo-500 bg-indigo-50', 'text-green-500 bg-green-50', 'text-pink-500 bg-pink-50', 'text-amber-500 bg-amber-50'];
                plan.meals.forEach((meal, index) => {
                    const colorClass = colors[index % colors.length];
                    const mealHtml = `
                        <div class="flex items-start gap-6 p-6 bg-gray-50 rounded-3xl group hover:bg-indigo-50/50 transition border border-transparent hover:border-indigo-100/30">
                            <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-sm font-black shadow-sm flex-shrink-0 ${colorClass}">
                                ${meal.time || 'Meal'}
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800 text-base group-hover:text-indigo-900 transition">${meal.name || ''}</h4>
                                <p class="text-gray-500 text-sm mt-1.5 leading-relaxed">${meal.desc || ''}</p>
                            </div>
                        </div>
                    `;
                    mealsContainer.insertAdjacentHTML('beforeend', mealHtml);
                });
            } else {
                mealsContainer.innerHTML = '<p class="text-gray-400 text-center py-8">No meal details found.</p>';
            }

            // Render Nutritionist Tips
            const tipsList = document.getElementById('clinicalTipsList');
            tipsList.innerHTML = '';
            if (plan.advice && plan.advice.length > 0) {
                plan.advice.forEach(tip => {
                    const tipHtml = `
                        <li class="flex items-start gap-3 text-sm text-gray-600 leading-relaxed">
                            <i class="fas fa-check-circle text-green-500 mt-1 flex-shrink-0"></i>
                            <span>${tip}</span>
                        </li>
                    `;
                    tipsList.insertAdjacentHTML('beforeend', tipHtml);
                });
            } else {
                tipsList.innerHTML = '<li class="text-gray-400 text-sm">Follow healthy eating guidelines.</li>';
            }

            // Display Results
            loading.classList.add('hidden');
            result.classList.remove('hidden');

        } catch (err) {
            console.error('Diet planner generation error:', err);
            alert('Could not customize your diet plan. Please try again.');
            loading.classList.add('hidden');
            placeholder.classList.remove('hidden');
        }
    }
</script>

<%- include('../partials/footer') %>

<% var title = 'Medicine Reminders - HMS'; %>
<%- include('../partials/header') %>
<script src="https://cdn.tailwindcss.com"></script>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/patient-sidebar', { active: 'reminders' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex justify-between items-end mb-10 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">My Medications</h1>
        <p class="text-gray-400 font-medium">Never miss a dose. Set your smart reminders here</p>
      </div>
      <button onclick="toggleModal()" class="hms-btn hms-btn-primary">
        <i class="fas fa-plus mr-2"></i> Add Reminder
      </button>
    </div>

    <!-- Reminders Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if (reminders.length === 0) { %>
        <div class="col-span-full py-20 text-center">
          <div class="w-32 h-32 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-pills text-4xl text-gray-400"></i>
          </div>
          <h4 class="text-xl font-bold text-white">No active medication reminders</h4>
          <p class="text-gray-400 mt-2">Add your first medication reminder above</p>
        </div>
      <% } else { %>
        <% reminders.forEach(rem => { %>
          <div class="hms-card animate-scale-in">
            <div class="flex justify-between items-start mb-6">
              <div class="w-14 h-14 bg-indigo-500/20 text-indigo-400 rounded-2xl flex items-center justify-center">
                <i class="fas fa-capsules text-xl"></i>
              </div>
              <span class="hms-badge hms-badge-primary"><%= rem.time %></span>
            </div>
            <h3 class="text-xl font-bold text-white mb-1"><%= rem.medicine_name %></h3>
            <p class="text-gray-400 font-medium mb-6">Dosage: <%= rem.dosage %></p>
            
            <div class="flex items-center justify-between pt-6 border-t border-white/10">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" class="sr-only peer" checked>
                <div class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                <span class="ml-3 text-sm font-medium text-gray-300">Active</span>
              </label>
              <button onclick="deleteReminder('<%= rem.id %>')" class="text-gray-400 hover:text-rose-400 transition"><i class="fas fa-trash-alt"></i></button>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<!-- Add Reminder Modal -->
<div id="reminderModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-slate-900 rounded-2xl w-full max-w-lg p-8 shadow-2xl border border-white/10">
    <div class="flex justify-between items-center mb-8">
      <h3 class="text-2xl font-black text-white">New Reminder</h3>
      <button onclick="toggleModal()" class="text-gray-400 hover:text-white"><i class="fas fa-times text-xl"></i></button>
    </div>
    
    <form action="/patient/reminders/add" method="POST" class="space-y-6">
      <div>
        <label class="block text-sm font-bold text-gray-300 mb-3">Medicine Name</label>
        <input type="text" name="medicine_name" required placeholder="e.g. Paracetamol" class="w-full bg-white/5 border border-white/10 focus:bg-white/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-white placeholder-gray-400 outline-none transition">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-bold text-gray-300 mb-3">Dosage</label>
          <input type="text" name="dosage" required placeholder="500mg" class="w-full bg-white/5 border border-white/10 focus:bg-white/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-white placeholder-gray-400 outline-none transition">
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-300 mb-3">Time</label>
          <input type="time" name="time" required class="w-full bg-white/5 border border-white/10 focus:bg-white/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-white placeholder-gray-400 outline-none transition">
        </div>
      </div>
      <button type="submit" class="w-full hms-btn hms-btn-primary py-4 text-lg font-bold">Set Reminder</button>
    </form>
  </div>
</div>

<script>
    function toggleModal() {
        const modal = document.getElementById('reminderModal');
        modal.classList.toggle('hidden');
    }

    async function deleteReminder(id) {
        if (confirm('Are you sure you want to delete this reminder?')) {
            try {
                const res = await fetch(`/patient/reminders/delete/${id}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                const data = await res.json();
                if (data.success) {
                    if (typeof window.hmsShowToast === 'function') {
                        window.hmsShowToast('Success', 'Reminder deleted successfully', 'success');
                    }
                    location.reload();
                } else {
                    if (typeof window.hmsShowToast === 'function') {
                        window.hmsShowToast('Error', data.message || 'Failed to delete reminder', 'error');
                    }
                }
            } catch (err) {
                console.error('Error deleting reminder:', err);
                if (typeof window.hmsShowToast === 'function') {
                    window.hmsShowToast('Error', 'Failed to delete reminder', 'error');
                }
            }
        }
    }
</script>

<%- include('../partials/footer') %>

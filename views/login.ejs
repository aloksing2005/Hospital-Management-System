<% var title = 'Sign In - HMS Enterprise'; %>
<%- include('partials/header') %>

<div class="min-h-[calc(100vh-80px)] flex items-center justify-center p-6 mesh-bg">
    <div class="w-full max-w-[1200px] grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left Side: Visual -->
        <div class="hidden lg:block">
            <div class="relative p-12 bg-indigo-600 rounded-[60px] overflow-hidden shadow-2xl shadow-indigo-200">
                <div class="relative z-10 text-white">
                    <span class="inline-block px-4 py-2 bg-white/20 rounded-full text-xs font-black uppercase tracking-[0.2em] mb-8">System Access</span>
                    <h2 class="text-6xl font-black mb-8 leading-tight">Empowering <br/> Medical <br/> Excellence.</h2>
                    <p class="text-indigo-100 text-xl leading-relaxed mb-12 max-w-md">Connect to the most advanced healthcare network. Manage patients, track resources, and save lives with AI-driven insights.</p>
                    
                    <div class="grid grid-cols-2 gap-8">
                        <div>
                            <p class="text-4xl font-black mb-1">99.9%</p>
                            <p class="text-indigo-300 font-bold uppercase text-xs tracking-widest">Platform Uptime</p>
                        </div>
                        <div>
                            <p class="text-4xl font-black mb-1">AES-256</p>
                            <p class="text-indigo-300 font-bold uppercase text-xs tracking-widest">Secure Encryption</p>
                        </div>
                    </div>
                </div>
                <i class="fas fa-shield-virus absolute -bottom-20 -right-20 text-[350px] text-white/5"></i>
            </div>
        </div>

        <!-- Right Side: Form -->
        <div class="max-w-md mx-auto lg:mx-0 w-full">
            <div class="bg-white dark:bg-slate-900 p-12 rounded-[50px] shadow-2xl border border-slate-100 dark:border-slate-800 animate__animated animate__fadeIn">
                <div class="mb-10">
                    <h3 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tighter">Welcome Back</h3>
                    <p class="text-slate-500 font-medium">Please enter your credentials to access the platform.</p>
                </div>

                <form action="/login" method="POST" class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-sm font-black text-slate-700 dark:text-slate-300 uppercase tracking-widest">Email Address</label>
                        <div class="relative">
                            <i class="fas fa-envelope absolute left-5 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input type="email" name="email" required class="form-input-enterprise pl-12 h-14" placeholder="name@enterprise.com">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <div class="flex justify-between items-center">
                            <label class="text-sm font-black text-slate-700 dark:text-slate-300 uppercase tracking-widest">Password</label>
                            <a href="#" class="text-xs font-bold text-indigo-600 hover:underline">Forgot?</a>
                        </div>
                        <div class="relative">
                            <i class="fas fa-lock absolute left-5 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input type="password" name="password" required class="form-input-enterprise pl-12 h-14" placeholder="••••••••">
                        </div>
                    </div>

                    <div class="flex items-center gap-3">
                        <input type="checkbox" id="remember" class="w-5 h-5 rounded-lg border-slate-200 text-indigo-600 focus:ring-indigo-500">
                        <label for="remember" class="text-sm font-bold text-slate-600 dark:text-slate-400">Keep me logged in for 30 days</label>
                    </div>

                    <button type="submit" class="w-full btn-enterprise btn-enterprise-primary h-14 justify-center text-lg">
                        Sign In to Dashboard
                        <i class="fas fa-arrow-right ml-2 text-sm"></i>
                    </button>
                </form>

                <div class="mt-12 pt-8 border-t border-slate-50 dark:border-slate-800 text-center">
                    <p class="text-slate-500 font-bold">New to the platform? <a href="/register" class="text-indigo-600 hover:underline">Request an Account</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

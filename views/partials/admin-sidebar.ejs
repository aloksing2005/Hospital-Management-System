<div id="hmsSidebarContainer" class="w-64 lg:w-72 flex-shrink-0 transition-all duration-300">
  <div id="hmsSidebar" class="hms-sidebar h-full flex flex-col relative">
    
    <!-- Collapse Toggle Button -->
    <div class="hidden lg:flex justify-end pr-2 pt-1 mb-2">
      <button type="button" id="sidebarCollapseBtn" class="w-7 h-7 rounded-lg bg-white/5 hover:bg-indigo-600 border border-white/10 hover:border-indigo-500 flex items-center justify-center text-white transition-all shadow-md cursor-pointer" title="Toggle Sidebar">
        <i class="fas fa-chevron-left text-[10px]" id="sidebarCollapseIcon"></i>
      </button>
    </div>

    <!-- Logo Section -->
    <div class="mb-6 text-center px-4 sidebar-logo-block">
      <div class="w-14 h-14 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-3 shadow-lg shadow-indigo-500/30 transition-all duration-300">
        <i class="fas fa-shield-alt text-xl text-white"></i>
      </div>
      <h5 class="text-white font-black tracking-tight text-base sidebar-logo-text">Admin Panel</h5>
      <p class="text-gray-500 text-[10px] font-medium mt-1 sidebar-logo-text">System Control</p>
    </div>
    
    <!-- Navigation -->
    <nav class="space-y-1 flex-1 px-3 overflow-y-auto scrollbar-none">
      <a class="hms-nav-link <%= active === 'dashboard' ? 'active' : '' %>" href="/admin/dashboard" title="Dashboard">
        <i class="fas fa-th-large"></i>
        <span>Dashboard</span>
      </a>
      <a class="hms-nav-link <%= active === 'command' ? 'active' : '' %>" href="/admin/command-center" title="Command Center">
        <i class="fas fa-satellite-dish text-indigo-400 animate-pulse"></i>
        <span>Command Center</span>
      </a>
      <a class="hms-nav-link <%= active === 'doctors' ? 'active' : '' %>" href="/admin/doctors" title="Doctors">
        <i class="fas fa-user-md text-emerald-400"></i>
        <span>Doctors</span>
      </a>
      <a class="hms-nav-link <%= active === 'patients' ? 'active' : '' %>" href="/admin/patients" title="Patients">
        <i class="fas fa-users text-cyan-400"></i>
        <span>Patients</span>
      </a>
      <a class="hms-nav-link <%= active === 'appointments' ? 'active' : '' %>" href="/admin/appointments" title="Appointments">
        <i class="fas fa-calendar-check"></i>
        <span>Appointments</span>
      </a>
      <a class="hms-nav-link <%= active === 'lab-reports' ? 'active' : '' %>" href="/admin/lab-reports" title="Lab Reports">
        <i class="fas fa-flask"></i>
        <span>Lab Reports</span>
      </a>
      <a class="hms-nav-link <%= active === 'ambulances' ? 'active' : '' %>" href="/admin/ambulances" title="Ambulance Fleet">
        <i class="fas fa-ambulance text-rose-400 animate-pulse"></i>
        <span>Ambulance Fleet</span>
      </a>
      <a class="hms-nav-link <%= active === 'resources' ? 'active' : '' %>" href="/admin/resources" title="Resources">
        <i class="fas fa-bed"></i>
        <span>Resources</span>
      </a>
      <a class="hms-nav-link <%= active === 'blood-bank' ? 'active' : '' %>" href="/admin/blood-bank" title="Blood Bank">
        <i class="fas fa-tint text-red-500"></i>
        <span>Blood Bank</span>
      </a>
      <a class="hms-nav-link <%= active === 'reports' ? 'active' : '' %>" href="/admin/reports" title="Reports">
        <i class="fas fa-chart-bar"></i>
        <span>Reports</span>
      </a>
    </nav>

    <!-- Logout -->
    <div class="mt-auto pt-4 border-t border-white/5 px-3">
      <a href="/logout" class="hms-nav-link text-rose-400 hover:bg-rose-500/10 hover:text-rose-300" title="Logout">
        <i class="fas fa-sign-out-alt"></i>
        <span>Logout</span>
      </a>
    </div>
  </div>
</div>

<script>
  (function () {
    const container = document.getElementById("hmsSidebarContainer");
    const sidebar = document.getElementById("hmsSidebar");
    const btn = document.getElementById("sidebarCollapseBtn");
    const icon = document.getElementById("sidebarCollapseIcon");
    
    if (sidebar && btn && icon && container) {
      // Load saved state
      const isCollapsed = localStorage.getItem("hms-admin-sidebar-collapsed") === "true";
      if (isCollapsed) {
        sidebar.classList.add("collapsed");
        container.classList.remove("w-64", "lg:w-72");
        container.classList.add("w-20");
        icon.className = "fas fa-chevron-right text-[10px]";
        
        // Hide logo text helper
        document.querySelectorAll(".sidebar-logo-text").forEach(el => el.classList.add("hidden"));
        document.querySelector(".sidebar-logo-block")?.classList.add("mb-2");
      }
      
      btn.addEventListener("click", function () {
        const collapsed = sidebar.classList.toggle("collapsed");
        if (collapsed) {
          container.classList.remove("w-64", "lg:w-72");
          container.classList.add("w-20");
          icon.className = "fas fa-chevron-right text-[10px]";
          localStorage.setItem("hms-admin-sidebar-collapsed", "true");
          
          document.querySelectorAll(".sidebar-logo-text").forEach(el => el.classList.add("hidden"));
          document.querySelector(".sidebar-logo-block")?.classList.add("mb-2");
        } else {
          container.classList.remove("w-20");
          container.classList.add("w-64", "lg:w-72");
          icon.className = "fas fa-chevron-left text-[10px]";
          localStorage.setItem("hms-admin-sidebar-collapsed", "false");
          
          document.querySelectorAll(".sidebar-logo-text").forEach(el => el.classList.remove("hidden"));
          document.querySelector(".sidebar-logo-block")?.classList.remove("mb-2");
        }
      });
    }
  })();
</script>

<!DOCTYPE html>
<html lang="en" data-theme="dark" id="hmsRoot">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title : 'HMS Premium' %></title>
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/hms-premium.css">
  
  <style>
    @keyframes animate-mesh {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    
    .hms-bg-mesh {
      background: radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.15) 0%, transparent 40%),
                  radial-gradient(circle at 90% 80%, rgba(139, 92, 246, 0.15) 0%, transparent 45%),
                  radial-gradient(circle at 50% 50%, rgba(14, 165, 233, 0.08) 0%, transparent 50%),
                  radial-gradient(circle at 30% 80%, rgba(244, 63, 94, 0.05) 0%, transparent 35%),
                  #030712;
      background-size: 200% 200%;
      animation: animate-mesh 22s ease infinite;
      min-height: 100vh;
    }

    [data-theme="light"] .hms-bg-mesh {
      background: radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.08) 0%, transparent 40%),
                  radial-gradient(circle at 90% 80%, rgba(139, 92, 246, 0.08) 0%, transparent 45%),
                  radial-gradient(circle at 50% 50%, rgba(14, 165, 233, 0.05) 0%, transparent 50%),
                  #f8fafc;
      background-size: 100% 100%;
      animation: none;
    }
    
    .hms-glass-premium {
      background: rgba(15, 23, 42, 0.45);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    [data-theme="light"] .hms-glass-premium {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(24px) saturate(180%);
      border: 1px solid rgba(0, 0, 0, 0.06);
      box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.08);
    }
    
    .hms-hover-lift {
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .hms-hover-lift:hover {
      transform: translateY(-5px) scale(1.01);
      border-color: rgba(99, 102, 241, 0.35);
      box-shadow: 0 20px 40px rgba(99, 102, 241, 0.12), 0 0 20px rgba(99, 102, 241, 0.08);
    }
    
    .hms-hover-lift-cyan:hover {
      border-color: rgba(14, 165, 233, 0.35);
      box-shadow: 0 20px 40px rgba(14, 165, 233, 0.12), 0 0 20px rgba(14, 165, 233, 0.08);
    }

    .hms-hover-lift-rose:hover {
      border-color: rgba(244, 63, 94, 0.35);
      box-shadow: 0 20px 40px rgba(244, 63, 94, 0.12), 0 0 20px rgba(244, 63, 94, 0.08);
    }

    .hms-hover-lift-amber:hover {
      border-color: rgba(245, 158, 11, 0.35);
      box-shadow: 0 20px 40px rgba(245, 158, 11, 0.12), 0 0 20px rgba(245, 158, 11, 0.08);
    }
    
    @keyframes ecg-sweep {
      0% { stroke-dashoffset: 800; }
      100% { stroke-dashoffset: 0; }
    }
    .ecg-line {
      stroke-dasharray: 800;
      animation: ecg-sweep 4s linear infinite;
    }

    /* Premium inputs focusing */
    .hms-input-modern {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      color: #fff;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hms-input-modern:focus {
      border-color: #6366f1;
      box-shadow: 0 0 15px rgba(99, 102, 241, 0.25);
      background: rgba(15, 23, 42, 0.85);
    }
  </style>

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#6366f1',
            secondary: '#0ea5e9',
            accent: '#8b5cf6',
            success: '#10b981',
            warning: '#f59e0b',
            danger: '#ef4444',
          }
        }
      }
    }
  </script>
</head>
<body class="hms-bg-mesh selection:bg-indigo-500/30">
  <!-- Mobile Sidebar Backdrop Overlay -->
  <div id="hmsSidebarOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 lg:hidden hidden transition-opacity duration-300 opacity-0"></div>

  <% if (typeof user !== 'undefined' && user) { %>
    <nav class="hms-navbar flex items-center justify-between px-6 lg:px-8">
      <div class="flex items-center gap-4">
        <% if (['patient', 'doctor', 'admin'].includes(user.role)) { %>
          <button type="button" id="mobileSidebarToggleBtn" class="lg:hidden w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 flex items-center justify-center text-white transition-all cursor-pointer" title="Toggle Sidebar">
            <i class="fas fa-bars"></i>
          </button>
        <% } %>
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-purple-600 text-white rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-500/30 group-hover:scale-105 transition-transform">
            <i class="fas fa-heartbeat text-xl"></i>
          </div>
          <span class="text-xl lg:text-2xl font-black tracking-tighter text-white uppercase">HMS<span class="text-gradient">Premium</span></span>
        </a>
      </div>
      
      <div class="flex items-center gap-4">
        <button type="button" class="w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 flex items-center justify-center text-white transition-all" id="hmsThemeToggle" title="Toggle light/dark">
          <i class="fas fa-moon" id="hmsThemeIcon"></i>
        </button>
        
        <div class="hidden lg:flex items-center gap-3 bg-white/5 px-4 py-2 rounded-xl border border-white/10">
          <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
          <span class="text-xs font-bold text-emerald-400 uppercase tracking-wider">Live</span>
        </div>

        <% if (typeof user !== 'undefined' && user) { %>
        <div class="relative">
          <button type="button" id="hmsNotifBell" class="relative w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 flex items-center justify-center text-white transition-all" title="Notifications">
            <i class="fas fa-bell"></i>
            <span id="hmsNotifBadge" class="absolute -top-1 -right-1 min-w-[18px] h-[18px] bg-rose-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center px-1 <%= (typeof unreadNotifications !== 'undefined' && unreadNotifications > 0) ? '' : 'hidden' %>"><%= (typeof unreadNotifications !== 'undefined' && unreadNotifications > 0) ? unreadNotifications : '' %></span>
          </button>
          <div id="hmsNotifPanel" class="absolute right-0 top-full mt-2 w-80 hms-glass-premium rounded-2xl shadow-2xl opacity-0 invisible transition-all duration-300 transform translate-y-2 scale-95 z-50 max-h-96 overflow-hidden">
            <div class="p-3 border-b border-white/10 flex justify-between items-center">
              <span class="text-white font-bold text-sm">Notifications</span>
              <a href="<%= user.role === 'patient' ? '/patient/notifications' : '/' + user.role + '/dashboard' %>" class="text-indigo-400 text-xs font-bold">View all</a>
            </div>
            <div id="hmsNotifList" class="overflow-y-auto max-h-72 p-2"></div>
          </div>
        </div>
        <% } %>
        
        <div class="relative">
          <button type="button" class="flex items-center gap-3 bg-white/5 hover:bg-white/10 px-4 py-2 rounded-xl text-white font-medium border border-white/10 transition-all" id="userMenuBtn">
            <img src="https://i.pravatar.cc/100?u=<%= user.id %>" class="w-9 h-9 rounded-xl border-2 border-indigo-500 shadow-lg cursor-pointer" alt="Profile">
            <span class="hidden lg:block text-sm font-semibold truncate max-w-[120px]"><%= user.name %></span>
            <i class="fas fa-chevron-down text-xs"></i>
          </button>
          <div class="absolute right-0 top-full mt-2 w-52 hms-glass-premium rounded-2xl shadow-2xl opacity-0 invisible transition-all duration-300 transform translate-y-2 scale-95 z-50" id="userMenuDropdown">
            <div class="p-2">
              <div class="px-3 py-2 mb-1">
                <p class="text-white font-bold text-sm truncate"><%= user.name %></p>
                <p class="text-gray-400 text-xs capitalize"><%= user.role %></p>
              </div>
              <div class="h-px bg-white/10 my-1"></div>
              <a href="/<%= user.role %>/dashboard" class="flex items-center gap-3 px-3 py-2 rounded-lg text-white hover:bg-indigo-600/30 transition-colors">
                <i class="fas fa-user text-indigo-400"></i>
                <span class="text-sm font-medium">Profile</span>
              </a>
              <% if (user.role === 'patient') { %>
              <a href="/patient/notifications" class="flex items-center gap-3 px-3 py-2 rounded-lg text-white hover:bg-indigo-600/30 transition-colors">
                <i class="fas fa-cog text-gray-400"></i>
                <span class="text-sm font-medium">Settings</span>
              </a>
              <% } %>
              <div class="h-px bg-white/10 my-2"></div>
              <a href="/logout" class="flex items-center gap-3 px-3 py-2 rounded-lg text-rose-400 hover:bg-rose-500/10 transition-colors">
                <i class="fas fa-power-off"></i>
                <span class="text-sm font-medium">Logout</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </nav>
  <% } else { %>
    <nav class="hms-navbar flex items-center justify-between px-6 lg:px-8">
      <a  class="flex items-center gap-3 group">
        <div class="w-11 h-11 bg-gradient-to-br from-indigo-500 to-purple-600 text-white rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-500/30 group-hover:scale-105 transition-transform">
          <i class="fas fa-heartbeat text-lg"></i>
        </div>
        <span class="text-xl font-black tracking-tighter text-white uppercase">HMS<span class="text-gradient">Premium</span></span>
      </a>
      
      <div class="flex items-center gap-4">
        <button type="button" class="w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 flex items-center justify-center text-white transition-all" id="hmsThemeToggleGuest" title="Toggle light/dark">
          <i class="fas fa-moon" id="hmsThemeIconGuest"></i>
        </button>
        <a href="/login" class="text-white/70 hover:text-white font-semibold text-sm uppercase tracking-wide transition-colors">Login</a>
        <a href="/register" class="hms-btn hms-btn-primary text-sm">Register</a>
      </div>
    </nav>
  <% } %>

  <div class="hms-toast-container" id="toastContainer"></div>

  <% if (typeof user !== 'undefined' && user && user.role === 'patient') { %>
  <button type="button" id="hmsSosBtn" class="fixed bottom-6 right-6 w-14 h-14 bg-gradient-to-br from-rose-500 to-red-600 text-white rounded-full shadow-2xl shadow-rose-500/40 flex items-center justify-center hover:scale-110 transition-transform z-50 animate-pulse" title="Emergency SOS">
    <i class="fas fa-bolt text-xl"></i>
  </button>
  <div id="hmsSosModal" class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/70 p-4">
    <div class="bg-slate-900 border border-rose-500/50 rounded-2xl p-8 max-w-md w-full text-center shadow-2xl">
      <div class="w-20 h-20 bg-rose-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
        <i class="fas fa-exclamation-triangle text-4xl text-rose-400"></i>
      </div>
      <h2 class="text-2xl font-black text-white mb-2">SOS Activated</h2>
      <p class="text-gray-300 mb-6">Emergency teams, admin, and nearest ambulance drivers have been notified with your live location.</p>
      <button type="button" onclick="document.getElementById('hmsSosModal').classList.add('hidden')" class="hms-btn hms-btn-primary w-full">Acknowledge</button>
    </div>
  </div>
  <% } %>

  <!-- Global Incoming Emergency SOS Modal for Staff (Admins, Drivers, Doctors) -->
  <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'driver' || user.role === 'doctor')) { %>
  <div id="hmsSosAlertModal" class="hidden fixed inset-0 z-[10000] flex items-center justify-center bg-black/80 backdrop-blur-md p-4">
    <div class="bg-slate-900 border border-red-500/50 rounded-3xl p-8 max-w-lg w-full text-center shadow-2xl relative overflow-hidden">
      <!-- Flashing ambient glow -->
      <div class="absolute inset-0 bg-red-500/10 animate-pulse pointer-events-none"></div>
      
      <div class="relative z-10">
        <div class="w-24 h-24 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-6 border border-red-500/30 animate-bounce">
          <i class="fas fa-radiation text-5xl text-red-500"></i>
        </div>
        <h2 class="text-3xl font-black text-white mb-2 uppercase tracking-wider text-red-500">CRITICAL EMERGENCY SOS</h2>
        <p class="text-gray-400 text-sm mb-6 uppercase tracking-widest font-semibold">Incoming Life-Saving Call Alert</p>
        
        <div class="bg-red-500/10 rounded-2xl p-5 mb-8 border border-red-500/20 text-left">
          <div class="mb-3">
            <span class="text-xs text-red-400 font-bold uppercase tracking-wider">Patient Name</span>
            <p id="hmsSosPatient" class="text-white text-lg font-black tracking-tight">Unknown Patient</p>
          </div>
          <div>
            <span class="text-xs text-red-400 font-bold uppercase tracking-wider">Status Description</span>
            <p id="hmsSosMsg" class="text-gray-300 text-sm">Emergency SOS Alert</p>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a id="hmsSosMapLink" target="_blank" href="#" class="hidden flex-1 px-6 py-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-2xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-indigo-600/30">
            <i class="fas fa-map-marked-alt"></i>
            <span>Track Location</span>
          </a>
          <button type="button" onclick="hmsStopSiren(); document.getElementById('hmsSosAlertModal').classList.add('hidden');" class="flex-1 px-6 py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-2xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-600/30">
            <i class="fas fa-volume-mute"></i>
            <span>Stop & Acknowledge</span>
          </button>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <div id="globalLoader" class="fixed inset-0 bg-black/50 z-[10000] hidden items-center justify-center">
    <div class="bg-white rounded-xl p-6 shadow-2xl flex items-center gap-4">
      <div class="w-8 h-8 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
      <span class="text-gray-800 font-medium">Loading...</span>
    </div>
  </div>

  <script>
    // Global loader utility
    window.hmsShowLoader = function () {
      const loader = document.getElementById('globalLoader');
      if (loader) {
        loader.classList.remove('hidden');
        loader.classList.add('flex');
      }
    };

    window.hmsHideLoader = function () {
      const loader = document.getElementById('globalLoader');
      if (loader) {
        loader.classList.add('hidden');
        loader.classList.remove('flex');
      }
    };

    // Retry utility for fetch calls
    window.hmsFetchWithRetry = async function (url, options = {}, maxRetries = 3, delay = 1000) {
      for (let i = 0; i < maxRetries; i++) {
        try {
          const response = await fetch(url, options);
          if (response.ok) {
            return response;
          }
          if (i === maxRetries - 1) {
            throw new Error(`Request failed with status ${response.status}`);
          }
        } catch (error) {
          if (i === maxRetries - 1) {
            throw error;
          }
          console.warn(`Retry ${i + 1}/${maxRetries} for ${url}:`, error.message);
          await new Promise(resolve => setTimeout(resolve, delay * (i + 1)));
        }
      }
    };

    // Show loader on page navigation
    document.addEventListener('DOMContentLoaded', function () {
      window.hmsIsNavigating = false;
      window.addEventListener('beforeunload', function () {
        window.hmsIsNavigating = true;
      });

      const links = document.querySelectorAll('a[href]:not([target="_blank"]):not([href^="#"]):not([href^="javascript:"])');
      links.forEach(function (link) {
        link.addEventListener('click', function () {
          window.hmsIsNavigating = true;
          window.hmsShowLoader();
        });
      });

      // Hide loader when page is fully loaded
      window.addEventListener('load', function () {
        window.hmsHideLoader();
      });
    });
  </script>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    (function () {
      window.hmsSendDebugLog = function (type, message, stack) {
        try {
          fetch('/api/debug/log', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              type: type,
              message: message,
              stack: stack || null,
              url: window.location.href
            })
          }).catch(function() {});
        } catch (e) {}
      };

      // Global error handler
      window.addEventListener('error', function (event) {
        console.error('Global error raw event:', event);
        if (window.hmsIsNavigating) return;

        let msg = '';
        let stack = '';
        if (event.error) {
          msg = event.error.message || String(event.error);
          stack = event.error.stack || '';
        } else {
          msg = event.message || 'Script resource/element execution failure: ' + (event.filename || 'unknown src');
        }

        if (!msg || typeof msg !== 'string') return;
        const lower = msg.toLowerCase();
        if (lower.indexOf('abort') !== -1 || lower.indexOf('fetch') !== -1 || lower.indexOf('network') !== -1 || lower.indexOf('script error') !== -1) return;

        window.hmsSendDebugLog('CRITICAL_EXCEPTION', msg, stack);

        if (typeof window.hmsShowToast === 'function') {
          window.hmsShowToast('CRITICAL EXCEPTION', `<pre class="text-[10px] font-mono whitespace-pre-wrap max-h-32 overflow-y-auto leading-tight text-white/90 bg-black/40 p-2 rounded">${stack || msg}</pre>`, 'error');
        }
      });

      // Global unhandled promise rejection handler
      window.addEventListener('unhandledrejection', function (event) {
        console.error('Unhandled promise rejection raw event:', event);
        if (window.hmsIsNavigating) return;

        const reason = event.reason;
        let msg = '';
        let stack = '';
        if (reason) {
          msg = reason.message || String(reason);
          stack = reason.stack || '';
        } else {
          msg = 'Unhandled promise rejection (empty reason)';
        }

        if (!msg || typeof msg !== 'string') return;
        const lower = msg.toLowerCase();
        if (lower.indexOf('abort') !== -1 || lower.indexOf('fetch') !== -1 || lower.indexOf('network') !== -1) return;

        window.hmsSendDebugLog('UNHANDLED_REJECTION', msg, stack);

        if (typeof window.hmsShowToast === 'function') {
          window.hmsShowToast('UNHANDLED REJECTION', `<pre class="text-[10px] font-mono whitespace-pre-wrap max-h-32 overflow-y-auto leading-tight text-white/90 bg-black/40 p-2 rounded">${stack || msg}</pre>`, 'error');
        }
      });

      const HMS_USER = <%- JSON.stringify(typeof user !== 'undefined' && user ? { id: String(user.id), role: user.role, name: user.name } : null) %>;
      window.HMS_USER = HMS_USER;

      window.hmsShowToast = function (title, message, type) {
        type = type || 'info';
        const container = document.getElementById('toastContainer');
        if (!container) return;
        const toastEl = document.createElement('div');
        toastEl.className = 'hms-toast hms-toast-' + type + ' animate-slide-in';
        toastEl.innerHTML = '<div class="flex justify-between items-start gap-4"><div><strong class="text-sm font-semibold uppercase tracking-wide opacity-90">' + title + '</strong><p class="text-sm mt-1 opacity-90">' + message + '</p></div><button type="button" class="text-white/50 hover:text-white transition-colors" aria-label="Close"><i class="fas fa-times"></i></button></div>';
        toastEl.querySelector('button').addEventListener('click', function () { toastEl.remove(); });
        container.appendChild(toastEl);
        setTimeout(function () {
          toastEl.style.opacity = '0';
          toastEl.style.transform = 'translateX(20px)';
          setTimeout(function () { toastEl.remove(); }, 300);
        }, 5000);
      };

      if (!window.__HMS_SOCKET__) {
        window.__HMS_SOCKET__ = io({
          reconnection: true,
          reconnectionDelay: 1000,
          reconnectionAttempts: 10,
          reconnectionDelayMax: 5000
        });
        const s = window.__HMS_SOCKET__;
        
        s.on('connect', function () {
          console.log('Socket.IO connected');
          if (HMS_USER) {
            s.emit('join', { userId: HMS_USER.id, role: HMS_USER.role });
          }
        });
        
        s.on('disconnect', function () {
          console.log('Socket.IO disconnected');
        });
        
        s.on('reconnect', function (attemptNumber) {
          console.log('Socket.IO reconnected after', attemptNumber, 'attempts');
          if (HMS_USER) {
            s.emit('join', { userId: HMS_USER.id, role: HMS_USER.role });
          }
        });
        
        s.on('reconnect_attempt', function (attemptNumber) {
          console.log('Socket.IO reconnection attempt', attemptNumber);
        });
        
        s.on('reconnect_failed', function () {
          console.error('Socket.IO reconnection failed');
          if (typeof window.hmsShowToast === 'function') {
            window.hmsShowToast('Connection', 'Failed to reconnect to server', 'error');
          }
        });
        if (!window.__HMS_LISTENERS__) {
          window.__HMS_LISTENERS__ = true;
          s.on('new-appointment', function (data) {
            if (HMS_USER && HMS_USER.role === 'admin') {
              window.hmsShowToast('New appointment', (data.patientName || 'Patient') + ' booked with Dr. ' + (data.doctorName || ''), 'info');
            }
          });
          s.on('appointment-update', function (data) {
            if (!HMS_USER || HMS_USER.role !== 'patient') return;
            if (String(data.patientId || '') !== HMS_USER.id) return;
            window.hmsShowToast('Appointment update', 'Your appointment is now ' + (data.status || 'updated'), 'success');
          });
          s.on('doctor-notification', function (data) {
            if (!HMS_USER || HMS_USER.role !== 'doctor') return;
            window.hmsShowToast('Clinical', (data && data.message) ? data.message : 'New notification', 'warning');
          });
          s.on('new-prescription', function (data) {
            if (!HMS_USER || HMS_USER.role !== 'patient') return;
            if (String(data.patientId || '') !== HMS_USER.id) return;
            window.hmsShowToast('Prescription', 'Dr. ' + (data.doctorName || '') + ' issued a new prescription', 'success');
          });
          s.on('new-lab-report', function (data) {
            if (!HMS_USER || HMS_USER.role !== 'patient') return;
            if (String(data.patientId || '') !== HMS_USER.id) return;
            window.hmsShowToast('Lab report', (data.reportName || 'New report') + ' uploaded', 'info');
          });
          s.on('chat-message', function (data) {
            if (typeof appendChatMessage === 'function') {
              appendChatMessage(data.message, 'received', data.fromName);
            }
          });
          s.on('admin-appointment-update', function (data) {
            var row = document.querySelector('tr[data-id="' + data.id + '"]');
            if (row) {
              var badge = row.querySelector('.badge');
              if (badge) {
                badge.className = 'badge badge-' + data.status;
                badge.textContent = data.status;
              }
            }
            if (HMS_USER && HMS_USER.role === 'admin') {
              window.hmsShowToast('Schedule', 'Appointment #' + data.id + ' → ' + data.status, 'info');
            }
          });
          s.on('resource-updated-broadcast', function (data) {
            var el = document.getElementById('qty-' + data.id);
            if (el) {
              el.innerHTML = data.available_quantity + ' <span class="text-muted fs-6">/ ' + data.total_quantity + '</span>';
            }
          });
          s.on('bed-status-broadcast', function (data) {
            var bed = document.getElementById('bed-' + data.bedId);
            if (!bed) return;
            var label = bed.querySelector('.status-label');
            if (data.status === 'occupied') {
              bed.classList.remove('bed-vacant');
              bed.classList.add('bed-occupied');
              if (label) label.innerText = 'Occupied';
            } else {
              bed.classList.remove('bed-occupied');
              bed.classList.add('bed-vacant');
              if (label) label.innerText = 'Vacant';
            }
          });
          s.on('sos-alert', function (data) {
            if (HMS_USER && (HMS_USER.role === 'admin' || HMS_USER.role === 'driver' || HMS_USER.role === 'doctor')) {
              window.hmsShowToast('SOS EMERGENCY', (data && data.patientName ? data.patientName + ' — ' : '') + (data && data.message ? data.message : 'Emergency SOS'), 'error');
            }
          });
          s.on('new-notification', function (data) {
            if (!HMS_USER) return;
            var badge = document.getElementById('hmsNotifBadge');
            if (badge) {
              var n = parseInt(badge.textContent, 10) || 0;
              badge.textContent = n + 1;
              badge.style.display = 'flex';
            }
            if (window.hmsShowToast) window.hmsShowToast(data.title || 'Notification', data.message || '', data.type || 'info');
          });
          s.on('admin-ambulance-request', function (data) {
            if (HMS_USER && HMS_USER.role === 'admin') {
              window.hmsShowToast('Ambulance', (data.patient_name || 'Patient') + ' — ' + (data.emergency_type || 'Request'), 'warning');
            }
          });
          s.on('emergency-broadcast', function (data) {
            window.hmsShowToast('Emergency', (data && data.message) ? data.message : 'Hospital-wide alert', 'error');
          });
        }
      }

      window.hmsSocket = function () { return window.__HMS_SOCKET__; };

      function applyTheme(theme) {
        var root = document.getElementById('hmsRoot');
        if (!root) return;
        root.setAttribute('data-theme', theme === 'light' ? 'light' : 'dark');
        try { localStorage.setItem('hmsTheme', theme === 'light' ? 'light' : 'dark'); } catch (e) {}
        var icons = [document.getElementById('hmsThemeIcon'), document.getElementById('hmsThemeIconGuest')];
        icons.forEach(function (ic) {
          if (!ic) return;
          ic.className = theme === 'light' ? 'fas fa-sun' : 'fas fa-moon';
        });
      }
      document.addEventListener('DOMContentLoaded', function () {
        var saved = 'dark';
        try { saved = localStorage.getItem('hmsTheme') || 'dark'; } catch (e) {}
        applyTheme(saved === 'light' ? 'light' : 'dark');
        function toggle() {
          var root = document.getElementById('hmsRoot');
          if (!root) return;
          var cur = root.getAttribute('data-theme');
          applyTheme(cur === 'light' ? 'dark' : 'light');
        }
        var b1 = document.getElementById('hmsThemeToggle');
        var b2 = document.getElementById('hmsThemeToggleGuest');
        if (b1) b1.addEventListener('click', toggle);
        if (b2) b2.addEventListener('click', toggle);

        // Mobile Sidebar Toggle Logic
        (function() {
          const toggleBtn = document.getElementById('mobileSidebarToggleBtn');
          const container = document.getElementById('hmsSidebarContainer');
          const overlay = document.getElementById('hmsSidebarOverlay');
          
          if (!toggleBtn || !container || !overlay) return;

          function openSidebar() {
            overlay.classList.remove('hidden');
            // trigger reflow
            void overlay.offsetWidth;
            overlay.classList.add('opacity-100');
            overlay.classList.remove('opacity-0');
            
            container.classList.add('translate-x-0');
            container.classList.remove('-translate-x-full');
            document.body.classList.add('overflow-hidden');
          }

          function closeSidebar() {
            container.classList.remove('translate-x-0');
            container.classList.add('-translate-x-full');
            
            overlay.classList.remove('opacity-100');
            overlay.classList.add('opacity-0');
            
            document.body.classList.remove('overflow-hidden');
            
            setTimeout(() => {
              if (!container.classList.contains('translate-x-0')) {
                overlay.classList.add('hidden');
              }
            }, 300);
          }

          toggleBtn.addEventListener('click', openSidebar);
          overlay.addEventListener('click', closeSidebar);
          
          document.addEventListener('click', function(e) {
            if (e.target && (e.target.closest('.mobile-sidebar-close-btn') || e.target.closest('.hms-nav-link'))) {
              closeSidebar();
            }
          });

          window.addEventListener('resize', function() {
            if (window.innerWidth >= 1024) {
              closeSidebar();
            }
          });
        })();

        // Global responsive tables data-label helper
        (function() {
          function setupResponsiveTables() {
            document.querySelectorAll('table.hms-table').forEach(table => {
              const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.innerText.trim());
              table.querySelectorAll('tbody tr').forEach(row => {
                row.querySelectorAll('td').forEach((td, index) => {
                  if (headers[index] && !td.getAttribute('data-label')) {
                    td.setAttribute('data-label', headers[index]);
                  }
                });
              });
            });
          }
          setupResponsiveTables();
          const observer = new MutationObserver(function() {
            setupResponsiveTables();
          });
          observer.observe(document.body, { childList: true, subtree: true });
        })();

      });
    })();
  </script>

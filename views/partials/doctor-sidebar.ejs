<div id="hmsSidebarContainer" class="w-64 lg:w-72 flex-shrink-0 fixed inset-y-0 left-0 z-50 transform -translate-x-full transition-transform duration-300 lg:relative lg:translate-x-0 lg:z-auto">
  <div id="hmsSidebar" class="hms-sidebar h-full flex flex-col relative">
    
    <!-- Collapse Toggle Button (Desktop Only) -->
    <div class="hidden lg:flex justify-end pr-2 pt-1 mb-2">
      <button type="button" id="sidebarCollapseBtn" class="w-7 h-7 rounded-lg bg-white/5 hover:bg-indigo-600 border border-white/10 hover:border-indigo-500 flex items-center justify-center text-white transition-all shadow-md cursor-pointer" title="Toggle Sidebar">
        <i class="fas fa-chevron-left text-[10px]" id="sidebarCollapseIcon"></i>
      </button>
    </div>

    <!-- Mobile Close Button -->
    <div class="flex lg:hidden justify-end pr-4 pt-2 mb-2">
      <button type="button" class="mobile-sidebar-close-btn w-8 h-8 rounded-lg bg-white/5 hover:bg-rose-600/20 border border-white/10 hover:border-rose-500/50 flex items-center justify-center text-gray-400 hover:text-rose-400 transition-all cursor-pointer" title="Close Sidebar">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <!-- Logo Section -->
    <div class="mb-6 text-center px-4 sidebar-logo-block">
      <div class="w-14 h-14 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-3 shadow-lg shadow-indigo-500/30 transition-all duration-300">
        <i class="fas fa-user-md text-xl text-white"></i>
      </div>
      <h5 class="text-white font-black tracking-tight text-base sidebar-logo-text">Doctor Station</h5>
      <p class="text-gray-500 text-[10px] font-medium mt-1 sidebar-logo-text">Physician Hub</p>
    </div>
    
    <!-- Navigation -->
    <nav class="space-y-1 flex-1 px-3 overflow-y-auto scrollbar-none">
      <a class="hms-nav-link <%= active === 'dashboard' ? 'active' : '' %>" href="/doctor/dashboard" title="Dashboard">
        <i class="fas fa-th-large"></i>
        <span>Dashboard</span>
      </a>
      <a class="hms-nav-link <%= active === 'appointments' ? 'active' : '' %>" href="/doctor/appointments" title="Appointments">
        <i class="fas fa-calendar-check"></i>
        <span>Appointments</span>
      </a>
      <a class="hms-nav-link <%= active === 'prescription' ? 'active' : '' %>" href="/doctor/prescription" title="Prescriptions">
        <i class="fas fa-file-prescription"></i>
        <span>Prescriptions</span>
      </a>
      <a class="hms-nav-link <%= active === 'anatomy' ? 'active' : '' %>" href="/doctor/anatomy" title="Anatomy Explainer">
        <i class="fas fa-dna animate-pulse"></i>
        <span>Anatomy Explainer</span>
      </a>
      <a class="hms-nav-link <%= active === 'profile' ? 'active' : '' %>" href="/doctor/profile" title="My Profile">
        <i class="fas fa-id-card"></i>
        <span>My Profile</span>
      </a>
      <a class="hms-nav-link <%= active === 'chat' ? 'active' : '' %>" href="/doctor/chat" title="Messages">
        <i class="fas fa-comment-dots text-purple-400"></i>
        <span>Messages</span>
      </a>
    </nav>

    <!-- Logout -->
    <div class="mt-auto pt-4 border-t border-white/5 px-3">
      <a href="/logout" class="hms-nav-link text-rose-400 hover:bg-rose-500/10 hover:text-rose-300" title="Logout">
        <i class="fas fa-sign-out-alt"></i>
        <span>Logout</span>
      </a>
    </div>
  </div>
</div>

<script>
  (function () {
    const container = document.getElementById("hmsSidebarContainer");
    const sidebar = document.getElementById("hmsSidebar");
    const btn = document.getElementById("sidebarCollapseBtn");
    const icon = document.getElementById("sidebarCollapseIcon");
    
    if (sidebar && btn && icon && container) {
      // Load saved state
      const isCollapsed = localStorage.getItem("hms-doctor-sidebar-collapsed") === "true";
      if (isCollapsed && window.innerWidth >= 1024) {
        sidebar.classList.add("collapsed");
        container.classList.remove("w-64", "lg:w-72");
        container.classList.add("w-20");
        icon.className = "fas fa-chevron-right text-[10px]";
        
        // Hide logo text helper
        document.querySelectorAll(".sidebar-logo-text").forEach(el => el.classList.add("hidden"));
        document.querySelector(".sidebar-logo-block")?.classList.add("mb-2");
      }
      
      btn.addEventListener("click", function () {
        const collapsed = sidebar.classList.toggle("collapsed");
        if (collapsed) {
          container.classList.remove("w-64", "lg:w-72");
          container.classList.add("w-20");
          icon.className = "fas fa-chevron-right text-[10px]";
          localStorage.setItem("hms-doctor-sidebar-collapsed", "true");
          
          document.querySelectorAll(".sidebar-logo-text").forEach(el => el.classList.add("hidden"));
          document.querySelector(".sidebar-logo-block")?.classList.add("mb-2");
        } else {
          container.classList.remove("w-20");
          container.classList.add("w-64", "lg:w-72");
          icon.className = "fas fa-chevron-left text-[10px]";
          localStorage.setItem("hms-doctor-sidebar-collapsed", "false");
          
          document.querySelectorAll(".sidebar-logo-text").forEach(el => el.classList.remove("hidden"));
          document.querySelector(".sidebar-logo-block")?.classList.remove("mb-2");
        }
      });
    }
  })();
</script>

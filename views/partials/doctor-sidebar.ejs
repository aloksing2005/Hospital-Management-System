<div class="col-md-3 col-lg-2 p-0">
  <div class="cyber-sidebar">
    <div class="mb-12 text-center animate__animated animate__fadeIn">
      <div class="w-20 h-20 bg-indigo-600/20 text-indigo-400 rounded-3xl flex items-center justify-center mx-auto mb-6 border border-indigo-500/30 shadow-[0_0_30px_rgba(99,102,241,0.2)]">
        <i class="fas fa-user-md text-3xl"></i>
      </div>
      <h5 class="text-white font-black tracking-[0.2em] uppercase text-xs">Physician Hub</h5>
      <p class="text-indigo-400/60 text-[10px] font-bold uppercase tracking-widest mt-2">Active Session</p>
    </div>
    
    <nav class="nav flex-column gap-2">
      <a class="cyber-nav-link <%= active === 'dashboard' ? 'active' : '' %>" href="/doctor/dashboard">
        <i class="fas fa-th-large"></i>
        <span>Overview</span>
      </a>
      <a class="cyber-nav-link <%= active === 'appointments' ? 'active' : '' %>" href="/doctor/appointments">
        <i class="fas fa-calendar-check"></i>
        <span>My Visits</span>
      </a>
      <a class="cyber-nav-link <%= active === 'anatomy' ? 'active' : '' %>" href="/doctor/anatomy">
        <i class="fas fa-dna"></i>
        <span>Explainer</span>
      </a>
      <a class="cyber-nav-link <%= active === 'profile' ? 'active' : '' %>" href="/doctor/profile">
        <i class="fas fa-id-card"></i>
        <span>My Profile</span>
      </a>
      <a class="cyber-nav-link <%= active === 'chat' ? 'active' : '' %>" href="/doctor/chat">
        <i class="fas fa-comment-dots"></i>
        <span>Messages</span>
      </a>
    </nav>

    <div class="mt-auto pt-10 border-t border-white/5">
        <a href="/logout" class="cyber-nav-link text-rose-400 hover:bg-rose-500/10">
            <i class="fas fa-power-off"></i>
            <span>Disconnect</span>
        </a>
    </div>
  </div>
</div>

<% var title = 'Verify Login - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex items-center justify-center min-h-[80vh] px-4 py-12">
  <div class="w-full max-w-md hms-card animate-scale-in">
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg">
        <i class="fas fa-shield-alt"></i>
      </div>
      <h2 class="text-2xl font-black text-white tracking-tight">Verification Required</h2>
      <p class="text-gray-400 text-sm mt-2">A 6-digit confirmation code was dispatched to your email. Enter it below to unlock access.</p>
    </div>

    <form action="/verify-login" method="POST" class="space-y-6">
      <div>
        <label class="hms-label text-center block mb-4">Enter 6-Digit OTP</label>
        <div class="flex justify-center">
          <input 
            type="text" 
            name="otp" 
            class="hms-input text-center text-3xl font-black tracking-[0.5em] pl-[0.5em] max-w-[280px]" 
            maxlength="6" 
            pattern="\d{6}" 
            required 
            placeholder="000000" 
            autofocus
            autocomplete="one-time-code"
          >
        </div>
      </div>

      <button type="submit" class="hms-btn hms-btn-primary w-full py-4 text-base font-bold flex items-center justify-center gap-2 shadow-lg shadow-indigo-600/20">
        <i class="fas fa-check-circle"></i>Verify & Authorize
      </button>
    </form>

    <div class="text-center mt-8 pt-6 border-t border-white/5 space-y-3">
      <p class="text-xs text-gray-500 leading-relaxed font-medium">Didn't receive the email? Check spam filters or confirm details.</p>
      <a href="/login" class="inline-flex items-center gap-1.5 text-xs text-indigo-400 hover:text-indigo-300 font-bold transition-colors">
        <i class="fas fa-arrow-left"></i> Back to Login
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<% var title = 'Manage Doctors - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/admin-sidebar', { active: 'doctors' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">Manage Doctors</h1>
        <p class="text-gray-400 font-medium">Add, edit, and manage healthcare professionals</p>
      </div>
      <button onclick="openAddDoctorModal()" class="hms-btn hms-btn-primary">
          <i class="fas fa-plus"></i>
          Add Doctor
        </button>
      </div>

      <!-- Doctors Table -->
      <div class="hms-card animate-scale-in">
        <div class="hms-table-container">
          <table class="hms-table">
            <thead>
              <tr>
                <th>Photo</th>
                <th>Name</th>
                <th>Specialization</th>
                <th>Location</th>
                <th>Fees</th>
                <th>Timing</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% doctors.forEach(doc => { %>
                <tr>
                  <td>
                    <img src="<%= doc.photo || 'https://i.pravatar.cc/50?u=' + doc.id %>" alt="<%= doc.name %>" class="w-12 h-12 rounded-xl object-cover">
                  </td>
                  <td class="font-semibold text-white"><%= doc.name.startsWith('Dr.') ? doc.name : 'Dr. ' + doc.name %></td>
                  <td><span class="hms-badge hms-badge-primary"><%= doc.specialization %></span></td>
                  <td class="text-gray-400"><%= doc.location || 'N/A' %></td>
                  <td class="text-emerald-400 font-semibold">₹<%= doc.fees %></td>
                  <td class="text-gray-400"><%= doc.available_from %> - <%= doc.available_to %></td>
                  <td>
                    <form action="/admin/doctors/delete/<%= doc.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this doctor?')">
                      <button type="submit" class="hms-btn hms-btn-danger hms-btn-sm">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add Doctor Modal -->
<div id="addDoctorModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center">
  <div class="hms-card max-w-2xl w-full mx-4 animate-scale-in max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-xl font-bold text-white">Add New Doctor</h3>
      <button type="button" onclick="closeAddDoctorModal()" class="text-gray-400 hover:text-white transition-colors">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form action="/admin/doctors/add" method="POST" enctype="multipart/form-data" class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="hms-label">Full Name</label>
          <input type="text" name="name" class="hms-input" required placeholder="Dr. John Doe">
        </div>
        <div>
          <label class="hms-label">Email</label>
          <input type="email" name="email" class="hms-input" required placeholder="doctor@example.com">
        </div>
        <div>
          <label class="hms-label">Password</label>
          <input type="password" name="password" class="hms-input" required placeholder="••••••••">
        </div>
        <div>
          <label class="hms-label">Specialization</label>
          <select name="specialization" class="hms-input hms-select">
            <option>General Physician</option>
            <option>Cardiologist</option>
            <option>Dermatologist</option>
            <option>Neurologist</option>
            <option>Orthopedic</option>
            <option>ENT Specialist</option>
            <option>Pediatrician</option>
            <option>Gynecologist</option>
            <option>Ophthalmologist</option>
            <option>Psychiatrist</option>
          </select>
        </div>
        <div>
          <label class="hms-label">Location</label>
          <input type="text" name="location" class="hms-input" placeholder="Clinic/Hospital address">
        </div>
        <div>
          <label class="hms-label">Fees (₹)</label>
          <input type="number" name="fees" class="hms-input" value="500" min="100" step="50">
        </div>
        <div>
          <label class="hms-label">Available From</label>
          <input type="time" name="available_from" class="hms-input" value="09:00">
        </div>
        <div>
          <label class="hms-label">Available To</label>
          <input type="time" name="available_to" class="hms-input" value="17:00">
        </div>
      </div>
      <div>
        <label class="hms-label">Photo</label>
        <input type="file" name="photo" class="hms-input" accept="image/*">
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="closeAddDoctorModal()" class="hms-btn hms-btn-secondary flex-1">Close</button>
        <button type="submit" class="hms-btn hms-btn-primary flex-1">
          <i class="fas fa-plus"></i>
          Add Doctor
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  if (socket) {
    socket.on('new-doctor-registered', (data) => {
      if (typeof window.hmsShowToast === 'function') {
        window.hmsShowToast('New Doctor', `Dr. ${data.name} has registered`, 'success');
      }
    });
  }
</script>

<script>
  function openAddDoctorModal() {
    const modal = document.getElementById('addDoctorModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeAddDoctorModal() {
    const modal = document.getElementById('addDoctorModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
</script>

<%- include('../partials/footer') %>

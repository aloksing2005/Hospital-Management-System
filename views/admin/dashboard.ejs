% var title = 'Admin Dashboard - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/admin-sidebar', { active: 'dashboard' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
      <!-- Page Header -->
      <div class="mb-8 animate-fade-in flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-black text-white mb-2">Hospital Command Center</h1>
          <p class="text-gray-400 font-medium">Welcome back, Administrator. Real-time telemetry is running stable.</p>
        </div>
        <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-xl border border-white/10 shrink-0 self-start md:self-auto">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
          </span>
          <span class="text-sm font-bold text-gray-300">Live Telemetry active</span>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Card 1: Total Patients -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-indigo-500/40 relative overflow-hidden group animate-scale-in transition-all duration-300">
          <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-indigo-500/10 blur-2xl pointer-events-none group-hover:bg-indigo-500/20 transition-all"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 rounded-xl flex items-center justify-center text-xl shadow-inner shadow-indigo-500/10">
              <i class="fas fa-users"></i>
            </div>
            <span class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest bg-indigo-500/10 px-2 py-0.5 rounded-full">Total</span>
          </div>
          <div class="text-3xl font-black text-white tracking-tight mb-1"><%= stats.total_patients || 0 %></div>
          <div class="text-sm font-bold text-gray-400 tracking-wide mb-3">Registered Patients</div>
          <div class="text-xs font-semibold text-emerald-400 flex items-center gap-1.5 bg-emerald-500/10 w-fit px-2.5 py-1 rounded-lg">
            <i class="fas fa-arrow-up text-[10px]"></i>
            <span>+12% this month</span>
          </div>
        </div>

        <!-- Card 2: Total Doctors -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-emerald-500/40 relative overflow-hidden group animate-scale-in animate-delay-100 transition-all duration-300">
          <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-emerald-500/10 blur-2xl pointer-events-none group-hover:bg-emerald-500/20 transition-all"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center text-xl shadow-inner shadow-emerald-500/10">
              <i class="fas fa-user-md"></i>
            </div>
            <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest bg-emerald-500/10 px-2 py-0.5 rounded-full">Staff</span>
          </div>
          <div class="text-3xl font-black text-white tracking-tight mb-1"><%= stats.total_doctors || 0 %></div>
          <div class="text-sm font-bold text-gray-400 tracking-wide mb-3">On-Duty Doctors</div>
          <div class="text-xs font-semibold text-emerald-400 flex items-center gap-1.5 bg-emerald-500/10 w-fit px-2.5 py-1 rounded-lg">
            <i class="fas fa-arrow-up text-[10px]"></i>
            <span>+3 new onboarded</span>
          </div>
        </div>

        <!-- Card 3: Total Appointments -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-amber-500/40 relative overflow-hidden group animate-scale-in animate-delay-200 transition-all duration-300">
          <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-amber-500/10 blur-2xl pointer-events-none group-hover:bg-amber-500/20 transition-all"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-amber-500/20 text-amber-400 rounded-xl flex items-center justify-center text-xl shadow-inner shadow-amber-500/10">
              <i class="fas fa-calendar-check"></i>
            </div>
            <span class="text-[10px] font-bold text-amber-400 uppercase tracking-widest bg-amber-500/10 px-2 py-0.5 rounded-full">Bookings</span>
          </div>
          <div class="text-3xl font-black text-white tracking-tight mb-1"><%= stats.total_appointments || 0 %></div>
          <div class="text-sm font-bold text-gray-400 tracking-wide mb-3">Total Appointments</div>
          <div class="text-xs font-semibold text-emerald-400 flex items-center gap-1.5 bg-emerald-500/10 w-fit px-2.5 py-1 rounded-lg">
            <i class="fas fa-arrow-up text-[10px]"></i>
            <span>+8% this week</span>
          </div>
        </div>

        <!-- Card 4: Pending Requests -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-rose-500/40 relative overflow-hidden group animate-scale-in animate-delay-300 transition-all duration-300">
          <div class="absolute -right-12 -top-12 w-28 h-28 rounded-full bg-rose-500/10 blur-2xl pointer-events-none group-hover:bg-rose-500/20 transition-all"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 bg-rose-500/20 text-rose-400 rounded-xl flex items-center justify-center text-xl shadow-inner shadow-rose-500/10">
              <i class="fas fa-clock animate-pulse"></i>
            </div>
            <span class="text-[10px] font-bold text-rose-400 uppercase tracking-widest bg-rose-500/10 px-2 py-0.5 rounded-full">Alerts</span>
          </div>
          <div class="text-3xl font-black text-white tracking-tight mb-1"><%= stats.pending_appointments || 0 %></div>
          <div class="text-sm font-bold text-gray-400 tracking-wide mb-3">Pending Requests</div>
          <div class="text-xs font-semibold text-rose-400 flex items-center gap-1.5 bg-rose-500/10 w-fit px-2.5 py-1 rounded-lg">
            <i class="fas fa-chevron-down text-[10px]"></i>
            <span>-5% from yesterday</span>
          </div>
        </div>
      </div>

      <!-- Recent Appointments -->
      <div class="hms-card hms-card-glass hms-card-elevated hover:border-white/10 transition-all mb-8 animate-fade-in relative overflow-hidden">
        <div class="absolute -right-20 -top-20 w-52 h-52 rounded-full bg-indigo-500/5 blur-3xl pointer-events-none"></div>
        <div class="flex items-center justify-between mb-6 relative z-10">
          <h3 class="text-xl font-bold text-white flex items-center gap-2">
            <i class="fas fa-file-invoice text-indigo-400"></i> Recent Patient Registrations
          </h3>
          <a href="/admin/appointments" class="hms-btn hms-btn-secondary text-sm">View Calendar</a>
        </div>
        
        <div class="hms-table-container relative z-10">
          <table class="hms-table w-full">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Patient</th>
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Assigned Doctor</th>
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Date</th>
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Slot Time</th>
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Status Badge</th>
                <th class="text-left py-3 px-4 text-xs font-black uppercase text-gray-400 tracking-wider">Modify Action</th>
              </tr>
            </thead>
            <tbody id="appointmentsTable">
              <% recentAppointments.forEach(app => { %>
                <tr data-id="<%= app.id %>" class="border-b border-white/5 hover:bg-white/5 transition-all">
                  <td class="py-3 px-4 font-bold text-white text-sm"><%= app.patient_name %></td>
                  <td class="py-3 px-4 text-gray-300 text-sm">Dr. <%= app.doctor_name %></td>
                  <td class="py-3 px-4 text-gray-400 text-xs font-medium"><%= new Date(app.date).toLocaleDateString() %></td>
                  <td class="py-3 px-4 text-gray-400 text-xs font-medium"><%= app.time_slot %></td>
                  <td class="py-3 px-4">
                    <span class="hms-badge hms-badge-<%= app.status === 'pending' ? 'warning' : app.status === 'confirmed' ? 'success' : app.status === 'completed' ? 'info' : 'danger' %> capitalize"><%= app.status %></span>
                  </td>
                  <td class="py-3 px-4">
                    <form action="/admin/appointments/update/<%= app.id %>" method="POST" class="inline">
                      <select name="status" class="bg-slate-800 text-white text-xs px-3 py-1.5 rounded-xl border border-white/15 focus:border-indigo-500 focus:outline-none transition-colors" onchange="this.form.submit()">
                        <option value="pending" <%= app.status === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="confirmed" <%= app.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                        <option value="completed" <%= app.status === 'completed' ? 'selected' : '' %>>Completed</option>
                        <option value="cancelled" <%= app.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                      </select>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Quick Actions and System status -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Quick Add Doctor -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-white/10 transition-all animate-fade-in relative overflow-hidden">
          <div class="absolute -left-20 -top-20 w-48 h-48 rounded-full bg-indigo-500/5 blur-3xl pointer-events-none"></div>
          
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2 relative z-10">
            <i class="fas fa-user-md text-indigo-400"></i>
            Quick Onboard Doctor
          </h3>
          <form action="/admin/doctors/add" method="POST" enctype="multipart/form-data" class="space-y-4 relative z-10">
            <div>
              <input type="text" name="name" class="hms-input w-full bg-slate-800/50 border border-white/10 text-white rounded-xl px-4 py-3 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all" placeholder="Doctor Full Name" required>
            </div>
            <div>
              <input type="email" name="email" class="hms-input w-full bg-slate-800/50 border border-white/10 text-white rounded-xl px-4 py-3 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all" placeholder="Email Address" required>
            </div>
            <div>
              <input type="password" name="password" class="hms-input w-full bg-slate-800/50 border border-white/10 text-white rounded-xl px-4 py-3 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all" placeholder="Security Password" required>
            </div>
            <div>
              <select name="specialization" class="hms-input hms-select w-full bg-slate-800 border border-white/10 text-white rounded-xl px-4 py-3 text-sm focus:border-indigo-500 transition-all">
                <option>General Physician</option>
                <option>Cardiologist</option>
                <option>Dermatologist</option>
                <option>Neurologist</option>
                <option>Orthopedic</option>
                <option>Pediatrician</option>
              </select>
            </div>
            <button type="submit" class="hms-btn hms-btn-primary w-full flex items-center justify-center gap-2 py-3 rounded-xl font-bold shadow-lg shadow-indigo-600/20">
              <i class="fas fa-plus-circle"></i>
              <span>Onboard Doctor Account</span>
            </button>
          </form>
        </div>

        <!-- System Telemetry Status -->
        <div class="hms-card hms-card-glass hms-card-elevated hover:border-white/10 transition-all animate-fade-in animate-delay-100 relative overflow-hidden">
          <div class="absolute -right-20 -bottom-20 w-48 h-48 rounded-full bg-emerald-500/5 blur-3xl pointer-events-none"></div>

          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2 relative z-10">
            <i class="fas fa-satellite-dish text-emerald-400 animate-pulse"></i>
            Infrastructure Telemetry
          </h3>
          <div class="space-y-4 relative z-10">
            <!-- Database -->
            <div class="flex items-center gap-4 p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl hover:bg-emerald-500/15 transition-all">
              <div class="relative flex h-3.5 w-3.5 shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-emerald-400"></span>
              </div>
              <div class="flex-grow min-w-0">
                <p class="text-white font-bold text-sm leading-none mb-1">Database Cluster</p>
                <p class="text-xs text-emerald-400 font-semibold uppercase tracking-wider">Connected & Fully Synced</p>
              </div>
              <i class="fas fa-check-circle text-emerald-400 text-lg"></i>
            </div>
            
            <!-- Socket.IO -->
            <div class="flex items-center gap-4 p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl hover:bg-emerald-500/15 transition-all">
              <div class="relative flex h-3.5 w-3.5 shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-emerald-400"></span>
              </div>
              <div class="flex-grow min-w-0">
                <p class="text-white font-bold text-sm leading-none mb-1">Socket.IO Gateway</p>
                <p class="text-xs text-emerald-400 font-semibold uppercase tracking-wider">Active Room Channels</p>
              </div>
              <i class="fas fa-check-circle text-emerald-400 text-lg"></i>
            </div>

            <!-- Email Service -->
            <div class="flex items-center gap-4 p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl hover:bg-emerald-500/15 transition-all">
              <div class="relative flex h-3.5 w-3.5 shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-emerald-400"></span>
              </div>
              <div class="flex-grow min-w-0">
                <p class="text-white font-bold text-sm leading-none mb-1">SMTP Notification Gateway</p>
                <p class="text-xs text-emerald-400 font-semibold uppercase tracking-wider">Ready to Dispatch</p>
              </div>
              <i class="fas fa-check-circle text-emerald-400 text-lg"></i>
            </div>

            <!-- SMS Service -->
            <div class="flex items-center gap-4 p-4 bg-amber-500/10 border border-amber-500/20 rounded-2xl hover:bg-amber-500/15 transition-all">
              <div class="relative flex h-3.5 w-3.5 shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-amber-400"></span>
              </div>
              <div class="flex-grow min-w-0">
                <p class="text-white font-bold text-sm leading-none mb-1">SMS Dispatch Center</p>
                <p class="text-xs text-amber-400 font-semibold uppercase tracking-wider">Fallback (Twilio Config Needed)</p>
              </div>
              <i class="fas fa-exclamation-triangle text-amber-400 text-lg animate-bounce"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  if (socket) {
    socket.on('new-appointment', (data) => {
      if (typeof window.hmsShowToast === 'function') {
        window.hmsShowToast('New appointment', (data.patientName || 'Patient') + ' booked with Dr. ' + (data.doctorName || ''), 'info');
      }
    });
  }
</script>

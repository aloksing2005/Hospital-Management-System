<% var title = 'Admin Dashboard - HMS'; %>
<%- include('../partials/header') %>

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <%- include('../partials/admin-sidebar', { active: 'dashboard' }) %>

    <!-- Main Content -->
    <div class="col-md-9 col-lg-10 p-4">
      <h2 class="fw-bold mb-4"><i class="fas fa-tachometer-alt me-2"></i>Admin Dashboard</h2>

      <!-- Stats Cards -->
      <div class="row g-4 mb-4">
        <div class="col-md-3">
          <div class="card stat-card p-3">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="text-muted mb-1">Total Patients</h6>
                <h3 class="fw-bold mb-0"><%= stats.total_patients || 0 %></h3>
              </div>
              <i class="fas fa-users fa-2x text-primary"></i>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card stat-card success p-3">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="text-muted mb-1">Total Doctors</h6>
                <h3 class="fw-bold mb-0"><%= stats.total_doctors || 0 %></h3>
              </div>
              <i class="fas fa-user-md fa-2x text-success"></i>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card stat-card warning p-3">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="text-muted mb-1">Total Appointments</h6>
                <h3 class="fw-bold mb-0"><%= stats.total_appointments || 0 %></h3>
              </div>
              <i class="fas fa-calendar-check fa-2x text-warning"></i>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card stat-card danger p-3">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="text-muted mb-1">Pending</h6>
                <h3 class="fw-bold mb-0"><%= stats.pending_appointments || 0 %></h3>
              </div>
              <i class="fas fa-clock fa-2x text-danger"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Appointments -->
      <div class="card mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0"><i class="fas fa-list me-2"></i>Recent Appointments</h5>
          <a href="/admin/appointments" class="btn btn-sm btn-primary">View All</a>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="bg-light">
                <tr>
                  <th>Patient</th>
                  <th>Doctor</th>
                  <th>Date</th>
                  <th>Time</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="appointmentsTable">
                <% recentAppointments.forEach(app => { %>
                  <tr data-id="<%= app.id %>">
                    <td><%= app.patient_name %></td>
                    <td>Dr. <%= app.doctor_name %></td>
                    <td><%= new Date(app.date).toLocaleDateString() %></td>
                    <td><%= app.time_slot %></td>
                    <td>
                      <span class="badge badge-<%= app.status %>"><%= app.status %></span>
                    </td>
                    <td>
                      <form action="/admin/appointments/update/<%= app.id %>" method="POST" class="d-inline">
                        <select name="status" class="form-select form-select-sm d-inline w-auto" onchange="this.form.submit()">
                          <option value="pending" <%= app.status === 'pending' ? 'selected' : '' %>>Pending</option>
                          <option value="confirmed" <%= app.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                          <option value="completed" <%= app.status === 'completed' ? 'selected' : '' %>>Completed</option>
                          <option value="cancelled" <%= app.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                        </select>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="row g-4">
        <div class="col-md-6">
          <div class="card p-4">
            <h5 class="fw-bold mb-3"><i class="fas fa-user-md me-2 text-primary"></i>Quick Add Doctor</h5>
            <form action="/admin/doctors/add" method="POST" enctype="multipart/form-data">
              <div class="mb-2">
                <input type="text" name="name" class="form-control" placeholder="Doctor Name" required>
              </div>
              <div class="mb-2">
                <input type="email" name="email" class="form-control" placeholder="Email" required>
              </div>
              <div class="mb-2">
                <input type="password" name="password" class="form-control" placeholder="Password" required>
              </div>
              <div class="mb-2">
                <select name="specialization" class="form-select">
                  <option>General Physician</option>
                  <option>Cardiologist</option>
                  <option>Dermatologist</option>
                  <option>Neurologist</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary w-100"><i class="fas fa-plus me-2"></i>Add Doctor</button>
            </form>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card p-4">
            <h5 class="fw-bold mb-3"><i class="fas fa-chart-pie me-2 text-success"></i>System Status</h5>
            <div class="d-flex align-items-center mb-3">
              <div class="bg-success rounded-circle" style="width:12px;height:12px"></div>
              <span class="ms-2">Database: Connected</span>
            </div>
            <div class="d-flex align-items-center mb-3">
              <div class="bg-success rounded-circle" style="width:12px;height:12px"></div>
              <span class="ms-2">Socket.IO: Active</span>
            </div>
            <div class="d-flex align-items-center mb-3">
              <div class="bg-success rounded-circle" style="width:12px;height:12px"></div>
              <span class="ms-2">Email Service: Ready</span>
            </div>
            <div class="d-flex align-items-center">
              <div class="bg-warning rounded-circle" style="width:12px;height:12px"></div>
              <span class="ms-2">SMS Service: Configure Twilio</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<% var title = 'Ambulance Monitor - HMS Premium'; %>
<%- include('../partials/header') %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/admin-sidebar', { active: 'ambulances' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">Fleet Monitoring</h1>
        <p class="text-gray-400">Real-time status of all hospital ambulances</p>
      </div>
      <div class="flex gap-3">
        <div class="flex items-center gap-2 bg-emerald-500/20 px-4 py-2 rounded-xl border border-emerald-500/30">
          <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
          <span class="text-emerald-400 font-bold"><%= ambulances.filter(a => a.status === 'available').length %> Available</span>
        </div>
        <div class="flex items-center gap-2 bg-indigo-500/20 px-4 py-2 rounded-xl border border-indigo-500/30">
          <span class="w-2 h-2 rounded-full bg-indigo-400"></span>
          <span class="text-indigo-400 font-bold"><%= ambulances.filter(a => a.status === 'busy').length %> Busy</span>
        </div>
      </div>
    </div>

    <!-- Map and Activity Log -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 hms-card p-4 h-[600px]">
        <div id="map" class="h-full w-full rounded-xl"></div>
      </div>
      <div class="hms-card p-6 flex flex-col h-[600px]">
        <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
          <i class="fas fa-history text-indigo-400"></i>
          Activity Log
        </h3>
        <div class="flex-grow overflow-y-auto space-y-4" id="activityLog">
          <div class="flex items-start gap-3 pb-4 border-b border-gray-700">
            <div class="w-8 h-8 bg-emerald-500/20 text-emerald-400 rounded-full flex items-center justify-center flex-shrink-0">
              <i class="fas fa-check text-xs"></i>
            </div>
            <div>
              <p class="text-sm text-white font-medium">AMB-101 is now <span class="text-emerald-400">Available</span></p>
              <p class="text-xs text-gray-500 mt-0.5">2 minutes ago</p>
            </div>
          </div>
        </div>
        <button class="mt-6 w-full py-3 text-indigo-400 font-bold bg-indigo-500/20 rounded-xl hover:bg-indigo-500/30 transition">
          Export Fleet Report
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  let map;
  let markers = {};
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  function initMap() {
    map = L.map('map').setView([28.6139, 77.2090], 12);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
  }
  initMap();
  if (socket) {
    socket.on('ambulance-location-sync', (data) => {
      if(!markers[data.driverId]) {
        const icon = L.icon({
          iconUrl: 'https://cdn-icons-png.flaticon.com/512/1032/1032988.png',
          iconSize: [35, 35]
        });
        markers[data.driverId] = L.marker([data.lat, data.lng], {icon}).addTo(map);
        logActivity(`Ambulance updated location`);
      } else {
        markers[data.driverId].setLatLng([data.lat, data.lng]);
      }
    });
    socket.on('new-ambulance-request', (data) => {
      logActivity(`New emergency request: ${data.emergency_type} at ${data.pickup_address}`);
      if (typeof window.hmsShowToast === 'function') {
        window.hmsShowToast("Emergency", `New request from ${data.patient_name}`, 'warning');
      }
    });
  }
  function logActivity(text) {
    const log = document.getElementById('activityLog');
    const div = document.createElement('div');
    div.className = 'flex items-start gap-3 pb-4 border-b border-gray-700 animate-fade-in';
    div.innerHTML = `
      <div class="w-8 h-8 bg-indigo-500/20 text-indigo-400 rounded-full flex items-center justify-center flex-shrink-0">
        <i class="fas fa-info text-xs"></i>
      </div>
      <div>
        <p class="text-sm text-white font-medium">${text}</p>
        <p class="text-xs text-gray-500 mt-0.5">Just now</p>
      </div>
    `;
    log.prepend(div);
  }
</script>
<%- include('../partials/footer') %>

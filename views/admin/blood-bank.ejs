<% var title = 'Blood Bank - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/admin-sidebar', { active: 'blood-bank' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">Blood Bank Inventory</h1>
        <p class="text-gray-400">Monitor blood reserves in real-time</p>
      </div>
    </div>

    <!-- Blood Inventory Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <% inventory.forEach(item => { %>
        <div class="hms-card animate-scale-in">
          <div class="flex justify-between items-center mb-4">
            <span class="text-2xl font-black text-rose-500"><%= item.blood_group %></span>
            <i class="fas fa-tint text-gray-600"></i>
          </div>
          <div class="text-4xl font-black text-white mb-2" id="units-<%= item.blood_group.replace('+', 'pos').replace('-', 'neg') %>"><%= item.units %></div>
          <div class="w-full bg-gray-700 h-2 rounded-full mb-4">
            <% let percent = (item.units / 100) * 100; if(percent > 100) percent = 100; %>
            <div class="h-full transition-all <%= item.status === 'critical' ? 'bg-rose-500' : (item.status === 'low' ? 'bg-amber-500' : 'bg-emerald-500') %>" id="bar-<%= item.blood_group.replace('+', 'pos').replace('-', 'neg') %>" style="width: <%= percent %>%"></div>
          </div>
          <span id="status-<%= item.blood_group.replace('+', 'pos').replace('-', 'neg') %>" class="hms-badge hms-badge-<%= item.status === 'critical' ? 'danger' : (item.status === 'low' ? 'warning' : 'success') %>"><%= item.status %></span>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  async function updateStock(group, change) {
    const id = group.replace('+', 'pos').replace('-', 'neg');
    const unitsEl = document.getElementById('units-' + id);
    let currentUnits = parseInt(unitsEl.innerText);
    let newUnits = currentUnits + change;
    if(newUnits < 0) newUnits = 0;
    try {
      const res = await fetch('/admin/blood-bank/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ blood_group: group, units: newUnits })
      });
      const data = await res.json();
      if (data.success) {
        unitsEl.innerText = newUnits;
        const statusEl = document.getElementById('status-' + id);
        if (newUnits < 10) {
          statusEl.className = 'hms-badge hms-badge-danger';
          statusEl.innerText = 'critical';
        } else if (newUnits < 25) {
          statusEl.className = 'hms-badge hms-badge-warning';
          statusEl.innerText = 'low';
        } else {
          statusEl.className = 'hms-badge hms-badge-success';
          statusEl.innerText = 'available';
        }
        if (typeof window.hmsShowToast === 'function') {
          window.hmsShowToast('Success', 'Stock updated', 'success');
        }
      } else {
        if (typeof window.hmsShowToast === 'function') {
          window.hmsShowToast('Error', data.message || 'Failed to update stock', 'error');
        }
      }
    } catch (err) {
      console.error('Error updating stock:', err);
      if (typeof window.hmsShowToast === 'function') {
        window.hmsShowToast('Error', 'Failed to update stock', 'error');
      }
    }
  }
  socket.on('blood-stock-updated', (data) => {
    const id = data.blood_group.replace('+', 'pos').replace('-', 'neg');
    const unitsEl = document.getElementById('units-' + id);
    const barEl = document.getElementById('bar-' + id);
    const statusEl = document.getElementById('status-' + id);
    if(unitsEl) {
      unitsEl.innerText = data.units;
      let percent = (data.units / 100) * 100;
      if(percent > 100) percent = 100;
      barEl.style.width = percent + '%';
      statusEl.innerText = data.status;
      statusEl.className = 'hms-badge hms-badge-' + (data.status === 'critical' ? 'danger' : (data.status === 'low' ? 'warning' : 'success'));
      barEl.className = 'h-full transition-all ' + (data.status === 'critical' ? 'bg-rose-500' : (data.status === 'low' ? 'bg-amber-500' : 'bg-emerald-500'));
    }
  });
</script>
<%- include('../partials/footer') %>

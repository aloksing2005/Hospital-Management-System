<% var title = 'Lab Reports - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/admin-sidebar', { active: 'lab-reports' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-8 animate-fade-in">
      <div>
        <h1 class="text-3xl font-black text-white mb-2">Patient Lab Reports</h1>
        <p class="text-gray-400">Manage and upload lab test results</p>
      </div>
      <button onclick="openUploadModal()" class="hms-btn hms-btn-primary">
        <i class="fas fa-upload"></i>
        Upload New Report
      </button>
    </div>

    <!-- Lab Reports Table -->
    <div class="hms-card animate-scale-in">
      <div class="hms-table-container">
        <table class="hms-table">
          <thead>
            <tr>
              <th>Patient</th>
              <th>Report Name</th>
              <th>Test Type</th>
              <th>Date</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (reports.length === 0) { %>
              <tr><td colspan="5" class="text-center py-8 text-gray-500">No reports uploaded yet</td></tr>
            <% } %>
            <% reports.forEach(report => { %>
              <tr>
                <td class="font-semibold text-white"><%= report.patient_name %></td>
                <td class="text-gray-400"><%= report.report_name %></td>
                <td><span class="hms-badge hms-badge-primary"><%= report.test_type %></span></td>
                <td class="text-gray-500"><%= new Date(report.created_at).toLocaleDateString() %></td>
                <td>
                  <a href="<%= report.file_path %>" target="_blank" class="hms-btn hms-btn-secondary hms-btn-sm">
                    <i class="fas fa-eye"></i>
                    View
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="uploadReportModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center">
  <div class="hms-card max-w-md w-full mx-4 animate-scale-in">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-xl font-bold text-white">Upload Lab Report</h3>
      <button type="button" onclick="closeUploadModal()" class="text-gray-400 hover:text-white">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form action="/admin/lab-reports/upload" method="POST" enctype="multipart/form-data" class="space-y-4">
      <div>
        <label class="hms-label">Select Patient</label>
        <select name="patient_id" class="hms-input hms-select" required>
          <option value="">-- Choose Patient --</option>
          <% patients.forEach(patient => { %>
            <option value="<%= patient.id %>"><%= patient.name %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="hms-label">Report Name</label>
        <input type="text" name="report_name" class="hms-input" placeholder="e.g. Blood Test Result" required>
      </div>
      <div>
        <label class="hms-label">Test Type</label>
        <select name="test_type" class="hms-input hms-select" required>
          <option value="Blood Test">Blood Test</option>
          <option value="Urine Test">Urine Test</option>
          <option value="X-Ray">X-Ray</option>
          <option value="CT Scan">CT Scan</option>
          <option value="MRI">MRI</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div>
        <label class="hms-label">Upload File (PDF/Image)</label>
        <input type="file" name="report" class="hms-input" required>
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="closeUploadModal()" class="hms-btn hms-btn-secondary flex-1">Cancel</button>
        <button type="submit" class="hms-btn hms-btn-primary flex-1">Upload & Notify</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openUploadModal() {
    const modal = document.getElementById('uploadReportModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
  function closeUploadModal() {
    const modal = document.getElementById('uploadReportModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
</script>
<%- include('../partials/footer') %>

<% var title = 'Patients - HMS Premium'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/admin-sidebar', { active: 'patients' }) %>

  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="mb-8 animate-fade-in">
      <h1 class="text-3xl font-black text-white mb-2">Patients</h1>
      <p class="text-gray-400 font-medium">View and manage all registered patients</p>
    </div>

    <!-- Patients Table -->
    <div class="hms-card animate-scale-in">
      <div class="hms-table-container">
        <table class="hms-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Registered</th>
            </tr>
          </thead>
          <tbody>
            <% patients.forEach(p => { %>
              <tr>
                <td class="text-gray-500 font-mono">#<%= p.id %></td>
                <td class="font-semibold text-white"><%= p.name %></td>
                <td class="text-gray-400"><%= p.email %></td>
                <td class="text-gray-400"><%= p.phone || 'N/A' %></td>
                <td class="text-gray-500"><%= new Date(p.created_at).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

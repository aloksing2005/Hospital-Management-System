<% var title = 'Appointments - HMS'; %>
<%- include('../partials/header') %>

<div class="flex h-screen">
  <!-- Sidebar -->
  <%- include('../partials/admin-sidebar', { active: 'appointments' }) %>
  <!-- Main Content -->
  <div class="flex-1 overflow-y-auto p-6 lg:p-8">
    <!-- Page Header -->
    <div class="mb-8 animate-fade-in">
      <h1 class="text-3xl font-black text-white mb-2">All Appointments</h1>
      <p class="text-gray-400 font-medium">Manage hospital appointment schedule</p>
    </div>

    <!-- Appointments Table -->
    <div class="hms-card animate-scale-in">
      <div class="hms-table-container">
        <table class="hms-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Patient</th>
              <th>Doctor</th>
              <th>Date</th>
              <th>Time</th>
              <th>Status</th>
              <th>Symptoms</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="appointmentsTable">
            <% appointments.forEach(app => { %>
              <tr data-id="<%= app.id %>">
                <td>#<%= app.id %></td>
                <td class="font-bold text-white"><%= app.patient_name %></td>
                <td>Dr. <%= app.doctor_name %></td>
                <td><%= new Date(app.date).toLocaleDateString() %></td>
                <td><%= app.time_slot %></td>
                <td>
                  <span class="hms-badge hms-badge-<%= app.status %>"><%= app.status %></span>
                </td>
                <td><small class="text-gray-400"><%= app.symptoms || 'N/A' %></small></td>
                <td>
                  <form action="/admin/appointments/update/<%= app.id %>" method="POST" class="inline">
                    <select name="status" class="bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-indigo-500" onchange="this.form.submit()">
                      <option value="pending" <%= app.status === 'pending' ? 'selected' : '' %>>Pending</option>
                      <option value="confirmed" <%= app.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                      <option value="completed" <%= app.status === 'completed' ? 'selected' : '' %>>Completed</option>
                      <option value="cancelled" <%= app.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  const socket = window.hmsSocket ? window.hmsSocket() : null;
  if (socket) {
    socket.on('admin-appointment-update', (data) => {
      const row = document.querySelector(`tr[data-id="${data.id}"]`);
      if (row) {
        const badge = row.querySelector('.hms-badge');
        if (badge) {
          badge.className = `hms-badge hms-badge-${data.status === 'pending' ? 'warning' : data.status === 'confirmed' ? 'success' : data.status === 'completed' ? 'info' : 'danger'}`;
          badge.textContent = data.status;
        }
      }
    });
  }
</script>

<%- include('../partials/footer') %>
